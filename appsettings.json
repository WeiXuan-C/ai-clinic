{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=ai-clinic.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "your-secret-key-min-32-characters-long-for-security",
    "Issuer": "ai-clinic",
    "Audience": "ai-clinic-users"
  },
  "AzureOpenAI": {
    "Endpoint": "https://your-resource.openai.azure.com/",
    "ApiKey": "your-api-key",
    "DeploymentName": "gpt-4"
  },
  "AI": {
    "Provider": "Local",
    "OpenAI": {
      "ApiKey": "your-openai-api-key",
      "Model": "gpt-4"
    },
    "Local": {
      "ModelPath": "./models/local-ai"
    }
  },
  "OpenRouter": {
    "ApiKey": "your-openrouter-api-key-here",
    "DefaultModel": "owl-alpha"
  }
}
