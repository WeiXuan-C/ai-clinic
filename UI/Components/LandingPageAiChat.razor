@using ai_clinic.Services
@using Microsoft.AspNetCore.Components.Web
@inject AiAssistantService AiService
@inject IJSRuntime JS

<div class="ai-chat-wrapper">
    <!-- Chat Toggle Button -->
    <button class="ai-chat-toggle @(IsOpen ? "active" : "")" @onclick="ToggleChat">
        @if (IsOpen)
        {
            <i data-lucide="x" class="toggle-icon"></i>
        }
        else
        {
            <i data-lucide="bot" class="toggle-icon"></i>
        }
        @if (!IsOpen && HasUnreadMessage)
        {
            <span class="notification-dot"></span>
        }
    </button>

    <!-- Chat Interface -->
    @if (IsOpen)
    {
        <div class="ai-chat-container card">
            <!-- Chat Header -->
            <div class="chat-header">
                <div class="header-content">
                    <div class="ai-avatar">
                        <i data-lucide="bot" class="avatar-icon"></i>
                    </div>
                    <div class="header-text">
                        <h3 class="headline-sm">AI Health Assistant</h3>
                        <p class="body-sm">
                            @if (IsTyping)
                            {
                                <span class="typing-indicator">
                                    <span class="dot"></span>
                                    <span class="dot"></span>
                                    <span class="dot"></span>
                                </span>
                            }
                            else
                            {
                                <span>Ask me anything about your health</span>
                            }
                        </p>
                    </div>
                </div>
                <button class="minimize-btn" @onclick="ToggleChat">
                    <i data-lucide="minimize-2"></i>
                </button>
            </div>

            <!-- Chat Messages -->
            <div class="chat-messages" @ref="MessageContainer">
                @if (Messages.Count == 0)
                {
                    <div class="welcome-message">
                        <div class="welcome-icon">
                            <i data-lucide="sparkles"></i>
                        </div>
                        <h4 class="headline-sm">Welcome to AI Clinic</h4>
                        <p class="body-md">I'm your AI health assistant. I can help you with:</p>
                        <div class="quick-actions">
                            <button class="quick-action-btn" @onclick='() => SendQuickMessage("What symptoms should I watch out for?")'>
                                <i data-lucide="activity"></i>
                                Symptom guidance
                            </button>
                            <button class="quick-action-btn" @onclick='() => SendQuickMessage("How does the AI clinic work?")'>
                                <i data-lucide="help-circle"></i>
                                How it works
                            </button>
                            <button class="quick-action-btn" @onclick='() => SendQuickMessage("What services do you offer?")'>
                                <i data-lucide="briefcase"></i>
                                Our services
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var message in Messages)
                    {
                        <div class="message @(message.IsUser ? "user-message" : "ai-message")">
                            @if (!message.IsUser)
                            {
                                <div class="message-avatar">
                                    <i data-lucide="bot"></i>
                                </div>
                            }
                            <div class="message-content">
                                @if (message.IsMarkdown && !message.IsUser)
                                {
                                    <MarkdownRenderer Content="@message.Content" />
                                }
                                else
                                {
                                    <p>@message.Content</p>
                                }
                                <span class="message-time">@message.Timestamp.ToString("h:mm tt")</span>
                            </div>
                            @if (message.IsUser)
                            {
                                <div class="message-avatar user">
                                    <i data-lucide="user"></i>
                                </div>
                            }
                        </div>
                    }
                }
            </div>

            <!-- Chat Input -->
            <div class="chat-input">
                <form @onsubmit="SendMessage" @onsubmit:preventDefault="true">
                    <div class="input-container">
                        <input 
                            type="text" 
                            class="input-field" 
                            placeholder="Type your message..."
                            @bind="CurrentMessage"
                            @bind:event="oninput"
                            disabled="@IsTyping"
                            @ref="InputElement"
                        />
                        <button 
                            type="submit" 
                            class="send-btn" 
                            disabled="@(string.IsNullOrWhiteSpace(CurrentMessage) || IsTyping)"
                        >
                            <i data-lucide="send"></i>
                        </button>
                    </div>
                </form>
                <p class="input-disclaimer">
                    <i data-lucide="shield-check"></i>
                    This is not medical advice. Consult a healthcare professional for serious concerns.
                </p>
            </div>
        </div>
    }
</div>

@code {
    private bool IsOpen { get; set; } = false;
    private bool IsTyping { get; set; } = false;
    private bool HasUnreadMessage { get; set; } = false;
    private string CurrentMessage { get; set; } = string.Empty;
    private List<ChatMessage> Messages { get; set; } = new();
    private ElementReference MessageContainer;
    private ElementReference InputElement;

    private class ChatMessage
    {
        public string Content { get; set; } = string.Empty;
        public bool IsUser { get; set; }
        public DateTime Timestamp { get; set; }
        public bool IsMarkdown { get; set; } = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeLucideIcons();
        }
        
        // Update Lucide icons after any render
        if (IsOpen)
        {
            await InitializeLucideIcons();
        }
    }

    private async Task InitializeLucideIcons()
    {
        try
        {
            await JS.InvokeVoidAsync("initializeLucide");
        }
        catch
        {
            // Ignore if lucide is not available
        }
    }

    private async Task ToggleChat()
    {
        IsOpen = !IsOpen;
        HasUnreadMessage = false;
        
        if (IsOpen)
        {
            await Task.Delay(100);
            await FocusInput();
        }
        
        StateHasChanged();
        await InitializeLucideIcons();
    }

    private async Task SendQuickMessage(string message)
    {
        CurrentMessage = message;
        await SendMessage();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(CurrentMessage) || IsTyping)
            return;

        var userMessage = CurrentMessage.Trim();
        CurrentMessage = string.Empty;

        // Add user message
        Messages.Add(new ChatMessage
        {
            Content = userMessage,
            IsUser = true,
            Timestamp = DateTime.Now,
            IsMarkdown = false
        });

        StateHasChanged();
        await ScrollToBottom();

        // Show typing indicator
        IsTyping = true;
        StateHasChanged();

        try
        {
            // Generate AI response using streaming
            var aiResponse = new System.Text.StringBuilder();
            
            // Add empty AI message that will be updated
            var aiMessageIndex = Messages.Count;
            Messages.Add(new ChatMessage
            {
                Content = "",
                IsUser = false,
                Timestamp = DateTime.Now,
                IsMarkdown = true
            });
            
            StateHasChanged();

            // Use streaming response for better UX
            await foreach (var chunk in AiService.GenerateStreamingMedicalResponseAsync(
                userMessage,
                medicalContext: GetConversationContext(),
                temperature: 0.7
            ))
            {
                aiResponse.Append(chunk);
                Messages[aiMessageIndex].Content = aiResponse.ToString();
                StateHasChanged();
                await ScrollToBottom();
                await Task.Delay(10); // Small delay for smooth streaming effect
            }

            // If no response received, add a default message
            if (string.IsNullOrWhiteSpace(Messages[aiMessageIndex].Content))
            {
                Messages[aiMessageIndex].Content = "I apologize, but I'm having trouble generating a response right now. Please try again or contact our support team.";
            }

            // Mark as unread if chat is minimized
            if (!IsOpen)
            {
                HasUnreadMessage = true;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AI CHAT] Error: {ex.Message}");
            Console.WriteLine($"[AI CHAT] Stack Trace: {ex.StackTrace}");
            
            // Add a more helpful error message
            var errorMessage = "I apologize, but I encountered an error processing your request. ";
            
            if (ex.Message.Contains("Empty response") || ex.Message.Contains("invalid model"))
            {
                errorMessage += "The AI model may be temporarily unavailable or misconfigured. Please try again in a moment.";
            }
            else if (ex.Message.Contains("API key"))
            {
                errorMessage += "There seems to be an issue with the AI service configuration. Please contact support.";
            }
            else
            {
                errorMessage += "Please try again or contact our support team if the issue persists.";
            }
            
            Messages.Add(new ChatMessage
            {
                Content = errorMessage,
                IsUser = false,
                Timestamp = DateTime.Now,
                IsMarkdown = false
            });
        }
        finally
        {
            IsTyping = false;
            StateHasChanged();
            await ScrollToBottom();
            await InitializeLucideIcons();
        }
    }

    private string GetConversationContext()
    {
        // Get last 3 exchanges for context
        var recentMessages = Messages.TakeLast(6).ToList();
        if (recentMessages.Count == 0)
            return string.Empty;

        var context = string.Join("\n", recentMessages.Select(m => 
            $"{(m.IsUser ? "Patient" : "AI")}: {m.Content}"));
        
        return $"Previous conversation:\n{context}";
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("scrollToBottom", MessageContainer);
        }
        catch
        {
            // Ignore scroll errors
        }
    }

    private async Task FocusInput()
    {
        try
        {
            await JS.InvokeVoidAsync("focusElement", InputElement);
        }
        catch
        {
            // Ignore focus errors
        }
    }
}
