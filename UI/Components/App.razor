<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="/css/stitch-design-system.css" />
    <link rel="stylesheet" href="/app.css" />
    <link rel="stylesheet" href="ai-clinic.styles.css" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
    
    <style>
        /* Loading indicator styles */
        #blazor-loading {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(255, 255, 255, 0.95);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            opacity: 1;
            transition: opacity 0.3s ease;
        }

        #blazor-loading.loaded {
            opacity: 0;
            pointer-events: none;
        }

        .loading-spinner {
            width: 50px;
            height: 50px;
            border: 4px solid #f3f3f3;
            border-top: 4px solid #0052cc;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Page transition loading bar */
        .page-loading-bar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #0052cc, #4DD4D4);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.3s ease;
            z-index: 10000;
            opacity: 0;
        }

        .page-loading-bar.active {
            opacity: 1;
            animation: loading-progress 2s ease-in-out;
        }

        @@keyframes loading-progress {
            0% { transform: scaleX(0); }
            50% { transform: scaleX(0.7); }
            100% { transform: scaleX(1); }
        }
    </style>
</head>

<body>
    <!-- Initial loading indicator -->
    <div id="blazor-loading">
        <div class="loading-spinner"></div>
    </div>

    <!-- Page transition loading bar -->
    <div id="page-loading-bar" class="page-loading-bar"></div>

    <Routes @rendermode="InteractiveServer" />

    <!-- Lucide Icons CDN -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <script src="_framework/blazor.web.js" autostart="false"></script>
    
    <script>
        // Initialize Lucide icons globally
        window.initializeLucide = function() {
            if (window.lucide && window.lucide.createIcons) {
                try {
                    // Use requestAnimationFrame to avoid conflicts with DOM updates
                    requestAnimationFrame(() => {
                        try {
                            // Clear any existing icon instances to prevent conflicts
                            window.lucide.createIcons();
                        } catch (innerError) {
                            // Silently ignore errors during icon creation
                            console.debug('Lucide icons initialization skipped:', innerError.message);
                        }
                    });
                } catch (e) {
                    console.debug('Lucide icons initialization warning:', e.message);
                }
            }
        };

        // Scroll to bottom of element
        window.scrollToBottom = function(elementId) {
            try {
                const element = document.getElementById(elementId);
                if (element) {
                    element.scrollTop = element.scrollHeight;
                }
            } catch (e) {
                console.warn('Scroll to bottom failed:', e);
            }
        };

        // Download file function for medical records
        window.downloadFile = function(filename, content) {
            try {
                let blob;
                
                // Determine content type based on file extension
                const extension = filename.split('.').pop().toLowerCase();
                
                if (extension === 'pdf') {
                    // For PDF, content is base64 encoded
                    const binaryString = window.atob(content);
                    const bytes = new Uint8Array(binaryString.length);
                    for (let i = 0; i < binaryString.length; i++) {
                        bytes[i] = binaryString.charCodeAt(i);
                    }
                    blob = new Blob([bytes], { type: 'application/pdf' });
                } else if (extension === 'csv') {
                    // For CSV
                    blob = new Blob([content], { type: 'text/csv;charset=utf-8' });
                } else if (extension === 'json') {
                    // For JSON
                    blob = new Blob([content], { type: 'application/json;charset=utf-8' });
                } else {
                    // Default to plain text
                    blob = new Blob([content], { type: 'text/plain;charset=utf-8' });
                }
                
                // Create download link
                const link = document.createElement('a');
                link.href = window.URL.createObjectURL(blob);
                link.download = filename;
                
                // Trigger download
                document.body.appendChild(link);
                link.click();
                
                // Cleanup
                document.body.removeChild(link);
                window.URL.revokeObjectURL(link.href);
            } catch (e) {
                console.error('Download failed:', e);
                alert('Failed to download file. Please try again.');
            }
        };

        // Download file from byte array (for PDF export from C#)
        window.downloadFileFromBytes = function(fileName, contentType, byteArray) {
            try {
                // Convert byte array to Uint8Array
                const bytes = new Uint8Array(byteArray);
                
                // Create blob with specified content type
                const blob = new Blob([bytes], { type: contentType });
                
                // Create object URL
                const url = URL.createObjectURL(blob);
                
                // Create temporary download link
                const link = document.createElement('a');
                link.href = url;
                link.download = fileName;
                
                // Trigger download
                document.body.appendChild(link);
                link.click();
                
                // Cleanup
                document.body.removeChild(link);
                URL.revokeObjectURL(url);
            } catch (e) {
                console.error('Download from bytes failed:', e);
                alert('Failed to download file. Please try again.');
            }
        };

        // Start Blazor manually to avoid double-start
        Blazor.start().then(() => {
            console.log('Blazor started successfully');
            
            // Hide initial loading indicator
            const loadingElement = document.getElementById('blazor-loading');
            if (loadingElement) {
                loadingElement.classList.add('loaded');
                setTimeout(() => {
                    loadingElement.style.display = 'none';
                }, 300);
            }

            // Initialize Lucide icons after Blazor loads
            setTimeout(() => {
                window.initializeLucide();
            }, 100);
        }).catch(err => {
            console.error('Blazor failed to start:', err);
            // Hide loading indicator even on error
            const loadingElement = document.getElementById('blazor-loading');
            if (loadingElement) {
                loadingElement.innerHTML = '<div style="color: red; text-align: center;"><h2>Failed to load application</h2><p>Please refresh the page</p></div>';
            }
        });

        // Show loading bar during navigation
        let loadingBar = null;
        let loadingTimeout = null;

        // Fallback: Monitor for navigation changes
        let lastUrl = location.href;
        new MutationObserver(() => {
            const url = location.href;
            if (url !== lastUrl) {
                lastUrl = url;
                
                // Show loading bar
                const bar = document.getElementById('page-loading-bar');
                if (bar) {
                    bar.classList.add('active');
                    
                    // Hide after a short delay and re-initialize icons
                    clearTimeout(loadingTimeout);
                    loadingTimeout = setTimeout(() => {
                        bar.classList.remove('active');
                        window.initializeLucide();
                    }, 500);
                }
            }
        }).observe(document, { subtree: true, childList: true });
    </script>
</body>

</html>
