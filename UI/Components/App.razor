<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="css/stitch-design-system.css" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        // Global Lucide initialization - only once
        (function() {
            if (window.lucideInitialized) return;
            window.lucideInitialized = true;

            let initTimeout;
            let isInitializing = false;

            window.initializeLucide = function() {
                if (isInitializing) return;
                
                // Clear any pending initialization
                clearTimeout(initTimeout);
                
                // Debounce: wait 150ms before initializing
                initTimeout = setTimeout(function() {
                    if (typeof lucide !== 'undefined') {
                        isInitializing = true;
                        try {
                            lucide.createIcons();
                        } finally {
                            isInitializing = false;
                        }
                    }
                }, 150);
            };

            // Initial load
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', window.initializeLucide);
            } else {
                window.initializeLucide();
            }

            // Listen to Blazor's enhanced navigation events instead of MutationObserver
            if (window.Blazor) {
                Blazor.addEventListener('enhancedload', window.initializeLucide);
            }
        })();
    </script>
    <HeadOutlet />
</head>

<body>
    <MudThemeProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />
    
    <Routes />
    
    <!-- Blazor Error UI -->
    <div id="blazor-error-ui" style="display: none; position: fixed; bottom: 0; left: 0; right: 0; background: #dc3545; color: white; padding: 1rem; text-align: center; z-index: 9999;">
        An unhandled error has occurred.
        <a href="" style="color: white; text-decoration: underline; margin-left: 1rem;">Reload</a>
        <a style="color: white; text-decoration: underline; margin-left: 1rem; cursor: pointer;" onclick="document.getElementById('blazor-error-ui').style.display='none'">Close</a>
    </div>
    
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
</body>

</html>
