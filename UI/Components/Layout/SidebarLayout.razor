@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Routing
@using ai_clinic.Services
@using ai_clinic.UI.Components
@inherits LayoutComponentBase
@implements IDisposable
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject AuthStateService AuthState
@inject UserService UserService
@inject PatientProfileService PatientProfileService
@inject DoctorProfileService DoctorProfileService

@code {
    private string? userName = null;
    private string? userEmail = null;
    private string? userInitials = null;
    private string? userPhotoUrl = null;
    private string currentPath = "";

    protected override void OnInitialized()
    {
        // Subscribe to auth state changes
        AuthState.OnAuthStateChanged += UpdateUserInfo;
        
        // Initialize user data from AuthState
        UpdateUserInfo();
        
        // Subscribe to navigation changes
        Navigation.LocationChanged += OnLocationChanged;
        currentPath = Navigation.Uri;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentPath = e.Location;
        InvokeAsync(StateHasChanged);
    }

    private async void UpdateUserInfo()
    {
        userName = AuthState.GetDisplayName();
        userEmail = AuthState.CurrentUser?.Email;
        userInitials = AuthState.GetUserInitials();
        
        // Load profile photo if user is a patient
        if (AuthState.IsPatient && AuthState.CurrentUser != null)
        {
            try
            {
                var photoData = await PatientProfileService.GetProfilePhotoAsync(AuthState.CurrentUser.Id);
                if (photoData != null && photoData.Length > 0)
                {
                    userPhotoUrl = $"data:image/jpeg;base64,{Convert.ToBase64String(photoData)}";
                    Console.WriteLine($"[Sidebar] Loaded profile photo, size: {photoData.Length} bytes");
                }
                else
                {
                    userPhotoUrl = null;
                    Console.WriteLine("[Sidebar] No profile photo found");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[Sidebar] Error loading profile photo: {ex.Message}");
                userPhotoUrl = null;
            }
        }
        
        // Trigger re-render
        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initialize Lucide icons for all pages using this layout
            await JSRuntime.InvokeVoidAsync("initializeLucide");
        }
        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task HandleLogout()
    {
        // Clear authentication state and session
        await AuthState.ClearCurrentUserAsync();
        
        // Navigate to sign-in page
        Navigation.NavigateTo("/auth/signin", forceLoad: true);
    }

    private bool IsActive(string href)
    {
        return currentPath.Contains(href, StringComparison.OrdinalIgnoreCase);
    }

    public void Dispose()
    {
        // Unsubscribe from auth state changes
        AuthState.OnAuthStateChanged -= UpdateUserInfo;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}


<link rel="stylesheet" href="/css/stitch-design-system.css" />

<AuthGuard RequiredRole="Patient">

<div class="dashboard-layout">
    <!-- Left Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <a href="/patient/profile" class="profile-section-link">
                <div class="profile-section">
                    <div class="avatar">
                        @if (!string.IsNullOrEmpty(userPhotoUrl))
                        {
                            <img src="@userPhotoUrl" alt="Profile" class="avatar-img" />
                        }
                        else if (!string.IsNullOrEmpty(userInitials))
                        {
                            <span class="avatar-text">@userInitials</span>
                        }
                        else
                        {
                            <i data-lucide="user"></i>
                        }
                    </div>
                    <div class="profile-info">
                        <h3 class="headline-sm">@(userName ?? "Welcome back")</h3>
                        <p class="body-sm">@(userEmail ?? "Clinical Sanctuary")</p>
                        <span class="status-badge">Active</span>
                    </div>
                </div>
            </a>
            <a href="/patient/consultation" class="btn btn-primary btn-block">
                + Start New Chat
            </a>
        </div>

        <nav class="sidebar-nav">
            <a href="/patient/dashboard" class="nav-item @(IsActive("/patient/dashboard") ? "active" : "")">
                <i data-lucide="layout-dashboard" class="nav-icon"></i>
                <span>Overview</span>
            </a>
            <a href="/patient/consultation" class="nav-item @(IsActive("/patient/consultation") ? "active" : "")">
                <i data-lucide="message-circle" class="nav-icon"></i>
                <span>Consultations</span>
            </a>
            <a href="/patient/records" class="nav-item @(IsActive("/patient/records") ? "active" : "")">
                <i data-lucide="clipboard-list" class="nav-icon"></i>
                <span>Records</span>
            </a>
            <a href="/patient/support" class="nav-item @(IsActive("/patient/support") ? "active" : "")">
                <i data-lucide="life-buoy" class="nav-icon"></i>
                <span>Support</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <a href="/patient/settings" class="nav-item @(IsActive("/patient/settings") ? "active" : "")">
                <i data-lucide="settings" class="nav-icon"></i>
                <span>Settings</span>
            </a>
            <a @onclick="HandleLogout" class="nav-item" style="cursor: pointer;">
                <i data-lucide="log-out" class="nav-icon"></i>
                <span>Logout</span>
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        @Body
    </main>
</div>

</AuthGuard>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .dashboard-layout {
        display: flex;
        background: #f7f9fb;
        font-family: 'Inter', sans-serif;
    }

    /* Sidebar */
    .sidebar {
        width: 280px;
        min-height: 100vh;
        max-height: 100vh;
        background: #ffffff;
        display: flex;
        flex-direction: column;
        overflow-y: auto;
        position: fixed;
        left: 0;
        top: 0;
    }

    .sidebar-header {
        padding: 32px 24px 24px;
        margin-bottom: 0;
    }

    .profile-section-link {
        text-decoration: none;
        color: inherit;
        display: block;
        margin-bottom: 24px;
    }

    .profile-section {
        display: flex;
        align-items: center;
        gap: 16px;
        position: relative;
        cursor: pointer;
        padding: 8px;
        border-radius: 12px;
        transition: background 0.2s;
        user-select: none;
        -webkit-user-select: none;
    }

    .profile-section:hover {
        background: #f2f4f6;
    }

    .profile-section:active {
        transform: scale(0.98);
    }

    .profile-section * {
        pointer-events: none;
    }

    /* Prevent Lucide SVG from blocking clicks */
    svg {
        pointer-events: none;
    }

    .avatar {
        width: 48px;
        height: 48px;
        min-width: 48px;
        min-height: 48px;
        border-radius: 50%;
        background: linear-gradient(135deg, #0052cc, #003d9b);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
        overflow: hidden;
    }

    .avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
    }

    .avatar-text {
        font-size: 18px;
        font-weight: 600;
        color: white;
        user-select: none;
    }

    .profile-info h3 {
        font-size: 14px;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 4px;
        line-height: 1.2;
    }

    .profile-info p {
        font-size: 12px;
        color: #434654;
        margin-bottom: 8px;
        line-height: 1.2;
    }

    .status-badge {
        display: inline-block;
        padding: 4px 12px;
        background: #76f3ea;
        color: #006a65;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 500;
        line-height: 1.2;
    }

    .btn-block {
        width: 100%;
        padding: 14px 24px;
        background: #0052cc;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        line-height: 1.2;
        cursor: pointer;
        transition: all 0.2s;
        font-family: 'Inter', sans-serif;
        text-align: center;
        white-space: nowrap;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-block:hover {
        background: #003d9b;
        transform: translateY(-1px);
    }

    .sidebar-nav {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        padding: 0.5rem 0;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.875rem 1.5rem;
        color: #434654;
        text-decoration: none;
        border-radius: 0;
        transition: all 0.2s;
        font-size: 0.875rem;
    }

    .nav-item:hover {
        background: #f2f4f6;
        color: #191c1e;
    }

    .nav-item.active {
        background: #dae2ff;
        color: #003d9b;
        font-weight: 600;
        border-left: 8px solid #0052cc;
        padding-left: calc(1.5rem - 3px);
    }

    .nav-icon {
        font-size: 1.25rem;
    }

    .sidebar-footer {
        border-top: 1px solid #e0e3e5;
        padding: 1rem 0 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    /* Main Content */
    .main-content {
        flex: 1;
        margin-left: 280px;
        padding: 2.5rem 3rem;
        overflow-y: auto;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .dashboard-layout {
            flex-direction: column;
        }

        .sidebar {
            width: 100%;
        }

        .main-content {
            padding: 1.5rem;
        }
    }
</style>

