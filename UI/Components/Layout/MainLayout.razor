@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@implements IDisposable

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<div class="page">
    <header class="header">
        <div class="container header-content">
            <a href="/" class="header-brand">AI Clinic</a>
            <nav class="header-nav">
                <a href="/general/consultation" class="nav-link @(IsActive("/general/consultation") || IsActive("/general/consultation") ? "active" : "")">Consultation</a>
                <a href="/general/doctors" class="nav-link @(IsActive("/general/doctors") || IsActive("/general/doctors") ? "active" : "")">Directory</a>
                <a href="/general/about" class="nav-link @(IsActive("/general/about") ? "active" : "")">About Us</a>
            </nav>
            <div class="header-actions">
                <a href="/auth/signin" class="btn-get-started">Get Started</a>
            </div>
        </div>
    </header>

    <main class="main-content">
        @Body
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-brand">
                    <h3 class="headline-sm">AI Clinic</h3>
                    <p class="body-md">© 2024 AI Clinic. The Clinical Sanctuary.</p>
                </div>
                <div class="footer-links">
                    <a href="#" class="footer-link">Privacy Policy</a>
                    <a href="#" class="footer-link">Terms of Service</a>
                    <a href="#" class="footer-link">HIPAA Compliance</a>
                    <a href="#" class="footer-link">Contact Support</a>
                </div>
                <div class="footer-social">
                    <button class="social-icon">
                        <i data-lucide="link"></i>
                    </button>
                    <button class="social-icon">
                        <i data-lucide="mail"></i>
                    </button>
                </div>
            </div>
        </div>
    </footer>
</div>

<style>
    .page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    /* Header */
    .header {
        position: sticky;
        top: 0;
        z-index: 1000;
        background: var(--surface-container-lowest);
        border-bottom: 1px solid var(--outline-variant);
        padding: 0.75rem 0;
    }

    .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
    }

    .header-brand {
        font-family: var(--font-headline);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--primary-container);
        text-decoration: none;
        white-space: nowrap;
    }

    .header-nav {
        display: flex;
        align-items: center;
        gap: 2rem;
        flex: 1;
    }

    .nav-link {
        text-decoration: none;
        color: var(--on-surface-variant);
        font-weight: 500;
        font-size: 0.9375rem;
        padding: 0.5rem 0;
        border-bottom: 2px solid transparent;
        transition: all 0.3s ease;
        white-space: nowrap;
    }

    .nav-link:hover {
        color: var(--on-surface);
    }

    .nav-link.active {
        color: var(--primary-container);
        border-bottom-color: var(--primary-container);
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .icon-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: transparent;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.3s ease;
    }

    .icon-btn:hover {
        background: var(--surface-container-low);
    }

    .icon {
        font-size: 1.25rem;
        opacity: 0.7;
    }

    .theme-toggle .icon {
        opacity: 1;
    }

    .btn-get-started {
        padding: 0.625rem 1.5rem;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-container) 100%);
        color: var(--on-primary);
        border: none;
        border-radius: var(--radius-full);
        font-family: var(--font-body);
        font-size: 0.9375rem;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.3s ease;
        white-space: nowrap;
    }

    .btn-get-started:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 61, 155, 0.3);
    }

    .main-content {
        flex: 1;
    }

    /* Footer */
    .footer {
        padding: 3rem 0;
        background: var(--surface-container-low);
    }

    .footer-content {
        display: grid;
        grid-template-columns: 1fr 2fr auto;
        gap: 3rem;
        align-items: center;
    }

    .footer-brand h3 {
        margin-bottom: 0.5rem;
    }

    .footer-brand p {
        color: var(--on-surface-variant);
        font-size: 0.875rem;
    }

    .footer-links {
        display: flex;
        gap: 2rem;
        justify-content: center;
    }

    .footer-link {
        color: var(--on-surface-variant);
        text-decoration: none;
        font-size: 0.875rem;
        transition: color 0.3s ease;
    }

    .footer-link:hover {
        color: var(--primary-container);
    }

    .footer-social {
        display: flex;
        gap: 1rem;
    }

    @@media (max-width: 768px) {
        .header-nav {
            display: none;
        }
        
        .header-content {
            gap: 1rem;
        }
    }

    @@media (max-width: 1024px) {
        .footer-content {
            grid-template-columns: 1fr;
            text-align: center;
        }

        .footer-links {
            flex-direction: column;
            gap: 1rem;
        }

        .footer-social {
            justify-content: center;
        }
    }
</style>