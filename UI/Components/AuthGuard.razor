@using ai_clinic.Services.Facades
@inject AuthFacade AuthFacade
@inject NavigationManager Navigation
@implements IDisposable

@if (!isLoading && isAuthenticated)
{
    @ChildContent
}
else if (isLoading)
{
    <div class="auth-guard-loading">
        <div class="spinner"></div>
        <p>Loading...</p>
    </div>
}

<style>
    .auth-guard-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        gap: 1rem;
    }

    .spinner {
        width: 40px;
        height: 40px;
        border: 4px solid #f3f3f3;
        border-top: 4px solid #0052cc;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
</style>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? RequiredRole { get; set; }

    [Parameter]
    public string RedirectTo { get; set; } = "/auth/signin";

    [Parameter]
    public bool EnablePeriodicCheck { get; set; } = false;

    [Parameter]
    public int CheckIntervalSeconds { get; set; } = 30;

    private bool isLoading = true;
    private bool isAuthenticated = false;
    private bool hasChecked = false;
    private System.Threading.Timer? periodicTimer;

    protected override void OnInitialized()
    {
        Console.WriteLine("[AuthGuard] OnInitialized called");
        
        // Subscribe to auth state changes
        AuthFacade.OnAuthStateChanged += HandleAuthStateChanged;

        // Start periodic check if enabled
        if (EnablePeriodicCheck)
        {
            periodicTimer = new System.Threading.Timer(
                async _ => await CheckAuthenticationAsync(),
                null,
                TimeSpan.FromSeconds(CheckIntervalSeconds),
                TimeSpan.FromSeconds(CheckIntervalSeconds)
            );
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !hasChecked)
        {
            hasChecked = true;
            Console.WriteLine("[AuthGuard] OnAfterRenderAsync - first render, checking auth");
            
            // Small delay to ensure JS interop is ready
            await Task.Delay(50);
            
            // Check authentication
            await CheckAuthenticationAsync();
        }
    }

    private async Task CheckAuthenticationAsync()
    {
        Console.WriteLine("[AuthGuard] CheckAuthenticationAsync started");
        
        try
        {
            // Revalidate session if needed
            if (!AuthFacade.IsInitialized)
            {
                Console.WriteLine("[AuthGuard] Revalidating session");
                await AuthFacade.RevalidateSessionAsync();
            }

            // Check authentication
            isAuthenticated = AuthFacade.IsAuthenticated;
            Console.WriteLine($"[AuthGuard] IsAuthenticated: {isAuthenticated}");
            Console.WriteLine($"[AuthGuard] CurrentUser: {AuthFacade.CurrentUser?.Email ?? "null"}");

            // Check role if required
            if (isAuthenticated && !string.IsNullOrEmpty(RequiredRole))
            {
                var currentRole = AuthFacade.CurrentUser?.Role.ToString();
                Console.WriteLine($"[AuthGuard] RequiredRole: {RequiredRole}, CurrentRole: {currentRole}");
                
                if (currentRole != RequiredRole)
                {
                    Console.WriteLine($"[AuthGuard] Role mismatch!");
                    isAuthenticated = false;
                }
            }

            // Update loading state BEFORE any navigation
            isLoading = false;
            Console.WriteLine("[AuthGuard] Setting isLoading = false");

            // Force UI update
            await InvokeAsync(StateHasChanged);
            Console.WriteLine("[AuthGuard] StateHasChanged called");

            // Redirect if not authenticated (after UI update)
            if (!isAuthenticated)
            {
                Console.WriteLine($"[AuthGuard] Not authenticated, redirecting to {RedirectTo}");
                await Task.Delay(100); // Give UI time to update
                Navigation.NavigateTo(RedirectTo, forceLoad: true);
            }
            else
            {
                Console.WriteLine("[AuthGuard] Authentication successful");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AuthGuard] Exception: {ex.Message}");
            Console.WriteLine($"[AuthGuard] Stack trace: {ex.StackTrace}");
            
            isAuthenticated = false;
            isLoading = false;
            
            await InvokeAsync(StateHasChanged);
            
            // Delay before redirect to ensure UI updates
            await Task.Delay(100);
            Navigation.NavigateTo(RedirectTo, forceLoad: true);
        }
    }

    private async void HandleAuthStateChanged()
    {
        Console.WriteLine("[AuthGuard] HandleAuthStateChanged triggered");
        await CheckAuthenticationAsync();
    }

    public void Dispose()
    {
        Console.WriteLine("[AuthGuard] Disposing");
        AuthFacade.OnAuthStateChanged -= HandleAuthStateChanged;
        periodicTimer?.Dispose();
    }
}
