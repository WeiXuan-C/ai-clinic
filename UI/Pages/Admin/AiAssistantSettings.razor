@page "/admin/ai-settings"
@using ai_clinic.Models
@using ai_clinic.Services.Facades
@layout Components.Layout.AdminSidebarLayout
@inject AuthFacade AuthFacade
@inject AdminFacade AdminFacade
@inject NavigationManager Navigation

<PageTitle>AI Assistant Settings - Admin Panel</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />
<link rel="stylesheet" href="/css/admin-ai-settings.css" />

<div class="ai-settings-page">
    <div class="page-header">
        <div>
            <h1>AI Assistant Settings</h1>
            <p class="text-muted">Manage AI models and configurations for consultation chatrooms</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-primary" @onclick="ShowCreateModal">
                <i class="bi bi-plus-circle"></i> Add AI Configuration
            </button>
            <button class="btn btn-outline-secondary" @onclick="NavigateBack">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </button>
        </div>
    </div>

    <!-- Information Banner -->
    <div class="alert alert-info" role="alert">
        <i class="bi bi-info-circle-fill"></i>
        <strong>AI Model Management:</strong> Configure which AI models are active and available for patients to use in consultation chatrooms. 
        Multiple models can be active simultaneously, and patients can switch between available models during their consultations.
    </div>

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @_successMessage
            <button type="button" class="btn-close" @onclick="() => _successMessage = null"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @_errorMessage
            <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
        </div>
    }

    <!-- Statistics Cards -->
    @if (_stats != null)
    {
        <div class="stats-grid">
            <div class="stat-card stat-primary">
                <div class="stat-icon">
                    <i class="bi bi-gear-fill"></i>
                </div>
                <div class="stat-content">
                    <h3>@_stats.TotalSettings</h3>
                    <p>Total Configurations</p>
                </div>
            </div>

            <div class="stat-card stat-success">
                <div class="stat-icon">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <div class="stat-content">
                    <h3>@_stats.ActiveSettings</h3>
                    <p>Active Configuration</p>
                </div>
            </div>

            <div class="stat-card stat-info">
                <div class="stat-icon">
                    <i class="bi bi-cpu-fill"></i>
                </div>
                <div class="stat-content">
                    <h3>@_stats.ModelsUsed</h3>
                    <p>Unique Models</p>
                </div>
            </div>

            <div class="stat-card stat-warning">
                <div class="stat-icon">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div class="stat-content">
                    <h3>@_stats.AvailableForPatients</h3>
                    <p>Available to Patients</p>
                </div>
            </div>
        </div>
    }

    @if (_isLoading)
    {
        <div class="loading-container">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p>Loading AI settings...</p>
        </div>
    }
    else if (_settings != null && _settings.Count > 0)
    {
        <!-- AI Settings Table -->
        <div class="table-container">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Model Name</th>
                        <th>Model Type</th>
                        <th>Status</th>
                        <th>Patient Access</th>
                        <th>Display Order</th>
                        <th>Features</th>
                        <th>Created At</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var setting in _settings.OrderBy(s => s.DisplayOrder))
                    {
                        <tr class="@(!setting.IsActive ? "inactive-row" : "active-row")">
                            <td>
                                <div class="model-cell">
                                    <i class="bi bi-cpu-fill"></i>
                                    <strong>@setting.ModelName</strong>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-info">
                                    @GetModelIcon(setting.ModelType) @setting.ModelType.ToString()
                                </span>
                            </td>
                            <td>
                                <span class="badge @(setting.IsActive ? "bg-success" : "bg-secondary")">
                                    @(setting.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" 
                                           type="checkbox" 
                                           checked="@setting.IsAvailableForPatients"
                                           @onchange="@(e => TogglePatientAvailability(setting.Id, (bool)e.Value!))"
                                           disabled="@(!setting.IsActive)" />
                                    <label class="form-check-label">
                                        @(setting.IsAvailableForPatients ? "Available" : "Unavailable")
                                    </label>
                                </div>
                            </td>
                            <td>
                                <input type="number" 
                                       class="form-control form-control-sm" 
                                       style="width: 80px;"
                                       value="@setting.DisplayOrder"
                                       @onchange="@(e => UpdateDisplayOrder(setting.Id, int.Parse(e.Value!.ToString()!)))"
                                       min="0" />
                            </td>
                            <td>
                                <div class="feature-badges">
                                    @if (setting.EnableDocumentAnalysis)
                                    {
                                        <span class="badge bg-info" title="Document Analysis">
                                            <i class="bi bi-file-text"></i> Docs
                                        </span>
                                    }
                                    @if (setting.EnableSymptomChecker)
                                    {
                                        <span class="badge bg-warning" title="Symptom Checker">
                                            <i class="bi bi-clipboard2-pulse"></i> Symptoms
                                        </span>
                                    }
                                    @if (setting.EnableDoctorRecommendation)
                                    {
                                        <span class="badge bg-primary" title="Doctor Recommendation">
                                            <i class="bi bi-person-badge"></i> Recommend
                                        </span>
                                    }
                                </div>
                            </td>
                            <td>@setting.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div class="action-buttons">
                                    @if (!setting.IsActive)
                                    {
                                        <button class="btn btn-sm btn-success" 
                                                @onclick="() => ActivateSetting(setting.Id)"
                                                title="Activate Configuration">
                                            <i class="bi bi-play-circle"></i>
                                        </button>
                                    }
                                    <button class="btn btn-sm btn-info" 
                                            @onclick="() => ShowEditModal(setting)"
                                            title="Edit Configuration">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger" 
                                            @onclick="() => ShowDeleteModal(setting)"
                                            title="Delete Configuration">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                    <button class="btn btn-sm btn-secondary" 
                                            @onclick="() => ShowDetailsModal(setting)"
                                            title="View Details">
                                        <i class="bi bi-info-circle"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-cpu"></i>
            <h3>No AI Configurations</h3>
            <p>Create your first AI assistant configuration to get started.</p>
            <button class="btn btn-primary" @onclick="ShowCreateModal">
                <i class="bi bi-plus-circle"></i> Add AI Configuration
            </button>
        </div>
    }
</div>

<!-- Create/Edit Modal -->
@if (_showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-dialog" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <h3>@(_isEditMode ? "Edit AI Configuration" : "Create AI Configuration")</h3>
                    <button class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Model Name <span class="text-danger">*</span></label>
                        <input type="text" 
                               class="form-control" 
                               @bind="_formModel.ModelName" 
                               placeholder="e.g., Gemma 4, MiniMax" />
                    </div>

                    <div class="form-group">
                        <label>Model Type <span class="text-danger">*</span></label>
                        <select class="form-control" @bind="_formModel.ModelType">
                            <option value="@AiModelType.Gemma4">🔷 Gemma 4 - Advanced medical analysis</option>
                            <option value="@AiModelType.MiniMax">⚡ MiniMax - Fast consultations</option>
                            <option value="@AiModelType.Nemotron">🔬 Nemotron - Specialized diagnostics</option>
                            <option value="@AiModelType.Owlapha">🦉 Owlapha - Comprehensive knowledge</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Description</label>
                        <textarea class="form-control" 
                                  rows="2" 
                                  @bind="_formModel.Description" 
                                  placeholder="Brief description of this AI model..."></textarea>
                    </div>

                    <div class="form-group">
                        <label>Display Order</label>
                        <input type="number" 
                               class="form-control" 
                               @bind="_formModel.DisplayOrder" 
                               min="0"
                               placeholder="0" />
                        <small class="form-text text-muted">Lower numbers appear first in patient selection</small>
                    </div>

                    <div class="form-group">
                        <label>System Prompt</label>
                        <textarea class="form-control" 
                                  rows="4" 
                                  @bind="_formModel.SystemPrompt" 
                                  placeholder="Optional custom system prompt for this AI model..."></textarea>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" 
                                   class="form-check-input" 
                                   id="isActiveCheck"
                                   @bind="_formModel.IsActive" />
                            <label class="form-check-label" for="isActiveCheck">
                                Set as Active
                            </label>
                        </div>
                        <small class="form-text text-muted">
                            Active models can be used in the system
                        </small>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" 
                                   class="form-check-input" 
                                   id="availableForPatientsCheck"
                                   @bind="_formModel.IsAvailableForPatients"
                                   disabled="@(!_formModel.IsActive)" />
                            <label class="form-check-label" for="availableForPatientsCheck">
                                Available for Patients
                            </label>
                        </div>
                        <small class="form-text text-muted">
                            Patients can select this model in their consultations
                        </small>
                    </div>

                    <hr />

                    <h5>Features</h5>

                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" 
                                   class="form-check-input" 
                                   id="enableDocAnalysis"
                                   @bind="_formModel.EnableDocumentAnalysis" />
                            <label class="form-check-label" for="enableDocAnalysis">
                                <i class="bi bi-file-text"></i> Enable Document Analysis
                            </label>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" 
                                   class="form-check-input" 
                                   id="enableSymptomChecker"
                                   @bind="_formModel.EnableSymptomChecker" />
                            <label class="form-check-label" for="enableSymptomChecker">
                                <i class="bi bi-clipboard2-pulse"></i> Enable Symptom Checker
                            </label>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" 
                                   class="form-check-input" 
                                   id="enableDoctorRec"
                                   @bind="_formModel.EnableDoctorRecommendation" />
                            <label class="form-check-label" for="enableDoctorRec">
                                <i class="bi bi-person-badge"></i> Enable Doctor Recommendation
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveSetting">
                        @(_isEditMode ? "Update" : "Create")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Delete Confirmation Modal -->
@if (_showDeleteModal)
{
    <div class="modal-overlay" @onclick="CloseDeleteModal">
        <div class="modal-dialog" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <h3>Confirm Deletion</h3>
                    <button class="btn-close" @onclick="CloseDeleteModal"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete the AI configuration for <strong>@_selectedSetting?.ModelName</strong>?</p>
                    <p class="text-danger">This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseDeleteModal">Cancel</button>
                    <button class="btn btn-danger" @onclick="DeleteSetting">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Details Modal -->
@if (_showDetailsModal && _selectedSetting != null)
{
    <div class="modal-overlay" @onclick="CloseDetailsModal">
        <div class="modal-dialog modal-lg" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <h3>AI Configuration Details</h3>
                    <button class="btn-close" @onclick="CloseDetailsModal"></button>
                </div>
                <div class="modal-body">
                    <div class="details-grid">
                        <div class="detail-item">
                            <label>Model Name</label>
                            <p>@_selectedSetting.ModelName</p>
                        </div>
                        <div class="detail-item">
                            <label>Model Type</label>
                            <p>
                                <span class="badge bg-info">
                                    @GetModelIcon(_selectedSetting.ModelType) @_selectedSetting.ModelType.ToString()
                                </span>
                            </p>
                        </div>
                        <div class="detail-item">
                            <label>Status</label>
                            <p>
                                <span class="badge @(_selectedSetting.IsActive ? "bg-success" : "bg-secondary")">
                                    @(_selectedSetting.IsActive ? "Active" : "Inactive")
                                </span>
                            </p>
                        </div>
                        <div class="detail-item">
                            <label>Patient Access</label>
                            <p>
                                <span class="badge @(_selectedSetting.IsAvailableForPatients ? "bg-success" : "bg-secondary")">
                                    @(_selectedSetting.IsAvailableForPatients ? "Available" : "Unavailable")
                                </span>
                            </p>
                        </div>
                        <div class="detail-item">
                            <label>Display Order</label>
                            <p>@_selectedSetting.DisplayOrder</p>
                        </div>
                        @if (!string.IsNullOrEmpty(_selectedSetting.Description))
                        {
                            <div class="detail-item full-width">
                                <label>Description</label>
                                <p>@_selectedSetting.Description</p>
                            </div>
                        }
                        <div class="detail-item">
                            <label>Configuration ID</label>
                            <p><code>@_selectedSetting.Id</code></p>
                        </div>
                        <div class="detail-item">
                            <label>Created At</label>
                            <p>@_selectedSetting.CreatedAt.ToString("MMMM dd, yyyy HH:mm:ss")</p>
                        </div>
                        <div class="detail-item">
                            <label>Last Updated</label>
                            <p>@_selectedSetting.UpdatedAt.ToString("MMMM dd, yyyy HH:mm:ss")</p>
                        </div>
                        <div class="detail-item">
                            <label>Features</label>
                            <div class="feature-list">
                                <div class="feature-item">
                                    <i class="bi @(_selectedSetting.EnableDocumentAnalysis ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger")"></i>
                                    Document Analysis
                                </div>
                                <div class="feature-item">
                                    <i class="bi @(_selectedSetting.EnableSymptomChecker ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger")"></i>
                                    Symptom Checker
                                </div>
                                <div class="feature-item">
                                    <i class="bi @(_selectedSetting.EnableDoctorRecommendation ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger")"></i>
                                    Doctor Recommendation
                                </div>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(_selectedSetting.SystemPrompt))
                        {
                            <div class="detail-item full-width">
                                <label>System Prompt</label>
                                <div class="system-prompt-box">
                                    @_selectedSetting.SystemPrompt
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseDetailsModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}
