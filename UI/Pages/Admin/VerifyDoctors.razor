@page "/admin/verify-doctors"
@using ai_clinic.Models
@using ai_clinic.Services.Facades
@layout Components.Layout.AdminSidebarLayout
@inject AuthFacade AuthFacade
@inject AdminFacade AdminFacade
@inject NavigationManager Navigation

<PageTitle>Verify Doctors - Admin Panel</PageTitle>

<div class="verify-doctors-page">
        <div class="page-header">
            <div>
                <h1>Doctor Verification</h1>
                <p class="text-muted">Review and verify doctor credentials</p>
            </div>
            <button class="btn btn-outline-secondary" @onclick="NavigateBack">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </button>
        </div>

        <!-- Filter Tabs -->
        <div class="filter-tabs">
            <button class="tab-btn @(_currentFilter == "pending" ? "active" : "")" 
                    @onclick="@(() => SetFilter("pending"))">
                Pending (@_pendingCount)
            </button>
            <button class="tab-btn @(_currentFilter == "verified" ? "active" : "")" 
                    @onclick="@(() => SetFilter("verified"))">
                Verified (@_verifiedCount)
            </button>
            <button class="tab-btn @(_currentFilter == "all" ? "active" : "")" 
                    @onclick="@(() => SetFilter("all"))">
                All Doctors (@_allCount)
            </button>
        </div>

        @if (_isLoading)
        {
            <div class="loading-container">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p>Loading doctors...</p>
            </div>
        }
        else if (_doctors.Count == 0)
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <h3>No doctors found</h3>
                <p>There are no doctors matching the current filter.</p>
            </div>
        }
        else
        {
            <div class="doctors-grid">
                @foreach (var doctor in _doctors)
                {
                    <div class="doctor-card @(doctor.IsVerified ? "verified" : "pending")">
                        <div class="doctor-header">
                            <div class="doctor-avatar">
                                @if (doctor.ProfilePhoto != null)
                                {
                                    <img src="data:image/jpeg;base64,@Convert.ToBase64String(doctor.ProfilePhoto)" 
                                         alt="@doctor.FullName" />
                                }
                                else
                                {
                                    <i class="bi bi-person-circle"></i>
                                }
                            </div>
                            <div class="doctor-info">
                                <h3>@doctor.FullName</h3>
                                <p class="specialization">@doctor.PrimarySpecialization</p>
                                <span class="badge @(doctor.IsVerified ? "bg-success" : "bg-warning")">
                                    @(doctor.IsVerified ? "Verified" : "Pending Verification")
                                </span>
                            </div>
                        </div>

                        <div class="doctor-details">
                            <div class="detail-row">
                                <span class="label">License Number:</span>
                                <span class="value">@doctor.LicenseNumber</span>
                            </div>
                            <div class="detail-row">
                                <span class="label">Email:</span>
                                <span class="value">@doctor.User.Email</span>
                            </div>
                            <div class="detail-row">
                                <span class="label">Experience:</span>
                                <span class="value">@(doctor.YearsOfExperience ?? 0) years</span>
                            </div>
                            <div class="detail-row">
                                <span class="label">Availability:</span>
                                <span class="value">@doctor.AvailabilityStatus</span>
                            </div>
                            <div class="detail-row">
                                <span class="label">Accepting Patients:</span>
                                <span class="value">@(doctor.IsAcceptingPatients ? "Yes" : "No")</span>
                            </div>
                            <div class="detail-row">
                                <span class="label">Registered:</span>
                                <span class="value">@doctor.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                            @if (doctor.SubSpecializations != null)
                            {
                                <div class="detail-row">
                                    <span class="label">Sub-specializations:</span>
                                    <span class="value">@doctor.SubSpecializations</span>
                                </div>
                            }
                        </div>

                        <div class="doctor-actions">
                            @if (!doctor.IsVerified)
                            {
                                <button class="btn btn-success" 
                                        @onclick="() => VerifyDoctor(doctor.UserId, true)"
                                        disabled="@_isProcessing">
                                    <i class="bi bi-check-circle"></i> Verify
                                </button>
                                <button class="btn btn-danger" 
                                        @onclick="() => RejectDoctor(doctor.UserId)"
                                        disabled="@_isProcessing">
                                    <i class="bi bi-x-circle"></i> Reject
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-warning" 
                                        @onclick="() => RevokeVerification(doctor.UserId)"
                                        disabled="@_isProcessing">
                                    <i class="bi bi-shield-x"></i> Revoke Verification
                                </button>
                            }
                            <button class="btn btn-outline-primary" 
                                    @onclick="() => ShowEditDoctorModal(doctor)">
                                <i class="bi bi-pencil-square"></i> Manage Profile
                            </button>
                            <button class="btn btn-outline-primary" 
                                    @onclick="() => ViewDoctorDetails(doctor.UserId)">
                                <i class="bi bi-eye"></i> View Details
                            </button>
                        </div>
                    </div>
                }
            </div>
        }

        @if (_showEditDoctorModal)
        {
            <div class="modal-overlay" @onclick="CloseEditDoctorModal">
                <div class="modal-content" @onclick:stopPropagation="true">
                    <div class="modal-header">
                        <h3>Manage Doctor Profile</h3>
                        <button class="btn-close" @onclick="CloseEditDoctorModal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="form-group">
                            <label>Full Name</label>
                            <input class="form-control" @bind="_doctorFullName" />
                        </div>
                        <div class="form-group">
                            <label>License Number</label>
                            <input class="form-control" @bind="_doctorLicenseNumber" />
                        </div>
                        <div class="form-group">
                            <label>Primary Specialization</label>
                            <input class="form-control" @bind="_doctorSpecialization" />
                        </div>
                        <div class="form-group">
                            <label>Years of Experience</label>
                            <input class="form-control" type="number" @bind="_doctorYearsOfExperience" />
                        </div>
                        <div class="form-group">
                            <label>Availability</label>
                            <select class="form-select" @bind="_doctorAvailability">
                                <option value="@DoctorAvailabilityStatus.Available">Available</option>
                                <option value="@DoctorAvailabilityStatus.Busy">Busy</option>
                                <option value="@DoctorAvailabilityStatus.Offline">Offline</option>
                            </select>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="doctor-active" @bind="_doctorIsActive" />
                            <label class="form-check-label" for="doctor-active">Active profile</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="doctor-accepting" @bind="_doctorAcceptingPatients" />
                            <label class="form-check-label" for="doctor-accepting">Accepting patients</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CloseEditDoctorModal">Cancel</button>
                        <button class="btn btn-primary" @onclick="SaveDoctorProfile" disabled="@_isProcessing">
                            Save Doctor Profile
                        </button>
                    </div>
                </div>
            </div>
        }

        @if (_successMessage != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i> @_successMessage
                <button type="button" class="btn-close" @onclick="() => _successMessage = null"></button>
            </div>
        }

        @if (_errorMessage != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i> @_errorMessage
                <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
            </div>
        }
    </div>

@code {
    private List<DoctorProfile> _doctors = new();
    private string _currentFilter = "pending";
    private bool _isLoading = true;
    private bool _isProcessing = false;
    private string? _successMessage;
    private string? _errorMessage;
    private int _pendingCount = 0;
    private int _verifiedCount = 0;
    private int _allCount = 0;
    private bool _showEditDoctorModal = false;
    private Guid? _editingDoctorUserId;
    private string _doctorFullName = "";
    private string _doctorLicenseNumber = "";
    private string _doctorSpecialization = "";
    private int? _doctorYearsOfExperience;
    private DoctorAvailabilityStatus _doctorAvailability = DoctorAvailabilityStatus.Offline;
    private bool _doctorAcceptingPatients = true;
    private bool _doctorIsActive = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDoctors();
    }

    private async Task LoadDoctors()
    {
        try
        {
            _isLoading = true;
            _errorMessage = null;

            // Load all doctors using AdminFacade
            var allDoctors = await AdminFacade.GetDoctorsForVerificationAsync();
            _allCount = allDoctors.Count;
            _verifiedCount = allDoctors.Count(d => d.IsVerified);
            _pendingCount = allDoctors.Count(d => !d.IsVerified);

            // Filter doctors based on current filter
            _doctors = _currentFilter switch
            {
                "pending" => allDoctors.Where(d => !d.IsVerified).ToList(),
                "verified" => allDoctors.Where(d => d.IsVerified).ToList(),
                "all" => allDoctors,
                _ => allDoctors
            };
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load doctors: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SetFilter(string filter)
    {
        _currentFilter = filter;
        await LoadDoctors();
    }

    private async Task VerifyDoctor(Guid doctorUserId, bool isVerified)
    {
        try
        {
            _isProcessing = true;
            _errorMessage = null;

            var currentUser = AuthFacade.CurrentUser;
            if (currentUser == null)
            {
                _errorMessage = "You must be logged in to perform this action.";
                return;
            }

            await AdminFacade.VerifyDoctorAsync(
                doctorUserId, 
                currentUser.Id, 
                isVerified);

            _successMessage = "Doctor verified successfully!";
            await LoadDoctors();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task RejectDoctor(Guid doctorUserId)
    {
        try
        {
            _isProcessing = true;
            _errorMessage = null;

            var currentUser = AuthFacade.CurrentUser;
            if (currentUser == null)
            {
                _errorMessage = "You must be logged in to perform this action.";
                return;
            }

            await AdminFacade.VerifyDoctorAsync(
                doctorUserId, 
                currentUser.Id, 
                false);

            _successMessage = "Doctor verification rejected.";
            await LoadDoctors();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task RevokeVerification(Guid doctorUserId)
    {
        try
        {
            _isProcessing = true;
            _errorMessage = null;

            var currentUser = AuthFacade.CurrentUser;
            if (currentUser == null)
            {
                _errorMessage = "You must be logged in to perform this action.";
                return;
            }

            await AdminFacade.VerifyDoctorAsync(
                doctorUserId, 
                currentUser.Id, 
                false);

            _successMessage = "Doctor verification revoked.";
            await LoadDoctors();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void ShowEditDoctorModal(DoctorProfile doctor)
    {
        _editingDoctorUserId = doctor.UserId;
        _doctorFullName = doctor.FullName;
        _doctorLicenseNumber = doctor.LicenseNumber;
        _doctorSpecialization = doctor.PrimarySpecialization;
        _doctorYearsOfExperience = doctor.YearsOfExperience;
        _doctorAvailability = doctor.AvailabilityStatus;
        _doctorAcceptingPatients = doctor.IsAcceptingPatients;
        _doctorIsActive = doctor.IsActive;
        _showEditDoctorModal = true;
    }

    private void CloseEditDoctorModal()
    {
        _showEditDoctorModal = false;
        _editingDoctorUserId = null;
    }

    private async Task SaveDoctorProfile()
    {
        if (!_editingDoctorUserId.HasValue)
            return;

        try
        {
            _isProcessing = true;
            _errorMessage = null;

            var currentUser = AuthFacade.CurrentUser;
            if (currentUser == null)
            {
                _errorMessage = "You must be logged in to perform this action.";
                return;
            }

            await AdminFacade.UpdateDoctorProfileAsync(
                currentUser.Id,
                _editingDoctorUserId.Value,
                _doctorFullName,
                _doctorLicenseNumber,
                _doctorSpecialization,
                _doctorYearsOfExperience,
                _doctorAvailability,
                _doctorAcceptingPatients,
                _doctorIsActive);

            _successMessage = "Doctor profile updated successfully.";
            CloseEditDoctorModal();
            await LoadDoctors();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void ViewDoctorDetails(Guid doctorUserId)
    {
        Navigation.NavigateTo($"/admin/doctor-details/{doctorUserId}");
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo("/admin/dashboard");
    }
}

