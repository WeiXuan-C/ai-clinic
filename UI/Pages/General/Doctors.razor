@page "/general/doctors"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout Components.Layout.MainLayout
@using ai_clinic.UI.State
@using ai_clinic.Interfaces
@inject DoctorProfileState DoctorProfileState
@inject DoctorRatingState DoctorRatingState
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<PageTitle>Find Doctors - AI Medical Clinic</PageTitle>

<div class="doctors-page">
    <div class="container">
        <!-- Header Section -->
        <div class="page-header-section">            
            <div class="search-row">
                <div class="search-container">
                    <i data-lucide="search" class="search-icon"></i>
                    <input type="text" @bind="searchQuery" @bind:event="oninput" placeholder="Search by name, specialty, or condition..." class="search-input" />
                </div>
                <button class="btn-available-today @(showAvailableOnly ? "active" : "")" @onclick="FilterAvailableToday">
                    <i data-lucide="calendar" class="calendar-icon"></i>
                    Available Today
                </button>
            </div>
        </div>

        <!-- Filters Section -->
        <section class="filters-section">
            <div class="filter-buttons">
                <select class="filter-select" @bind="selectedSpecialty">
                    <option value="">All Specialties</option>
                    @foreach (var specialty in specialties)
                    {
                        <option value="@specialty">@specialty</option>
                    }
                </select>
                <select class="filter-select" @bind="minRating">
                    <option value="0">All Ratings</option>
                    <option value="4">4+ Stars</option>
                    <option value="4.5">4.5+ Stars</option>
                </select>
            </div>
            <div class="results-count">@FilteredDoctors.Count() specialists found</div>
        </section>

        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>Loading doctors...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-error">
                <i data-lucide="alert-circle"></i>
                @errorMessage
            </div>
        }
        else if (!FilteredDoctors.Any())
        {
            <div class="empty-state">
                <i data-lucide="user-x"></i>
                <h3>No doctors found</h3>
                <p class="empty-message">No doctors found matching your criteria</p>
                <button class="btn-primary" @onclick="ClearFilters">Clear Filters</button>
            </div>
        }
        else
        {
            <!-- Doctors Grid -->
            <section class="doctors-grid">
                @foreach (var doctor in FilteredDoctors)
                {
                    var avgRating = doctorRatings.ContainsKey(doctor.Id) ? doctorRatings[doctor.Id] : (double)doctor.AverageRating;
                    
                    <div class="doctor-card">
                        <div class="doctor-card-header">
                            <div class="doctor-photo">
                                @if (!string.IsNullOrEmpty(doctor.ProfilePhotoUrl))
                                {
                                    <img src="@doctor.ProfilePhotoUrl" alt="@doctor.FullName" class="photo-img" />
                                }
                                else
                                {
                                    <div class="photo-placeholder" style="background: @GetDoctorColor(doctor.Id);">
                                        @doctor.FullName.Substring(0, 1)
                                    </div>
                                }
                                @if (doctor.AvailabilityStatus == "available")
                                {
                                    <span class="online-badge"></span>
                                }
                            </div>
                            
                            <div class="doctor-info">
                                <h3 class="doctor-name">
                                    @if (!string.IsNullOrEmpty(doctor.Title))
                                    {
                                        <span>@doctor.Title </span>
                                    }
                                    @doctor.FullName
                                    @if (doctor.IsVerified)
                                    {
                                        <i data-lucide="badge-check" class="verified-icon" title="Verified"></i>
                                    }
                                </h3>
                                <div class="doctor-tags">
                                    <span class="specialty-tag">@doctor.PrimarySpecialization.ToUpper()</span>
                                    @if (doctor.YearsOfExperience.HasValue)
                                    {
                                        <span class="experience-tag">@doctor.YearsOfExperience yrs exp</span>
                                    }
                                </div>
                            </div>
                        </div>
                        
                        <div class="doctor-rating">
                            <div class="stars">
                                @for (int i = 0; i < 5; i++)
                                {
                                    <i data-lucide="star" class="star @(i < Math.Floor(avgRating) ? "filled" : "")"></i>
                                }
                            </div>
                            <span class="rating-text">@avgRating.ToString("0.0") <span class="review-count">(@doctor.TotalRatings reviews)</span></span>
                        </div>

                        @if (doctor.LanguagesSpoken != null && doctor.LanguagesSpoken.Length > 0)
                        {
                            <div class="doctor-languages">
                                <i data-lucide="languages"></i>
                                <span>@string.Join(", ", doctor.LanguagesSpoken.Take(3))</span>
                            </div>
                        }

                        @if (doctor.MedicalExpertiseTags != null && doctor.MedicalExpertiseTags.Length > 0)
                        {
                            <div class="expertise-tags">
                                @foreach (var tag in doctor.MedicalExpertiseTags.Take(3))
                                {
                                    <span class="expertise-tag">@tag</span>
                                }
                            </div>
                        }
                        
                        <div class="availability-card">
                            <div class="availability-info">
                                <i data-lucide="clock" class="clock-icon"></i>
                                <div class="availability-text">
                                    <div class="availability-label">Status</div>
                                    <div class="availability-time">@GetAvailabilityText(doctor.AvailabilityStatus)</div>
                                </div>
                            </div>
                            @if (doctor.AvailabilityStatus == "available" && doctor.IsAcceptingPatients)
                            {
                                <span class="availability-badge">✦ AVAILABLE</span>
                            }
                            else if (doctor.IsAcceptingPatients)
                            {
                                <span class="ai-assist-badge">✦ ACCEPTING</span>
                            }
                        </div>

                        <div class="doctor-stats">
                            <div class="stat-item">
                                <i data-lucide="users"></i>
                                <span>@doctor.TotalConsultations consultations</span>
                            </div>
                            @if (doctor.CurrentActiveConversations > 0)
                            {
                                <div class="stat-item">
                                    <i data-lucide="message-circle"></i>
                                    <span>@doctor.CurrentActiveConversations active</span>
                                </div>
                            }
                        </div>

                        <div class="card-actions">
                            <button class="btn-view-profile" @onclick="() => ViewProfile(doctor.Id)">
                                View Profile
                            </button>
                            <button class="btn-book-consultation" @onclick="() => BookAppointment(doctor.Id)" disabled="@(!doctor.IsAcceptingPatients)">
                                Book Consultation
                            </button>
                        </div>
                    </div>
                }
            </section>
        }
    </div>
</div>

@code {
    private List<Doctor> doctors = new();
    private Dictionary<Guid, double> doctorRatings = new();
    private string searchQuery = "";
    private bool showAvailableOnly = false;
    private string selectedSpecialty = "";
    private double minRating = 0;
    private bool isLoading = false;
    private string? errorMessage;

    private List<string> specialties = new();

    private IEnumerable<Doctor> FilteredDoctors =>
        doctors.Where(d =>
            (string.IsNullOrEmpty(searchQuery) || 
             d.FullName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) || 
             d.PrimarySpecialization.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
             (d.MedicalExpertiseTags != null && d.MedicalExpertiseTags.Any(t => t.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)))) &&
            (!showAvailableOnly || (d.AvailabilityStatus == "available" && d.IsAcceptingPatients)) &&
            (string.IsNullOrEmpty(selectedSpecialty) || d.PrimarySpecialization == selectedSpecialty) &&
            (minRating == 0 || (double)d.AverageRating >= minRating)
        );

    protected override async Task OnInitializedAsync()
    {
        await LoadDoctors();
        await JSRuntime.InvokeVoidAsync("lucide.createIcons");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            await JSRuntime.InvokeVoidAsync("lucide.createIcons");
        }
    }

    private async Task LoadDoctors()
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var allDoctors = await DoctorProfileState.GetAllAsync();
            doctors = allDoctors.Where(d => d.IsActive).ToList();

            // Extract unique specialties
            specialties = doctors
                .Select(d => d.PrimarySpecialization)
                .Distinct()
                .OrderBy(s => s)
                .ToList();

            // Load ratings for each doctor
            foreach (var doctor in doctors)
            {
                try
                {
                    var avgRating = await DoctorRatingState.GetAverageRatingAsync(doctor.Id);
                    doctorRatings[doctor.Id] = avgRating;
                }
                catch
                {
                    // Use the stored average rating if fetching fails
                    doctorRatings[doctor.Id] = (double)doctor.AverageRating;
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load doctors: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void FilterAvailableToday()
    {
        showAvailableOnly = !showAvailableOnly;
        StateHasChanged();
    }

    private void BookAppointment(Guid doctorId)
    {
        Navigation.NavigateTo($"/patient/consultation?doctorId={doctorId}");
    }

    private void ViewProfile(Guid doctorId)
    {
        Navigation.NavigateTo($"/doctor/{doctorId}");
    }

    private void ClearFilters()
    {
        searchQuery = "";
        showAvailableOnly = false;
        selectedSpecialty = "";
        minRating = 0;
        StateHasChanged();
    }

    private string GetAvailabilityText(string status)
    {
        return status switch
        {
            "available" => "Available Now",
            "busy" => "Currently Busy",
            "offline" => "Offline",
            _ => "Unknown"
        };
    }

    private string GetDoctorColor(Guid doctorId)
    {
        var colors = new[]
        {
            "linear-gradient(135deg, #667eea 0%, #764ba2 100%)",
            "linear-gradient(135deg, #f093fb 0%, #f5576c 100%)",
            "linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)",
            "linear-gradient(135deg, #43e97b 0%, #38f9d7 100%)",
            "linear-gradient(135deg, #fa709a 0%, #fee140 100%)",
            "linear-gradient(135deg, #30cfd0 0%, #330867 100%)"
        };
        
        var hash = doctorId.GetHashCode();
        var index = Math.Abs(hash) % colors.Length;
        return colors[index];
    }
}

