@page "/general/doctors"
@layout Components.Layout.MainLayout

<PageTitle>Find Doctors - AI Medical Clinic</PageTitle>

<div class="doctors-page">
    <div class="container">
        <!-- Header Section -->
        <div class="page-header">
            <div class="header-content">
                <h1 class="page-title">Find Your Doctor</h1>
                <p class="page-subtitle">Connect with experienced healthcare professionals</p>
            </div>
        </div>

        <!-- Search and Filters -->
        <div class="filters-section">
            <div class="search-box">
                <i data-lucide="search" class="search-icon"></i>
                <input 
                    type="text" 
                    placeholder="Search by name, specialization, or expertise..." 
                    class="search-input"
                    value="@searchQuery"
                    @onchange="OnSearchChanged"
                />
            </div>

            <div class="filters-row">
                <div class="filter-group">
                    <label class="filter-label">Specialization</label>
                    <select class="filter-select" value="@selectedSpecialization" @onchange="OnSpecializationChanged">
                        <option value="All">All Specializations</option>
                        @foreach (var spec in specializations)
                        {
                            <option value="@spec">@spec</option>
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <label class="filter-label">Availability</label>
                    <select class="filter-select" value="@selectedAvailability" @onchange="OnAvailabilityChanged">
                        <option value="All">All Doctors</option>
                        <option value="Available">Available Now</option>
                        <option value="Accepting">Accepting Patients</option>
                    </select>
                </div>

                <div class="results-count">
                    <span class="count-number">@filteredDoctors.Count</span>
                    <span class="count-label">doctors found</span>
                </div>
            </div>
        </div>

        <!-- Loading State -->
        @if (isLoading)
        {
            <div class="loading-state">
                <div class="loading-spinner"></div>
                <p>Loading doctors...</p>
            </div>
        }
        <!-- Empty State -->
        else if (!filteredDoctors.Any())
        {
            <div class="empty-state">
                <i data-lucide="user-x"></i>
                <h3>No Doctors Found</h3>
                <p class="empty-message">Try adjusting your search or filters</p>
            </div>
        }
        <!-- Doctors Grid -->
        else
        {
            <div class="doctors-grid">
                @foreach (var doctor in filteredDoctors)
                {
                    <div class="doctor-card">
                        <!-- Availability Badge -->
                        <div class="availability-badge @GetAvailabilityClass(doctor.AvailabilityStatus)">
                            <span class="status-dot"></span>
                            @GetAvailabilityText(doctor.AvailabilityStatus)
                        </div>

                        <!-- Doctor Photo -->
                        <div class="doctor-photo">
                            @if (!string.IsNullOrEmpty(doctor.ProfilePhotoUrl))
                            {
                                <img src="@doctor.ProfilePhotoUrl" alt="@doctor.FullName" />
                            }
                            else
                            {
                                <div class="photo-placeholder">
                                    <i data-lucide="user"></i>
                                </div>
                            }
                        </div>

                        <!-- Doctor Info -->
                        <div class="doctor-info">
                            <h3 class="doctor-name">@doctor.Title @doctor.FullName</h3>
                            <p class="doctor-specialization">@doctor.Specialization</p>

                            <!-- Rating -->
                            <div class="doctor-rating">
                                <div class="stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        @if (i <= Math.Floor(doctor.AverageRating))
                                        {
                                            <i data-lucide="star" class="star-filled"></i>
                                        }
                                        else if (i - 0.5 <= (double)doctor.AverageRating)
                                        {
                                            <i data-lucide="star" class="star-half"></i>
                                        }
                                        else
                                        {
                                            <i data-lucide="star" class="star-empty"></i>
                                        }
                                    }
                                </div>
                                <span class="rating-text">@doctor.AverageRating.ToString("0.0") (@doctor.TotalRatings reviews)</span>
                            </div>

                            <!-- Experience -->
                            <div class="doctor-meta">
                                <div class="meta-item">
                                    <i data-lucide="briefcase"></i>
                                    <span>@doctor.YearsOfExperience years experience</span>
                                </div>
                                @if (doctor.LanguagesSpoken.Any())
                                {
                                    <div class="meta-item">
                                        <i data-lucide="languages"></i>
                                        <span>@string.Join(", ", doctor.LanguagesSpoken.Take(2))</span>
                                    </div>
                                }
                            </div>

                            <!-- Expertise Tags -->
                            @if (doctor.MedicalExpertise.Any())
                            {
                                <div class="expertise-tags">
                                    @foreach (var expertise in doctor.MedicalExpertise.Take(3))
                                    {
                                        <span class="tag">@expertise</span>
                                    }
                                    @if (doctor.MedicalExpertise.Count > 3)
                                    {
                                        <span class="tag tag-more">+@(doctor.MedicalExpertise.Count - 3) more</span>
                                    }
                                </div>
                            }

                            <!-- Action Button -->
                            <button 
                                class="btn-consult" 
                                @onclick="() => ConsultWithDoctor(doctor.UserId)"
                                disabled="@(!doctor.IsAcceptingPatients)">
                                @if (doctor.IsAcceptingPatients)
                                {
                                    <i data-lucide="message-circle"></i>
                                    <span>Consult Now</span>
                                }
                                else
                                {
                                    <i data-lucide="x-circle"></i>
                                    <span>Not Accepting Patients</span>
                                }
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .doctors-page {
        min-height: calc(100vh - 60px);
        background: var(--background);
        padding: 2rem 0;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    /* Page Header */
    .page-header {
        margin-bottom: 2rem;
    }

    .header-content {
        text-align: center;
    }

    .page-title {
        font-family: var(--font-headline);
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--on-surface);
        margin-bottom: 0.5rem;
    }

    .page-subtitle {
        font-size: 1.125rem;
        color: var(--on-surface-variant);
    }

    /* Filters Section */
    .filters-section {
        background: var(--surface-container-low);
        border-radius: var(--radius-xl);
        padding: 1.5rem;
        margin-bottom: 2rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .search-box {
        position: relative;
        margin-bottom: 1.5rem;
    }

    .search-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.25rem;
        color: var(--on-surface-variant);
        pointer-events: none;
    }

    .search-input {
        width: 100%;
        padding: 0.875rem 1rem 0.875rem 3rem;
        border: 1px solid var(--outline-variant);
        border-radius: var(--radius-lg);
        font-family: var(--font-body);
        font-size: 1rem;
        color: var(--on-surface);
        background: var(--surface);
        transition: all 0.3s ease;
    }

    .search-input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(0, 61, 155, 0.1);
    }

    .filters-row {
        display: flex;
        gap: 1rem;
        align-items: flex-end;
        flex-wrap: wrap;
    }

    .filter-group {
        flex: 1;
        min-width: 200px;
    }

    .filter-label {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--on-surface);
        margin-bottom: 0.5rem;
    }

    .filter-select {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1px solid var(--outline-variant);
        border-radius: var(--radius-lg);
        font-family: var(--font-body);
        font-size: 0.9375rem;
        color: var(--on-surface);
        background: var(--surface);
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .filter-select:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(0, 61, 155, 0.1);
    }

    .results-count {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 0.5rem 1.5rem;
        background: var(--primary-container);
        border-radius: var(--radius-lg);
    }

    .count-number {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--primary);
    }

    .count-label {
        font-size: 0.75rem;
        color: var(--on-surface-variant);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    /* Loading State */
    .loading-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem 2rem;
        text-align: center;
    }

    .loading-spinner {
        width: 50px;
        height: 50px;
        border: 4px solid var(--surface-container-high);
        border-top: 4px solid var(--primary);
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-bottom: 1rem;
    }

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    /* Empty State */
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem 2rem;
        text-align: center;
        min-height: 400px;
    }

    .empty-state i {
        font-size: 3rem;
        color: var(--on-surface-variant);
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--on-surface);
        margin-bottom: 0.5rem;
    }

    .empty-message {
        color: var(--on-surface-variant);
        font-size: 1rem;
    }

    /* Doctors Grid */
    .doctors-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
    }

    /* Doctor Card */
    .doctor-card {
        position: relative;
        background: var(--surface-container-low);
        border-radius: var(--radius-xl);
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .doctor-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }

    /* Availability Badge */
    .availability-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        display: flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.375rem 0.75rem;
        border-radius: var(--radius-full);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.05em;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .status-available {
        background: #d1fae5;
        color: #065f46;
    }

    .status-available .status-dot {
        background: #10b981;
    }

    .status-busy {
        background: #fef3c7;
        color: #92400e;
    }

    .status-busy .status-dot {
        background: #f59e0b;
    }

    .status-offline {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-offline .status-dot {
        background: #ef4444;
    }

    /* Doctor Photo */
    .doctor-photo {
        width: 100px;
        height: 100px;
        margin: 0 auto 1rem;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid var(--primary-container);
    }

    .doctor-photo img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .photo-placeholder {
        width: 100%;
        height: 100%;
        background: var(--surface-container-high);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        color: var(--on-surface-variant);
    }

    /* Doctor Info */
    .doctor-info {
        text-align: center;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .doctor-name {
        font-family: var(--font-headline);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--on-surface);
        margin-bottom: 0.25rem;
    }

    .doctor-specialization {
        font-size: 0.9375rem;
        color: var(--primary);
        font-weight: 600;
        margin-bottom: 0.75rem;
    }

    /* Rating */
    .doctor-rating {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .stars {
        display: flex;
        gap: 0.25rem;
    }

    .stars i {
        font-size: 1rem;
    }

    .star-filled {
        color: #fbbf24;
    }

    .star-half {
        color: #fbbf24;
    }

    .star-empty {
        color: var(--outline-variant);
    }

    .rating-text {
        font-size: 0.875rem;
        color: var(--on-surface-variant);
    }

    /* Doctor Meta */
    .doctor-meta {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .meta-item {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        color: var(--on-surface-variant);
    }

    .meta-item i {
        font-size: 1rem;
    }

    /* Expertise Tags */
    .expertise-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        justify-content: center;
        margin-bottom: 1rem;
    }

    .tag {
        padding: 0.25rem 0.75rem;
        background: var(--secondary-container);
        color: var(--on-surface);
        border-radius: var(--radius-full);
        font-size: 0.75rem;
        font-weight: 500;
    }

    .tag-more {
        background: var(--surface-container-high);
        color: var(--on-surface-variant);
    }

    /* Consult Button */
    .btn-consult {
        width: 100%;
        padding: 0.875rem 1.5rem;
        background: var(--primary);
        color: var(--on-primary);
        border: none;
        border-radius: var(--radius-lg);
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
        margin-top: auto;
    }

    .btn-consult:hover:not(:disabled) {
        background: var(--primary-container);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 61, 155, 0.3);
    }

    .btn-consult:disabled {
        background: var(--surface-container-high);
        color: var(--on-surface-variant);
        cursor: not-allowed;
        opacity: 0.6;
    }

    .btn-consult i {
        font-size: 1.125rem;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .page-title {
            font-size: 2rem;
        }

        .filters-row {
            flex-direction: column;
        }

        .filter-group {
            width: 100%;
        }

        .results-count {
            width: 100%;
        }

        .doctors-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
