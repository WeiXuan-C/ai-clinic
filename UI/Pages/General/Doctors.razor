@page "/general/doctors"
@layout Components.Layout.MainLayout
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<PageTitle>Find Doctors - AI Medical Clinic</PageTitle>

<div class="doctors-page">
    <div class="container">
        <div class="empty-state">
            <i data-lucide="users"></i>
            <h3>Doctor Directory</h3>
            <p class="empty-message">Doctor directory feature coming soon</p>
        </div>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initializeLucide");
        }
    }
}

<style>
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem 2rem;
        text-align: center;
        min-height: 400px;
    }

    .empty-state i {
        font-size: 3rem;
        color: #434654;
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        font-size: 1.5rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.5rem;
    }

    .empty-message {
        color: #434654;
        font-size: 1rem;
    }
</style>
