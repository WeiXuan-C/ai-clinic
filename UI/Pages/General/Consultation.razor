@page "/general/consultation"
@layout Components.Layout.MainLayout

<PageTitle>Consultation - AI Medical Clinic</PageTitle>

<div class="consultation-page">
    @if (!messages.Any())
    {
        <!-- Empty State with Input -->
        <div class="empty-state-wrapper">
            <div class="chat-container">
                <div class="empty-state">
                    <h1 class="welcome-title">What can I help with?</h1>
                </div>
                
                <!-- Message Input -->
                <div class="input-section">
                    <div class="input-wrapper">
                        <button class="attach-btn" @onclick="AttachDocument" title="Attach file">
                            <i data-lucide="paperclip" class="attach-icon"></i>
                        </button>
                        <input 
                            type="text" 
                            @bind="newMessage" 
                            @bind:event="oninput" 
                            @onkeydown="HandleKeyPress" 
                            placeholder="Message AI Health Assistant..." 
                            class="message-input" 
                        />
                        <button class="voice-btn" @onclick="VoiceInput" title="Voice input">
                            <i data-lucide="mic" class="voice-icon"></i>
                        </button>
                        <button class="send-btn" @onclick="SendMessage" disabled="@string.IsNullOrWhiteSpace(newMessage)">
                            <i data-lucide="arrow-up" class="send-icon"></i>
                        </button>
                    </div>
                    <div class="input-footer">
                        <div class="footer-left">
                            <span class="footer-text">AI Health Assistant can make mistakes. Verify important information.</span>
                        </div>
                        <div class="footer-right">
                            <div class="credits-badge">
                                <i data-lucide="coins" class="credit-icon"></i>
                                <span class="credit-number">@availableCredits credits</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else 
    {
        <!-- Messages Container -->
        <div class="messages-wrapper">
            <div class="chat-container">
                <div class="messages-container" id="messages-container">
                @foreach (var message in messages)
                {
                    @if (message.Type == MessageType.AI)
                    {
                        <div class="message-row ai-message-row">
                            <div class="message-avatar ai-avatar">
                                <i data-lucide="sparkles" class="avatar-icon"></i>
                            </div>
                            <div class="message-bubble ai-bubble">
                                <p class="message-text">@message.Content</p>
                                @if (!string.IsNullOrEmpty(message.ActionLabel))
                                {
                                    <button class="ai-insight-btn" @onclick="@(() => HandleAIInsight(message.ActionLabel))">
                                        <i data-lucide="microscope" class="insight-icon"></i>
                                        @message.ActionLabel
                                    </button>
                                }
                            </div>
                        </div>
                    }
                    else if (message.Type == MessageType.User)
                    {
                        <div class="message-row user-message-row">
                            <div class="message-bubble user-bubble">
                                <p class="message-text">@message.Content</p>
                            </div>
                            <div class="message-avatar user-avatar">
                                <i data-lucide="user" class="avatar-icon"></i>
                            </div>
                        </div>
                    }
                }

                @if (isTyping)
                {
                    <div class="message-row ai-message-row">
                        <div class="message-avatar ai-avatar">
                            <i data-lucide="sparkles" class="avatar-icon"></i>
                        </div>
                        <div class="typing-indicator">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                    </div>
                }
                </div>
            </div>
        </div>
        
        <!-- Message Input -->
        <div class="message-input-section">
            <div class="chat-container">
                <div class="input-wrapper">
                    <button class="attach-btn" @onclick="AttachDocument" title="Attach file">
                        <i data-lucide="paperclip" class="attach-icon"></i>
                    </button>
                    <input 
                        type="text" 
                        @bind="newMessage" 
                        @bind:event="oninput" 
                        @onkeydown="HandleKeyPress" 
                        placeholder="Message AI Health Assistant..." 
                        class="message-input" 
                    />
                    <button class="voice-btn" @onclick="VoiceInput" title="Voice input">
                        <i data-lucide="mic" class="voice-icon"></i>
                    </button>
                    <button class="send-btn" @onclick="SendMessage" disabled="@string.IsNullOrWhiteSpace(newMessage)">
                        <i data-lucide="arrow-up" class="send-icon"></i>
                    </button>
                </div>
                <div class="input-footer">
                    <div class="footer-left">
                        <span class="footer-text">AI Health Assistant can make mistakes. Verify important information.</span>
                    </div>
                    <div class="footer-right">
                        <div class="credits-badge">
                            <i data-lucide="coins" class="credit-icon"></i>
                            <span class="credit-number">@availableCredits credits</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Login Prompt Modal -->
    @if (showLoginPrompt)
    {
        <div class="modal-overlay" @onclick="CloseLoginPrompt">
            <div class="modal-content modal-content-large" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h2 class="modal-title">Continue Your Consultation</h2>
                    <button class="modal-close" @onclick="CloseLoginPrompt">
                        <i data-lucide="x"></i>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="login-prompt-icon">
                        <i data-lucide="lock" style="font-size: 3rem; color: var(--primary);"></i>
                    </div>
                    <p class="login-prompt-text">
                        You've reached the limit of 3 free queries. Sign in or create an account to continue your consultation and access more features.
                    </p>

                    <!-- AI Recommended Doctors Preview -->
                    @if (messages.Count >= 2)
                    {
                        <div class="doctor-recommendations-section">
                            <div class="recommendations-header">
                                <i data-lucide="sparkles" class="ai-icon"></i>
                                <h3 class="recommendations-title">AI Recommended Specialists</h3>
                            </div>
                            <p class="recommendations-subtitle">Based on your symptoms, we found matching doctors</p>
                            
                            <div class="doctor-preview-cards">
                                <!-- Preview Card 1 -->
                                <div class="doctor-preview-card">
                                    <div class="doctor-preview-blur">
                                        <div class="doctor-preview-avatar">👨‍⚕️</div>
                                        <div class="doctor-preview-info">
                                            <div class="doctor-preview-name">Dr. ████████</div>
                                            <div class="doctor-preview-specialty">Cardiologist</div>
                                            <div class="doctor-preview-rating">⭐ 4.8 (120+ reviews)</div>
                                            <div class="doctor-preview-match">
                                                <span class="match-badge">95% Match</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="blur-overlay">
                                        <i data-lucide="lock" class="lock-icon"></i>
                                    </div>
                                </div>

                                <!-- Preview Card 2 -->
                                <div class="doctor-preview-card">
                                    <div class="doctor-preview-blur">
                                        <div class="doctor-preview-avatar">👨‍⚕️</div>
                                        <div class="doctor-preview-info">
                                            <div class="doctor-preview-name">Dr. ████████</div>
                                            <div class="doctor-preview-specialty">Internal Medicine</div>
                                            <div class="doctor-preview-rating">⭐ 4.9 (85+ reviews)</div>
                                            <div class="doctor-preview-match">
                                                <span class="match-badge">92% Match</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="blur-overlay">
                                        <i data-lucide="lock" class="lock-icon"></i>
                                    </div>
                                </div>

                                <!-- Preview Card 3 -->
                                <div class="doctor-preview-card">
                                    <div class="doctor-preview-blur">
                                        <div class="doctor-preview-avatar">👨‍⚕️</div>
                                        <div class="doctor-preview-info">
                                            <div class="doctor-preview-name">Dr. ████████</div>
                                            <div class="doctor-preview-specialty">General Practitioner</div>
                                            <div class="doctor-preview-rating">⭐ 4.7 (95+ reviews)</div>
                                            <div class="doctor-preview-match">
                                                <span class="match-badge">88% Match</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="blur-overlay">
                                        <i data-lucide="lock" class="lock-icon"></i>
                                    </div>
                                </div>
                            </div>

                            <div class="unlock-message">
                                <i data-lucide="info" class="info-icon"></i>
                                <span>Sign in to view full doctor profiles and book consultations</span>
                            </div>
                        </div>
                    }

                    <div class="login-prompt-features">
                        <div class="feature-item">
                            <i data-lucide="check-circle"></i>
                            <span>Unlimited AI consultations</span>
                        </div>
                        <div class="feature-item">
                            <i data-lucide="check-circle"></i>
                            <span>Connect with real doctors</span>
                        </div>
                        <div class="feature-item">
                            <i data-lucide="check-circle"></i>
                            <span>Save your medical history</span>
                        </div>
                        <div class="feature-item">
                            <i data-lucide="check-circle"></i>
                            <span>Access prescriptions and records</span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn-primary" @onclick="NavigateToSignIn">
                        <i data-lucide="log-in"></i>
                        Sign In
                    </button>
                    <button class="btn-secondary" @onclick="NavigateToSignUp">
                        <i data-lucide="user-plus"></i>
                        Create Account
                    </button>
                </div>
            </div>
        </div>
    }
</div>


<style>
    .consultation-page {
        min-height: calc(100vh - 60px);
        background: var(--background);
        display: flex;
        flex-direction: column;
    }

    .chat-container {
        max-width: 768px;
        margin: 0 auto;
        width: 100%;
    }

    /* Empty State */
    .empty-state-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 120px);
        padding: 2rem 0;
    }

    .empty-state {
        text-align: center;
        margin-bottom: 2rem;
    }

    .welcome-title {
        font-family: var(--font-headline);
        font-size: 2.5rem;
        font-weight: 600;
        color: var(--on-surface);
        margin: 0;
    }

    .input-section {
        width: 100%;
    }

    /* Credits Bar */
    .credits-bar {
        background: var(--surface-container-lowest);
        border-bottom: 1px solid var(--outline-variant);
        padding: 0.75rem 0;
    }

    .credits-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .credits-label {
        font-size: 0.875rem;
        color: var(--on-surface-variant);
        font-weight: 500;
    }

    .credits-amount {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.375rem 1rem;
        background: var(--secondary-container);
        border-radius: var(--radius-full);
    }

    .credit-icon {
        font-size: 1.125rem;
    }

    .credit-number {
        font-size: 1rem;
        font-weight: 700;
        color: var(--on-surface);
    }

    /* Chat Header */
    .chat-header {
        background: var(--surface-container-lowest);
        padding: 1.5rem 0;
        border-bottom: 1px solid var(--outline-variant);
    }

    .chat-title {
        font-family: var(--font-headline);
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--on-surface);
        margin-bottom: 0.5rem;
    }

    .chat-subtitle {
        font-size: 0.875rem;
        color: var(--on-surface-variant);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .subtitle-icon {
        font-size: 1rem;
    }

    .separator {
        opacity: 0.5;
    }

    /* Messages Wrapper */
    .messages-wrapper {
        flex: 1;
        overflow-y: auto;
        padding: 1rem 0;
    }

    .messages-container {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* Message Rows */
    .message-row {
        display: flex;
        gap: 1rem;
        align-items: flex-start;
    }

    .ai-message-row,
    .doctor-message-row {
        justify-content: flex-start;
    }

    .user-message-row {
        justify-content: flex-end;
    }

    /* Message Avatars */
    .message-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1.25rem;
    }

    .ai-avatar {
        background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-container) 100%);
    }

    .user-avatar {
        background: var(--primary-container);
    }

    .doctor-avatar {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    /* Message Bubbles */
    .message-bubble {
        max-width: 70%;
        padding: 1rem 1.25rem;
        border-radius: var(--radius-xl);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .ai-bubble {
        background: #E0F7FA;
        color: var(--on-surface);
    }

    .user-bubble {
        background: var(--surface-container-high);
        color: var(--on-surface);
    }

    .doctor-bubble {
        background: #E8EAF6;
        color: var(--on-surface);
    }

    .message-text {
        font-size: 0.9375rem;
        line-height: 1.6;
        margin: 0;
    }

    /* Doctor Badge */
    .doctor-badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        background: var(--primary-container);
        color: var(--on-primary);
        border-radius: var(--radius-full);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        margin-bottom: 0.75rem;
    }

    /* AI Insight Button */
    .ai-insight-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: var(--secondary-container);
        color: var(--secondary);
        border: none;
        border-radius: var(--radius-full);
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        margin-top: 0.75rem;
        transition: all 0.3s ease;
    }

    .ai-insight-btn:hover {
        background: var(--secondary);
        color: var(--on-secondary);
        transform: translateY(-2px);
    }

    .insight-icon {
        font-size: 1rem;
    }

    /* Suggestion Card */
    .suggestion-card {
        position: relative;
        background: var(--surface-container-low);
        border-radius: var(--radius-xl);
        padding: 1.5rem;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
    }

    .ai-assist-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        padding: 0.25rem 0.75rem;
        background: var(--secondary-container);
        color: var(--secondary);
        border-radius: var(--radius-full);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.05em;
    }

    .suggestion-content {
        display: flex;
        gap: 1rem;
    }

    .suggestion-icon {
        font-size: 2rem;
        flex-shrink: 0;
    }

    .suggestion-body {
        flex: 1;
    }

    .suggestion-title {
        font-family: var(--font-headline);
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--on-surface);
        margin-bottom: 0.5rem;
    }

    .suggestion-text {
        font-size: 0.9375rem;
        color: var(--on-surface-variant);
        margin-bottom: 1rem;
        line-height: 1.6;
    }

    .suggestion-actions {
        display: flex;
        gap: 0.75rem;
    }

    .btn-suggestion-primary {
        padding: 0.625rem 1.25rem;
        background: var(--secondary);
        color: var(--on-secondary);
        border: none;
        border-radius: var(--radius-lg);
        font-family: var(--font-body);
        font-size: 0.9375rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-suggestion-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 106, 101, 0.3);
    }

    .btn-suggestion-secondary {
        padding: 0.625rem 1.25rem;
        background: transparent;
        color: var(--on-surface-variant);
        border: 1px solid var(--outline-variant);
        border-radius: var(--radius-lg);
        font-family: var(--font-body);
        font-size: 0.9375rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-suggestion-secondary:hover {
        background: var(--surface-container-high);
    }

    /* Typing Indicator */
    .typing-indicator {
        display: flex;
        gap: 0.5rem;
        padding: 1rem 1.25rem;
        background: #E0F7FA;
        border-radius: var(--radius-xl);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .typing-indicator span {
        width: 8px;
        height: 8px;
        background: var(--secondary);
        border-radius: 50%;
        animation: typing 1.4s infinite;
    }

    .typing-indicator span:nth-child(2) {
        animation-delay: 0.2s;
    }

    .typing-indicator span:nth-child(3) {
        animation-delay: 0.4s;
    }

    @@keyframes typing {
        0%, 60%, 100% {
            transform: translateY(0);
        }
        30% {
            transform: translateY(-10px);
        }
    }

    /* Message Input Section */
    .message-input-section {
        background: var(--background);
        padding: 1rem 0 2rem 0;
        position: sticky;
        bottom: 0;
    }

    .input-wrapper {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--surface-container-low);
        border: 1px solid var(--outline-variant);
        border-radius: var(--radius-full);
        padding: 0.5rem 0.75rem;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
    }

    .input-wrapper:focus-within {
        border-color: var(--primary-container);
        box-shadow: 0 4px 16px rgba(0, 61, 155, 0.12);
    }

    .attach-btn,
    .voice-btn {
        width: 36px;
        height: 36px;
        background: transparent;
        border: none;
        cursor: pointer;
        font-size: 1.25rem;
        opacity: 0.6;
        transition: all 0.3s ease;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }

    .attach-btn:hover,
    .voice-btn:hover {
        opacity: 1;
        background: var(--surface-container-high);
    }

    .message-input {
        flex: 1;
        border: none;
        background: transparent;
        font-family: var(--font-body);
        font-size: 1rem;
        color: var(--on-surface);
        outline: none;
        padding: 0.5rem;
        min-height: 24px;
    }

    .message-input::placeholder {
        color: var(--on-surface-variant);
    }

    .send-btn {
        width: 36px;
        height: 36px;
        background: var(--on-surface);
        color: var(--surface);
        border: none;
        border-radius: 50%;
        font-size: 1.125rem;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        flex-shrink: 0;
    }

    .send-btn:hover:not(:disabled) {
        background: var(--primary-container);
        transform: scale(1.05);
    }

    .send-btn:disabled {
        opacity: 0.3;
        cursor: not-allowed;
        background: var(--surface-container-high);
    }

    .send-icon {
        display: block;
        line-height: 1;
    }

    /* Input Footer */
    .input-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 0.75rem;
        font-size: 0.75rem;
        color: var(--on-surface-variant);
        padding: 0 0.5rem;
    }

    .footer-left {
        flex: 1;
    }

    .footer-text {
        opacity: 0.7;
    }

    .footer-right {
        display: flex;
        align-items: center;
    }

    .credits-badge {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.375rem 0.75rem;
        background: var(--secondary-container);
        border-radius: var(--radius-full);
        font-weight: 600;
    }

    .credit-icon {
        font-size: 0.875rem;
    }

    .credit-number {
        font-size: 0.75rem;
        color: var(--on-surface);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .chat-container {
            padding: 0 0.75rem;
        }

        .welcome-title {
            font-size: 1.75rem;
        }

        .message-bubble {
            max-width: 85%;
        }

        .suggestion-actions {
            flex-direction: column;
        }

        .input-footer {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.5rem;
        }

        .footer-right {
            width: 100%;
            justify-content: flex-start;
        }
    }

    /* Login Prompt Modal */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        padding: 1rem;
    }

    .modal-content {
        background: var(--surface);
        border-radius: var(--radius-xl);
        max-width: 500px;
        width: 100%;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        animation: modalSlideIn 0.3s ease-out;
        max-height: 90vh;
        overflow-y: auto;
    }

    .modal-content-large {
        max-width: 700px;
    }

    @@keyframes modalSlideIn {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem;
        border-bottom: 1px solid var(--outline-variant);
    }

    .modal-title {
        font-family: var(--font-headline);
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--on-surface);
        margin: 0;
    }

    .modal-close {
        width: 36px;
        height: 36px;
        background: transparent;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: all 0.3s ease;
        font-size: 1.25rem;
        color: var(--on-surface-variant);
    }

    .modal-close:hover {
        background: var(--surface-container-high);
    }

    .modal-body {
        padding: 2rem 1.5rem;
        text-align: center;
    }

    .login-prompt-icon {
        margin-bottom: 1.5rem;
    }

    .login-prompt-text {
        font-size: 1rem;
        color: var(--on-surface-variant);
        line-height: 1.6;
        margin-bottom: 2rem;
    }

    .login-prompt-features {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        text-align: left;
        margin-bottom: 1rem;
