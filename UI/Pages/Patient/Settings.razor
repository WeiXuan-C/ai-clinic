@page "/patient/settings"
@layout Components.Layout.SidebarLayout

<PageTitle>Settings - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>Settings</h1>
        <p class="body-md" style="margin: 0.5rem;">
            Manage your account preferences and privacy settings
        </p>
    </div>
</header>

<!-- Content Grid -->
@if (isLoading)
{
    <div style="text-align: center; padding: 3rem;">
        <p class="body-md">Loading settings...</p>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div style="text-align: center; padding: 3rem;">
        <p class="body-md" style="color: #d32f2f;">@errorMessage</p>
    </div>
}
else
{
@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="success-banner">
        <i data-lucide="check-circle"></i>
        <span>@successMessage</span>
    </div>
}
<div class="content-grid">
    <!-- Account Settings -->
    <section class="settings-card">
        <div class="section-header">
            <div class="header-with-icon">
                <i data-lucide="user-cog" class="section-icon"></i>
                <h2 class="headline-md">Account Settings</h2>
            </div>
        </div>
        <div class="settings-list">
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Email Address</h4>
                    <p class="body-sm">@settings.Email</p>
                </div>
                <button class="btn-link" @onclick="OpenEmailChangeModal">Change</button>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Password</h4>
                    <p class="body-sm">••••••••</p>
                </div>
                <button class="btn-link" @onclick="OpenPasswordChangeModal">Change</button>
            </div>
        </div>
    </section>

    <!-- Privacy & Security -->
    <section class="settings-card">
        <div class="section-header">
            <div class="header-with-icon">
                <i data-lucide="shield" class="section-icon"></i>
                <h2 class="headline-md">Privacy & Security</h2>
            </div>
        </div>
        <div class="settings-list">
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Data Sharing</h4>
                    <p class="body-sm">Share health data with research programs</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" @bind="settings.DataSharingEnabled" @bind:after="SaveSettings" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">AI Analysis</h4>
                    <p class="body-sm">Allow AI to analyze your health data</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" @bind="settings.AiAnalysisEnabled" @bind:after="SaveSettings" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Activity Tracking</h4>
                    <p class="body-sm">Track app usage for better experience</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" @bind="settings.ActivityTrackingEnabled" @bind:after="SaveSettings" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Download My Data</h4>
                    <p class="body-sm">Export all your personal and medical data</p>
                </div>
                <button class="btn-link" @onclick="DownloadMyData" disabled="@isDownloadingData">
                    @if (isDownloadingData)
                    {
                        <span>Downloading...</span>
                    }
                    else
                    {
                        <span>Download</span>
                    }
                </button>
            </div>
        </div>
    </section>

    <!-- Danger Zone -->
    <section class="settings-card danger-zone">
        <div class="section-header">
            <div class="header-with-icon">
                <i data-lucide="alert-triangle" class="section-icon danger"></i>
                <h2 class="headline-md">Danger Zone</h2>
            </div>
        </div>
        <div class="settings-list">
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Deactivate Account</h4>
                    <p class="body-sm">Temporarily disable your account</p>
                </div>
                <button class="btn-danger-outline">Deactivate</button>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Delete Account</h4>
                    <p class="body-sm">Permanently delete your account and all data</p>
                </div>
                <button class="btn-danger">Delete</button>
            </div>
        </div>
    </section>
</div>

<style>
    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1.5rem;
    }

    .header-left h1 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #191c1e;
        margin: 0.25rem 0.5rem;
        font-family: 'Manrope', sans-serif;
    }

    .header-left p {
        color: #434654;
        margin: 0 0.5rem;
    }

    .content-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.25rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    /* Settings Card */
    .settings-card {
        background: white;
        padding: 1.5rem;
        border-radius: 12px;
    }

    .settings-card.danger-zone {
        border: 2px solid #ffebee;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.25rem;
    }

    .header-with-icon {
        display: flex;
        align-items: center;
        gap: 0.625rem;
    }

    .section-icon {
        font-size: 1.25rem;
        color: #0052cc;
    }

    .section-icon.danger {
        color: #d32f2f;
    }

    .section-header h2 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #191c1e;
    }

    /* Settings List */
    .settings-list {
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
    }

    .setting-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem;
        background: #f7f9fb;
        border-radius: 10px;
    }

    .setting-info {
        flex: 1;
    }

    .setting-info h4 {
        font-size: 0.9375rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.25rem;
    }

    .setting-info p {
        font-size: 0.8125rem;
        color: #434654;
        margin: 0;
    }

    /* Toggle Switch */
    .toggle-switch {
        position: relative;
        display: inline-block;
        width: 48px;
        height: 28px;
    }

    .toggle-switch input {
        opacity: 0;
        width: 0;
        height: 0;
    }

    .toggle-slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #e6e8ea;
        transition: 0.3s;
        border-radius: 28px;
    }

    .toggle-slider:before {
        position: absolute;
        content: "";
        height: 20px;
        width: 20px;
        left: 4px;
        bottom: 4px;
        background-color: white;
        transition: 0.3s;
        border-radius: 50%;
    }

    input:checked + .toggle-slider {
        background-color: #0052cc;
    }

    input:checked + .toggle-slider:before {
        transform: translateX(20px);
    }

    /* Buttons */
    .btn-link {
        color: #0052cc;
        background: none;
        border: none;
        font-weight: 600;
        cursor: pointer;
        font-size: 0.875rem;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        transition: all 0.2s;
    }

    .btn-link:hover {
        background: #e3f2fd;
    }

    .select-input {
        padding: 0.625rem 1rem;
        border: 1px solid #e6e8ea;
        border-radius: 8px;
        font-size: 0.875rem;
        cursor: pointer;
        background: white;
        min-width: 150px;
    }

    .select-input:focus {
        outline: none;
        border-color: #0052cc;
    }

    .btn-primary-sm {
        padding: 0.625rem 1.25rem;
        background: #0052cc;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

    .btn-primary-sm:hover {
        background: #003d9b;
    }

    .btn-danger-outline {
        padding: 0.625rem 1.25rem;
        background: white;
        color: #d32f2f;
        border: 2px solid #d32f2f;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

    .btn-danger-outline:hover {
        background: #ffebee;
    }

    .btn-danger {
        padding: 0.625rem 1.25rem;
        background: #d32f2f;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

    .btn-danger:hover {
        background: #b71c1c;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .setting-item {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }
    }

    /* Modal Styles */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-content {
        background: white;
        border-radius: 12px;
        padding: 2rem;
        max-width: 500px;
        width: 90%;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .modal-header h3 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #191c1e;
        margin: 0;
    }

    .close-button {
        background: none;
        border: none;
        font-size: 1.5rem;
        color: #434654;
        cursor: pointer;
        padding: 0;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        transition: all 0.2s;
    }

    .close-button:hover {
        background: #f7f9fb;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-label {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.5rem;
    }

    .form-input {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1px solid #e6e8ea;
        border-radius: 8px;
        font-size: 0.875rem;
        box-sizing: border-box;
    }

    .form-input:focus {
        outline: none;
        border-color: #0052cc;
    }

    .form-hint {
        display: block;
        font-size: 0.75rem;
        color: #434654;
        margin-top: 0.375rem;
    }

    .alert {
        padding: 0.75rem 1rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
        font-size: 0.875rem;
    }

    .alert-error {
        background: #ffebee;
        color: #d32f2f;
        border: 1px solid #ef9a9a;
    }

    .alert-success {
        background: #e8f5e9;
        color: #2e7d32;
        border: 1px solid #81c784;
    }

    .modal-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
        margin-top: 1.5rem;
    }

    .btn-secondary {
        padding: 0.75rem 1.5rem;
        background: #f7f9fb;
        color: #434654;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

    .btn-secondary:hover {
        background: #e6e8ea;
    }

    .btn-primary {
        padding: 0.75rem 1.5rem;
        background: #0052cc;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

    .btn-primary:hover {
        background: #003d9b;
    }

    .btn-primary:disabled,
    .btn-secondary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .password-input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .password-input-wrapper .form-input {
        padding-right: 3rem;
    }

    .password-toggle-btn {
        position: absolute;
        right: 0.75rem;
        background: none;
        border: none;
        color: #434654;
        cursor: pointer;
        padding: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
        transition: all 0.2s;
    }

    .password-toggle-btn:hover {
        background: #f7f9fb;
        color: #0052cc;
    }

    .password-toggle-btn i {
        width: 20px;
        height: 20px;
    }

    .success-banner {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 1.25rem;
        background: #e8f5e9;
        border: 1px solid #81c784;
        border-radius: 12px;
        color: #2e7d32;
        font-size: 0.9375rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 2px 8px rgba(46, 125, 50, 0.1);
    }

    .success-banner i {
        font-size: 1.25rem;
    }
</style>
}

<!-- Email Change Modal -->
@if (showEmailChangeModal)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Change Email Address</h3>
                <button class="close-button" @onclick="CloseEmailChangeModal">&times;</button>
            </div>

            @if (!string.IsNullOrEmpty(emailErrorMessage))
            {
                <div class="alert alert-error">@emailErrorMessage</div>
            }

            @if (!string.IsNullOrEmpty(emailSuccessMessage))
            {
                <div class="alert alert-success">@emailSuccessMessage</div>
            }

            <div class="form-group">
                <label class="form-label">Current Email</label>
                <input type="email" class="form-input" value="@settings.Email" disabled />
            </div>

            <div class="form-group">
                <label class="form-label">New Email Address</label>
                <input type="email" class="form-input" @bind="newEmail" placeholder="Enter new email address" />
                <span class="form-hint">We'll verify that this email is not already in use</span>
            </div>

            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CloseEmailChangeModal" disabled="@isChangingEmail">Cancel</button>
                <button class="btn-primary" @onclick="SubmitEmailChange" disabled="@isChangingEmail">
                    @(isChangingEmail ? "Updating..." : "Update Email")
                </button>
            </div>
        </div>
    </div>
}

<!-- Password Change Modal -->
@if (showPasswordChangeModal)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Change Password</h3>
                <button class="close-button" @onclick="ClosePasswordChangeModal">&times;</button>
            </div>

            @if (!string.IsNullOrEmpty(passwordErrorMessage))
            {
                <div class="alert alert-error">@passwordErrorMessage</div>
            }

            @if (!string.IsNullOrEmpty(passwordSuccessMessage))
            {
                <div class="alert alert-success">@passwordSuccessMessage</div>
            }

            <div class="form-group">
                <label class="form-label">Current Password</label>
                <div class="password-input-wrapper">
                    <input type="@(showCurrentPassword ? "text" : "password")" class="form-input" @bind="currentPassword" placeholder="Enter current password" />
                    <button type="button" class="password-toggle-btn" @onclick="ToggleCurrentPasswordVisibility">
                        <i data-lucide="@(showCurrentPassword ? "eye-off" : "eye")"></i>
                    </button>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">New Password</label>
                <div class="password-input-wrapper">
                    <input type="@(showNewPassword ? "text" : "password")" class="form-input" @bind="newPassword" placeholder="Enter new password" />
                    <button type="button" class="password-toggle-btn" @onclick="ToggleNewPasswordVisibility">
                        <i data-lucide="@(showNewPassword ? "eye-off" : "eye")"></i>
                    </button>
                </div>
                <span class="form-hint">Must be at least 8 characters with uppercase, lowercase, number, and special character</span>
            </div>

            <div class="form-group">
                <label class="form-label">Confirm New Password</label>
                <div class="password-input-wrapper">
                    <input type="@(showConfirmPassword ? "text" : "password")" class="form-input" @bind="confirmPassword" placeholder="Confirm new password" />
                    <button type="button" class="password-toggle-btn" @onclick="ToggleConfirmPasswordVisibility">
                        <i data-lucide="@(showConfirmPassword ? "eye-off" : "eye")"></i>
                    </button>
                </div>
                <span class="form-hint">Re-enter the new password to confirm</span>
            </div>

            <div class="modal-actions">
                <button class="btn-secondary" @onclick="ClosePasswordChangeModal" disabled="@isChangingPassword">Cancel</button>
                <button class="btn-primary" @onclick="SubmitPasswordChange" disabled="@isChangingPassword">
                    @(isChangingPassword ? "Updating..." : "Update Password")
                </button>
            </div>
        </div>
    </div>
}
