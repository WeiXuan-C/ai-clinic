@page "/patient/settings"
@layout Components.Layout.SidebarLayout

<PageTitle>Settings - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>Settings</h1>
        <p class="body-md" style="margin: 0.5rem;">
            Manage your account preferences and privacy settings
        </p>
    </div>
</header>

<!-- Content Grid -->
<div class="content-grid">
    <!-- Account Settings -->
    <section class="settings-card">
        <div class="section-header">
            <div class="header-with-icon">
                <i data-lucide="user-cog" class="section-icon"></i>
                <h2 class="headline-md">Account Settings</h2>
            </div>
        </div>
        <div class="settings-list">
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Email Address</h4>
                    <p class="body-sm">sarah.johnson@email.com</p>
                </div>
                <button class="btn-link">Change</button>
            </div>
        </div>
    </section>

    <!-- Privacy & Security -->
    <section class="settings-card">
        <div class="section-header">
            <div class="header-with-icon">
                <i data-lucide="shield" class="section-icon"></i>
                <h2 class="headline-md">Privacy & Security</h2>
            </div>
        </div>
        <div class="settings-list">
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Data Sharing</h4>
                    <p class="body-sm">Share health data with research programs</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">AI Analysis</h4>
                    <p class="body-sm">Allow AI to analyze your health data</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" checked />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Activity Tracking</h4>
                    <p class="body-sm">Track app usage for better experience</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" checked />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Download My Data</h4>
                    <p class="body-sm">Export all your personal and medical data</p>
                </div>
                <button class="btn-link">Download</button>
            </div>
        </div>
    </section>

    <!-- Danger Zone -->
    <section class="settings-card danger-zone">
        <div class="section-header">
            <div class="header-with-icon">
                <i data-lucide="alert-triangle" class="section-icon danger"></i>
                <h2 class="headline-md">Danger Zone</h2>
            </div>
        </div>
        <div class="settings-list">
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Deactivate Account</h4>
                    <p class="body-sm">Temporarily disable your account</p>
                </div>
                <button class="btn-danger-outline">Deactivate</button>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Delete Account</h4>
                    <p class="body-sm">Permanently delete your account and all data</p>
                </div>
                <button class="btn-danger">Delete</button>
            </div>
        </div>
    </section>
</div>

<style>
    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2rem;
    }

    .header-left h1 {
        font-size: 2rem;
        font-weight: 700;
        color: #191c1e;
        margin: 0.5rem;
        font-family: 'Manrope', sans-serif;
    }

    .header-left p {
        color: #434654;
    }

    .content-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        max-width: 900px;
    }

    /* Settings Card */
    .settings-card {
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .settings-card.danger-zone {
        border: 2px solid #ffebee;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.75rem;
    }

    .header-with-icon {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .section-icon {
        font-size: 1.5rem;
        color: #0052cc;
    }

    .section-icon.danger {
        color: #d32f2f;
    }

    .section-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
    }

    /* Settings List */
    .settings-list {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .setting-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem;
        background: #f7f9fb;
        border-radius: 12px;
    }

    .setting-info {
        flex: 1;
    }

    .setting-info h4 {
        font-size: 1rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.25rem;
    }

    .setting-info p {
        font-size: 0.875rem;
        color: #434654;
    }

    /* Toggle Switch */
    .toggle-switch {
        position: relative;
        display: inline-block;
        width: 48px;
        height: 28px;
    }

    .toggle-switch input {
        opacity: 0;
        width: 0;
        height: 0;
    }

    .toggle-slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #e6e8ea;
        transition: 0.3s;
        border-radius: 28px;
    }

    .toggle-slider:before {
        position: absolute;
        content: "";
        height: 20px;
        width: 20px;
        left: 4px;
        bottom: 4px;
        background-color: white;
        transition: 0.3s;
        border-radius: 50%;
    }

    input:checked + .toggle-slider {
        background-color: #0052cc;
    }

    input:checked + .toggle-slider:before {
        transform: translateX(20px);
    }

    /* Buttons */
    .btn-link {
        color: #0052cc;
        background: none;
        border: none;
        font-weight: 600;
        cursor: pointer;
        font-size: 0.875rem;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        transition: all 0.2s;
    }

    .btn-link:hover {
        background: #e3f2fd;
    }

    .select-input {
        padding: 0.625rem 1rem;
        border: 1px solid #e6e8ea;
        border-radius: 8px;
        font-size: 0.875rem;
        cursor: pointer;
        background: white;
        min-width: 150px;
    }

    .select-input:focus {
        outline: none;
        border-color: #0052cc;
    }

    .btn-primary-sm {
        padding: 0.625rem 1.25rem;
        background: #0052cc;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

    .btn-primary-sm:hover {
        background: #003d9b;
    }

    .btn-danger-outline {
        padding: 0.625rem 1.25rem;
        background: white;
        color: #d32f2f;
        border: 2px solid #d32f2f;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

    .btn-danger-outline:hover {
        background: #ffebee;
    }

    .btn-danger {
        padding: 0.625rem 1.25rem;
        background: #d32f2f;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

    .btn-danger:hover {
        background: #b71c1c;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .setting-item {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }
    }
</style>
