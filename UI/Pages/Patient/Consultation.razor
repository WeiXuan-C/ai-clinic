@page "/patient/consultation"
@layout Components.Layout.SidebarLayout

<style>
    .consultation-container {
        display: grid;
        grid-template-columns: 280px 1fr 320px;
        height: 100vh;
        background: #f5f7fa;
        gap: 0;
        margin: -2.5rem -3rem -2.5rem -3rem;
        width: calc(100% + 6rem);
        position: relative;
    }

    /* History Sidebar */
    .history-sidebar {
        background: white;
        border-right: 1px solid #e5e7eb;
        padding: 24px 16px;
        overflow-y: auto;
        overflow-x: hidden;
        height: 100vh;
        position: relative;
    }

    .history-sidebar::-webkit-scrollbar {
        width: 8px;
    }

    .history-sidebar::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    .history-sidebar::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 4px;
    }

    .history-sidebar::-webkit-scrollbar-thumb:hover {
        background: #a8a8a8;
    }

    .history-sidebar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .history-sidebar h3 {
        font-size: 12px;
        font-weight: 600;
        color: #6b7280;
        letter-spacing: 0.5px;
    }

    .new-consultation-btn {
        padding: 6px 12px;
        background: #0ea5e9;
        color: white;
        border: none;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
    }

    .history-item {
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 8px;
        cursor: pointer;
        transition: background 0.2s;
    }

    .history-item:hover {
        background: #f9fafb;
    }

    .history-item.active {
        background: #e0f2fe;
        border-left: 3px solid #0ea5e9;
    }

    .history-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 4px;
    }

    .history-title {
        font-size: 14px;
        font-weight: 500;
        color: #111827;
    }

    .history-meta {
        font-size: 12px;
        color: #6b7280;
    }

    .unread-badge {
        background: #ef4444;
        color: white;
        font-size: 10px;
        font-weight: 600;
        padding: 2px 6px;
        border-radius: 10px;
    }

    .urgent-tag {
        display: inline-block;
        font-size: 11px;
        color: #dc2626;
        margin-top: 4px;
    }

    /* Chat Area */
    .chat-area {
        display: flex;
        flex-direction: column;
        background: white;
        position: relative;
        height: 100vh;
        overflow: hidden;
        z-index: 1;
    }

    .chat-header {
        border-bottom: 1px solid #e5e7eb;
        background: white;
        flex-shrink: 0;
    }

    .mode-toggle {
        display: flex;
        gap: 8px;
        padding: 16px;
    }

    .toggle-btn {
        flex: 1;
        padding: 12px 16px;
        border: 2px solid #e5e7eb;
        border-radius: 8px;
        background: white;
        cursor: pointer;
        font-size: 14px;
        font-weight: 500;
        color: #6b7280;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .toggle-btn:hover {
        border-color: #0ea5e9;
    }

    .toggle-btn.active {
        background: #0ea5e9;
        border-color: #0ea5e9;
        color: white;
    }

    .active-doctor-info {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        background: #f9fafb;
        border-top: 1px solid #e5e7eb;
    }

    .mini-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
    }

    .doctor-details-mini {
        flex: 1;
    }

    .doctor-name-mini {
        font-size: 14px;
        font-weight: 600;
        color: #111827;
    }

    .doctor-status {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: #6b7280;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .status-dot.online {
        background: #10b981;
    }

    .video-call-btn {
        padding: 8px 16px;
        background: #0ea5e9;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    /* Messages */
    .messages-container {
        flex: 1;
        overflow-y: auto;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 16px;
        min-height: 0;
    }

    .messages-container::-webkit-scrollbar {
        width: 8px;
    }

    .messages-container::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    .messages-container::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 4px;
    }

    .messages-container::-webkit-scrollbar-thumb:hover {
        background: #a8a8a8;
    }

    .message {
        display: flex;
        gap: 12px;
        max-width: 80%;
    }

    .message.user-message {
        align-self: flex-end;
        flex-direction: row-reverse;
    }

    .message-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

    .user-message .message-avatar {
        background: #3b82f6;
    }

    .ai-message .message-avatar {
        background: #10b981;
    }

    .message-content {
        flex: 1;
    }

    .message-text {
        padding: 12px 16px;
        border-radius: 12px;
        font-size: 14px;
        line-height: 1.5;
    }

    .user-message .message-text {
        background: #dbeafe;
        color: #1e3a8a;
    }

    .ai-message .message-text {
        background: #d1fae5;
        color: #065f46;
    }

    .message-time {
        font-size: 11px;
        color: #9ca3af;
        margin-top: 4px;
        text-align: right;
    }

    .ai-insight-card {
        background: linear-gradient(135deg, #e0f2fe 0%, #dbeafe 100%);
        padding: 16px;
        border-radius: 12px;
        border-left: 4px solid #0ea5e9;
        margin: 16px 0;
    }

    .insight-icon {
        font-size: 24px;
        margin-bottom: 8px;
    }

    .insight-content strong {
        font-size: 12px;
        font-weight: 600;
        color: #0369a1;
        display: block;
        margin-bottom: 6px;
    }

    .insight-content p {
        font-size: 14px;
        color: #075985;
        margin: 0;
    }

    /* Input Area */
    .input-area {
        padding: 16px 24px;
        border-top: 1px solid #e5e7eb;
        background: white;
        flex-shrink: 0;
    }

    .input-features {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .feature-badge {
        font-size: 12px;
        color: #10b981;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .input-box {
        display: flex;
        gap: 8px;
        align-items: center;
        padding: 12px;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        background: #f9fafb;
    }

    .icon-btn {
        background: transparent;
        border: none;
        font-size: 20px;
        cursor: pointer;
        padding: 4px;
    }

    .input-box input {
        flex: 1;
        border: none;
        background: transparent;
        font-size: 14px;
        outline: none;
    }

    .send-btn {
        width: 36px;
        height: 36px;
        background: #0ea5e9;
        color: white;
        border: none;
        border-radius: 50%;
        font-size: 18px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .send-btn.disabled {
        background: #d1d5db;
        cursor: not-allowed;
    }

    /* Context Sidebar */
    .context-sidebar {
        background: white;
        border-left: 1px solid #e5e7eb;
        padding: 24px 16px;
        overflow-y: auto;
        overflow-x: hidden;
        height: 100vh;
        position: relative;
    }

    .context-sidebar::-webkit-scrollbar {
        width: 8px;
    }

    .context-sidebar::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    .context-sidebar::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 4px;
    }

    .context-sidebar::-webkit-scrollbar-thumb:hover {
        background: #a8a8a8;
    }

    .context-sidebar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .context-sidebar h3 {
        font-size: 16px;
        font-weight: 600;
        color: #111827;
        margin-bottom: 8px;
    }

    .context-description {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 20px;
        line-height: 1.5;
    }

    .document-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 20px;
    }

    .document-item {
        display: flex;
        gap: 12px;
        padding: 12px;
        border-radius: 8px;
    }

    .document-item.analyzed {
        background: #dbeafe;
    }

    .document-item.verified {
        background: #fce7f3;
    }

    .doc-icon {
        font-size: 24px;
    }

    .doc-info {
        flex: 1;
    }

    .doc-name {
        font-size: 13px;
        font-weight: 500;
        color: #111827;
        margin-bottom: 2px;
    }

    .doc-meta {
        font-size: 11px;
        color: #6b7280;
        margin-bottom: 4px;
    }

    .doc-status {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .analyzed .doc-status {
        color: #1e40af;
    }

    .verified .doc-status {
        color: #be185d;
    }

    .insight-header {
        font-size: 12px;
        font-weight: 600;
        color: #0369a1;
        margin-bottom: 8px;
        letter-spacing: 0.5px;
    }

    .export-btn {
        width: 100%;
        padding: 12px;
        background: #f3f4f6;
        color: #374151;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .export-btn:hover {
        background: #e5e7eb;
    }
</style>

<div class="consultation-container">
    <!-- Left Sidebar: History -->
    <div class="history-sidebar">
        <div class="history-sidebar-header">
            <h3>HISTORY</h3>
            <button class="new-consultation-btn">+ New</button>
        </div>
        <div class="history-list">
            <div class="history-item active">
                <div class="history-header">
                    <div class="history-title">Chest Pain Follow-up</div>
                    <span class="unread-badge">2</span>
                </div>
                <div class="history-meta">Oct 23, 2024 • Active</div>
                <span class="urgent-tag">🔴 Urgent</span>
            </div>
            <div class="history-item">
                <div class="history-header">
                    <div class="history-title">Annual Checkup</div>
                </div>
                <div class="history-meta">Sep 15, 2024 • Completed</div>
            </div>
            <div class="history-item">
                <div class="history-header">
                    <div class="history-title">Prescription Refill</div>
                </div>
                <div class="history-meta">Aug 30, 2024 • Completed</div>
            </div>
        </div>
    </div>

    <!-- Main Chat Area -->
    <div class="chat-area">
        <!-- Header with Mode Toggle -->
        <div class="chat-header">
            <div class="mode-toggle">
                <button class="toggle-btn active">
                    <span class="icon">🤖</span> AI Assistant
                </button>
                <button class="toggle-btn">
                    <span class="icon">👨‍⚕️</span> Human Doctor
                </button>
            </div>
        </div>

        <!-- Chat Messages -->
        <div class="messages-container">
            <div class="message user-message">
                <div class="message-avatar">
                    <span class="avatar-icon">👤</span>
                </div>
                <div class="message-content">
                    <div class="message-text">
                        I've been experiencing chest pain for the past few days. Should I be concerned?
                        <div class="message-time">10:30</div>
                    </div>
                </div>
            </div>

            <div class="message ai-message">
                <div class="message-avatar">
                    <span class="avatar-icon">🤖</span>
                </div>
                <div class="message-content">
                    <div class="message-text">
                        I understand your concern about chest pain. Can you describe the pain in more detail? For example:
                        - Is it sharp or dull?
                        - Does it come and go, or is it constant?
                        - Does it worsen with physical activity?
                        - Are you experiencing any other symptoms like shortness of breath or dizziness?
                        <div class="message-time">10:31</div>
                    </div>
                </div>
            </div>

            <div class="message user-message">
                <div class="message-avatar">
                    <span class="avatar-icon">👤</span>
                </div>
                <div class="message-content">
                    <div class="message-text">
                        It's a dull pain that comes and goes. It gets worse when I exercise. No other symptoms.
                        <div class="message-time">10:33</div>
                    </div>
                </div>
            </div>

            <div class="ai-insight-card">
                <div class="insight-icon">💡</div>
                <div class="insight-content">
                    <strong>AI INSIGHT CARD</strong>
                    <p>Based on your symptoms and medical history, this could be related to your hypertension. I recommend scheduling an in-person consultation with a cardiologist.</p>
                </div>
            </div>
        </div>

        <!-- Input Area -->
        <div class="input-area">
            <div class="input-features">
                <span class="feature-badge">🔒 End-to-end encrypted medical sanctuary</span>
            </div>
            
            <div class="input-box">
                <button class="icon-btn">😊</button>
                <input type="text" 
                       placeholder="Describe your symptoms or ask a question..." 
                       value="" />
                <button class="icon-btn">🎤</button>
                <button class="send-btn disabled">
                    ➤
                </button>
            </div>
        </div>
    </div>

    <!-- Right Sidebar: Document Context -->
    <div class="context-sidebar">
        <div class="context-sidebar-header">
            <h3>Document Context</h3>
        </div>
        <p class="context-description">The following documents are being used by the AI to provide context for this conversation.</p>
        
        <div class="document-list">
            <div class="document-item analyzed">
                <div class="doc-icon">📄</div>
                <div class="doc-info">
                    <div class="doc-name">Blood_Panel_Oct23.pdf</div>
                    <div class="doc-meta">Uploaded 2h ago</div>
                    <div class="doc-status">AI ANALYZED</div>
                </div>
            </div>

            <div class="document-item verified">
                <div class="doc-icon">🖼️</div>
                <div class="doc-info">
                    <div class="doc-name">ECG_Scan_Final.jpg</div>
                    <div class="doc-meta">Uploaded Sep 30</div>
                    <div class="doc-status">HUMAN VERIFIED</div>
                </div>
            </div>
        </div>

        <div class="ai-insight-card">
            <div class="insight-header">💡 AI INSIGHT CARD</div>
            <p>The AI detected a correlation between your high stress logs and recent glucose spikes.</p>
        </div>

        <button class="export-btn">⬇️ Export Conversation</button>
    </div>
</div>
