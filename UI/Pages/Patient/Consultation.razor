@page "/patient/consultation"
@layout Components.Layout.SidebarLayout
@using ai_clinic.Models
@using ai_clinic.UI.Components

<style>
    .consultation-container {
        display: grid;
        grid-template-columns: 280px 1fr 320px;
        height: 100vh;
        background: #f5f7fa;
        gap: 0;
        margin: -2.5rem -3rem -2.5rem -3rem;
        width: calc(100% + 6rem);
        position: relative;
    }

    /* History Sidebar */
    .history-sidebar {
        background: white;
        border-right: 1px solid #e5e7eb;
        padding: 24px 16px;
        overflow-y: auto;
        overflow-x: hidden;
        height: 100vh;
        position: relative;
    }

    .history-sidebar::-webkit-scrollbar {
        width: 8px;
    }

    .history-sidebar::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    .history-sidebar::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 4px;
    }

    .history-sidebar::-webkit-scrollbar-thumb:hover {
        background: #a8a8a8;
    }

    .history-sidebar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .history-sidebar h3 {
        font-size: 12px;
        font-weight: 600;
        color: #6b7280;
        letter-spacing: 0.5px;
    }

    .new-consultation-btn {
        padding: 8px 14px;
        background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
        box-shadow: 0 2px 4px rgba(14, 165, 233, 0.2);
    }

    .new-consultation-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(14, 165, 233, 0.3);
    }

    .history-item {
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 8px;
        cursor: pointer;
        transition: background 0.2s;
    }

    .history-item:hover {
        background: #f9fafb;
    }

    .history-item.active {
        background: #e0f2fe;
        border-left: 3px solid #0ea5e9;
    }

    .history-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 4px;
    }

    .history-title {
        font-size: 14px;
        font-weight: 500;
        color: #111827;
    }

    .history-meta {
        font-size: 12px;
        color: #6b7280;
    }

    .unread-badge {
        background: #ef4444;
        color: white;
        font-size: 10px;
        font-weight: 600;
        padding: 2px 6px;
        border-radius: 10px;
    }

    .ai-tag {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        color: #10b981;
        margin-top: 4px;
        font-weight: 500;
    }

    /* Chat Area */
    .chat-area {
        display: flex;
        flex-direction: column;
        background: white;
        position: relative;
        height: 100vh;
        overflow: hidden;
        z-index: 1;
    }

    .chat-header {
        border-bottom: 1px solid #e5e7eb;
        background: white;
        flex-shrink: 0;
        padding: 16px 24px;
    }

    .chat-header-title {
        font-size: 18px;
        font-weight: 600;
        color: #111827;
        display: flex;
        align-items: center;
        gap: 8px;
        min-height: 28px;
    }

    /* Messages */
    .messages-container {
        flex: 1;
        overflow-y: auto;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 16px;
        min-height: 0;
    }

    .messages-container::-webkit-scrollbar {
        width: 8px;
    }

    .messages-container::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    .messages-container::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 4px;
    }

    .messages-container::-webkit-scrollbar-thumb:hover {
        background: #a8a8a8;
    }

    .message {
        display: flex;
        gap: 12px;
        max-width: 80%;
    }

    .message.user-message {
        align-self: flex-end;
        flex-direction: row-reverse;
    }

    .message-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .user-message .message-avatar {
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
    }

    .ai-message .message-avatar {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    }

    .doctor-message .message-avatar {
        background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
    }

    .message-content {
        flex: 1;
    }

    .message-text {
        padding: 14px 18px;
        border-radius: 16px;
        font-size: 14px;
        line-height: 1.6;
        white-space: pre-wrap;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    }

    .user-message .message-text {
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        color: white;
    }

    .ai-message .message-text {
        background: #f9fafb;
        color: #111827;
        border: 1px solid #e5e7eb;
    }

    .doctor-message .message-text {
        background: #f5f3ff;
        color: #5b21b6;
        border: 1px solid #e9d5ff;
    }

    .message-time {
        font-size: 11px;
        color: #9ca3af;
        margin-top: 6px;
        opacity: 0.8;
    }

    .user-message .message-time {
        color: rgba(255, 255, 255, 0.9);
    }

    .typing-indicator {
        display: flex;
        gap: 6px;
        padding: 14px 18px;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        width: fit-content;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    }

    .typing-indicator span {
        width: 8px;
        height: 8px;
        background: #6b7280;
        border-radius: 50%;
        animation: typing 1.4s infinite;
    }

    .typing-indicator span:nth-child(2) {
        animation-delay: 0.2s;
    }

    .typing-indicator span:nth-child(3) {
        animation-delay: 0.4s;
    }

    @@keyframes typing {
        0%, 60%, 100% {
            transform: translateY(0);
        }
        30% {
            transform: translateY(-10px);
        }
    }

    /* Input Area */
    .input-area {
        padding: 20px 24px;
        border-top: 1px solid #e5e7eb;
        background: white;
        flex-shrink: 0;
    }

    .input-features {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 14px;
    }

    .feature-badge {
        font-size: 12px;
        color: #10b981;
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 500;
    }

    .model-selector-btn {
        padding: 8px 14px;
        background: white;
        color: #374151;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .model-selector-btn:hover {
        background: #f9fafb;
        border-color: #0ea5e9;
        color: #0ea5e9;
    }

    .input-box {
        display: flex;
        gap: 10px;
        align-items: center;
        padding: 14px 16px;
        border: 2px solid #e5e7eb;
        border-radius: 16px;
        background: white;
        transition: all 0.2s;
    }

    .input-box:focus-within {
        border-color: #0ea5e9;
        box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1);
    }

    .icon-btn {
        background: transparent;
        border: none;
        color: #6b7280;
        cursor: pointer;
        padding: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        transition: all 0.2s;
    }

    .icon-btn:hover {
        background: #f3f4f6;
        color: #374151;
    }

    .input-box input {
        flex: 1;
        border: none;
        background: transparent;
        font-size: 14px;
        outline: none;
        color: #111827;
    }

    .input-box input::placeholder {
        color: #9ca3af;
    }

    .send-btn {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
        color: white;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        box-shadow: 0 2px 4px rgba(14, 165, 233, 0.2);
    }

    .send-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(14, 165, 233, 0.3);
    }

    .send-btn.disabled {
        background: #e5e7eb;
        cursor: not-allowed;
        box-shadow: none;
    }

    .send-btn.disabled:hover {
        transform: none;
    }

    /* Context Sidebar */
    .context-sidebar {
        background: white;
        border-left: 1px solid #e5e7eb;
        padding: 24px 16px;
        overflow-y: auto;
        overflow-x: hidden;
        height: 100vh;
        position: relative;
    }

    .context-sidebar::-webkit-scrollbar {
        width: 8px;
    }

    .context-sidebar::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    .context-sidebar::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 4px;
    }

    .context-sidebar::-webkit-scrollbar-thumb:hover {
        background: #a8a8a8;
    }

    .context-sidebar h3 {
        font-size: 16px;
        font-weight: 600;
        color: #111827;
        margin-bottom: 8px;
    }

    .context-description {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 20px;
        line-height: 1.5;
    }

    /* Modal */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-content {
        background: white;
        border-radius: 16px;
        padding: 32px;
        max-width: 600px;
        width: 90%;
        max-height: 80vh;
        overflow-y: auto;
    }

    .modal-header {
        font-size: 24px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 24px;
    }

    .modal-options {
        display: flex;
        gap: 16px;
        margin-bottom: 24px;
    }

    .option-card {
        flex: 1;
        padding: 24px;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
        text-align: center;
    }

    .option-card:hover {
        border-color: #0ea5e9;
        background: #f0f9ff;
    }

    .option-card.selected {
        border-color: #0ea5e9;
        background: #e0f2fe;
    }

    .option-icon {
        margin-bottom: 12px;
        display: flex;
        justify-content: center;
    }

    .option-title {
        font-size: 18px;
        font-weight: 600;
        color: #111827;
        margin-bottom: 8px;
    }

    .option-description {
        font-size: 14px;
        color: #6b7280;
    }

    .doctor-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 24px;
        max-height: 300px;
        overflow-y: auto;
    }

    .doctor-card {
        padding: 16px;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        gap: 12px;
    }

    .doctor-card:hover {
        border-color: #0ea5e9;
    }

    .doctor-card.selected {
        border-color: #0ea5e9;
        background: #e0f2fe;
    }

    .doctor-avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .doctor-info {
        flex: 1;
    }

    .doctor-name {
        font-size: 16px;
        font-weight: 600;
        color: #111827;
    }

    .doctor-specialty {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 4px;
    }

    .doctor-rating {
        font-size: 12px;
        color: #f59e0b;
    }

    .modal-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
    }

    .btn-cancel {
        padding: 12px 24px;
        background: white;
        color: #6b7280;
        border: 2px solid #e5e7eb;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-cancel:hover {
        border-color: #d1d5db;
        background: #f9fafb;
    }

    .btn-create {
        padding: 12px 24px;
        background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 2px 4px rgba(14, 165, 233, 0.2);
    }

    .btn-create:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(14, 165, 233, 0.3);
    }

    .btn-create:disabled {
        background: #e5e7eb;
        cursor: not-allowed;
        box-shadow: none;
        transform: none;
    }

    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: #6b7280;
    }

    .empty-state-icon {
        font-size: 64px;
        margin-bottom: 16px;
    }

    .empty-state-text {
        font-size: 18px;
        font-weight: 500;
    }

    /* Model Selector Styles */
    .model-card {
        padding: 16px;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: 12px;
    }

    .model-card:hover {
        border-color: #0ea5e9;
        background: #f0f9ff;
    }

    .model-card.selected {
        border-color: #0ea5e9;
        background: #e0f2fe;
    }

    .model-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
    }

    .model-name {
        font-size: 16px;
        font-weight: 600;
        color: #111827;
    }

    .model-badge {
        padding: 4px 8px;
        background: #10b981;
        color: white;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 600;
    }

    .model-id {
        font-size: 12px;
        color: #6b7280;
        font-family: monospace;
        margin-bottom: 8px;
    }

    .model-description {
        font-size: 13px;
        color: #4b5563;
        line-height: 1.5;
    }

    /* Recommended Doctor Card */
    .recommended-doctor-card {
        padding: 12px;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
        background: white;
    }

    .recommended-doctor-card:hover {
        border-color: #0ea5e9;
        background: #f0f9ff;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(14, 165, 233, 0.15);
    }

    .recommended-doctor-card button:hover {
        background: #0284c7;
    }

    /* Medical Records Styles */
    .record-section {
        margin-bottom: 16px;
    }

    .record-section:last-child {
        margin-bottom: 0;
    }

    .record-section-header {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 10px;
        padding-bottom: 6px;
        border-bottom: 1px solid #e5e7eb;
    }

    .record-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 10px;
        transition: all 0.2s;
        cursor: pointer;
        position: relative;
    }

    .record-card::after {
        content: "›";
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 20px;
        color: #9ca3af;
        opacity: 0;
        transition: all 0.2s;
    }

    .record-card:hover {
        border-color: #0ea5e9;
        box-shadow: 0 4px 8px rgba(14, 165, 233, 0.15);
        transform: translateY(-2px);
    }

    .record-card:hover::after {
        opacity: 1;
        right: 8px;
    }

    .record-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
    }

    .record-badge {
        font-size: 10px;
        font-weight: 600;
        padding: 3px 8px;
        border-radius: 4px;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

    .record-badge.note {
        background: #dbeafe;
        color: #1e40af;
    }

    .record-badge.active {
        background: #d1fae5;
        color: #065f46;
    }

    .record-badge.inactive {
        background: #fee2e2;
        color: #991b1b;
    }

    .record-date {
        font-size: 11px;
        color: #6b7280;
    }

    .record-card-body {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .record-diagnosis,
    .record-medication {
        font-size: 13px;
        font-weight: 600;
        color: #111827;
        margin: 0;
        line-height: 1.4;
    }

    .record-detail {
        font-size: 11px;
        color: #6b7280;
        margin: 0;
        line-height: 1.4;
    }

    .finalized-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 10px;
        font-weight: 600;
        color: #065f46;
        background: #d1fae5;
        padding: 2px 6px;
        border-radius: 4px;
        width: fit-content;
    }

    .last-updated-text {
        font-size: 10px;
        color: #9ca3af;
        font-style: italic;
    }

    /* Preview Modal Styles */
    .preview-modal {
        max-width: 600px;
        width: 90%;
    }

    .modal-header-flex {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 2px solid #e5e7eb;
    }

    .preview-modal-title {
        font-size: 20px;
        font-weight: 600;
        color: #111827;
        margin: 0 0 4px 0;
    }

    .last-updated-info {
        font-size: 12px;
        color: #6b7280;
        margin: 0;
    }

    .close-btn {
        background: transparent;
        border: none;
        color: #6b7280;
        cursor: pointer;
        padding: 4px;
        border-radius: 6px;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .close-btn:hover {
        background: #f3f4f6;
        color: #111827;
    }

    .preview-content {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .preview-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .preview-field-label {
        font-size: 12px;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .preview-field-value {
        font-size: 14px;
        color: #111827;
        line-height: 1.6;
        white-space: pre-wrap;
        padding: 10px 12px;
        background: #f9fafb;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
    }
</style>

<div class="consultation-container">
    <!-- Left Sidebar: History -->
    <div class="history-sidebar">
        <div class="history-sidebar-header">
            <h3>CONVERSATIONS</h3>
            <button class="new-consultation-btn" @onclick="ShowNewConversationDialog">
                <i data-lucide="plus" style="width: 14px; height: 14px;"></i>
                New
            </button>
        </div>
        <div class="history-list">
            @if (conversationList.Any())
            {
                @foreach (var conv in conversationList)
                {
                    <div class="history-item @(currentConversation?.Id == conv.Id ? "active" : "")" 
                         @onclick="@(() => LoadConversation(conv.Id))">
                        <div class="history-header">
                            <div class="history-title">@conv.Title</div>
                            @if (conv.UnreadCount > 0)
                            {
                                <span class="unread-badge">@conv.UnreadCount</span>
                            }
                        </div>
                        <div class="history-meta">@FormatTime(conv.LastMessageAt) • @conv.Status</div>
                        @if (conv.IsAiConversation)
                        {
                            <span class="ai-tag">
                                <i data-lucide="bot" style="width: 12px; height: 12px;"></i>
                                AI Assistant
                            </span>
                        }
                        else
                        {
                            <span class="ai-tag">
                                <i data-lucide="stethoscope" style="width: 12px; height: 12px;"></i>
                                @conv.DoctorName
                            </span>
                        }
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: 24px; color: #6b7280;">
                    <i data-lucide="inbox" style="width: 48px; height: 48px; color: #d1d5db; margin: 0 auto 12px;"></i>
                    <p>No conversations yet</p>
                    <p style="font-size: 12px; margin-top: 8px;">Click "New" to start</p>
                </div>
            }
        </div>
    </div>

    <!-- Main Chat Area -->
    <div class="chat-area">
        @if (currentConversation != null)
        {
            <!-- Header -->
            <div class="chat-header" @key="@($"header-{currentConversation.Id}")">
                <div class="chat-header-title">
                    @if (currentConversation.AssignedDoctorId == null)
                    {
                        <i data-lucide="bot" style="width: 20px; height: 20px; color: #10b981;"></i>
                        <span>AI Assistant</span>
                    }
                    else
                    {
                        <i data-lucide="stethoscope" style="width: 20px; height: 20px; color: #8b5cf6;"></i>
                        <span>Dr. @(currentConversation.AssignedDoctor?.DoctorProfile?.FullName ?? "Doctor")</span>
                    }
                </div>
            </div>

            <!-- Chat Messages -->
            <div class="messages-container" id="messages-container">
                @foreach (var message in messages)
                {
                    <div class="message @(message.SenderType == MessageSenderType.Patient ? "user-message" : 
                                         message.SenderType == MessageSenderType.AI ? "ai-message" : "doctor-message")">
                        <div class="message-avatar">
                            @if (message.SenderType == MessageSenderType.Patient)
                            {
                                @if (!string.IsNullOrEmpty(patientPhotoUrl))
                                {
                                    <img src="@patientPhotoUrl" alt="User" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" />
                                }
                                else
                                {
                                    <i data-lucide="user" style="width: 20px; height: 20px; color: white;"></i>
                                }
                            }
                            else if (message.SenderType == MessageSenderType.AI)
                            {
                                <i data-lucide="bot" style="width: 20px; height: 20px; color: white;"></i>
                            }
                            else
                            {
                                <i data-lucide="stethoscope" style="width: 20px; height: 20px; color: white;"></i>
                            }
                        </div>
                        <div class="message-content">
                            <div class="message-text">
                                @if (message.SenderType == MessageSenderType.AI || message.SenderType == MessageSenderType.Doctor)
                                {
                                    <MarkdownRenderer Content="@message.Content" />
                                }
                                else
                                {
                                    @message.Content
                                }
                                
                                @* Display attachments if any *@
                                @if (!string.IsNullOrEmpty(message.DocumentReferences))
                                {
                                    var docs = GetMessageDocuments(message.Id);
                                    if (docs.Any())
                                    {
                                        <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(0,0,0,0.1);">
                                            @foreach (var doc in docs)
                                            {
                                                @if (IsImageDocument(doc))
                                                {
                                                    <!-- Image attachment - display inline -->
                                                    <div style="margin-top: 8px;">
                                                        <img src="@GetImageDataUrl(doc)" 
                                                             alt="@doc.FileName" 
                                                             style="max-width: 100%; max-height: 300px; border-radius: 8px; cursor: pointer;"
                                                             @onclick="@(() => DownloadDocument(doc))"
                                                             title="Click to download: @doc.FileName" />
                                                        <div style="font-size: 11px; color: #6b7280; margin-top: 4px;">
                                                            @doc.FileName (@FormatFileSize(doc.FileSizeBytes))
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <!-- Non-image attachment - show download link -->
                                                    <div style="margin-top: 8px; padding: 8px 12px; background: rgba(0,0,0,0.05); border-radius: 8px; display: flex; align-items: center; gap: 8px; cursor: pointer;"
                                                         @onclick="@(() => DownloadDocument(doc))">
                                                        <i data-lucide="file" style="width: 16px; height: 16px; color: #6b7280;"></i>
                                                        <div style="flex: 1; min-width: 0;">
                                                            <div style="font-size: 12px; font-weight: 500; color: #111827; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                                @doc.FileName
                                                            </div>
                                                            <div style="font-size: 11px; color: #6b7280;">
                                                                @FormatFileSize(doc.FileSizeBytes)
                                                            </div>
                                                        </div>
                                                        <i data-lucide="download" style="width: 16px; height: 16px; color: #3b82f6;"></i>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                }
                                
                                <div class="message-time">@message.CreatedAt.ToString("HH:mm")</div>
                            </div>
                        </div>
                    </div>
                }

                @if (isTyping)
                {
                    <div class="message ai-message">
                        <div class="message-avatar">
                            @if (currentConversation.AssignedDoctorId == null)
                            {
                                <i data-lucide="bot" style="width: 20px; height: 20px; color: white;"></i>
                            }
                            else
                            {
                                <i data-lucide="stethoscope" style="width: 20px; height: 20px; color: white;"></i>
                            }
                        </div>
                        <div class="typing-indicator">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                    </div>
                }
            </div>

            <!-- Input Area -->
            <div class="input-area" @key="@($"input-{currentConversation.Id}")">
                <div class="input-features">
                    <span class="feature-badge">
                        <i data-lucide="shield-check" style="width: 14px; height: 14px;"></i>
                        End-to-end encrypted medical sanctuary
                    </span>
                    @if (currentConversation.AssignedDoctorId == null)
                    {
                        <button class="model-selector-btn" @onclick="ShowModelSelector">
                            <i data-lucide="cpu" style="width: 14px; height: 14px;"></i>
                            @ConsultationFacade.GetCurrentAiModelName()
                        </button>
                    }
                    else
                    {
                        <div style="width: 140px;"></div>
                    }
                </div>

                @* Attachments Preview *@
                @if (attachments.Any())
                {
                    <div style="display: flex; gap: 8px; margin-bottom: 12px; flex-wrap: wrap;">
                        @foreach (var attachment in attachments)
                        {
                            <div style="position: relative; padding: 8px 12px; background: #f3f4f6; border-radius: 8px; display: flex; align-items: center; gap: 8px; max-width: 200px;">
                                @if (attachment.PreviewUrl != null)
                                {
                                    <img src="@attachment.PreviewUrl" alt="@attachment.FileName" style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px;" />
                                }
                                else
                                {
                                    <i data-lucide="file" style="width: 20px; height: 20px; color: #6b7280;"></i>
                                }
                                <div style="flex: 1; min-width: 0;">
                                    <div style="font-size: 12px; font-weight: 500; color: #111827; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                        @attachment.FileName
                                    </div>
                                    <div style="font-size: 11px; color: #6b7280;">
                                        @FormatFileSize(attachment.FileSize)
                                    </div>
                                </div>
                                <button @onclick="@(() => RemoveAttachment(attachment))" 
                                        style="background: transparent; border: none; color: #ef4444; cursor: pointer; padding: 4px; display: flex; align-items: center;">
                                    <i data-lucide="x" style="width: 16px; height: 16px;"></i>
                                </button>
                            </div>
                        }
                    </div>
                }

                @if (isUploadingFile)
                {
                    <div style="margin-bottom: 12px; padding: 8px; background: #f0f9ff; border-radius: 8px; display: flex; align-items: center; gap: 8px;">
                        <div class="typing-indicator" style="margin: 0;">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                        <span style="font-size: 12px; color: #0ea5e9;">Uploading file...</span>
                    </div>
                }
                
                <div class="input-box">
                    <button class="icon-btn" title="Emoji">
                        <i data-lucide="smile" style="width: 20px; height: 20px;"></i>
                    </button>
                    <InputFile OnChange="HandleFileSelected" multiple accept="image/*,.pdf,.doc,.docx" id="file-upload" style="display: none;" />
                    <label for="file-upload" class="icon-btn" title="Attach file" style="cursor: pointer; margin: 0;">
                        <i data-lucide="paperclip" style="width: 20px; height: 20px;"></i>
                    </label>
                    <input type="text" 
                           placeholder="Describe your symptoms or ask a question..." 
                           @bind="newMessage"
                           @bind:event="oninput"
                           @onkeydown="HandleKeyPress" />
                    <button class="icon-btn" title="Voice input">
                        <i data-lucide="mic" style="width: 20px; height: 20px;"></i>
                    </button>
                    <button class="send-btn @(string.IsNullOrWhiteSpace(newMessage) && attachments.Count == 0 ? "disabled" : "")" 
                            @onclick="SendMessage"
                            disabled="@(string.IsNullOrWhiteSpace(newMessage) && attachments.Count == 0)"
                            title="Send message">
                        <i data-lucide="send" style="width: 20px; height: 20px;"></i>
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i data-lucide="message-circle" style="width: 64px; height: 64px; color: #d1d5db; margin-bottom: 16px;"></i>
                <div class="empty-state-text">Select a conversation or create a new one</div>
            </div>
        }
    </div>

    <!-- Right Sidebar: Document Context -->
    <div class="context-sidebar">
        <h3>Conversation Info</h3>
        @if (currentConversation != null)
        {
            <p class="context-description">
                @if (currentConversation.AssignedDoctorId == null)
                {
                    <text>AI-powered consultation with intelligent health insights.</text>
                }
                else
                {
                    <text>Consultation with @currentConversation.AssignedDoctor?.DoctorProfile?.FullName</text>
                }
            </p>
            
            <div style="margin-top: 20px;">
                <p style="font-size: 13px; color: #6b7280; margin-bottom: 8px;">
                    <strong>Started:</strong> @currentConversation.StartedAt.ToString("MMM dd, yyyy HH:mm")
                </p>
                <p style="font-size: 13px; color: #6b7280; margin-bottom: 8px;">
                    <strong>Messages:</strong> @currentConversation.TotalMessages
                </p>
                <p style="font-size: 13px; color: #6b7280; margin-bottom: 8px;">
                    <strong>Status:</strong> @currentConversation.Status
                </p>
            </div>

            @* AI推荐医生列表 *@
            @if (currentConversation.AssignedDoctorId == null && messages.Count >= 3 && !isLoadingRecommendations)
            {
                <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid #e5e7eb;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                        <h3 style="font-size: 16px; font-weight: 600; color: #111827; margin: 0; display: flex; align-items: center; gap: 8px;">
                            <i data-lucide="sparkles" style="width: 18px; height: 18px; color: #0ea5e9;"></i>
                            AI Recommendations
                        </h3>
                        @if (!showRecommendedDoctors)
                        {
                            <button @onclick="LoadRecommendedDoctors" 
                                    style="padding: 6px 12px; background: #0ea5e9; color: white; border: none; border-radius: 8px; font-size: 12px; cursor: pointer; display: flex; align-items: center; gap: 4px;">
                                <i data-lucide="eye" style="width: 14px; height: 14px;"></i>
                                Show
                            </button>
                        }
                    </div>
                    
                    @if (showRecommendedDoctors)
                    {
                        <p style="font-size: 13px; color: #6b7280; margin-bottom: 16px; line-height: 1.5;">
                            Based on your symptoms, here are recommended specialists:
                        </p>

                        @if (recommendedDoctors.Any())
                        {
                            <div style="display: flex; flex-direction: column; gap: 12px;">
                                @foreach (var doctor in recommendedDoctors.Take(3))
                                {
                                    <div class="recommended-doctor-card" @onclick="@(() => ShowDoctorDetails(doctor))">
                                        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                                            <div style="width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                                <i data-lucide="user-round" style="width: 24px; height: 24px; color: white;"></i>
                                            </div>
                                            <div style="flex: 1; min-width: 0;">
                                                <div style="font-size: 14px; font-weight: 600; color: #111827; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                    Dr. @doctor.FullName
                                                </div>
                                                <div style="font-size: 12px; color: #6b7280; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                    @doctor.PrimarySpecialization
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
                                            <div style="font-size: 11px; color: #f59e0b; font-weight: 500; display: flex; align-items: center; gap: 4px;">
                                                <i data-lucide="star" style="width: 12px; height: 12px; fill: #f59e0b;"></i>
                                                @doctor.AverageRating.ToString("F1")
                                            </div>
                                            <div style="font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 12px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                                                @doctor.MatchScore.ToString("F0")% Match
                                            </div>
                                        </div>

                                        @if (doctor.MatchReasons.Any())
                                        {
                                            <div style="font-size: 11px; color: #10b981; margin-bottom: 8px; display: flex; align-items: start; gap: 4px;">
                                                <i data-lucide="check-circle" style="width: 12px; height: 12px; flex-shrink: 0; margin-top: 1px;"></i>
                                                <span>@doctor.MatchReasons.First()</span>
                                            </div>
                                        }

                                        <button @onclick="@(() => StartConsultationWithDoctor(doctor.UserId))" 
                                                @onclick:stopPropagation="true"
                                                style="width: 100%; padding: 8px; background: #0ea5e9; color: white; border: none; border-radius: 6px; font-size: 12px; font-weight: 500; cursor: pointer; transition: background 0.2s;">
                                            Consult Now
                                        </button>
                                    </div>
                                }
                            </div>

                            @if (recommendedDoctors.Count > 3)
                            {
                                <button @onclick="ShowAllRecommendedDoctors" 
                                        style="width: 100%; margin-top: 12px; padding: 8px; background: transparent; color: #0ea5e9; border: 1px solid #0ea5e9; border-radius: 6px; font-size: 12px; font-weight: 500; cursor: pointer;">
                                    View All (@recommendedDoctors.Count)
                                </button>
                            }
                        }
                        else
                        {
                            <div style="text-align: center; padding: 16px; color: #6b7280; font-size: 13px;">
                                <i data-lucide="search" style="width: 32px; height: 32px; color: #d1d5db; margin: 0 auto 8px;"></i>
                                <div>No recommendations yet</div>
                            </div>
                        }
                    }
                </div>
            }
                
            @if (isLoadingRecommendations)
            {
                <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid #e5e7eb;">
                    <div style="text-align: center; padding: 24px; color: #6b7280;">
                        <div class="typing-indicator" style="margin: 0 auto 12px;">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                        <div style="font-size: 13px;">Finding best doctors for you...</div>
                    </div>
                </div>
            }

            <!-- Medical Records Section (Patient View) -->
            @if (currentConversation != null)
            {
                <div style="margin-top: 24px; padding-top: 20px; border-top: 2px solid #e5e7eb;">
                    <h3 style="font-size: 16px; font-weight: 600; color: #111827; margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
                        <i data-lucide="file-text" style="width: 18px; height: 18px; color: #8b5cf6;"></i>
                        Medical Records
                    </h3>
                    <p style="font-size: 12px; color: #6b7280; margin-bottom: 16px;">
                        Click any record to view details
                    </p>
                    
                    @if (isLoadingRecords)
                    {
                        <div style="text-align: center; padding: 16px; color: #6b7280;">
                            <p style="font-size: 12px;">Loading records...</p>
                        </div>
                    }
                    else if (relatedPrescriptions.Any() || relatedConsultationNotes.Any())
                    {
                        <!-- Consultation Notes -->
                        @if (relatedConsultationNotes.Any())
                        {
                            <div class="record-section">
                                <div class="record-section-header">
                                    <i data-lucide="stethoscope" style="width: 14px; height: 14px;"></i>
                                    <span>Consultation Notes (@relatedConsultationNotes.Count)</span>
                                </div>
                                @foreach (var note in relatedConsultationNotes.Take(3))
                                {
                                    <div class="record-card" @onclick="@(() => PreviewConsultationNote(note))">
                                        <div class="record-card-header">
                                            <span class="record-badge note">NOTE</span>
                                            <span class="record-date">@note.CreatedAt.ToString("MMM dd")</span>
                                        </div>
                                        <div class="record-card-body">
                                            <p class="record-diagnosis">@note.Diagnosis</p>
                                            @if (!string.IsNullOrEmpty(note.TreatmentPlan))
                                            {
                                                <p class="record-detail">Plan: @TruncateText(note.TreatmentPlan, 60)</p>
                                            }
                                            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 6px;">
                                                @if (note.IsFinalized)
                                                {
                                                    <span class="finalized-badge">
                                                        <i data-lucide="check-circle" style="width: 10px; height: 10px;"></i>
                                                        Finalized
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span></span>
                                                }
                                                <span class="last-updated-text">Updated @note.UpdatedAt.ToString("MMM dd, HH:mm")</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                                @if (relatedConsultationNotes.Count > 3)
                                {
                                    <p style="font-size: 11px; color: #6b7280; text-align: center; margin-top: 8px;">
                                        +@(relatedConsultationNotes.Count - 3) more notes
                                    </p>
                                }
                            </div>
                        }

                        <!-- Prescriptions -->
                        @if (relatedPrescriptions.Any())
                        {
                            <div class="record-section">
                                <div class="record-section-header">
                                    <i data-lucide="pill" style="width: 14px; height: 14px;"></i>
                                    <span>Prescriptions (@relatedPrescriptions.Count)</span>
                                </div>
                                @foreach (var rx in relatedPrescriptions.Take(3))
                                {
                                    <div class="record-card" @onclick="@(() => PreviewPrescription(rx))">
                                        <div class="record-card-header">
                                            <span class="record-badge @(rx.IsActive ? "active" : "inactive")">
                                                @(rx.IsActive ? "ACTIVE" : "INACTIVE")
                                            </span>
                                            <span class="record-date">@rx.CreatedAt.ToString("MMM dd")</span>
                                        </div>
                                        <div class="record-card-body">
                                            <p class="record-medication">@rx.MedicationName</p>
                                            <p class="record-detail">@rx.Dosage • @rx.Frequency</p>
                                            @if (!string.IsNullOrEmpty(rx.Duration))
                                            {
                                                <p class="record-detail">Duration: @rx.Duration</p>
                                            }
                                            <span class="last-updated-text" style="margin-top: 6px; display: block;">Updated @rx.UpdatedAt.ToString("MMM dd, HH:mm")</span>
                                        </div>
                                    </div>
                                }
                                @if (relatedPrescriptions.Count > 3)
                                {
                                    <p style="font-size: 11px; color: #6b7280; text-align: center; margin-top: 8px;">
                                        +@(relatedPrescriptions.Count - 3) more prescriptions
                                    </p>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div style="text-align: center; padding: 16px; color: #9ca3af;">
                            <i data-lucide="inbox" style="width: 32px; height: 32px; margin-bottom: 8px; opacity: 0.5;"></i>
                            <p style="font-size: 12px;">No medical records yet</p>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <p class="context-description">No conversation selected</p>
        }
    </div>
</div>

<!-- Preview Modal for Consultation Note (Patient View) -->
@if (showNotePreviewModal && selectedNote != null)
{
    <div class="modal-overlay" @onclick="CloseNotePreview">
        <div class="modal-content preview-modal" @onclick:stopPropagation="true">
            <div class="modal-header-flex">
                <div>
                    <h3 class="preview-modal-title">Consultation Note</h3>
                    <p class="last-updated-info">Last updated: @selectedNote.UpdatedAt.ToString("MMM dd, yyyy HH:mm")</p>
                </div>
                <button @onclick="CloseNotePreview" class="close-btn">
                    <i data-lucide="x" style="width: 20px; height: 20px;"></i>
                </button>
            </div>
            <div class="preview-content">
                <div class="preview-field">
                    <div class="preview-field-label">Symptoms</div>
                    <div class="preview-field-value">@(string.IsNullOrWhiteSpace(selectedNote.Symptoms) ? "—" : selectedNote.Symptoms)</div>
                </div>
                <div class="preview-field">
                    <div class="preview-field-label">Physical Examination</div>
                    <div class="preview-field-value">@(string.IsNullOrWhiteSpace(selectedNote.PhysicalExamination) ? "—" : selectedNote.PhysicalExamination)</div>
                </div>
                <div class="preview-field">
                    <div class="preview-field-label">Diagnosis</div>
                    <div class="preview-field-value">@selectedNote.Diagnosis</div>
                </div>
                <div class="preview-field">
                    <div class="preview-field-label">Treatment Plan</div>
                    <div class="preview-field-value">@(string.IsNullOrWhiteSpace(selectedNote.TreatmentPlan) ? "—" : selectedNote.TreatmentPlan)</div>
                </div>
                <div class="preview-field">
                    <div class="preview-field-label">Follow-up Instructions</div>
                    <div class="preview-field-value">@(string.IsNullOrWhiteSpace(selectedNote.FollowUpInstructions) ? "—" : selectedNote.FollowUpInstructions)</div>
                </div>
                @if (selectedNote.IsFinalized)
                {
                    <div class="finalized-badge" style="width: fit-content; margin-top: 12px;">
                        <i data-lucide="check-circle" style="width: 12px; height: 12px;"></i>
                        Finalized
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- Preview Modal for Prescription (Patient View) -->
@if (showPrescriptionPreviewModal && selectedPrescription != null)
{
    <div class="modal-overlay" @onclick="ClosePrescriptionPreview">
        <div class="modal-content preview-modal" @onclick:stopPropagation="true">
            <div class="modal-header-flex">
                <div>
                    <h3 class="preview-modal-title">Prescription</h3>
                    <p class="last-updated-info">Last updated: @selectedPrescription.UpdatedAt.ToString("MMM dd, yyyy HH:mm")</p>
                </div>
                <button @onclick="ClosePrescriptionPreview" class="close-btn">
                    <i data-lucide="x" style="width: 20px; height: 20px;"></i>
                </button>
            </div>
            <div class="preview-content">
                <div class="preview-field">
                    <div class="preview-field-label">Medication</div>
                    <div class="preview-field-value">@selectedPrescription.MedicationName</div>
                </div>
                <div class="preview-field">
                    <div class="preview-field-label">Dosage</div>
                    <div class="preview-field-value">@selectedPrescription.Dosage</div>
                </div>
                <div class="preview-field">
                    <div class="preview-field-label">Frequency</div>
                    <div class="preview-field-value">@selectedPrescription.Frequency</div>
                </div>
                <div class="preview-field">
                    <div class="preview-field-label">Duration</div>
                    <div class="preview-field-value">@(string.IsNullOrWhiteSpace(selectedPrescription.Duration) ? "—" : selectedPrescription.Duration)</div>
                </div>
                <div class="preview-field">
                    <div class="preview-field-label">Instructions</div>
                    <div class="preview-field-value">@(string.IsNullOrWhiteSpace(selectedPrescription.Instructions) ? "—" : selectedPrescription.Instructions)</div>
                </div>
                <div class="preview-field">
                    <div class="preview-field-label">Status</div>
                    <div class="preview-field-value">
                        <span class="record-badge @(selectedPrescription.IsActive ? "active" : "inactive")">
                            @(selectedPrescription.IsActive ? "ACTIVE" : "INACTIVE")
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- New Conversation Modal -->
@if (showNewConversationModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                Start New Consultation
                @if (!isLoadingDoctors && availableDoctors.Any())
                {
                    <div style="font-size: 14px; font-weight: 400; color: #6b7280; margin-top: 8px;">
                        @availableDoctors.Count doctor(s) available for consultation
                    </div>
                }
            </div>
            
            <div class="modal-options">
                <div class="option-card @(selectedDoctorId == null && isAiMode ? "selected" : "")" 
                     @onclick="@(() => { isAiMode = true; selectedDoctorId = null; })">
                    <div class="option-icon">
                        <i data-lucide="bot" style="width: 48px; height: 48px; color: #10b981;"></i>
                    </div>
                    <div class="option-title">AI Assistant</div>
                    <div class="option-description">Instant responses, 24/7 availability</div>
                </div>
                
                <div class="option-card @(!isAiMode ? "selected" : "")" 
                     @onclick="@(() => isAiMode = false)">
                    <div class="option-icon">
                        <i data-lucide="stethoscope" style="width: 48px; height: 48px; color: #8b5cf6;"></i>
                    </div>
                    <div class="option-title">Human Doctor</div>
                    <div class="option-description">Professional medical consultation</div>
                </div>
            </div>

            @if (!isAiMode)
            {
                <!-- Search Box -->
                <div style="margin-bottom: 16px;">
                    <div style="position: relative;">
                        <input type="text"
                               placeholder="Search by name or specialization..."
                               @bind="DoctorSearchQuery"
                               @bind:event="oninput"
                               style="width: 100%; padding: 12px 40px 12px 16px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 14px; outline: none;" />
                        <i data-lucide="search" style="width: 18px; height: 18px; color: #9ca3af; position: absolute; right: 12px; top: 50%; transform: translateY(-50%);"></i>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(DoctorSearchQuery) && filteredDoctors.Any())
                    {
                        <div style="margin-top: 8px; font-size: 12px; color: #6b7280;">
                            Found @filteredDoctors.Count doctor(s)
                        </div>
                    }
                </div>

                <div class="doctor-list">
                    @if (isLoadingDoctors)
                    {
                        <div style="text-align: center; padding: 32px; color: #6b7280;">
                            <div class="typing-indicator" style="margin: 0 auto;">
                                <span></span>
                                <span></span>
                                <span></span>
                            </div>
                            <div style="margin-top: 16px; font-size: 14px;">Loading available doctors...</div>
                        </div>
                    }
                    else if (filteredDoctors.Any())
                    {
                        @foreach (var doctor in filteredDoctors)
                        {
                            <div class="doctor-card @(selectedDoctorId == doctor.UserId ? "selected" : "")"
                                 @onclick="@(() => selectedDoctorId = doctor.UserId)">
                                <div class="doctor-avatar">
                                    <i data-lucide="user-round" style="width: 28px; height: 28px; color: #6b7280;"></i>
                                </div>
                                <div class="doctor-info">
                                    <div class="doctor-name">Dr. @doctor.FullName</div>
                                    <div class="doctor-specialty">@doctor.PrimarySpecialization</div>
                                    <div class="doctor-rating" style="display: flex; align-items: center; gap: 4px;">
                                        <i data-lucide="star" style="width: 12px; height: 12px; fill: #f59e0b; color: #f59e0b;"></i>
                                        @doctor.AverageRating.ToString("F1") (@doctor.TotalRatings reviews)
                                    </div>
                                    @if (doctor.YearsOfExperience.HasValue)
                                    {
                                        <div style="font-size: 12px; color: #6b7280; margin-top: 4px;">
                                            @doctor.YearsOfExperience years experience
                                        </div>
                                    }
                                    <div style="font-size: 12px; margin-top: 4px;">
                                        <span style="@GetAvailabilityStatusStyle(doctor.AvailabilityStatus)">
                                            @GetAvailabilityStatusText(doctor.AvailabilityStatus)
                                        </span>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else if (!string.IsNullOrWhiteSpace(DoctorSearchQuery))
                    {
                        <div style="text-align: center; padding: 32px; color: #6b7280;">
                            <i data-lucide="search-x" style="width: 48px; height: 48px; color: #d1d5db; margin: 0 auto 16px;"></i>
                            <div style="font-size: 16px; font-weight: 500; margin-bottom: 8px;">No doctors found</div>
                            <div style="font-size: 14px;">Try adjusting your search criteria</div>
                        </div>
                    }
                    else
                    {
                        <div style="text-align: center; padding: 32px; color: #6b7280;">
                            <i data-lucide="user-x" style="width: 48px; height: 48px; color: #d1d5db; margin: 0 auto 16px;"></i>
                            <div style="font-size: 16px; font-weight: 500; margin-bottom: 8px;">No doctors available</div>
                            <div style="font-size: 14px;">All doctors are currently busy. Please try again later or use AI Assistant.</div>
                        </div>
                    }
                </div>
            }

            <div class="modal-actions">
                <button class="btn-cancel" @onclick="CloseModal">Cancel</button>
                <button class="btn-create" 
                        @onclick="@(() => CreateNewConversation(isAiMode))"
                        disabled="@(!isAiMode && selectedDoctorId == null)">
                    Create Conversation
                </button>
            </div>
        </div>
    </div>
}

<!-- Model Selector Modal -->
@if (showModelSelectorModal)
{
    <div class="modal-overlay" @onclick="CloseModelSelector">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">Select AI Model</div>
            
            <div style="margin-bottom: 16px;">
                <p style="font-size: 14px; color: #6b7280;">
                    Choose the AI model that best fits your needs. Each model has different strengths.
                </p>
            </div>

            <div style="max-height: 400px; overflow-y: auto;">
                @foreach (var model in availableModels)
                {
                    <div class="model-card @(currentModelKey == model.Key ? "selected" : "")"
                         @onclick="@(() => SwitchModel(model.Key))">
                        <div class="model-card-header">
                            <div class="model-name">@model.DisplayName</div>
                            @if (currentModelKey == model.Key)
                            {
                                <span class="model-badge">ACTIVE</span>
                            }
                        </div>
                        <div class="model-id">@model.ModelId</div>
                        <div class="model-description">@model.Description</div>
                    </div>
                }
            </div>

            <div class="modal-actions">
                <button class="btn-cancel" @onclick="CloseModelSelector">Close</button>
            </div>
        </div>
    </div>
}

<!-- All Recommended Doctors Modal -->
@if (showAllRecommendedDoctorsModal)
{
    <div class="modal-overlay" @onclick="CloseAllRecommendedDoctors">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                🤖 AI Recommended Doctors
                <div style="font-size: 14px; font-weight: 400; color: #6b7280; margin-top: 8px;">
                    Based on your symptoms and conversation history
                </div>
            </div>

            <div class="doctor-list">
                @foreach (var doctor in recommendedDoctors)
                {
                    <div class="doctor-card @(selectedRecommendedDoctorId == doctor.UserId ? "selected" : "")"
                         @onclick="@(() => selectedRecommendedDoctorId = doctor.UserId)">
                        <div class="doctor-avatar">👨‍⚕️</div>
                        <div class="doctor-info">
                            <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 4px;">
                                <div class="doctor-name">Dr. @doctor.FullName</div>
                                <div style="font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 12px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                                    @doctor.MatchScore.ToString("F0")% Match
                                </div>
                            </div>
                            <div class="doctor-specialty">@doctor.PrimarySpecialization</div>
                            <div class="doctor-rating" style="display: flex; align-items: center; gap: 4px;">
                                <i data-lucide="star" style="width: 12px; height: 12px; fill: #f59e0b; color: #f59e0b;"></i>
                                @doctor.AverageRating.ToString("F1") (@doctor.TotalRatings reviews)
                            </div>
                            @if (doctor.YearsOfExperience.HasValue)
                            {
                                <div style="font-size: 12px; color: #6b7280; margin-top: 4px;">
                                    @doctor.YearsOfExperience years experience
                                </div>
                            }
                            <div style="font-size: 12px; margin-top: 8px;">
                                <span style="@GetAvailabilityStatusStyle(doctor.AvailabilityStatus)">
                                    @GetAvailabilityStatusText(doctor.AvailabilityStatus)
                                </span>
                            </div>
                            @if (doctor.MatchReasons.Any())
                            {
                                <div style="margin-top: 8px; padding: 8px; background: #f0fdf4; border-radius: 6px;">
                                    <div style="font-size: 11px; font-weight: 600; color: #10b981; margin-bottom: 4px;">
                                        Why recommended:
                                    </div>
                                    @foreach (var reason in doctor.MatchReasons.Take(2))
                                    {
                                        <div style="font-size: 11px; color: #059669; margin-bottom: 2px; display: flex; align-items: start; gap: 4px;">
                                            <i data-lucide="check" style="width: 12px; height: 12px; flex-shrink: 0; margin-top: 1px;"></i>
                                            <span>@reason</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="modal-actions">
                <button class="btn-cancel" @onclick="CloseAllRecommendedDoctors">Cancel</button>
                <button class="btn-create" 
                        @onclick="@(() => StartConsultationWithDoctor(selectedRecommendedDoctorId))"
                        disabled="@(selectedRecommendedDoctorId == null)">
                    Start Consultation
                </button>
            </div>
        </div>
    </div>
}

