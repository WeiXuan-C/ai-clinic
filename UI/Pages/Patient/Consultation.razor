    private async Task SendMessage()
    {
        if (!string.IsNullOrWhiteSpace(currentMessage))
        {
            var userMessage = new ConsultationMessage
            {
                Id = messages.Count + 1,
                Content = currentMessage,
                IsFromUser = true,
                Timestamp = DateTime.Now
            };
            messages.Add(userMessage);
            
            var sentMessage = currentMessage;
            currentMessage = "";
            
            // Simulate AI/Doctor response
            isTyping = true;
            StateHasChanged();
            
            await Task.Delay(2000); // Simulate thinking time
            
            isTyping = false;
            messages.Add(new ConsultationMessage
            {
                Id = messages.Count + 1,
                Content = GenerateResponse(sentMessage),
                IsFromUser = false,
                Timestamp = DateTime.Now,
                HasQuickActions = true
            });
            
            StateHasChanged();
        }
    }

