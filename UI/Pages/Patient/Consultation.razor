@page "/patient/consultation"
@layout Components.Layout.SidebarLayout
@using ai_clinic.Models

<style>
    .consultation-container {
        display: grid;
        grid-template-columns: 280px 1fr 320px;
        height: 100vh;
        background: #f5f7fa;
        gap: 0;
        margin: -2.5rem -3rem -2.5rem -3rem;
        width: calc(100% + 6rem);
        position: relative;
    }

    /* History Sidebar */
    .history-sidebar {
        background: white;
        border-right: 1px solid #e5e7eb;
        padding: 24px 16px;
        overflow-y: auto;
        overflow-x: hidden;
        height: 100vh;
        position: relative;
    }

    .history-sidebar::-webkit-scrollbar {
        width: 8px;
    }

    .history-sidebar::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    .history-sidebar::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 4px;
    }

    .history-sidebar::-webkit-scrollbar-thumb:hover {
        background: #a8a8a8;
    }

    .history-sidebar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .history-sidebar h3 {
        font-size: 12px;
        font-weight: 600;
        color: #6b7280;
        letter-spacing: 0.5px;
    }

    .new-consultation-btn {
        padding: 6px 12px;
        background: #0ea5e9;
        color: white;
        border: none;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
    }

    .new-consultation-btn:hover {
        background: #0284c7;
    }

    .history-item {
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 8px;
        cursor: pointer;
        transition: background 0.2s;
    }

    .history-item:hover {
        background: #f9fafb;
    }

    .history-item.active {
        background: #e0f2fe;
        border-left: 3px solid #0ea5e9;
    }

    .history-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 4px;
    }

    .history-title {
        font-size: 14px;
        font-weight: 500;
        color: #111827;
    }

    .history-meta {
        font-size: 12px;
        color: #6b7280;
    }

    .unread-badge {
        background: #ef4444;
        color: white;
        font-size: 10px;
        font-weight: 600;
        padding: 2px 6px;
        border-radius: 10px;
    }

    .ai-tag {
        display: inline-block;
        font-size: 11px;
        color: #10b981;
        margin-top: 4px;
    }

    /* Chat Area */
    .chat-area {
        display: flex;
        flex-direction: column;
        background: white;
        position: relative;
        height: 100vh;
        overflow: hidden;
        z-index: 1;
    }

    .chat-header {
        border-bottom: 1px solid #e5e7eb;
        background: white;
        flex-shrink: 0;
    }

    .mode-toggle {
        display: flex;
        gap: 8px;
        padding: 16px;
    }

    .toggle-btn {
        flex: 1;
        padding: 12px 16px;
        border: 2px solid #e5e7eb;
        border-radius: 8px;
        background: white;
        cursor: pointer;
        font-size: 14px;
        font-weight: 500;
        color: #6b7280;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .toggle-btn:hover {
        border-color: #0ea5e9;
    }

    .toggle-btn.active {
        background: #0ea5e9;
        border-color: #0ea5e9;
        color: white;
    }

    /* Messages */
    .messages-container {
        flex: 1;
        overflow-y: auto;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 16px;
        min-height: 0;
    }

    .messages-container::-webkit-scrollbar {
        width: 8px;
    }

    .messages-container::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    .messages-container::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 4px;
    }

    .messages-container::-webkit-scrollbar-thumb:hover {
        background: #a8a8a8;
    }

    .message {
        display: flex;
        gap: 12px;
        max-width: 80%;
    }

    .message.user-message {
        align-self: flex-end;
        flex-direction: row-reverse;
    }

    .message-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

    .user-message .message-avatar {
        background: #3b82f6;
    }

    .ai-message .message-avatar {
        background: #10b981;
    }

    .doctor-message .message-avatar {
        background: #8b5cf6;
    }

    .message-content {
        flex: 1;
    }

    .message-text {
        padding: 12px 16px;
        border-radius: 12px;
        font-size: 14px;
        line-height: 1.5;
        white-space: pre-wrap;
    }

    .user-message .message-text {
        background: #dbeafe;
        color: #1e3a8a;
    }

    .ai-message .message-text {
        background: #d1fae5;
        color: #065f46;
    }

    .doctor-message .message-text {
        background: #ede9fe;
        color: #5b21b6;
    }

    .message-time {
        font-size: 11px;
        color: #9ca3af;
        margin-top: 4px;
        text-align: right;
    }

    .typing-indicator {
        display: flex;
        gap: 6px;
        padding: 12px 16px;
        background: #d1fae5;
        border-radius: 12px;
        width: fit-content;
    }

    .typing-indicator span {
        width: 8px;
        height: 8px;
        background: #10b981;
        border-radius: 50%;
        animation: typing 1.4s infinite;
    }

    .typing-indicator span:nth-child(2) {
        animation-delay: 0.2s;
    }

    .typing-indicator span:nth-child(3) {
        animation-delay: 0.4s;
    }

    @@keyframes typing {
        0%, 60%, 100% {
            transform: translateY(0);
        }
        30% {
            transform: translateY(-10px);
        }
    }

    /* Input Area */
    .input-area {
        padding: 16px 24px;
        border-top: 1px solid #e5e7eb;
        background: white;
        flex-shrink: 0;
    }

    .input-features {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .feature-badge {
        font-size: 12px;
        color: #10b981;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .model-selector-btn {
        padding: 6px 12px;
        background: #f3f4f6;
        color: #374151;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .model-selector-btn:hover {
        background: #e5e7eb;
        border-color: #0ea5e9;
    }

    .input-box {
        display: flex;
        gap: 8px;
        align-items: center;
        padding: 12px;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        background: #f9fafb;
    }

    .icon-btn {
        background: transparent;
        border: none;
        font-size: 20px;
        cursor: pointer;
        padding: 4px;
    }

    .input-box input {
        flex: 1;
        border: none;
        background: transparent;
        font-size: 14px;
        outline: none;
    }

    .send-btn {
        width: 36px;
        height: 36px;
        background: #0ea5e9;
        color: white;
        border: none;
        border-radius: 50%;
        font-size: 18px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .send-btn.disabled {
        background: #d1d5db;
        cursor: not-allowed;
    }

    /* Context Sidebar */
    .context-sidebar {
        background: white;
        border-left: 1px solid #e5e7eb;
        padding: 24px 16px;
        overflow-y: auto;
        overflow-x: hidden;
        height: 100vh;
        position: relative;
    }

    .context-sidebar::-webkit-scrollbar {
        width: 8px;
    }

    .context-sidebar::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    .context-sidebar::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 4px;
    }

    .context-sidebar::-webkit-scrollbar-thumb:hover {
        background: #a8a8a8;
    }

    .context-sidebar h3 {
        font-size: 16px;
        font-weight: 600;
        color: #111827;
        margin-bottom: 8px;
    }

    .context-description {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 20px;
        line-height: 1.5;
    }

    /* Modal */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-content {
        background: white;
        border-radius: 16px;
        padding: 32px;
        max-width: 600px;
        width: 90%;
        max-height: 80vh;
        overflow-y: auto;
    }

    .modal-header {
        font-size: 24px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 24px;
    }

    .modal-options {
        display: flex;
        gap: 16px;
        margin-bottom: 24px;
    }

    .option-card {
        flex: 1;
        padding: 24px;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
        text-align: center;
    }

    .option-card:hover {
        border-color: #0ea5e9;
        background: #f0f9ff;
    }

    .option-card.selected {
        border-color: #0ea5e9;
        background: #e0f2fe;
    }

    .option-icon {
        font-size: 48px;
        margin-bottom: 12px;
    }

    .option-title {
        font-size: 18px;
        font-weight: 600;
        color: #111827;
        margin-bottom: 8px;
    }

    .option-description {
        font-size: 14px;
        color: #6b7280;
    }

    .doctor-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 24px;
        max-height: 300px;
        overflow-y: auto;
    }

    .doctor-card {
        padding: 16px;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        gap: 12px;
    }

    .doctor-card:hover {
        border-color: #0ea5e9;
    }

    .doctor-card.selected {
        border-color: #0ea5e9;
        background: #e0f2fe;
    }

    .doctor-avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .doctor-info {
        flex: 1;
    }

    .doctor-name {
        font-size: 16px;
        font-weight: 600;
        color: #111827;
    }

    .doctor-specialty {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 4px;
    }

    .doctor-rating {
        font-size: 12px;
        color: #f59e0b;
    }

    .modal-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
    }

    .btn-cancel {
        padding: 12px 24px;
        background: transparent;
        color: #6b7280;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
    }

    .btn-create {
        padding: 12px 24px;
        background: #0ea5e9;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
    }

    .btn-create:disabled {
        background: #d1d5db;
        cursor: not-allowed;
    }

    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: #6b7280;
    }

    .empty-state-icon {
        font-size: 64px;
        margin-bottom: 16px;
    }

    .empty-state-text {
        font-size: 18px;
        font-weight: 500;
    }

    /* Model Selector Styles */
    .model-card {
        padding: 16px;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: 12px;
    }

    .model-card:hover {
        border-color: #0ea5e9;
        background: #f0f9ff;
    }

    .model-card.selected {
        border-color: #0ea5e9;
        background: #e0f2fe;
    }

    .model-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
    }

    .model-name {
        font-size: 16px;
        font-weight: 600;
        color: #111827;
    }

    .model-badge {
        padding: 4px 8px;
        background: #10b981;
        color: white;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 600;
    }

    .model-id {
        font-size: 12px;
        color: #6b7280;
        font-family: monospace;
        margin-bottom: 8px;
    }

    .model-description {
        font-size: 13px;
        color: #4b5563;
        line-height: 1.5;
    }
</style>

<div class="consultation-container">
    <!-- Left Sidebar: History -->
    <div class="history-sidebar">
        <div class="history-sidebar-header">
            <h3>CONVERSATIONS</h3>
            <button class="new-consultation-btn" @onclick="ShowNewConversationDialog">+ New</button>
        </div>
        <div class="history-list">
            @if (conversationList.Any())
            {
                @foreach (var conv in conversationList)
                {
                    <div class="history-item @(currentConversation?.Id == conv.Id ? "active" : "")" 
                         @onclick="@(() => LoadConversation(conv.Id))">
                        <div class="history-header">
                            <div class="history-title">@conv.Title</div>
                            @if (conv.UnreadCount > 0)
                            {
                                <span class="unread-badge">@conv.UnreadCount</span>
                            }
                        </div>
                        <div class="history-meta">@FormatTime(conv.LastMessageAt) • @conv.Status</div>
                        @if (conv.IsAiConversation)
                        {
                            <span class="ai-tag">🤖 AI Assistant</span>
                        }
                        else
                        {
                            <span class="ai-tag">👨‍⚕️ @conv.DoctorName</span>
                        }
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: 24px; color: #6b7280;">
                    <p>No conversations yet</p>
                    <p style="font-size: 12px; margin-top: 8px;">Click "+ New" to start</p>
                </div>
            }
        </div>
    </div>

    <!-- Main Chat Area -->
    <div class="chat-area">
        @if (currentConversation != null)
        {
            <!-- Header with Mode Toggle -->
            <div class="chat-header">
                <div class="mode-toggle">
                    <button class="toggle-btn @(isAiMode ? "active" : "")" disabled>
                        <span class="icon">🤖</span> AI Assistant
                    </button>
                    <button class="toggle-btn @(!isAiMode ? "active" : "")" disabled>
                        <span class="icon">👨‍⚕️</span> Human Doctor
                    </button>
                </div>
            </div>

            <!-- Chat Messages -->
            <div class="messages-container" id="messages-container">
                @foreach (var message in messages)
                {
                    <div class="message @(message.SenderType == MessageSenderType.Patient ? "user-message" : 
                                         message.SenderType == MessageSenderType.AI ? "ai-message" : "doctor-message")">
                        <div class="message-avatar">
                            <span class="avatar-icon">
                                @if (message.SenderType == MessageSenderType.Patient)
                                {
                                    @:👤
                                }
                                else if (message.SenderType == MessageSenderType.AI)
                                {
                                    @:🤖
                                }
                                else
                                {
                                    @:👨‍⚕️
                                }
                            </span>
                        </div>
                        <div class="message-content">
                            <div class="message-text">
                                @message.Content
                                <div class="message-time">@message.CreatedAt.ToString("HH:mm")</div>
                            </div>
                        </div>
                    </div>
                }

                @if (isTyping)
                {
                    <div class="message ai-message">
                        <div class="message-avatar">
                            <span class="avatar-icon">🤖</span>
                        </div>
                        <div class="typing-indicator">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                    </div>
                }
            </div>

            <!-- Input Area -->
            <div class="input-area">
                <div class="input-features">
                    <span class="feature-badge">🔒 End-to-end encrypted medical sanctuary</span>
                    <button class="model-selector-btn" @onclick="ShowModelSelector">
                        🤖 @AiAssistantService.CurrentModelName
                    </button>
                </div>
                
                <div class="input-box">
                    <button class="icon-btn">😊</button>
                    <input type="text" 
                           placeholder="Describe your symptoms or ask a question..." 
                           @bind="newMessage"
                           @bind:event="oninput"
                           @onkeydown="HandleKeyPress" />
                    <button class="icon-btn">🎤</button>
                    <button class="send-btn @(string.IsNullOrWhiteSpace(newMessage) ? "disabled" : "")" 
                            @onclick="SendMessage"
                            disabled="@string.IsNullOrWhiteSpace(newMessage)">
                        ➤
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-state-icon">💬</div>
                <div class="empty-state-text">Select a conversation or create a new one</div>
            </div>
        }
    </div>

    <!-- Right Sidebar: Document Context -->
    <div class="context-sidebar">
        <h3>Conversation Info</h3>
        @if (currentConversation != null)
        {
            <p class="context-description">
                @if (currentConversation.AssignedDoctorId == null)
                {
                    <text>AI-powered consultation with intelligent health insights.</text>
                }
                else
                {
                    <text>Consultation with @currentConversation.AssignedDoctor?.DoctorProfile?.FullName</text>
                }
            </p>
            
            <div style="margin-top: 20px;">
                <p style="font-size: 13px; color: #6b7280; margin-bottom: 8px;">
                    <strong>Started:</strong> @currentConversation.StartedAt.ToString("MMM dd, yyyy HH:mm")
                </p>
                <p style="font-size: 13px; color: #6b7280; margin-bottom: 8px;">
                    <strong>Messages:</strong> @currentConversation.TotalMessages
                </p>
                <p style="font-size: 13px; color: #6b7280; margin-bottom: 8px;">
                    <strong>Status:</strong> @currentConversation.Status
                </p>
            </div>
        }
        else
        {
            <p class="context-description">No conversation selected</p>
        }
    </div>
</div>

<!-- New Conversation Modal -->
@if (showNewConversationModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                Start New Consultation
                @if (!isLoadingDoctors && availableDoctors.Any())
                {
                    <div style="font-size: 14px; font-weight: 400; color: #6b7280; margin-top: 8px;">
                        @availableDoctors.Count doctor(s) available for consultation
                    </div>
                }
            </div>
            
            <div class="modal-options">
                <div class="option-card @(selectedDoctorId == null && isAiMode ? "selected" : "")" 
                     @onclick="@(() => { isAiMode = true; selectedDoctorId = null; })">
                    <div class="option-icon">🤖</div>
                    <div class="option-title">AI Assistant</div>
                    <div class="option-description">Instant responses, 24/7 availability</div>
                </div>
                
                <div class="option-card @(!isAiMode ? "selected" : "")" 
                     @onclick="@(() => isAiMode = false)">
                    <div class="option-icon">👨‍⚕️</div>
                    <div class="option-title">Human Doctor</div>
                    <div class="option-description">Professional medical consultation</div>
                </div>
            </div>

            @if (!isAiMode)
            {
                <!-- Search Box -->
                <div style="margin-bottom: 16px;">
                    <div style="position: relative;">
                        <input type="text" 
                               placeholder="Search by name or specialization..." 
                               @bind="doctorSearchQuery"
                               @bind:event="oninput"
                               style="width: 100%; padding: 12px 40px 12px 16px; border: 2px solid #e5e7eb; border-radius: 8px; font-size: 14px; outline: none;" />
                        <span style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); font-size: 18px; color: #9ca3af;">🔍</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(doctorSearchQuery) && filteredDoctors.Any())
                    {
                        <div style="margin-top: 8px; font-size: 12px; color: #6b7280;">
                            Found @filteredDoctors.Count doctor(s)
                        </div>
                    }
                </div>

                <div class="doctor-list">
                    @if (isLoadingDoctors)
                    {
                        <div style="text-align: center; padding: 32px; color: #6b7280;">
                            <div class="typing-indicator" style="margin: 0 auto;">
                                <span></span>
                                <span></span>
                                <span></span>
                            </div>
                            <div style="margin-top: 16px; font-size: 14px;">Loading available doctors...</div>
                        </div>
                    }
                    else if (filteredDoctors.Any())
                    {
                        @foreach (var doctor in filteredDoctors)
                        {
                            <div class="doctor-card @(selectedDoctorId == doctor.UserId ? "selected" : "")"
                                 @onclick="@(() => selectedDoctorId = doctor.UserId)">
                                <div class="doctor-avatar">👨‍⚕️</div>
                                <div class="doctor-info">
                                    <div class="doctor-name">Dr. @doctor.FullName</div>
                                    <div class="doctor-specialty">@doctor.PrimarySpecialization</div>
                                    <div class="doctor-rating">
                                        ⭐ @doctor.AverageRating.ToString("F1") (@doctor.TotalRatings reviews)
                                    </div>
                                    @if (doctor.YearsOfExperience.HasValue)
                                    {
                                        <div style="font-size: 12px; color: #6b7280; margin-top: 4px;">
                                            @doctor.YearsOfExperience years experience
                                        </div>
                                    }
                                    <div style="font-size: 12px; margin-top: 4px;">
                                        <span style="@GetAvailabilityStatusStyle(doctor.AvailabilityStatus)">
                                            @GetAvailabilityStatusText(doctor.AvailabilityStatus)
                                        </span>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else if (!string.IsNullOrWhiteSpace(doctorSearchQuery))
                    {
                        <div style="text-align: center; padding: 32px; color: #6b7280;">
                            <div style="font-size: 48px; margin-bottom: 16px;">🔍</div>
                            <div style="font-size: 16px; font-weight: 500; margin-bottom: 8px;">No doctors found</div>
                            <div style="font-size: 14px;">Try adjusting your search criteria</div>
                        </div>
                    }
                    else
                    {
                        <div style="text-align: center; padding: 32px; color: #6b7280;">
                            <div style="font-size: 48px; margin-bottom: 16px;">👨‍⚕️</div>
                            <div style="font-size: 16px; font-weight: 500; margin-bottom: 8px;">No doctors available</div>
                            <div style="font-size: 14px;">All doctors are currently busy. Please try again later or use AI Assistant.</div>
                        </div>
                    }
                </div>
            }

            <div class="modal-actions">
                <button class="btn-cancel" @onclick="CloseModal">Cancel</button>
                <button class="btn-create" 
                        @onclick="@(() => CreateNewConversation(isAiMode))"
                        disabled="@(!isAiMode && selectedDoctorId == null)">
                    Create Conversation
                </button>
            </div>
        </div>
    </div>
}

<!-- Model Selector Modal -->
@if (showModelSelectorModal)
{
    <div class="modal-overlay" @onclick="CloseModelSelector">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">Select AI Model</div>
            
            <div style="margin-bottom: 16px;">
                <p style="font-size: 14px; color: #6b7280;">
                    Choose the AI model that best fits your needs. Each model has different strengths.
                </p>
            </div>

            <div style="max-height: 400px; overflow-y: auto;">
                @foreach (var model in availableModels)
                {
                    <div class="model-card @(currentModelKey == model.Key ? "selected" : "")"
                         @onclick="@(() => SwitchModel(model.Key))">
                        <div class="model-card-header">
                            <div class="model-name">@model.DisplayName</div>
                            @if (currentModelKey == model.Key)
                            {
                                <span class="model-badge">ACTIVE</span>
                            }
                        </div>
                        <div class="model-id">@model.ModelId</div>
                        <div class="model-description">@model.Description</div>
                    </div>
                }
            </div>

            <div class="modal-actions">
                <button class="btn-cancel" @onclick="CloseModelSelector">Close</button>
            </div>
        </div>
    </div>
}

