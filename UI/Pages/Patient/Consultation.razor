</style>

<div class="consultation-container">
    <!-- Left Sidebar: History -->
    <div class="history-sidebar">
        <div class="history-sidebar-header">
            <h3>CONVERSATIONS</h3>
            <button class="new-consultation-btn" @onclick="ShowNewConversationDialog">
                <span style="font-size: 14px; font-weight: bold;">+</span>
                New
            </button>
        </div>
        <div class="history-list">
            @if (conversationList.Any())
            {
                @foreach (var conv in conversationList)
                {
                    <div class="history-item @(currentConversation?.Id == conv.Id ? "active" : "")" 
                         @onclick="@(() => LoadConversation(conv.Id))">
                        <div class="history-header">
                            <div class="history-title">@conv.Title</div>
                            @if (conv.UnreadCount > 0)
                            {
                                <span class="unread-badge">@conv.UnreadCount</span>
                            }
                        </div>
                        <div class="history-meta">@FormatTime(conv.LastMessageAt) • @conv.Status</div>
                        @if (conv.IsAiConversation)
                        {
                            <span class="ai-tag">
                                <span style="font-size: 11px;">🤖</span>
                                AI Assistant
                            </span>
                        }
                        else
                        {
                            <span class="ai-tag">
                                <span style="font-size: 11px;">🩺</span>
                                @conv.DoctorName
                            </span>
                        }
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: 24px; color: #6b7280;">
                    <div style="font-size: 48px; color: #d1d5db; margin: 0 auto 12px;">📥</div>
                    <p>No conversations yet</p>
                    <p style="font-size: 12px; margin-top: 8px;">Click "New" to start</p>
                </div>
            }
        </div>
    </div>

    <!-- Main Chat Area -->
    <div class="chat-area">
        @if (currentConversation != null)
        {
            <!-- Header -->
            <div class="chat-header" @key="@($"header-{currentConversation.Id}")">
                <div class="chat-header-title">
                    @if (currentConversation.AssignedDoctorId == null)
                    {
                        <span style="font-size: 20px;">🤖</span>
                        <span>AI Assistant</span>
                    }
                    else
                    {
                        <span style="font-size: 20px;">🩺</span>
                        <span>Dr. @(currentConversation.AssignedDoctor?.DoctorProfile?.FullName ?? "Doctor")</span>
                    }
                </div>
            </div>

            <!-- Chat Messages -->
            <div class="messages-container" id="messages-container">
                @foreach (var message in messages)
                {
                    <div class="message @(message.SenderType == MessageSenderType.Patient ? "user-message" : 
                                         message.SenderType == MessageSenderType.AI ? "ai-message" : "doctor-message")">
                        <div class="message-avatar">
                            @if (message.SenderType == MessageSenderType.Patient)
                            {
                                @if (!string.IsNullOrEmpty(patientPhotoUrl))
                                {
                                    <img src="@patientPhotoUrl" alt="User" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" />
                                }
                                else
                                {
                                    <span style="font-size: 20px; color: white;">👤</span>
                                }
                            }
                            else if (message.SenderType == MessageSenderType.AI)
                            {
                                <span style="font-size: 20px; color: white;">🤖</span>
                            }
                            else
                            {
                                <span style="font-size: 20px; color: white;">🩺</span>
                            }
                        </div>
                        <div class="message-content">
                            <div class="message-text">
                                @if (message.SenderType == MessageSenderType.AI || message.SenderType == MessageSenderType.Doctor)
                                {
                                    <MarkdownRenderer Content="@message.Content" />
                                }
                                else
                                {
                                    @message.Content
                                }
                                
                                @* Display attachments if any *@
                                @if (!string.IsNullOrEmpty(message.DocumentReferences))
                                {
                                    var docs = GetMessageDocuments(message.Id);
                                    if (docs.Any())
                                    {
                                        <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(0,0,0,0.1);">
                                            @foreach (var doc in docs)
                                            {
                                                @if (IsImageDocument(doc))
                                                {
                                                    <!-- Image attachment - display inline -->
                                                    <div style="margin-top: 8px;">
                                                        <img src="@GetImageDataUrl(doc)" 
                                                             alt="@doc.FileName" 
                                                             style="max-width: 100%; max-height: 300px; border-radius: 8px; cursor: pointer;"
                                                             @onclick="@(() => DownloadDocument(doc))"
                                                             title="Click to download: @doc.FileName" />
                                                        <div style="font-size: 11px; color: #6b7280; margin-top: 4px;">
                                                            @doc.FileName (@FormatFileSize(doc.FileSizeBytes))
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <!-- Non-image attachment - show download link -->
                                                    <div style="margin-top: 8px; padding: 8px 12px; background: rgba(0,0,0,0.05); border-radius: 8px; display: flex; align-items: center; gap: 8px; cursor: pointer;"
                                                         @onclick="@(() => DownloadDocument(doc))">
                                                        <span style="font-size: 16px; color: #6b7280;">📄</span>
                                                        <div style="flex: 1; min-width: 0;">
                                                            <div style="font-size: 12px; font-weight: 500; color: #111827; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                                @doc.FileName
                                                            </div>
                                                            <div style="font-size: 11px; color: #6b7280;">
                                                                @FormatFileSize(doc.FileSizeBytes)
                                                            </div>
                                                        </div>
                                                        <span style="font-size: 16px; color: #3b82f6;">⬇️</span>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                }
                                
                                <div class="message-time">@message.CreatedAt.ToString("HH:mm")</div>
                            </div>
                        </div>
                    </div>
                }

                @if (isTyping)
                {
                    <div class="message ai-message">
                        <div class="message-avatar">
                            @if (currentConversation.AssignedDoctorId == null)
                            {
                                <span style="font-size: 20px; color: white;">🤖</span>
                            }
                            else
                            {
                                <span style="font-size: 20px; color: white;">🩺</span>
                            }
                        </div>
                        <div class="typing-indicator">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                    </div>
                }
            </div>

            <!-- Input Area -->
            <div class="input-area" @key="@($"input-{currentConversation.Id}")">
                @if (currentConversation.Status == ConversationStatus.Closed)
                {
                    <div class="consultation-closed-banner">
                        <span style="font-size: 18px;">🔒</span>
                        <span>This consultation has been closed by your doctor. You can view messages but cannot send new ones.</span>
                    </div>
                }
                else
                {
                    <div class="input-features">
                        <span class="feature-badge">
                            <span style="font-size: 14px;">🛡️</span>
                            End-to-end encrypted medical sanctuary
                        </span>
                        @if (currentConversation.AssignedDoctorId == null)
                        {
                            <button class="model-selector-btn" @onclick="ShowModelSelector">
                                <span style="font-size: 14px;">🧠</span>
                                @ConsultationFacade.GetCurrentAiModelName()
                            </button>
                        }
                        else
                        {
                            <div style="width: 140px;"></div>
                        }
                    </div>

                    @* Attachments Preview *@
                    @if (attachments.Any())
                    {
                        <div style="display: flex; gap: 8px; margin-bottom: 12px; flex-wrap: wrap;">
                            @foreach (var attachment in attachments)
                            {
                                <div style="position: relative; padding: 8px 12px; background: #f3f4f6; border-radius: 8px; display: flex; align-items: center; gap: 8px; max-width: 200px;">
                                    @if (attachment.PreviewUrl != null)
                                    {
                                        <img src="@attachment.PreviewUrl" alt="@attachment.FileName" style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px;" />
                                    }
                                    else
                                    {
                                        <span style="font-size: 20px; color: #6b7280;">📄</span>
                                    }
                                    <div style="flex: 1; min-width: 0;">
                                        <div style="font-size: 12px; font-weight: 500; color: #111827; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                            @attachment.FileName
                                        </div>
                                        <div style="font-size: 11px; color: #6b7280;">
                                            @FormatFileSize(attachment.FileSize)
                                        </div>
                                    </div>
                                    <button @onclick="@(() => RemoveAttachment(attachment))" 
                                            style="background: transparent; border: none; color: #ef4444; cursor: pointer; padding: 4px; display: flex; align-items: center;">
                                        <span style="font-size: 16px; font-weight: bold;">×</span>
                                    </button>
                                </div>
                            }
                        </div>
                    }

                    @if (isUploadingFile)
                    {
                        <div style="margin-bottom: 12px; padding: 8px; background: #f0f9ff; border-radius: 8px; display: flex; align-items: center; gap: 8px;">
                            <div class="typing-indicator" style="margin: 0;">
                                <span></span>
                                <span></span>
                                <span></span>
                            </div>
                            <span style="font-size: 12px; color: #0ea5e9;">Uploading file...</span>
                        </div>
                    }
                    
                    <div class="input-box">
                        <button class="icon-btn" title="Emoji" @onclick="ToggleEmojiPicker">
                            <span style="font-size: 20px;">😊</span>
                        </button>
                        
                        @if (showEmojiPicker)
                        {
                            <div class="emoji-picker" @onclick:stopPropagation>
                                <div class="emoji-picker-header">
                                    <div class="emoji-tabs">
                                        @foreach (var category in emojiCategories)
                                        {
                                            <button class="emoji-tab @(selectedEmojiCategory == category.Key ? "active" : "")" 
                                                    @onclick="() => SelectEmojiCategory(category.Key)"
                                                    title="@category.Key">
                                                @category.Value[0]
                                            </button>
                                        }
                                    </div>
                                    <button class="emoji-close-btn" @onclick="CloseEmojiPicker" title="Close">✕</button>
                                </div>
                                <div class="emoji-grid">
                                    @foreach (var emoji in GetEmojisForCategory(selectedEmojiCategory))
                                    {
                                        <button class="emoji-btn" @onclick="() => InsertEmoji(emoji)" title="@emoji">
                                            @emoji
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                        
                        <InputFile OnChange="HandleFileSelected" multiple accept="image/*,.pdf,.doc,.docx" id="file-upload" style="display: none;" />
                        <label for="file-upload" class="icon-btn" title="Attach file" style="cursor: pointer; margin: 0;">
                            <span style="font-size: 20px;">📎</span>
                        </label>
                        <input type="text" 
                               placeholder="Describe your symptoms or ask a question..." 
                               @bind="newMessage"
                               @bind:event="oninput"
                               @onkeydown="HandleKeyPress"
                               @ref="messageInputRef" />
                        <button class="send-btn @(string.IsNullOrWhiteSpace(newMessage) && attachments.Count == 0 ? "disabled" : "")" 
                                @onclick="SendMessage"
                                disabled="@(string.IsNullOrWhiteSpace(newMessage) && attachments.Count == 0)"
                                title="Send message">
                            <span style="font-size: 20px;">➤</span>
                        </button>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div style="font-size: 64px; color: #d1d5db; margin-bottom: 16px;">💬</div>
                <div class="empty-state-text">Select a conversation or create a new one</div>
            </div>
        }
    </div>

    <!-- Right Sidebar: Document Context -->
    <div class="context-sidebar">
        <h3>Conversation Info</h3>
        @if (currentConversation != null)
        {
            <p class="context-description">
                @if (currentConversation.AssignedDoctorId == null)
                {
                    <text>AI-powered consultation with intelligent health insights.</text>
                }
                else
                {
                    <text>Consultation with @currentConversation.AssignedDoctor?.DoctorProfile?.FullName</text>
                }
            </p>
            
            <div style="margin-top: 20px;">
                <p style="font-size: 13px; color: #6b7280; margin-bottom: 8px;">
                    <strong>Started:</strong> @currentConversation.StartedAt.ToString("MMM dd, yyyy HH:mm")
                </p>
                <p style="font-size: 13px; color: #6b7280; margin-bottom: 8px;">
                    <strong>Messages:</strong> @currentConversation.TotalMessages
                </p>
                <p style="font-size: 13px; color: #6b7280; margin-bottom: 8px;">
                    <strong>Status:</strong> @currentConversation.Status
                </p>
            </div>

            @* Doctor Rating Display *@
            @if (existingRating != null && currentConversation.AssignedDoctorId != null)
            {
                <div style="margin-top: 24px; padding: 20px; background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%); border-radius: 12px; border: 2px solid #fbbf24;">
                    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
                        <h3 style="font-size: 15px; font-weight: 700; color: #111827; margin: 0; display: flex; align-items: center; gap: 8px;">
                            <span style="font-size: 18px;">⭐</span>
                            Your Rating
                        </h3>
                        <div style="font-size: 20px; font-weight: 800; color: #f59e0b;">
                            @existingRating.Rating<span style="font-size: 14px; color: #6b7280;">/5</span>
                        </div>
                    </div>
                    
                    <div style="display: flex; gap: 4px; margin-bottom: 12px;">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span style="font-size: 18px;">⭐</span>
                        }
                    </div>

                    @if (existingRating.ProfessionalismRating.HasValue || existingRating.CommunicationRating.HasValue || 
                         existingRating.KnowledgeRating.HasValue || existingRating.ResponseTimeRating.HasValue)
                    {
                        <div style="display: flex; flex-direction: column; gap: 6px; padding: 12px; background: white; border-radius: 8px; margin-bottom: 12px;">
                            <p style="font-size: 12px; font-weight: 600; color: #6b7280; margin: 0 0 6px 0;">Detailed Ratings:</p>
                            @if (existingRating.ProfessionalismRating.HasValue)
                            {
                                <div style="display: flex; justify-content: space-between; font-size: 12px;">
                                    <span style="color: #6b7280;">Professionalism</span>
                                    <span style="color: #f59e0b; font-weight: 600;">@existingRating.ProfessionalismRating/5</span>
                                </div>
                            }
                            @if (existingRating.CommunicationRating.HasValue)
                            {
                                <div style="display: flex; justify-content: space-between; font-size: 12px;">
                                    <span style="color: #6b7280;">Communication</span>
                                    <span style="color: #f59e0b; font-weight: 600;">@existingRating.CommunicationRating/5</span>
                                </div>
                            }
                            @if (existingRating.KnowledgeRating.HasValue)
                            {
                                <div style="display: flex; justify-content: space-between; font-size: 12px;">
                                    <span style="color: #6b7280;">Knowledge</span>
                                    <span style="color: #f59e0b; font-weight: 600;">@existingRating.KnowledgeRating/5</span>
                                </div>
                            }
                            @if (existingRating.ResponseTimeRating.HasValue)
                            {
                                <div style="display: flex; justify-content: space-between; font-size: 12px;">
                                    <span style="color: #6b7280;">Response Time</span>
                                    <span style="color: #f59e0b; font-weight: 600;">@existingRating.ResponseTimeRating/5</span>
                                </div>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(existingRating.ReviewText))
                    {
                        <div style="padding: 12px; background: white; border-radius: 8px; margin-bottom: 12px;">
                            <p style="font-size: 12px; font-weight: 600; color: #6b7280; margin: 0 0 6px 0;">Your Review:</p>
                            <p style="font-size: 13px; color: #374151; margin: 0; line-height: 1.5; font-style: italic;">
                                "@existingRating.ReviewText"
                            </p>
                        </div>
                    }

                    <div style="text-align: right; font-size: 11px; color: #9ca3af;">
                        Rated on @existingRating.CreatedAt.ToString("MMM dd, yyyy")
                    </div>
                </div>
            }

            @* AI推荐医生列表 *@
            @if (currentConversation.AssignedDoctorId == null && messages.Count >= 3 && !isLoadingRecommendations)
            {
                <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid #e5e7eb;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                        <h3 style="font-size: 16px; font-weight: 600; color: #111827; margin: 0; display: flex; align-items: center; gap: 8px;">
                            <span style="font-size: 18px;">✨</span>
                            AI Recommendations
                        </h3>
                        @if (!showRecommendedDoctors)
                        {
                            <button @onclick="LoadRecommendedDoctors" 
                                    style="padding: 6px 12px; background: #0ea5e9; color: white; border: none; border-radius: 8px; font-size: 12px; cursor: pointer; display: flex; align-items: center; gap: 4px;">
                                <span style="font-size: 14px;">👁️</span>
                                Show
                            </button>
                        }
                    </div>
                    
                    @if (showRecommendedDoctors)
                    {
                        <p style="font-size: 13px; color: #6b7280; margin-bottom: 16px; line-height: 1.5;">
                            Based on your symptoms, here are recommended specialists:
                        </p>

                        @if (recommendedDoctors.Any())
                        {
                            <div style="display: flex; flex-direction: column; gap: 12px;">
                                @foreach (var doctor in recommendedDoctors.Take(3))
                                {
                                    <div class="recommended-doctor-card" @onclick="@(() => ShowDoctorDetails(doctor))">
                                        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                                            <div style="width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                                <span style="font-size: 24px;">👤</span>
                                            </div>
                                            <div style="flex: 1; min-width: 0;">
                                                <div style="font-size: 14px; font-weight: 600; color: #111827; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                    Dr. @doctor.FullName
                                                </div>
                                                <div style="font-size: 12px; color: #6b7280; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                    @doctor.PrimarySpecialization
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
                                            <div style="font-size: 11px; color: #f59e0b; font-weight: 500; display: flex; align-items: center; gap: 4px;">
                                                <span style="font-size: 18px;">⭐</span>
                                                @doctor.AverageRating.ToString("F1")
                                            </div>
                                            <div style="font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 12px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                                                @doctor.MatchScore.ToString("F0")% Match
                                            </div>
                                        </div>

                                        @if (doctor.MatchReasons.Any())
                                        {
                                            <div style="font-size: 11px; color: #10b981; margin-bottom: 8px; display: flex; align-items: start; gap: 4px;">
                                                <span style="font-size: 12px;">✓</span>
                                                <span>@doctor.MatchReasons.First()</span>
                                            </div>
                                        }

                                        <button @onclick="@(() => StartConsultationWithDoctor(doctor.UserId))" 
                                                @onclick:stopPropagation="true"
                                                style="width: 100%; padding: 8px; background: #0ea5e9; color: white; border: none; border-radius: 6px; font-size: 12px; font-weight: 500; cursor: pointer; transition: background 0.2s;">
                                            Consult Now
                                        </button>
                                    </div>
                                }
                            </div>

                            @if (recommendedDoctors.Count > 3)
                            {
                                <button @onclick="ShowAllRecommendedDoctors" 
                                        style="width: 100%; margin-top: 12px; padding: 8px; background: transparent; color: #0ea5e9; border: 1px solid #0ea5e9; border-radius: 6px; font-size: 12px; font-weight: 500; cursor: pointer;">
                                    View All (@recommendedDoctors.Count)
                                </button>
                            }
                        }
                        else
                        {
                            <div style="text-align: center; padding: 16px; color: #6b7280; font-size: 13px;">
                                <span style="font-size: 32px;">🔍</span>
                                <div>No recommendations yet</div>
                            </div>
                        }
                    }
                </div>
            }
                
            @if (isLoadingRecommendations)
            {
                <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid #e5e7eb;">
                    <div style="text-align: center; padding: 24px; color: #6b7280;">
                        <div class="typing-indicator" style="margin: 0 auto 12px;">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                        <div style="font-size: 13px;">Finding best doctors for you...</div>
                    </div>
                </div>
            }

            <!-- Medical Records Section (Patient View) -->
            @if (currentConversation != null)
            {
                <div style="margin-top: 24px; padding-top: 20px; border-top: 2px solid #e5e7eb;">
                    <h3 style="font-size: 16px; font-weight: 600; color: #111827; margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
                        <span style="font-size: 18px;">📄</span>
                        Medical Records
                    </h3>
                    <p style="font-size: 12px; color: #6b7280; margin-bottom: 16px;">
                        Click any record to view details
                    </p>
                    
                    @if (isLoadingRecords)
                    {
                        <div style="text-align: center; padding: 16px; color: #6b7280;">
                            <p style="font-size: 12px;">Loading records...</p>
                        </div>
                    }
                    else if (relatedPrescriptions.Any() || relatedConsultationNotes.Any())
                    {
                        <!-- Consultation Notes -->
                        @if (relatedConsultationNotes.Any())
                        {
                            <div class="record-section">
                                <div class="record-section-header">
                                    <span style="font-size: 14px;">🩺</span>
                                    <span>Consultation Notes (@relatedConsultationNotes.Count)</span>
                                </div>
                                @foreach (var note in relatedConsultationNotes.Take(3))
                                {
                                    <div class="record-card" @onclick="@(() => PreviewConsultationNote(note))">
                                        <div class="record-card-header">
                                            <span class="record-badge note">NOTE</span>
                                            <span class="record-date">@note.CreatedAt.ToString("MMM dd")</span>
                                        </div>
                                        <div class="record-card-body">
                                            <p class="record-diagnosis">@note.Diagnosis</p>
                                            @if (!string.IsNullOrEmpty(note.TreatmentPlan))
                                            {
                                                <p class="record-detail">Plan: @TruncateText(note.TreatmentPlan, 60)</p>
                                            }
                                            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 6px;">
                                                @if (note.IsFinalized)
                                                {
                                                    <span class="finalized-badge">
                                                        <span style="font-size: 12px;">✓</span>
                                                        Finalized
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span></span>
                                                }
                                                <span class="last-updated-text">Updated @note.UpdatedAt.ToString("MMM dd, HH:mm")</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                                @if (relatedConsultationNotes.Count > 3)
                                {
                                    <p style="font-size: 11px; color: #6b7280; text-align: center; margin-top: 8px;">
                                        +@(relatedConsultationNotes.Count - 3) more notes
                                    </p>
                                }
                            </div>
                        }

                        <!-- Prescriptions -->
                        @if (relatedPrescriptions.Any())
                        {
                            <div class="record-section">
                                <div class="record-section-header">
                                    <span style="font-size: 14px;">💊</span>
                                    <span>Prescriptions (@relatedPrescriptions.Count)</span>
                                </div>
                                @foreach (var rx in relatedPrescriptions.Take(3))
                                {
                                    <div class="record-card" @onclick="@(() => PreviewPrescription(rx))">
                                        <div class="record-card-header">
                                            <span class="record-badge @(rx.IsActive ? "active" : "inactive")">
                                                @(rx.IsActive ? "ACTIVE" : "INACTIVE")
                                            </span>
                                            <span class="record-date">@rx.CreatedAt.ToString("MMM dd")</span>
                                        </div>
                                        <div class="record-card-body">
                                            <p class="record-medication">@rx.MedicationName</p>
                                            <p class="record-detail">@rx.Dosage • @rx.Frequency</p>
                                            @if (!string.IsNullOrEmpty(rx.Duration))
                                            {
                                                <p class="record-detail">Duration: @rx.Duration</p>
                                            }
                                            <span class="last-updated-text" style="margin-top: 6px; display: block;">Updated @rx.UpdatedAt.ToString("MMM dd, HH:mm")</span>
                                        </div>
                                    </div>
                                }
                                @if (relatedPrescriptions.Count > 3)
                                {
                                    <p style="font-size: 11px; color: #6b7280; text-align: center; margin-top: 8px;">
                                        +@(relatedPrescriptions.Count - 3) more prescriptions
                                    </p>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div style="text-align: center; padding: 16px; color: #9ca3af;">
                            <span style="font-size: 32px;">📥</span>
                            <p style="font-size: 12px;">No medical records yet</p>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <p class="context-description">No conversation selected</p>
        }
    </div>
</div>

<!-- Rating Dialog -->
@if (showRatingDialog && currentConversation != null)
{
    <div class="modal-overlay">
        <div class="modal-content rating-modal">
            <div class="rating-modal-header">
                <h2>Rate Your Consultation</h2>
                <button class="close-btn" @onclick="CloseRatingDialog">
                    <span style="font-size: 20px; font-weight: bold;">×</span>
                </button>
            </div>

            <div class="rating-content">
                <div class="rating-intro">
                    <div class="rating-icon-circle">
                        <span style="font-size: 18px;">⭐</span>
                    </div>
                    <p class="rating-description">
                        How was your experience with Dr. @(currentConversation.AssignedDoctor?.DoctorProfile?.FullName)?
                    </p>
                    <p class="rating-subdescription">Your feedback helps us maintain quality care</p>
                </div>

                <!-- Overall Rating Card -->
                <div class="rating-card primary">
                    <div class="rating-card-header">
                        <h3>Overall Rating</h3>
                        <span class="required-badge">Required</span>
                    </div>
                    
                    <!-- Clickable Rating Buttons -->
                    <div class="rating-buttons-row">
                        @for (int i = 1; i <= 5; i++)
                        {
                            var ratingValue = i;
                            var isSelected = selectedRating == ratingValue;
                            <button type="button" 
                                    class="rating-btn @(isSelected ? "selected" : "")"
                                    @onclick="@(() => SetOverallRating(ratingValue))">
                                <div class="rating-btn-content">
                                    <span class="rating-number">@ratingValue</span>
                                    <span style="font-size: 18px;">⭐</span>
                                </div>
                            </button>
                        }
                    </div>

                    <!-- Descriptive Labels -->
                    <div class="rating-descriptions">
                        <span class="rating-desc-item">😞 Poor</span>
                        <span class="rating-desc-item">😐 Fair</span>
                        <span class="rating-desc-item">🙂 Good</span>
                        <span class="rating-desc-item">😊 Very Good</span>
                        <span class="rating-desc-item">🤩 Excellent</span>
                    </div>

                    @if (selectedRating > 0)
                    {
                        <div class="rating-feedback">
                            <span style="font-size: 12px;">✓</span>
                            <span>You rated <strong>@GetRatingText(selectedRating)</strong> (@selectedRating out of 5 stars)</span>
                        </div>
                    }
                    else
                    {
                        <div class="rating-hint">
                            <span style="font-size: 16px;">👆</span>
                            <span>Click a number to rate your experience</span>
                        </div>
                    }
                </div>

                <!-- Detailed Ratings Card -->
                <div class="rating-card secondary">
                    <div class="rating-card-header">
                        <h3>Detailed Feedback</h3>
                        <span class="optional-badge">Optional</span>
                    </div>
                    <p class="card-description">Help us understand specific aspects of your experience</p>

                    <div class="detailed-ratings-grid">
                    
                    <div class="rating-section-inline">
                        <div class="rating-section-left">
                            <span style="font-size: 20px;">👤</span>
                            <label class="rating-label">Professionalism</label>
                        </div>
                        <div class="rating-buttons-row small">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var ratingValue = i;
                                var isSelected = professionalismRating == ratingValue;
                                <button type="button" 
                                        class="rating-btn small @(isSelected ? "selected" : "")"
                                        @onclick="@(() => SetProfessionalismRating(ratingValue))">
                                    <span>@ratingValue</span>
                                </button>
                            }
                        </div>
                    </div>

                    <div class="rating-section-inline">
                        <div class="rating-section-left">
                            <span style="font-size: 20px;">💬</span>
                            <label class="rating-label">Communication</label>
                        </div>
                        <div class="rating-buttons-row small">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var ratingValue = i;
                                var isSelected = communicationRating == ratingValue;
                                <button type="button" 
                                        class="rating-btn small @(isSelected ? "selected" : "")"
                                        @onclick="@(() => SetCommunicationRating(ratingValue))">
                                    <span>@ratingValue</span>
                                </button>
                            }
                        </div>
                    </div>

                    <div class="rating-section-inline">
                        <div class="rating-section-left">
                            <span style="font-size: 20px;">🧠</span>
                            <label class="rating-label">Knowledge</label>
                        </div>
                        <div class="rating-buttons-row small">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var ratingValue = i;
                                var isSelected = knowledgeRating == ratingValue;
                                <button type="button" 
                                        class="rating-btn small @(isSelected ? "selected" : "")"
                                        @onclick="@(() => SetKnowledgeRating(ratingValue))">
                                    <span>@ratingValue</span>
                                </button>
                            }
                        </div>
                    </div>

                    <div class="rating-section-inline">
                        <div class="rating-section-left">
                            <span style="font-size: 20px;">⏰</span>
                            <label class="rating-label">Response Time</label>
                        </div>
                        <div class="rating-buttons-row small">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var ratingValue = i;
                                var isSelected = responseTimeRating == ratingValue;
                                <button type="button" 
                                        class="rating-btn small @(isSelected ? "selected" : "")"
                                        @onclick="@(() => SetResponseTimeRating(ratingValue))">
                                    <span>@ratingValue</span>
                                </button>
                            }
                        </div>
                    </div>
                    
                    </div>
                </div>

                <!-- Review Text Card -->
                <div class="rating-card">
                    <div class="rating-card-header">
                        <h3>Your Review</h3>
                        <span class="optional-badge">Optional</span>
                    </div>
                    <p class="card-description">Share more details about your experience</p>
                    <textarea class="review-textarea" 
                              @bind="reviewText" 
                              placeholder="Share your experience..."
                              rows="4"></textarea>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="error-banner">
                        <span style="font-size: 18px;">⚠️</span>
                        @errorMessage
                    </div>
                }

                <!-- Actions -->
                <div class="modal-actions">
                    <button class="btn-cancel" @onclick="CloseRatingDialog">Skip</button>
                    <button class="btn-submit-rating" 
                            @onclick="SubmitRating" 
                            disabled="@isSubmittingRating">
                        @if (isSubmittingRating)
                        {
                            <span>Submitting...</span>
                        }
                        else
                        {
                            <span>Submit Rating</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

