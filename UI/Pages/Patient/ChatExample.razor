@page "/patient/chat"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout Components.Layout.SidebarLayout
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>AI Clinic - Chat</PageTitle>

@code {
    public void Dispose()
    {
        // Cleanup if needed
    }
}

<link rel="stylesheet" href="/css/stitch-design-system.css" />

@if (!AuthController.IsAuthenticated())
{
    <div class="auth-checking">
        <div class="spinner"></div>
        <p>Checking authentication...</p>
    </div>
}
else
{
<div class="chat-example-container">
    <div class="chat-header">
        <div class="header-info">
            <h2>AI Clinic Consultation</h2>
            @if (currentConversation != null && currentConversation.AssignedDoctorId != null)
            {
                <span class="doctor-badge">
                    <i data-lucide="user-check"></i>
                    Doctor Assigned
                </span>
            }
            else
            {
                <span class="ai-badge">
                    <i data-lucide="bot"></i>
                    AI Assistant
                </span>
            }
        </div>
        @if (currentConversation != null)
        {
            <div class="conversation-stats">
                <span class="stat-item">
                    <i data-lucide="message-circle"></i>
                    @currentConversation.TotalMessages messages
                </span>
                <span class="stat-item">
                    <i data-lucide="clock"></i>
                    Started @currentConversation.StartedAt.ToString("MMM dd, HH:mm")
                </span>
            </div>
        }
    </div>

    <div class="messages-area" @ref="messagesContainer">
        @if (isLoadingConversation)
        {
            <div class="loading">
                <div class="spinner"></div>
                <p>Loading conversation...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-state">
                <i data-lucide="alert-circle"></i>
                <p>@errorMessage</p>
                <button class="btn btn-primary" @onclick="LoadConversation">
                    <i data-lucide="refresh-cw"></i>
                    Retry
                </button>
            </div>
        }
        else if (currentConversation == null)
        {
            <div class="empty-state">
                <i data-lucide="message-square"></i>
                <h3>Start a New Conversation</h3>
                <p>Send a message to begin your consultation with our AI assistant</p>
            </div>
        }
        else if (!messages.Any())
        {
            <div class="empty-state">
                <i data-lucide="sparkles"></i>
                <h3>Welcome to AI Clinic</h3>
                <p>How can I help you today? Describe your symptoms or health concerns.</p>
            </div>
        }
        else
        {
            @foreach (var message in messages)
            {
                <div class="message @GetMessageClass(message)">
                    <div class="message-avatar">
                        @if (message.SenderType == MessageSenderType.Patient)
                        {
                            <i data-lucide="user"></i>
                        }
                        else if (message.SenderType == MessageSenderType.Doctor)
                        {
                            <i data-lucide="stethoscope"></i>
                        }
                        else if (message.SenderType == MessageSenderType.AI)
                        {
                            <i data-lucide="bot"></i>
                        }
                        else
                        {
                            <i data-lucide="info"></i>
                        }
                    </div>
                    <div class="message-bubble">
                        <div class="message-header">
                            <span class="message-sender">@GetSenderName(message)</span>
                            <span class="message-time">@message.SentAt.ToString("HH:mm")</span>
                        </div>
                        <div class="message-content">
                            @message.Content
                        </div>
                        @if (message.AiConfidenceScore != null)
                        {
                            <div class="ai-confidence">
                                <i data-lucide="zap"></i>
                                Confidence: @((message.AiConfidenceScore * 100).Value.ToString("F0"))%
                            </div>
                        }
                    </div>
                </div>
            }
            @if (isSendingMessage)
            {
                <div class="message typing-indicator">
                    <div class="message-avatar">
                        <i data-lucide="bot"></i>
                    </div>
                    <div class="message-bubble">
                        <div class="typing-dots">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="input-area">
        <textarea 
            class="message-input" 
            placeholder="Type your message... (Press Enter to send, Shift+Enter for new line)" 
            @bind="messageInput"
            @onkeydown="HandleKeyDown"
            rows="1"
            disabled="@isSendingMessage"></textarea>
        
        <button 
            class="send-button" 
            @onclick="SendMessage"
            disabled="@(string.IsNullOrWhiteSpace(messageInput) || isSendingMessage)">
            @if (isSendingMessage)
            {
                <div class="button-spinner"></div>
            }
            else
            {
                <i data-lucide="send"></i>
            }
        </button>
    </div>

    <div class="actions-area">
        @if (currentConversation != null && currentConversation.AssignedDoctorId == null)
        {
            <button class="action-button" @onclick="RequestDoctor" disabled="@isRequestingDoctor">
                <i data-lucide="user-plus"></i>
                @(isRequestingDoctor ? "Requesting..." : "Request Human Doctor")
            </button>
        }
        <button class="action-button secondary" @onclick="LoadConversation" disabled="@isLoadingConversation">
            <i data-lucide="refresh-cw"></i>
            Refresh
        </button>
        @if (currentConversation != null)
        {
            <button class="action-button secondary" @onclick="CreateNewConversation">
                <i data-lucide="plus-circle"></i>
                New Conversation
            </button>
        }
    </div>
</div>
}

<style>
    .auth-checking {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 400px;
        gap: 1rem;
    }

    .spinner {
        width: 48px;
        height: 48px;
        border: 4px solid #e6e8ea;
        border-top-color: #0052cc;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .chat-example-container {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        height: calc(100vh - 120px);
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(25, 28, 30, 0.08);
        overflow: hidden;
    }

    .chat-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 2rem;
        background: linear-gradient(135deg, #0052cc 0%, #003d9b 100%);
        color: white;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .header-info {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .chat-header h2 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 700;
        font-family: 'Manrope', sans-serif;
    }

    .doctor-badge, .ai-badge {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 20px;
        font-size: 0.875rem;
        font-weight: 600;
    }

    .conversation-stats {
        display: flex;
        gap: 1.5rem;
        font-size: 0.875rem;
        opacity: 0.9;
    }

    .stat-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .messages-area {
        flex: 1;
        overflow-y: auto;
        padding: 2rem;
        background: #f7f9fb;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .loading, .error-state, .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 3rem 2rem;
        gap: 1rem;
        color: #434654;
    }

    .error-state {
        color: #d32f2f;
    }

    .error-state i, .empty-state i {
        font-size: 3rem;
        opacity: 0.5;
    }

    .empty-state h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
        margin: 0;
    }

    .empty-state p {
        color: #434654;
        max-width: 400px;
    }

    .message {
        display: flex;
        gap: 1rem;
        max-width: 80%;
        animation: slideIn 0.3s ease-out;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .patient-message {
        align-self: flex-end;
        flex-direction: row-reverse;
    }

    .doctor-message, .ai-message, .system-message {
        align-self: flex-start;
    }

    .message-avatar {
        width: 40px;
        height: 40px;
        min-width: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
    }

    .patient-message .message-avatar {
        background: #0052cc;
        color: white;
    }

    .doctor-message .message-avatar {
        background: #8b5cf6;
        color: white;
    }

    .ai-message .message-avatar {
        background: #76f3ea;
        color: #006a65;
    }

    .system-message .message-avatar {
        background: #e6e8ea;
        color: #434654;
    }

    .message-bubble {
        flex: 1;
        padding: 1rem 1.25rem;
        border-radius: 16px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    }

    .patient-message .message-bubble {
        background: #0052cc;
        color: white;
        border-bottom-right-radius: 4px;
    }

    .doctor-message .message-bubble {
        background: white;
        color: #191c1e;
        border-bottom-left-radius: 4px;
    }

    .ai-message .message-bubble {
        background: white;
        color: #191c1e;
        border-bottom-left-radius: 4px;
        border-left: 3px solid #76f3ea;
    }

    .system-message .message-bubble {
        background: #f7f9fb;
        color: #434654;
        border-left: 3px solid #e6e8ea;
    }

    .message-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
    }

    .message-sender {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        opacity: 0.8;
    }

    .message-time {
        font-size: 0.75rem;
        opacity: 0.6;
    }

    .message-content {
        font-size: 0.9375rem;
        line-height: 1.6;
        white-space: pre-wrap;
        word-wrap: break-word;
    }

    .ai-confidence {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.75rem;
        padding-top: 0.75rem;
        border-top: 1px solid #e6e8ea;
        font-size: 0.75rem;
        color: #434654;
    }

    .typing-indicator {
        opacity: 0.7;
    }

    .typing-dots {
        display: flex;
        gap: 0.375rem;
        padding: 0.5rem 0;
    }

    .typing-dots span {
        width: 8px;
        height: 8px;
        background: #434654;
        border-radius: 50%;
        animation: typing 1.4s infinite;
    }

    .typing-dots span:nth-child(2) {
        animation-delay: 0.2s;
    }

    .typing-dots span:nth-child(3) {
        animation-delay: 0.4s;
    }

    @@keyframes typing {
        0%, 60%, 100% {
            transform: translateY(0);
            opacity: 0.7;
        }
        30% {
            transform: translateY(-10px);
            opacity: 1;
        }
    }

    .input-area {
        display: flex;
        gap: 1rem;
        padding: 1.5rem 2rem;
        background: white;
        border-top: 1px solid #e6e8ea;
    }

    .message-input {
        flex: 1;
        padding: 1rem 1.25rem;
        border: 2px solid #e6e8ea;
        border-radius: 12px;
        font-size: 0.9375rem;
        font-family: 'Inter', sans-serif;
        outline: none;
        resize: none;
        max-height: 120px;
        transition: all 0.2s;
    }

    .message-input:focus {
        border-color: #0052cc;
        box-shadow: 0 0 0 3px rgba(0, 82, 204, 0.1);
    }

    .message-input:disabled {
        background: #f7f9fb;
        cursor: not-allowed;
        opacity: 0.6;
    }

    .send-button {
        width: 56px;
        height: 56px;
        min-width: 56px;
        background: #0052cc;
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 1.25rem;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .send-button:hover:not(:disabled) {
        background: #003d9b;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 82, 204, 0.3);
    }

    .send-button:disabled {
        background: #d1d5db;
        cursor: not-allowed;
        transform: none;
    }

    .button-spinner {
        width: 20px;
        height: 20px;
        border: 3px solid rgba(255, 255, 255, 0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    .actions-area {
        display: flex;
        gap: 1rem;
        padding: 1rem 2rem 1.5rem;
        background: white;
        border-top: 1px solid #e6e8ea;
    }

    .action-button {
        flex: 1;
        padding: 0.75rem 1.5rem;
        background: #0052cc;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .action-button:hover:not(:disabled) {
        background: #003d9b;
        transform: translateY(-1px);
    }

    .action-button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
    }

    .action-button.secondary {
        background: #e6e8ea;
        color: #191c1e;
    }

    .action-button.secondary:hover:not(:disabled) {
        background: #d8dadc;
    }

    .btn {
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-primary {
        background: #0052cc;
        color: white;
    }

    .btn-primary:hover {
        background: #003d9b;
        transform: translateY(-1px);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .chat-example-container {
            height: calc(100vh - 80px);
            border-radius: 0;
        }

        .chat-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }

        .conversation-stats {
            flex-direction: column;
            gap: 0.5rem;
        }

        .message {
            max-width: 90%;
        }

        .actions-area {
            flex-direction: column;
        }
    }
</style>
