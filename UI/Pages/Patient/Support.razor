        text-align: center;
        cursor: pointer;
        transition: all 0.2s;
    }

    .action-card:hover {
        background: #eceef0;
        transform: translateY(-4px);
    }

    .action-icon {
        width: 48px;
        height: 48px;
        background: #76f3ea;
        border-radius: 12px;
