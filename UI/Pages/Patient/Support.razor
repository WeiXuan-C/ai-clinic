        border-radius: 16px;
    }

    .quick-actions-section h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
        margin-bottom: 1.5rem;
    }

    .actions-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
    }

    .action-card {
        padding: 1.5rem;
        background: #f7f9fb;
