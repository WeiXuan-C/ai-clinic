@page "/patient/support"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout Components.Layout.SidebarLayout

<PageTitle>Support - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>Help & Support</h1>
        <p class="body-md" style="margin: 0.5rem;">
            <span class="status-indicator">●</span>
            We're here to help 24/7
        </p>
    </div>
    <div class="header-right">
        <button class="btn btn-primary">
            <i data-lucide="ticket"></i>
            My Tickets (3)
        </button>
    </div>
</header>

<!-- Content Grid -->
<div class="content-grid">
    <!-- Quick Actions -->
    <section class="quick-actions-section">
        <h2 class="headline-md">Quick Actions</h2>
        <div class="actions-grid">
            <div class="action-card">
                <i data-lucide="message-square" class="action-icon"></i>
                <h3 class="headline-sm">Live Chat</h3>
                <p class="body-sm">Chat with our support team</p>
            </div>
            <div class="action-card">
                <i data-lucide="phone" class="action-icon"></i>
                <h3 class="headline-sm">Call Us</h3>
                <p class="body-sm">1-800-AI-CLINIC</p>
            </div>
            <div class="action-card">
                <i data-lucide="mail" class="action-icon"></i>
                <h3 class="headline-sm">Email</h3>
                <p class="body-sm">support@aiclinic.com</p>
            </div>
            <div class="action-card">
                <i data-lucide="book-open" class="action-icon"></i>
                <h3 class="headline-sm">Help Center</h3>
                <p class="body-sm">Browse articles & guides</p>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
        <div class="section-header">
            <h2 class="headline-md">Frequently Asked Questions</h2>
            <div class="search-box">
                <i data-lucide="search"></i>
                <input type="text" placeholder="Search FAQs..." />
            </div>
        </div>
        
        <div class="faq-list">
            <div class="faq-item">
                <div class="faq-question">
                    <h4 class="headline-sm">How do I schedule an appointment?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">You can schedule an appointment by clicking on "Book Doctor Visit" from your dashboard or navigating to the Consultation page. Select your preferred doctor, date, and time slot.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <h4 class="headline-sm">How do I access my medical records?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">Navigate to the "Medical Records" section from the sidebar menu. You can view, download, and share your records securely from there.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <h4 class="headline-sm">Is my health data secure?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">Yes, we use bank-level encryption and are fully HIPAA compliant. Your data is encrypted both in transit and at rest, and we never share your information without your explicit consent.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <h4 class="headline-sm">How does the AI assistant work?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">Our AI assistant uses advanced machine learning to analyze your symptoms and health data. It provides preliminary assessments but always recommends consulting with a licensed physician for diagnosis and treatment.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <h4 class="headline-sm">Can I connect my wearable devices?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">Yes! We support Apple Watch, Fitbit, Garmin, and other popular wearables. Go to Settings > Connected Devices to link your devices.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <h4 class="headline-sm">What insurance plans do you accept?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">We accept most major insurance plans including Blue Cross Blue Shield, Aetna, UnitedHealthcare, Cigna, and Medicare. Contact our billing department for specific plan verification.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Form -->
    <section class="contact-form-section">
        <div class="section-header">
            <h2 class="headline-md">Create Support Ticket</h2>
            <p class="body-sm">We typically respond within 24 hours</p>
        </div>
        
        <!-- Create Ticket Form -->
        <form class="contact-form">
            <div class="form-group">
                <label class="body-sm">Subject *</label>
                <input type="text" 
                       class="form-input" 
                       placeholder="Brief description of your issue"
                       required />
            </div>

            <div class="form-group">
                <label class="body-sm">Category</label>
                <select class="form-input">
                    <option value="">Select a category...</option>
                    <option value="technical">Technical Support</option>
                    <option value="billing">Billing Question</option>
                    <option value="appointment">Appointment Issue</option>
                    <option value="records">Medical Records</option>
                    <option value="general">General Inquiry</option>
                    <option value="feedback">Feedback</option>
                </select>
            </div>
            
            <div class="form-group">
                <label class="body-sm">Priority *</label>
                <div class="priority-options">
                    <label class="radio-option">
                        <input type="radio" name="priority" value="low" checked />
                        <span>Low</span>
                    </label>
                    <label class="radio-option">
                        <input type="radio" name="priority" value="medium" />
                        <span>Medium</span>
                    </label>
                    <label class="radio-option">
                        <input type="radio" name="priority" value="high" />
                        <span>High</span>
                    </label>
                    <label class="radio-option">
                        <input type="radio" name="priority" value="urgent" />
                        <span>Urgent</span>
                    </label>
                </div>
            </div>

            <div class="form-group">
                <label class="body-sm">Description *</label>
                <textarea class="form-input" 
                          rows="6" 
                          placeholder="Describe your issue or question in detail..."
                          required></textarea>
            </div>

            <button type="submit" class="btn btn-primary">
                <i data-lucide="send"></i>
                <span>Create Ticket</span>
            </button>
        </form>
    </section>

    <!-- Support Resources -->
    <section class="resources-section">
        <h2 class="headline-md">Support Resources</h2>
        <div class="resources-list">
            <a href="#" class="resource-item">
                <i data-lucide="book" class="resource-icon"></i>
                <div class="resource-info">
                    <h4 class="headline-sm">User Guide</h4>
                    <p class="body-sm">Complete guide to using the platform</p>
                </div>
                <i data-lucide="arrow-right" class="arrow-icon"></i>
            </a>
            <a href="#" class="resource-item">
                <i data-lucide="video" class="resource-icon"></i>
                <div class="resource-info">
                    <h4 class="headline-sm">Video Tutorials</h4>
                    <p class="body-sm">Step-by-step video instructions</p>
                </div>
                <i data-lucide="arrow-right" class="arrow-icon"></i>
            </a>
            <a href="#" class="resource-item">
                <i data-lucide="shield-check" class="resource-icon"></i>
                <div class="resource-info">
                    <h4 class="headline-sm">Privacy & Security</h4>
                    <p class="body-sm">Learn about data protection</p>
                </div>
                <i data-lucide="arrow-right" class="arrow-icon"></i>
            </a>
            <a href="#" class="resource-item">
                <i data-lucide="file-text" class="resource-icon"></i>
                <div class="resource-info">
                    <h4 class="headline-sm">Terms of Service</h4>
                    <p class="body-sm">Read our terms and conditions</p>
                </div>
                <i data-lucide="arrow-right" class="arrow-icon"></i>
            </a>
        </div>
    </section>

    <!-- System Status -->
    <section class="status-section">
        <div class="section-header">
            <h2 class="headline-md">System Status</h2>
            <span class="badge badge-success">ALL SYSTEMS OPERATIONAL</span>
        </div>
        <div class="status-list">
            <div class="status-item">
                <div class="status-indicator operational"></div>
                <span class="body-md">Patient Portal</span>
                <span class="status-label">Operational</span>
            </div>
            <div class="status-item">
                <div class="status-indicator operational"></div>
                <span class="body-md">AI Assistant</span>
                <span class="status-label">Operational</span>
            </div>
            <div class="status-item">
                <div class="status-indicator operational"></div>
                <span class="body-md">Appointment Booking</span>
                <span class="status-label">Operational</span>
            </div>
            <div class="status-item">
                <div class="status-indicator operational"></div>
                <span class="body-md">Medical Records</span>
                <span class="status-label">Operational</span>
            </div>
        </div>
    </section>
</div>

<style>
    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2rem;
    }

    .header-left h1 {
        font-size: 2rem;
        font-weight: 700;
        color: #191c1e;
        margin: 0.5rem;
        font-family: 'Manrope', sans-serif;
    }

    .header-left p {
        color: #434654;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .status-indicator {
        color: #76f3ea;
        font-size: 0.75rem;
    }

    .header-right {
        display: flex;
        gap: 1rem;
    }

    .content-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 2rem;
    }

    /* Quick Actions */
    .quick-actions-section {
        grid-column: span 2;
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .quick-actions-section h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
        margin-bottom: 1.5rem;
    }

    .actions-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
    }

    .action-card {
        padding: 1.5rem;
        background: #f7f9fb;
        border-radius: 12px;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s;
    }

    .action-card:hover {
        background: #eceef0;
        transform: translateY(-4px);
    }

    .action-icon {
        width: 48px;
        height: 48px;
        background: #76f3ea;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: #006a65;
        margin: 0 auto 1rem;
    }

    .action-card h3 {
        font-size: 1rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.5rem;
    }

    .action-card p {
        color: #434654;
        font-size: 0.875rem;
    }

    /* FAQ Section */
    .faq-section {
        grid-column: span 1;
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.75rem;
    }

    .section-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
    }

    .section-header p {
        color: #434654;
    }

    .search-box {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        background: #f7f9fb;
        border-radius: 8px;
        min-width: 250px;
    }

    .search-box input {
        border: none;
        background: transparent;
        outline: none;
        font-size: 0.875rem;
        width: 100%;
    }

    .faq-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .faq-item {
        border: 1px solid #e6e8ea;
        border-radius: 12px;
        overflow: hidden;
    }

    .faq-question {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem;
        background: #f7f9fb;
        cursor: pointer;
        transition: background 0.2s;
    }

    .faq-question:hover {
        background: #eceef0;
    }

    .faq-question h4 {
        font-size: 1rem;
        font-weight: 600;
        color: #191c1e;
    }

    .faq-icon {
        color: #434654;
        transition: transform 0.3s;
    }

    .faq-answer {
        padding: 1.25rem;
        background: white;
        border-top: 1px solid #e6e8ea;
    }

    .faq-answer p {
        color: #434654;
        line-height: 1.6;
    }

    /* Contact Form */
    .contact-form-section {
        grid-column: span 1;
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .contact-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-group label {
        color: #434654;
        font-weight: 500;
    }

    .form-input {
        padding: 0.875rem 1rem;
        border: 1px solid #e6e8ea;
        border-radius: 8px;
        font-size: 0.9375rem;
        font-family: 'Inter', sans-serif;
        transition: all 0.2s;
    }

    .form-input:focus {
        outline: none;
        border-color: #0052cc;
        box-shadow: 0 0 0 3px rgba(0, 82, 204, 0.1);
    }

    textarea.form-input {
        resize: vertical;
    }

    .priority-options {
        display: flex;
        gap: 1rem;
    }

    .radio-option {
        flex: 1;
        padding: 0.75rem;
        border: 2px solid #e6e8ea;
        border-radius: 8px;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s;
    }

    .radio-option input {
        display: none;
    }

    .radio-option span {
        font-size: 0.875rem;
        font-weight: 500;
        color: #434654;
    }

    .radio-option:has(input:checked) {
        border-color: #0052cc;
        background: #e3f2fd;
    }

    .radio-option:has(input:checked) span {
        color: #0052cc;
    }

    .file-upload {
        padding: 2rem;
        border: 2px dashed #e6e8ea;
        border-radius: 8px;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s;
        position: relative;
    }

    .file-upload:hover {
        border-color: #0052cc;
        background: #f7f9fb;
    }

    .file-upload i {
        font-size: 2rem;
        color: #434654;
        margin-bottom: 0.5rem;
    }

    .file-upload span {
        display: block;
        color: #434654;
        font-size: 0.875rem;
    }

    .file-upload input {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
    }

    /* Resources Section */
    .resources-section {
        grid-column: span 2;
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .resources-section h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
        margin-bottom: 1.5rem;
    }

    .resources-list {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }

    .resource-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem;
        background: #f7f9fb;
        border-radius: 12px;
        text-decoration: none;
        transition: all 0.2s;
    }

    .resource-item:hover {
        background: #eceef0;
        transform: translateX(4px);
    }

    .resource-icon {
        width: 48px;
        height: 48px;
        min-width: 48px;
        background: #76f3ea;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: #006a65;
    }

    .resource-info {
        flex: 1;
    }

    .resource-info h4 {
        font-size: 1rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.25rem;
    }

    .resource-info p {
        font-size: 0.75rem;
        color: #434654;
    }

    .arrow-icon {
        color: #434654;
    }

    /* System Status */
    .status-section {
        grid-column: span 2;
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .status-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .status-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        background: #f7f9fb;
        border-radius: 8px;
    }

    .status-indicator {
        width: 12px;
        height: 12px;
        border-radius: 50%;
    }

    .status-indicator.operational {
        background: #76f3ea;
    }

    .status-item span:nth-child(2) {
        flex: 1;
        color: #191c1e;
    }

    .status-label {
        color: #006a65;
        font-size: 0.875rem;
        font-weight: 600;
    }

    .badge {
        padding: 0.375rem 0.75rem;
        border-radius: 6px;
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.05em;
    }

    .badge-success {
        background: #76f3ea;
        color: #006a65;
    }

    .btn {
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-primary {
        background: #0052cc;
        color: white;
    }

    .btn-primary:hover {
        background: #003d9b;
        transform: translateY(-1px);
    }

    .btn-primary:disabled {
        background: #ccc;
        cursor: not-allowed;
        transform: none;
    }

    .btn-secondary {
        background: #f7f9fb;
        color: #191c1e;
        border: 1px solid #e6e8ea;
    }

    .btn-secondary:hover {
        background: #eceef0;
    }

    .btn-outline {
        background: transparent;
        color: #0052cc;
        border: 1px solid #0052cc;
    }

    .btn-outline:hover {
        background: #e3f2fd;
    }

    .btn-sm {
        padding: 0.5rem 1rem;
        font-size: 0.8125rem;
    }

    /* Loading & Empty States */
    .loading-state,
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem;
        text-align: center;
    }

    .loading-state .spinner {
        width: 48px;
        height: 48px;
        border: 4px solid #f7f9fb;
        border-top-color: #0052cc;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-bottom: 1rem;
    }

    .spinner-sm {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .empty-state i {
        font-size: 3rem;
        color: #434654;
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        font-size: 1.25rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: #434654;
        margin-bottom: 1.5rem;
    }

    /* Alerts */
    .alert {
        padding: 1rem;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .alert-error {
        background: #ffebee;
        color: #c62828;
        border: 1px solid #ef5350;
    }

    .alert-success {
        background: #e8f5e9;
        color: #2e7d32;
        border: 1px solid #66bb6a;
    }

    .alert i {
        font-size: 1.25rem;
    }

    /* Ticket List */
    .ticket-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .ticket-card {
        padding: 1.5rem;
        background: #f7f9fb;
        border-radius: 12px;
        border-left: 4px solid #e6e8ea;
        transition: all 0.2s;
    }

    .ticket-card:hover {
        background: #eceef0;
        transform: translateX(4px);
    }

    .ticket-card.status-open {
        border-left-color: #0052cc;
    }

    .ticket-card.status-progress {
        border-left-color: #ff9800;
    }

    .ticket-card.status-resolved {
        border-left-color: #4caf50;
    }

    .ticket-card.status-closed {
        border-left-color: #9e9e9e;
    }

    .ticket-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 0.75rem;
    }

    .ticket-info {
        flex: 1;
    }

    .ticket-info h4 {
        font-size: 1rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.25rem;
    }

    .ticket-id {
        font-size: 0.75rem;
        color: #434654;
        font-family: monospace;
    }

    .ticket-badges {
        display: flex;
        gap: 0.5rem;
    }

    .badge {
        padding: 0.25rem 0.625rem;
        border-radius: 6px;
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .badge-low {
        background: #e3f2fd;
        color: #1976d2;
    }

    .badge-medium {
        background: #fff3e0;
        color: #f57c00;
    }

    .badge-high {
        background: #ffebee;
        color: #d32f2f;
    }

    .badge-urgent {
        background: #fce4ec;
        color: #c2185b;
    }

    .badge-open {
        background: #e3f2fd;
        color: #1976d2;
    }

    .badge-in_progress {
        background: #fff3e0;
        color: #f57c00;
    }

    .badge-resolved {
        background: #e8f5e9;
        color: #388e3c;
