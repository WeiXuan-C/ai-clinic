@page "/patient/support"
@layout Components.Layout.SidebarLayout
@using ai_clinic.Models
@using ai_clinic.Services
@using ai_clinic.Services.Facades
@using Microsoft.JSInterop
@inject AuthFacade AuthFacade
@inject SupportTicketService SupportTicketService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Support - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>Help & Support</h1>
        <p class="body-md" style="margin: 0.5rem;">
            <span class="status-indicator">●</span>
            We're here to help 24/7
        </p>
    </div>
    <div class="header-right">
        <button class="btn btn-primary" @onclick="ScrollToTickets">
            <i data-lucide="ticket"></i>
            My Tickets (@tickets.Count)
        </button>
    </div>
</header>

<!-- Content Grid -->
<div class="content-grid">
    <!-- Quick Actions -->
    <section class="quick-actions-section">
        <h2 class="headline-md">Quick Actions</h2>
        <div class="actions-grid">
            <div class="action-card">
                <i data-lucide="message-square" class="action-icon"></i>
                <h3 class="headline-sm">Live Chat</h3>
                <p class="body-sm">Chat with our support team</p>
            </div>
            <div class="action-card">
                <i data-lucide="phone" class="action-icon"></i>
                <h3 class="headline-sm">Call Us</h3>
                <p class="body-sm">1-800-AI-CLINIC</p>
            </div>
            <div class="action-card">
                <i data-lucide="mail" class="action-icon"></i>
                <h3 class="headline-sm">Email</h3>
                <p class="body-sm">support@aiclinic.com</p>
            </div>
            <div class="action-card">
                <i data-lucide="book-open" class="action-icon"></i>
                <h3 class="headline-sm">Help Center</h3>
                <p class="body-sm">Browse articles & guides</p>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
        <div class="section-header">
            <h2 class="headline-md">Frequently Asked Questions</h2>
            <div class="search-box">
                <i data-lucide="search"></i>
                <input type="text" placeholder="Search FAQs..." />
            </div>
        </div>
        
        <div class="faq-list">
            <div class="faq-item @(faqStates[0] ? "" : "collapsed")">
                <div class="faq-question" @onclick="() => ToggleFaq(0)">
                    <h4 class="headline-sm">How do I schedule an appointment?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">You can schedule an appointment by clicking on "Book Doctor Visit" from your dashboard or navigating to the Consultation page. Select your preferred doctor, date, and time slot.</p>
                </div>
            </div>

            <div class="faq-item @(faqStates[1] ? "" : "collapsed")">
                <div class="faq-question" @onclick="() => ToggleFaq(1)">
                    <h4 class="headline-sm">How do I access my medical records?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">Navigate to the "Medical Records" section from the sidebar menu. You can view, download, and share your records securely from there.</p>
                </div>
            </div>

            <div class="faq-item @(faqStates[2] ? "" : "collapsed")">
                <div class="faq-question" @onclick="() => ToggleFaq(2)">
                    <h4 class="headline-sm">Is my health data secure?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">Yes, we use bank-level encryption and are fully HIPAA compliant. Your data is encrypted both in transit and at rest, and we never share your information without your explicit consent.</p>
                </div>
            </div>

            <div class="faq-item @(faqStates[3] ? "" : "collapsed")">
                <div class="faq-question" @onclick="() => ToggleFaq(3)">
                    <h4 class="headline-sm">How does the AI assistant work?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">Our AI assistant uses advanced machine learning to analyze your symptoms and health data. It provides preliminary assessments but always recommends consulting with a licensed physician for diagnosis and treatment.</p>
                </div>
            </div>

            <div class="faq-item @(faqStates[4] ? "" : "collapsed")">
                <div class="faq-question" @onclick="() => ToggleFaq(4)">
                    <h4 class="headline-sm">Can I connect my wearable devices?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">Yes! We support Apple Watch, Fitbit, Garmin, and other popular wearables. Go to Settings > Connected Devices to link your devices.</p>
                </div>
            </div>

            <div class="faq-item @(faqStates[5] ? "" : "collapsed")">
                <div class="faq-question" @onclick="() => ToggleFaq(5)">
                    <h4 class="headline-sm">What insurance plans do you accept?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">We accept most major insurance plans including Blue Cross Blue Shield, Aetna, UnitedHealthcare, Cigna, and Medicare. Contact our billing department for specific plan verification.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Form -->
    <section class="contact-form-section">
        <div class="section-header">
            <h2 class="headline-md">Create Support Ticket</h2>
            <p class="body-sm">We typically respond within 24 hours</p>
        </div>
        
        <!-- Create Ticket Form -->
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">
                <i data-lucide="check-circle"></i>
                <span>@successMessage</span>
            </div>
        }
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-error">
                <i data-lucide="alert-circle"></i>
                <span>@errorMessage</span>
            </div>
        }

        <EditForm Model="newTicket" OnValidSubmit="CreateTicket" class="contact-form">
            <DataAnnotationsValidator />
            <div class="form-group">
                <label class="body-sm">Subject *</label>
                <input type="text" 
                       class="form-input" 
                       placeholder="Brief description of your issue"
                       @bind="newTicket.Subject"
                       required />
            </div>

            <div class="form-group">
                <label class="body-sm">Category</label>
                <select class="form-input" @bind="newTicket.Category">
                    <option value="">Select a category...</option>
                    <option value="technical">Technical Support</option>
                    <option value="billing">Billing Question</option>
                    <option value="appointment">Appointment Issue</option>
                    <option value="records">Medical Records</option>
                    <option value="general">General Inquiry</option>
                    <option value="feedback">Feedback</option>
                </select>
            </div>
            
            <div class="form-group">
                <label class="body-sm">Priority *</label>
                <div class="priority-options">
                    <label class="radio-option">
                        <input type="radio" name="priority" value="low" checked="@(newTicket.Priority == "low")" @onchange="@(() => newTicket.Priority = "low")" />
                        <span>Low</span>
                    </label>
                    <label class="radio-option">
                        <input type="radio" name="priority" value="medium" checked="@(newTicket.Priority == "medium")" @onchange="@(() => newTicket.Priority = "medium")" />
                        <span>Medium</span>
                    </label>
                    <label class="radio-option">
                        <input type="radio" name="priority" value="high" checked="@(newTicket.Priority == "high")" @onchange="@(() => newTicket.Priority = "high")" />
                        <span>High</span>
                    </label>
                    <label class="radio-option">
                        <input type="radio" name="priority" value="urgent" checked="@(newTicket.Priority == "urgent")" @onchange="@(() => newTicket.Priority = "urgent")" />
                        <span>Urgent</span>
                    </label>
                </div>
            </div>

            <div class="form-group">
                <label class="body-sm">Description *</label>
                <textarea class="form-input" 
                          rows="6" 
                          placeholder="Describe your issue or question in detail..."
                          @bind="newTicket.Description"
                          required></textarea>
            </div>

            <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                <i data-lucide="send"></i>
                <span>@(isSubmitting ? "Creating..." : "Create Ticket")</span>
            </button>
        </EditForm>
    </section>

    <section class="resources-section" id="tickets-section">
        <h2 class="headline-md">My Support Tickets</h2>
        @if (isLoadingTickets)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p class="body-md">Loading tickets...</p>
            </div>
        }
        else if (!tickets.Any())
        {
            <div class="empty-state">
                <i data-lucide="ticket"></i>
                <h3>No tickets yet</h3>
                <p>Your submitted support requests will appear here.</p>
            </div>
        }
        else
        {
            <div class="ticket-list">
                @foreach (var ticket in tickets)
                {
                    <div class="ticket-card-compact status-@ticket.Status.Replace("_", "-")" @onclick="() => OpenTicketDetails(ticket)">
                        <div class="ticket-compact-header">
                            <div class="ticket-compact-info">
                                <h4>@ticket.Subject</h4>
                                <span class="ticket-id">@ticket.Id.ToString()[..8]</span>
                            </div>
                            <div class="ticket-badges">
                                <span class="badge badge-@ticket.Priority">@ticket.Priority</span>
                                <span class="badge badge-@ticket.Status">@ticket.Status.Replace("_", " ")</span>
                            </div>
                        </div>
                        <div class="ticket-compact-footer">
                            <span class="ticket-date">
                                <i data-lucide="calendar"></i>
                                @ticket.CreatedAt.ToString("MMM dd, yyyy")
                            </span>
                            <span class="body-sm">@ticket.Category</span>
                            @if (ticket.Responses.Any(r => !r.IsInternalNote))
                            {
                                <span class="response-indicator">
                                    <i data-lucide="message-circle"></i>
                                    @ticket.Responses.Count(r => !r.IsInternalNote) response(s)
                                </span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <!-- Ticket Details Dialog -->
    @if (selectedTicket != null)
    {
        <div class="modal-overlay" @onclick="CloseTicketDetails">
            <div class="modal-dialog" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h2>Ticket Details</h2>
                    <button class="btn-close" @onclick="CloseTicketDetails">
                        <i data-lucide="x"></i>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="ticket-detail-header">
                        <div class="ticket-detail-title">
                            <h3>@selectedTicket.Subject</h3>
                            <span class="ticket-id">ID: @selectedTicket.Id.ToString()[..8]</span>
                        </div>
                        <div class="ticket-badges">
                            <span class="badge badge-@selectedTicket.Priority">@selectedTicket.Priority</span>
                            <span class="badge badge-@selectedTicket.Status">@selectedTicket.Status.Replace("_", " ")</span>
                        </div>
                    </div>

                    <div class="ticket-detail-meta">
                        <div class="meta-item">
                            <i data-lucide="calendar"></i>
                            <span>Created: @selectedTicket.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                        </div>
                        <div class="meta-item">
                            <i data-lucide="tag"></i>
                            <span>Category: @selectedTicket.Category</span>
                        </div>
                    </div>

                    <div class="ticket-detail-description">
                        <h4>Description</h4>
                        <p>@selectedTicket.Description</p>
                    </div>

                    @if (selectedTicket.Responses.Any(r => !r.IsInternalNote))
                    {
                        <div class="ticket-detail-responses">
                            <h4>Support Responses (@selectedTicket.Responses.Count(r => !r.IsInternalNote))</h4>
                            <div class="responses-timeline">
                                @foreach (var response in selectedTicket.Responses.Where(r => !r.IsInternalNote).OrderBy(r => r.CreatedAt))
                                {
                                    <div class="response-card">
                                        <div class="response-card-header">
                                            <div class="response-avatar">
                                                <i data-lucide="user-check"></i>
                                            </div>
                                            <div class="response-info">
                                                <strong>Support Team</strong>
                                                <span class="response-time">@response.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                                            </div>
                                        </div>
                                        <div class="response-card-body">
                                            <p>@response.Message</p>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="empty-responses">
                            <i data-lucide="clock"></i>
                            <p>No responses yet. Our support team will respond within 24 hours.</p>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseTicketDetails">Close</button>
                </div>
            </div>
        </div>
    }

    <!-- System Status -->
    <section class="status-section">
        <div class="section-header">
            <h2 class="headline-md">System Status</h2>
            <span class="badge badge-success">ALL SYSTEMS OPERATIONAL</span>
        </div>
        <div class="status-list">
            <div class="status-item">
                <div class="status-indicator operational"></div>
                <span class="body-md">Patient Portal</span>
                <span class="status-label">Operational</span>
            </div>
            <div class="status-item">
                <div class="status-indicator operational"></div>
                <span class="body-md">AI Assistant</span>
                <span class="status-label">Operational</span>
            </div>
            <div class="status-item">
                <div class="status-indicator operational"></div>
                <span class="body-md">Appointment Booking</span>
                <span class="status-label">Operational</span>
            </div>
            <div class="status-item">
                <div class="status-indicator operational"></div>
                <span class="body-md">Medical Records</span>
                <span class="status-label">Operational</span>
            </div>
        </div>
    </section>
</div>

@code {
    private List<SupportTicket> tickets = new();
    private SupportTicket newTicket = new() { Priority = "medium" };
    private SupportTicket? selectedTicket = null;
    private bool isSubmitting;
    private bool isLoadingTickets = true;
    private string? errorMessage;
    private string? successMessage;
    
    // FAQ states - true means expanded, false means collapsed
    private bool[] faqStates = new bool[6]; // Start all collapsed (false)

    protected override async Task OnInitializedAsync()
    {
        if (!AuthFacade.IsAuthenticated || AuthFacade.CurrentUser?.Role != UserRole.Patient)
        {
            Navigation.NavigateTo("/auth/signin");
            return;
        }

        await LoadTickets();
        ResetForm();
    }

    private void ToggleFaq(int index)
    {
        if (index >= 0 && index < faqStates.Length)
        {
            faqStates[index] = !faqStates[index];
        }
    }

    private async Task ScrollToTickets()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("scrollToElement", "tickets-section");
        }
        catch (Exception)
        {
            // Fallback: if JS fails, just continue
        }
    }

    private void OpenTicketDetails(SupportTicket ticket)
    {
        selectedTicket = ticket;
    }

    private void CloseTicketDetails()
    {
        selectedTicket = null;
    }

    private async Task LoadTickets()
    {
        isLoadingTickets = true;
        try
        {
            tickets = await SupportTicketService.GetByUserIdAsync(AuthFacade.CurrentUser!.Id);
        }
        finally
        {
            isLoadingTickets = false;
        }
    }

    private async Task CreateTicket()
    {
        errorMessage = null;
        successMessage = null;

        if (string.IsNullOrWhiteSpace(newTicket.Subject) || string.IsNullOrWhiteSpace(newTicket.Description))
        {
            errorMessage = "Subject and description are required.";
            return;
        }

        isSubmitting = true;
        try
        {
            newTicket.UserId = AuthFacade.CurrentUser!.Id;
            newTicket.Status = "open";
            await SupportTicketService.CreateAsync(newTicket);
            successMessage = "Support ticket created successfully.";
            ResetForm();
            await LoadTickets();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to create ticket: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ResetForm()
    {
        newTicket = new SupportTicket
        {
            Priority = "medium",
            Category = "technical"
        };
    }
}

<style>
    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2rem;
    }

    .header-left h1 {
        font-size: 2rem;
        font-weight: 700;
        color: #191c1e;
        margin: 0.5rem;
        font-family: 'Manrope', sans-serif;
    }

    .header-left p {
        color: #434654;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .status-indicator {
        color: #76f3ea;
