    }

    .action-card h3 {
        font-size: 1rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.5rem;
    }

    .action-card p {
        color: #434654;
        font-size: 0.875rem;
    }

    /* FAQ Section */
    .faq-section {
        grid-column: span 1;
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.75rem;
    }

    .section-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
    }

    .section-header p {
        color: #434654;
    }

    .search-box {
