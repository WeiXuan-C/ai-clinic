@page "/patient/settings-mud"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout Components.Layout.SidebarLayout
@inject AuthState AuthState
@inject PatientController PatientController
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Settings - AI Medical Clinic</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    @if (!AuthState.IsAuthenticated)
    {
        <MudPaper Class="pa-8 text-center">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.body1" Class="mt-4">Checking authentication...</MudText>
        </MudPaper>
    }
    else if (isLoading)
    {
        <MudPaper Class="pa-8 text-center">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.body1" Class="mt-4">Loading settings...</MudText>
        </MudPaper>
    }
    else
    {
        <MudText Typo="Typo.h4" Class="mb-2">Settings</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
            Manage your account preferences and privacy settings
        </MudText>

        <!-- Account Settings -->
        <MudPaper Class="pa-6 mb-4" Elevation="2">
            <div class="d-flex align-center mb-4">
                <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Class="mr-3" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Account Settings</MudText>
            </div>
            
            <MudList T="string">
                <MudListItem T="string">
                    <div class="d-flex justify-space-between align-center" style="width: 100%;">
                        <div>
                            <MudText Typo="Typo.subtitle1">Email Address</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@userSettings?.Email</MudText>
                        </div>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small">Change</MudButton>
                    </div>
                </MudListItem>
            </MudList>
        </MudPaper>

        <!-- Privacy & Security -->
        <MudPaper Class="pa-6 mb-4" Elevation="2">
            <div class="d-flex align-center mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Security" Class="mr-3" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Privacy & Security</MudText>
            </div>
            
            <MudList T="string">
                <MudListItem T="string">
                    <div class="d-flex justify-space-between align-center" style="width: 100%;">
                        <div>
                            <MudText Typo="Typo.subtitle1">Data Sharing</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Share health data with research programs</MudText>
                        </div>
                        <MudSwitch T="bool" @bind-Value="dataSharingEnabled" Color="Color.Primary" />
                    </div>
                </MudListItem>
                <MudDivider />
                <MudListItem T="string">
                    <div class="d-flex justify-space-between align-center" style="width: 100%;">
                        <div>
                            <MudText Typo="Typo.subtitle1">AI Analysis</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Allow AI to analyze your health data</MudText>
                        </div>
                        <MudSwitch T="bool" @bind-Value="aiAnalysisEnabled" Color="Color.Primary" />
                    </div>
                </MudListItem>
                <MudDivider />
                <MudListItem T="string">
                    <div class="d-flex justify-space-between align-center" style="width: 100%;">
                        <div>
                            <MudText Typo="Typo.subtitle1">Activity Tracking</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Track app usage for better experience</MudText>
                        </div>
                        <MudSwitch T="bool" @bind-Value="activityTrackingEnabled" Color="Color.Primary" />
                    </div>
                </MudListItem>
                <MudDivider />
                <MudListItem T="string">
                    <div class="d-flex justify-space-between align-center" style="width: 100%;">
                        <div>
                            <MudText Typo="Typo.subtitle1">Download My Data</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Export all your personal and medical data</MudText>
                        </div>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Download">
                            Download
                        </MudButton>
                    </div>
                </MudListItem>
            </MudList>

            <div class="d-flex justify-end mt-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSettings" Disabled="@isSaving">
                    @(isSaving ? "Saving..." : "Save Changes")
                </MudButton>
            </div>
        </MudPaper>

        <!-- Danger Zone -->
        <MudPaper Class="pa-6" Elevation="2" Style="border: 2px solid #ffebee;">
            <div class="d-flex align-center mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-3" Color="Color.Error" />
                <MudText Typo="Typo.h6" Color="Color.Error">Danger Zone</MudText>
            </div>
            
            <MudList T="string">
                <MudListItem T="string">
                    <div class="d-flex justify-space-between align-center" style="width: 100%;">
                        <div>
                            <MudText Typo="Typo.subtitle1">Deactivate Account</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Temporarily disable your account</MudText>
                        </div>
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" OnClick="ShowDeactivateDialog">
                            Deactivate
                        </MudButton>
                    </div>
                </MudListItem>
                <MudDivider />
                <MudListItem T="string">
                    <div class="d-flex justify-space-between align-center" style="width: 100%;">
                        <div>
                            <MudText Typo="Typo.subtitle1">Delete Account</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Permanently delete your account and all data</MudText>
                        </div>
                        <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" OnClick="ShowDeleteDialog">
                            Delete
                        </MudButton>
                    </div>
                </MudListItem>
            </MudList>
        </MudPaper>
    }
</MudContainer>

@code {
    private bool isLoading = true;
    private bool isSaving = false;
    private User? userSettings;

    private bool dataSharingEnabled;
    private bool aiAnalysisEnabled;
    private bool activityTrackingEnabled;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/auth/signin");
            return;
        }
        
        await LoadSettings();
    }

    private async Task LoadSettings()
    {
        try
        {
            isLoading = true;

            if (AuthState.CurrentUser == null)
            {
                Snackbar.Add("Please sign in to view settings.", Severity.Warning);
                await Task.Delay(1500);
                Navigation.NavigateTo("/auth/signin");
                return;
            }

            userSettings = await PatientController.GetUserSettingsAsync(AuthState.CurrentUser.Id);

            if (userSettings != null)
            {
                dataSharingEnabled = userSettings.DataSharingEnabled;
                aiAnalysisEnabled = userSettings.AiAnalysisEnabled;
                activityTrackingEnabled = userSettings.ActivityTrackingEnabled;
            }
            else
            {
                Snackbar.Add("Settings not found.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading settings: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveSettings()
    {
        try
        {
            isSaving = true;

            if (AuthState.CurrentUser == null)
            {
                Snackbar.Add("User not authenticated", Severity.Error);
                return;
            }

            var request = new UpdateUserSettingsRequest(
                DataSharingEnabled: dataSharingEnabled,
                AiAnalysisEnabled: aiAnalysisEnabled,
                ActivityTrackingEnabled: activityTrackingEnabled
            );

            var (success, message) = await PatientController.UpdateUserSettingsAsync(AuthState.CurrentUser.Id, request);

            if (success)
            {
                Snackbar.Add(message, Severity.Success);
            }
            else
            {
                Snackbar.Add(message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving settings: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ShowDeactivateDialog()
    {
        Snackbar.Add("Deactivate account feature coming soon", Severity.Info);
    }

    private void ShowDeleteDialog()
    {
        Snackbar.Add("Delete account feature coming soon", Severity.Info);
    }
}
