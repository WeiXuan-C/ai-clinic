        overflow-y: auto;
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 2rem;
        border-bottom: 1px solid #e6e8ea;
    }

    .modal-header h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
    }

