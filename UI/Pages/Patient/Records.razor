        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: transparent;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

    .icon-btn:hover {
        background: #f7f9fb;
    }

    .modal-body {
        padding: 2rem;
    }

    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
        padding: 1.5rem 2rem;
        border-top: 1px solid #e6e8ea;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-group label {
        display: block;
        color: #434654;
        font-weight: 500;
        margin-bottom: 0.5rem;
    }

    .form-input {
        width: 100%;
        padding: 0.875rem 1rem;
        border: 1px solid #e6e8ea;
        border-radius: 8px;
        font-size: 0.9375rem;
        font-family: 'Inter', sans-serif;
        transition: all 0.2s;
    }

    .form-input:focus {
        outline: none;
        border-color: #0052cc;
        box-shadow: 0 0 0 3px rgba(0, 82, 204, 0.1);
    }

    .file-input {
        width: 100%;
        padding: 0.875rem 1rem;
        border: 2px dashed #e6e8ea;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .file-input:hover {
        border-color: #0052cc;
        background: #f7f9fb;
    }

    .file-preview {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.875rem 1rem;
        background: #f7f9fb;
        border-radius: 8px;
        margin-top: 0.75rem;
    }

    .file-preview i {
        color: #0052cc;
    }

    .alert {
        padding: 1rem;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .alert-error {
        background: #ffebee;
        color: #c62828;
        border: 1px solid #ef5350;
    }

    .alert-success {
        background: #e8f5e9;
        color: #2e7d32;
        border: 1px solid #66bb6a;
    }

    .alert i {
        font-size: 1.25rem;
    }

    .spinner-sm {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .loading-state,
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem 2rem;
        text-align: center;
    }

    .loading-state .spinner {
        width: 48px;
        height: 48px;
        border: 4px solid #f7f9fb;
        border-top-color: #0052cc;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-bottom: 1rem;
    }

    .empty-state i {
        font-size: 3rem;
        color: #434654;
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        font-size: 1.25rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: #434654;
        margin-bottom: 1.5rem;
    }

    .text-muted {
        color: #434654 !important;
    }

    .badge-other {
        background: #f3f4f6;
        color: #6b7280;
    }

    .record-icon.other {
        background: #f3f4f6;
        color: #6b7280;
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .content-grid {
            grid-template-columns: 1fr;
        }

        .records-section,
        .stats-card,
        .timeline-card {
            grid-column: span 1;
        }

        .search-box {
            min-width: 200px;
        }
    }

    @@media (max-width: 768px) {
        .filter-tabs {
            gap: 0.5rem;
        }

        .record-actions {
            flex-direction: column;
            align-items: flex-end;
        }

        .header-right {
            flex-direction: column;
        }
    }
</style>


<!-- Preview Modal -->
@if (showPreviewModal && previewRecord != null)
{
    <div class="modal-overlay" @onclick="ClosePreviewModal">
        <div class="modal-content preview-modal-large" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div>
                    <h3>@previewRecord.Title</h3>
                    <p style="font-size: 0.875rem; color: #434654; margin-top: 0.25rem;">
                        @previewRecord.Type • @FormatDate(previewRecord.Date)
                    </p>
                </div>
                <button class="icon-btn" @onclick="ClosePreviewModal">
                    <i data-lucide="x"></i>
                </button>
            </div>
            <div class="modal-body">
                @if (previewRecord.RecordCategory == "medical_record" && previewMedicalRecord != null)
                {
                    <div class="preview-section">
                        <h4 class="preview-section-title">Record Type</h4>
                        <p class="preview-section-content">@previewMedicalRecord.RecordType</p>
                    </div>
                    <div class="preview-section">
                        <h4 class="preview-section-title">Content</h4>
                        <p class="preview-section-content">@previewMedicalRecord.Content</p>
                    </div>
                    @if (!string.IsNullOrEmpty(previewMedicalRecord.DiagnosisDescription))
                    {
                        <div class="preview-section">
                            <h4 class="preview-section-title">Diagnosis</h4>
                            <p class="preview-section-content">
                                @if (!string.IsNullOrEmpty(previewMedicalRecord.DiagnosisCode))
                                {
                                    <strong>Code:</strong> @previewMedicalRecord.DiagnosisCode <br/>
                                }
                                @previewMedicalRecord.DiagnosisDescription
                            </p>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(previewMedicalRecord.Medications))
                    {
                        <div class="preview-section">
                            <h4 class="preview-section-title">Medications</h4>
                            <p class="preview-section-content">@previewMedicalRecord.Medications</p>
                        </div>
                    }
                }
                else if (previewRecord.RecordCategory == "prescription" && previewPrescription != null)
                {
                    <div class="preview-section">
                        <h4 class="preview-section-title">Medication</h4>
                        <p class="preview-section-content">@previewPrescription.MedicationName</p>
                    </div>
                    <div class="preview-section">
                        <h4 class="preview-section-title">Dosage</h4>
                        <p class="preview-section-content">@previewPrescription.Dosage</p>
                    </div>
                    <div class="preview-section">
                        <h4 class="preview-section-title">Frequency</h4>
                        <p class="preview-section-content">@previewPrescription.Frequency</p>
                    </div>
                    @if (!string.IsNullOrEmpty(previewPrescription.Duration))
                    {
                        <div class="preview-section">
                            <h4 class="preview-section-title">Duration</h4>
                            <p class="preview-section-content">@previewPrescription.Duration</p>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(previewPrescription.Instructions))
                    {
                        <div class="preview-section">
                            <h4 class="preview-section-title">Instructions</h4>
                            <p class="preview-section-content">@previewPrescription.Instructions</p>
                        </div>
                    }
                    <div class="preview-section">
                        <h4 class="preview-section-title">Status</h4>
                        <p class="preview-section-content">
                            <span class="badge @(previewPrescription.IsActive ? "badge-visit" : "badge-other")">
                                @(previewPrescription.IsActive ? "ACTIVE" : "INACTIVE")
                            </span>
                        </p>
                    </div>
                }
                else if (previewRecord.RecordCategory == "document" && previewDocument != null)
                {
                    <div class="preview-section">
                        <h4 class="preview-section-title">File Information</h4>
                        <p class="preview-section-content">
                            <strong>Filename:</strong> @previewDocument.FileName<br/>
                            <strong>Type:</strong> @previewDocument.FileType<br/>
                            <strong>Size:</strong> @FormatFileSize(previewDocument.FileSizeBytes)<br/>
                            @if (!string.IsNullOrEmpty(previewDocument.MimeType))
                            {
                                <strong>Format:</strong> @previewDocument.MimeType <br/>
                            }
                        </p>
                    </div>
                    @if (!string.IsNullOrEmpty(previewDocument.Description))
                    {
                        <div class="preview-section">
                            <h4 class="preview-section-title">Description</h4>
                            <p class="preview-section-content">@previewDocument.Description</p>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(previewDocument.ExtractedText))
                    {
                        <div class="preview-section">
                            <h4 class="preview-section-title">Extracted Text</h4>
                            <p class="preview-section-content">@previewDocument.ExtractedText</p>
                        </div>
                    }
                    @if (IsImageDocument(previewDocument))
                    {
                        <div class="preview-section">
                            <h4 class="preview-section-title">Image Preview</h4>
                            <img src="@GetDocumentDataUrl(previewDocument)" alt="@previewDocument.FileName" 
                                 style="max-width: 100%; border-radius: 8px; margin-top: 0.5rem;" />
                        </div>
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="ClosePreviewModal">Close</button>
                <button class="btn btn-primary" @onclick="@(() => DownloadRecord(previewRecord.Id, previewRecord.RecordCategory))">
                    <i data-lucide="download"></i>
                    Download
                </button>
            </div>
        </div>
    </div>
}

<style>
    /* Preview Modal Styles */
    .preview-modal-large {
        max-width: 800px;
    }

    .preview-section {
        margin-bottom: 1.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #e6e8ea;
    }

    .preview-section:last-child {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }

    .preview-section-title {
        font-size: 0.875rem;
        font-weight: 600;
        color: #434654;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.75rem;
    }

    .preview-section-content {
        font-size: 1rem;
        color: #191c1e;
        line-height: 1.6;
        white-space: pre-wrap;
    }
</style>
