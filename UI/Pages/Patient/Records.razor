        background: #fff3e0;
        color: #f57c00;
    }

    .record-icon.immunization {
        background: #fce4ec;
        color: #c2185b;
    }

    .record-icon.ai {
        background: #76f3ea;
        color: #006a65;
    }

    .record-info {
        flex: 1;
    }

    .record-info h4 {
        font-size: 1rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.25rem;
    }

    .record-info p {
        font-size: 0.75rem;
