        transition: all 0.2s;
        white-space: nowrap;
        font-size: 0.875rem;
    }

    .tab-btn:hover {
        background: #f7f9fb;
    }

    .tab-btn.active {
        background: #0052cc;
        color: white;
        border-color: #0052cc;
    }

    .content-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 2rem;
    }

    /* Records Section */
