                    <span class="timeline-date">Oct 12, 2023</span>
                    <p class="body-md">Prescription - Lisinopril</p>
                </div>
            </div>
            *@
        </div>
    </section>
</div>

<style>
    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2rem;
    }

    .header-left h1 {
        font-size: 2rem;
        font-weight: 700;
        color: #191c1e;
        margin: 0.5rem;
        font-family: 'Manrope', sans-serif;
    }

    .header-left p {
        color: #434654;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .status-indicator {
        color: #76f3ea;
        font-size: 0.75rem;
    }

    .header-right {
        display: flex;
        gap: 1rem;
    }

    /* Filter Tabs */
    .filter-tabs {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        overflow-x: auto;
        padding-bottom: 0.5rem;
    }

    .tab-btn {
        padding: 0.75rem 1.5rem;
        background: white;
        border: 1px solid #e6e8ea;
