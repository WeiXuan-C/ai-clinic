@page "/patient/records"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout Components.Layout.SidebarLayout
@using Microsoft.AspNetCore.Components.Forms
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<PageTitle>Medical Records - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>Medical Records</h1>
        <p class="body-md" style="margin: 0.5rem;">
            <span class="status-indicator">●</span>
            Secure access to your complete medical history
        </p>
    </div>
    <div class="header-right">
        <button class="btn btn-secondary" @onclick="ExportRecords" disabled="@(documents.Count == 0)">
            <i data-lucide="download"></i>
            Export Records
        </button>
        <button class="btn btn-primary" @onclick="ShowUploadDialog">
            <i data-lucide="upload"></i>
            Upload Document
        </button>
    </div>
</header>

<!-- Upload Dialog -->
@if (showUploadDialog)
{
    <div class="modal-overlay" @onclick="CloseUploadDialog">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3 class="headline-md">Upload Medical Document</h3>
                <button class="icon-btn" @onclick="CloseUploadDialog">
                    <i data-lucide="x"></i>
                </button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(uploadError))
                {
                    <div class="alert alert-error">
                        <i data-lucide="alert-circle"></i>
                        @uploadError
                    </div>
                }

                @if (!string.IsNullOrEmpty(uploadSuccess))
                {
                    <div class="alert alert-success">
                        <i data-lucide="check-circle"></i>
                        @uploadSuccess
                    </div>
                }

                <div class="form-group">
                    <label class="body-sm">Document Type *</label>
                    <select class="form-input" @bind="uploadDocumentType">
                        <option value="">Select type...</option>
                        <option value="lab_result">Lab Result</option>
                        <option value="prescription">Prescription</option>
                        <option value="visit_note">Visit Note</option>
                        <option value="imaging">Imaging</option>
                        <option value="immunization">Immunization</option>
                        <option value="other">Other</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="body-sm">Description (optional)</label>
                    <input type="text" 
                           class="form-input" 
                           @bind="uploadDescription" 
                           placeholder="Brief description of the document" />
                </div>

                <div class="form-group">
                    <label class="body-sm">File *</label>
                    <InputFile OnChange="HandleFileSelected" class="file-input" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" />
                    @if (selectedFile != null)
                    {
                        <div class="file-preview">
                            <i data-lucide="file"></i>
                            <span>@selectedFile.Name (@FormatFileSize(selectedFile.Size))</span>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseUploadDialog" disabled="@isUploading">
                    Cancel
                </button>
                <button class="btn btn-primary" @onclick="HandleUpload" disabled="@(isUploading || selectedFile == null || string.IsNullOrEmpty(uploadDocumentType))">
                    @if (isUploading)
                    {
                        <span class="spinner-sm"></span>
                        <span>Uploading...</span>
                    }
                    else
                    {
                        <i data-lucide="upload"></i>
                        <span>Upload</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

<!-- Filter Tabs -->
<div class="filter-tabs">
    <button class="tab-btn @(selectedFilter == "all" ? "active" : "")" @onclick='() => selectedFilter = "all"'>
        All Records (@documents.Count)
    </button>
    <button class="tab-btn @(selectedFilter == "lab_result" ? "active" : "")" @onclick='() => selectedFilter = "lab_result"'>
        Lab Results (@documents.Count(d => d.FileType == "lab_result"))
    </button>
    <button class="tab-btn @(selectedFilter == "prescription" ? "active" : "")" @onclick='() => selectedFilter = "prescription"'>
        Prescriptions (@documents.Count(d => d.FileType == "prescription"))
    </button>
    <button class="tab-btn @(selectedFilter == "imaging" ? "active" : "")" @onclick='() => selectedFilter = "imaging"'>
        Imaging (@documents.Count(d => d.FileType == "imaging"))
    </button>
    <button class="tab-btn @(selectedFilter == "visit_note" ? "active" : "")" @onclick='() => selectedFilter = "visit_note"'>
        Visit Notes (@documents.Count(d => d.FileType == "visit_note"))
    </button>
    <button class="tab-btn @(selectedFilter == "immunization" ? "active" : "")" @onclick='() => selectedFilter = "immunization"'>
        Immunizations (@documents.Count(d => d.FileType == "immunization"))
    </button>
</div>

<!-- Content Grid -->
<div class="content-grid">
    <!-- Recent Records -->
    <section class="records-section">
        <div class="section-header">
            <h2 class="headline-md">@(selectedFilter == "all" ? "All Records" : GetFilterLabel(selectedFilter))</h2>
            <div class="search-box">
                <i data-lucide="search"></i>
                <input type="text" placeholder="Search records..." @bind="searchQuery" @bind:event="oninput" />
            </div>
        </div>
        
        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>Loading records...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-error">
                <i data-lucide="alert-circle"></i>
                @errorMessage
            </div>
        }
        else if (!FilteredDocuments.Any())
        {
            <div class="empty-state">
                <i data-lucide="inbox"></i>
                <h3>No records found</h3>
                <p>@(string.IsNullOrEmpty(searchQuery) ? "Upload your first medical document to get started" : "No records match your search")</p>
                <button class="btn btn-primary" @onclick="ShowUploadDialog">
                    <i data-lucide="upload"></i>
                    Upload Document
                </button>
            </div>
        }
        else
        {
            <div class="records-list">
                @foreach (var doc in FilteredDocuments)
                {
                    <div class="record-item">
                        <div class="record-icon @GetDocumentTypeClass(doc.FileType)">
                            <i data-lucide="@GetDocumentIcon(doc.FileType)"></i>
                        </div>
                        <div class="record-info">
                            <h4 class="headline-sm">@doc.FileName</h4>
                            <p class="body-sm">@GetDocumentTypeLabel(doc.FileType) • @doc.CreatedAt.ToString("MMMM dd, yyyy")</p>
                            @if (!string.IsNullOrEmpty(doc.Description))
                            {
                                <p class="body-sm">@doc.Description</p>
                            }
                            <p class="body-sm text-muted">@FormatFileSize(doc.FileSizeBytes)</p>
                        </div>
                        <div class="record-actions">
                            <span class="badge badge-@GetDocumentTypeClass(doc.FileType)">@GetDocumentTypeLabel(doc.FileType).ToUpper()</span>
                            <button class="icon-btn-sm" @onclick="() => ViewDocument(doc)" title="View">
                                <i data-lucide="eye"></i>
                            </button>
                            <button class="icon-btn-sm" @onclick="() => DownloadDocument(doc)" title="Download">
                                <i data-lucide="download"></i>
                            </button>
                            <button class="icon-btn-sm" @onclick="() => DeleteDocument(doc)" title="Delete">
                                <i data-lucide="trash-2"></i>
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <!-- Quick Stats -->
    <section class="stats-card">
        <h3 class="headline-md">Record Summary</h3>
        <div class="stats-list">
            <div class="stat-item">
                <i data-lucide="file-text" class="stat-icon"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">@documents.Count</h4>
                    <p class="body-sm">Total Records</p>
                </div>
            </div>
            <div class="stat-item">
                <i data-lucide="flask-conical" class="stat-icon"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">@documents.Count(d => d.FileType == "lab_result")</h4>
                    <p class="body-sm">Lab Results</p>
                </div>
            </div>
            <div class="stat-item">
                <i data-lucide="pill" class="stat-icon"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">@documents.Count(d => d.FileType == "prescription")</h4>
                    <p class="body-sm">Prescriptions</p>
                </div>
            </div>
            <div class="stat-item">
                <i data-lucide="scan" class="stat-icon"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">@documents.Count(d => d.FileType == "imaging")</h4>
                    <p class="body-sm">Imaging Studies</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Timeline View -->
    <section class="timeline-card">
        <div class="section-header">
            <h3 class="headline-md">Medical Timeline</h3>
        </div>
        <div class="timeline">
            @foreach (var doc in documents.OrderByDescending(d => d.CreatedAt).Take(5))
            {
                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content">
                        <span class="timeline-date">@doc.CreatedAt.ToString("MMM dd, yyyy")</span>
                        <p class="body-md">@doc.FileName</p>
                    </div>
                </div>
            }
            @if (documents.Count == 0)
            {
                <p class="body-sm text-muted">No records yet</p>
            }
        </div>
    </section>
</div>

<style>
    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2rem;
    }

    .header-left h1 {
        font-size: 2rem;
        font-weight: 700;
        color: #191c1e;
        margin: 0.5rem;
        font-family: 'Manrope', sans-serif;
    }

    .header-left p {
        color: #434654;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .status-indicator {
        color: #76f3ea;
        font-size: 0.75rem;
    }

    .header-right {
        display: flex;
        gap: 1rem;
    }

    /* Filter Tabs */
    .filter-tabs {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        overflow-x: auto;
        padding-bottom: 0.5rem;
    }

    .tab-btn {
        padding: 0.75rem 1.5rem;
        background: white;
        border: 1px solid #e6e8ea;
        border-radius: 8px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
        font-size: 0.875rem;
    }

    .tab-btn:hover {
        background: #f7f9fb;
    }

    .tab-btn.active {
        background: #0052cc;
        color: white;
        border-color: #0052cc;
    }

    .content-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 2rem;
    }

    /* Records Section */
    .records-section {
        grid-column: span 1;
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.75rem;
    }

    .section-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
    }

    .search-box {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        background: #f7f9fb;
        border-radius: 8px;
        min-width: 300px;
    }

    .search-box input {
        border: none;
        background: transparent;
        outline: none;
        font-size: 0.875rem;
        width: 100%;
    }

    .records-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .record-item {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        padding: 1.25rem;
        background: #f7f9fb;
        border-radius: 12px;
        transition: all 0.2s;
    }

    .record-item:hover {
        background: #eceef0;
        transform: translateX(4px);
    }

    .record-icon {
        width: 48px;
        height: 48px;
        min-width: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    .record-icon.lab {
        background: #e3f2fd;
        color: #1976d2;
    }

    .record-icon.prescription {
        background: #f3e5f5;
        color: #7b1fa2;
    }

    .record-icon.visit {
        background: #e8f5e9;
        color: #388e3c;
    }

    .record-icon.imaging {
        background: #fff3e0;
        color: #f57c00;
    }

    .record-icon.immunization {
        background: #fce4ec;
        color: #c2185b;
    }

    .record-icon.ai {
        background: #76f3ea;
        color: #006a65;
    }

    .record-info {
        flex: 1;
    }

    .record-info h4 {
        font-size: 1rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.25rem;
    }

    .record-info p {
        font-size: 0.75rem;
        color: #434654;
        margin-bottom: 0.125rem;
    }

    .record-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .badge {
        padding: 0.375rem 0.75rem;
        border-radius: 6px;
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        white-space: nowrap;
    }

    .badge-lab {
        background: #e3f2fd;
        color: #1976d2;
    }

    .badge-prescription {
        background: #f3e5f5;
        color: #7b1fa2;
    }

    .badge-visit {
        background: #e8f5e9;
        color: #388e3c;
    }

    .badge-imaging {
        background: #fff3e0;
        color: #f57c00;
    }

    .badge-immunization {
        background: #fce4ec;
        color: #c2185b;
    }

    .badge-ai {
        background: #76f3ea;
        color: #006a65;
    }

    .icon-btn-sm {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: white;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

    .icon-btn-sm:hover {
        background: #e6e8ea;
    }

    /* Stats Card */
    .stats-card {
        grid-column: span 1;
        background: white;
        padding: 2rem;
        border-radius: 16px;
        height: fit-content;
    }

    .stats-card h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
        margin-bottom: 1.5rem;
    }

    .stats-list {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .stat-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem;
        background: #f7f9fb;
        border-radius: 12px;
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        min-width: 48px;
        background: #76f3ea;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: #006a65;
    }

    .stat-info h4 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #191c1e;
        margin-bottom: 0.25rem;
    }

    .stat-info p {
        color: #434654;
        font-size: 0.875rem;
    }

    /* Timeline Card */
    .timeline-card {
        grid-column: span 1;
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .timeline-card .section-header {
        margin-bottom: 1.5rem;
    }

    .timeline-card h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
    }

    .link-primary {
        color: #0052cc;
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 600;
    }

    .timeline {
        position: relative;
        padding-left: 2rem;
    }

    .timeline::before {
        content: '';
        position: absolute;
        left: 8px;
        top: 0;
        bottom: 0;
        width: 2px;
        background: #e6e8ea;
    }

    .timeline-item {
        position: relative;
        margin-bottom: 1.5rem;
    }

    .timeline-item:last-child {
        margin-bottom: 0;
    }

    .timeline-dot {
        position: absolute;
        left: -1.5rem;
        top: 0.25rem;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: #0052cc;
        border: 3px solid white;
        box-shadow: 0 0 0 2px #e6e8ea;
    }

    .timeline-content {
        padding-left: 0.5rem;
    }

    .timeline-date {
        font-size: 0.75rem;
        color: #434654;
        font-weight: 600;
        display: block;
        margin-bottom: 0.25rem;
    }

    .timeline-content p {
        color: #191c1e;
        font-size: 0.875rem;
    }

    .btn {
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-primary {
        background: #0052cc;
        color: white;
    }

    .btn-primary:hover {
        background: #003d9b;
        transform: translateY(-1px);
    }

    .btn-secondary {
        background: #e6e8ea;
        color: #191c1e;
    }

    .btn-secondary:hover {
        background: #d8dadc;
    }

    /* Modal */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-content {
        background: white;
        border-radius: 16px;
        width: 90%;
        max-width: 600px;
        max-height: 90vh;
        overflow-y: auto;
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 2rem;
        border-bottom: 1px solid #e6e8ea;
    }

    .modal-header h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
    }

    .icon-btn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: transparent;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

    .icon-btn:hover {
        background: #f7f9fb;
    }

    .modal-body {
        padding: 2rem;
    }

    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
        padding: 1.5rem 2rem;
        border-top: 1px solid #e6e8ea;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-group label {
        display: block;
        color: #434654;
        font-weight: 500;
        margin-bottom: 0.5rem;
    }

    .form-input {
        width: 100%;
        padding: 0.875rem 1rem;
        border: 1px solid #e6e8ea;
        border-radius: 8px;
        font-size: 0.9375rem;
        font-family: 'Inter', sans-serif;
        transition: all 0.2s;
    }

    .form-input:focus {
        outline: none;
        border-color: #0052cc;
        box-shadow: 0 0 0 3px rgba(0, 82, 204, 0.1);
    }

    .file-input {
        width: 100%;
        padding: 0.875rem 1rem;
        border: 2px dashed #e6e8ea;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .file-input:hover {
        border-color: #0052cc;
        background: #f7f9fb;
    }

    .file-preview {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.875rem 1rem;
        background: #f7f9fb;
        border-radius: 8px;
        margin-top: 0.75rem;
    }

    .file-preview i {
        color: #0052cc;
    }

    .alert {
        padding: 1rem;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .alert-error {
        background: #ffebee;
        color: #c62828;
        border: 1px solid #ef5350;
    }

    .alert-success {
        background: #e8f5e9;
        color: #2e7d32;
        border: 1px solid #66bb6a;
    }

    .alert i {
        font-size: 1.25rem;
    }

    .spinner-sm {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .loading-state,
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem 2rem;
        text-align: center;
    }

    .loading-state .spinner {
        width: 48px;
        height: 48px;
        border: 4px solid #f7f9fb;
        border-top-color: #0052cc;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-bottom: 1rem;
    }

    .empty-state i {
        font-size: 3rem;
        color: #434654;
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        font-size: 1.25rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: #434654;
        margin-bottom: 1.5rem;
    }

    .text-muted {
        color: #434654 !important;
    }

    .badge-other {
        background: #f3f4f6;
        color: #6b7280;
    }

    .record-icon.other {
        background: #f3f4f6;
        color: #6b7280;
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .content-grid {
            grid-template-columns: 1fr;
        }

        .records-section,
        .stats-card,
        .timeline-card {
            grid-column: span 1;
        }

        .search-box {
            min-width: 200px;
        }
    }

    @@media (max-width: 768px) {
        .filter-tabs {
            gap: 0.5rem;
        }

        .record-actions {
            flex-direction: column;
            align-items: flex-end;
        }

        .header-right {
            flex-direction: column;
        }
    }
</style>
