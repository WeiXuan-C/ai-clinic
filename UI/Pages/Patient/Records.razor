@page "/patient/records"
@layout Components.Layout.SidebarLayout

<PageTitle>Medical Records - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>Medical Records</h1>
        <p class="body-md" style="margin: 0.5rem;">
            <span class="status-indicator">●</span>
            Secure access to your complete medical history
        </p>
    </div>
    <div class="header-right">
        <button class="btn btn-secondary" @onclick="ShowExportDialog">
            <i data-lucide="download"></i>
            Export Records
        </button>
        <button class="btn btn-primary" @onclick="ShowUploadDialog">
            <i data-lucide="upload"></i>
            Upload Document
        </button>
    </div>
</header>

@* Export Options Dialog *@
@if (showExportDialog)
{
    <div class="modal-overlay" @onclick="CloseExportDialog">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Export Medical Records</h3>
                <button class="icon-btn" @onclick="CloseExportDialog">
                    <i data-lucide="x"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Export Range</label>
                    <select class="form-input" @bind="exportRange">
                        <option value="all">All Records</option>
                        <option value="custom">Custom Date Range</option>
                    </select>
                </div>

                @if (exportRange == "custom")
                {
                    <div class="form-group">
                        <label>Start Date</label>
                        <input type="date" class="form-input" @bind="exportStartDate" max="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="form-group">
                        <label>End Date</label>
                        <input type="date" class="form-input" @bind="exportEndDate" max="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                }

                @if (!string.IsNullOrEmpty(exportErrorMessage))
                {
                    <div class="alert alert-error">
                        <i data-lucide="alert-circle"></i>
                        <span>@exportErrorMessage</span>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseExportDialog">Cancel</button>
                <button class="btn btn-primary" @onclick="ExportRecords" disabled="@isExporting">
                    @if (isExporting)
                    {
                        <div class="spinner-sm"></div>
                        <span>Exporting...</span>
                    }
                    else
                    {
                        <i data-lucide="download"></i>
                        <span>Export to PDF</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

<!-- Upload Dialog -->
<!-- Hidden by default -->

<!-- Filter Tabs -->
<div class="filter-tabs">
    <button class="tab-btn active">
        All Records (5)
    </button>
    <button class="tab-btn">
        Lab Results (2)
    </button>
    <button class="tab-btn">
        Prescriptions (1)
    </button>
    <button class="tab-btn">
        Imaging (1)
    </button>
    <button class="tab-btn">
        Visit Notes (1)
    </button>
    <button class="tab-btn">
        Immunizations (0)
    </button>
</div>

<!-- Content Grid -->
<div class="content-grid">
    <!-- Recent Records -->
    <section class="records-section">
        <div class="section-header">
            <h2 class="headline-md">All Records</h2>
            <div class="search-box">
                <i data-lucide="search"></i>
                <input type="text" placeholder="Search records..." />
            </div>
        </div>
        
        <div class="records-list">
            <div class="record-item">
                <div class="record-icon lab">
                    <i data-lucide="flask-conical"></i>
                </div>
                <div class="record-info">
                    <h4 class="headline-sm">Blood Test Results</h4>
                    <p class="body-sm">Lab Result • October 15, 2023</p>
                    <p class="body-sm">Complete blood count analysis</p>
                    <p class="body-sm text-muted">2.4 MB</p>
                </div>
                <div class="record-actions">
                    <span class="badge badge-lab">LAB RESULT</span>
                    <button class="icon-btn-sm" title="View">
                        <i data-lucide="eye"></i>
                    </button>
                    <button class="icon-btn-sm" title="Download">
                        <i data-lucide="download"></i>
                    </button>
                    <button class="icon-btn-sm" title="Delete">
                        <i data-lucide="trash-2"></i>
                    </button>
                </div>
            </div>
            <div class="record-item">
                <div class="record-icon prescription">
                    <i data-lucide="pill"></i>
                </div>
                <div class="record-info">
                    <h4 class="headline-sm">Prescription - Lisinopril</h4>
                    <p class="body-sm">Prescription • October 12, 2023</p>
                    <p class="body-sm">Blood pressure medication</p>
                    <p class="body-sm text-muted">156 KB</p>
                </div>
                <div class="record-actions">
                    <span class="badge badge-prescription">PRESCRIPTION</span>
                    <button class="icon-btn-sm" title="View">
                        <i data-lucide="eye"></i>
                    </button>
                    <button class="icon-btn-sm" title="Download">
                        <i data-lucide="download"></i>
                    </button>
                    <button class="icon-btn-sm" title="Delete">
                        <i data-lucide="trash-2"></i>
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick Stats -->
    <section class="stats-card">
        <h3 class="headline-md">Record Summary</h3>
        <div class="stats-list">
            <div class="stat-item">
                <i data-lucide="file-text" class="stat-icon"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">5</h4>
                    <p class="body-sm">Total Records</p>
                </div>
            </div>
            <div class="stat-item">
                <i data-lucide="flask-conical" class="stat-icon"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">2</h4>
                    <p class="body-sm">Lab Results</p>
                </div>
            </div>
            <div class="stat-item">
                <i data-lucide="pill" class="stat-icon"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">1</h4>
                    <p class="body-sm">Prescriptions</p>
                </div>
            </div>
            <div class="stat-item">
                <i data-lucide="scan" class="stat-icon"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">1</h4>
                    <p class="body-sm">Imaging Studies</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Timeline View -->
    <section class="timeline-card">
        <div class="section-header">
            <h3 class="headline-md">Medical Timeline</h3>
        </div>
        <div class="timeline">
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="timeline-date">Oct 15, 2023</span>
                    <p class="body-md">Blood Test Results</p>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="timeline-date">Oct 12, 2023</span>
                    <p class="body-md">Prescription - Lisinopril</p>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
