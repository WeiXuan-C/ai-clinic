    }

    .badge-visit {
        background: #e8f5e9;
        color: #388e3c;
    }

    .badge-imaging {
        background: #fff3e0;
        color: #f57c00;
    }

    .badge-immunization {
        background: #fce4ec;
        color: #c2185b;
    }

    .badge-ai {
        background: #76f3ea;
        color: #006a65;
    }

    .icon-btn-sm {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: white;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

    .icon-btn-sm:hover {
        background: #e6e8ea;
    }

    /* Stats Card */
    .stats-card {
        grid-column: span 1;
        background: white;
        padding: 2rem;
        border-radius: 16px;
        height: fit-content;
    }

    .stats-card h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
        margin-bottom: 1.5rem;
    }

    .stats-list {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .stat-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem;
        background: #f7f9fb;
        border-radius: 12px;
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        min-width: 48px;
        background: #76f3ea;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: #006a65;
    }

    .stat-info h4 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #191c1e;
        margin-bottom: 0.25rem;
    }

    .stat-info p {
        color: #434654;
        font-size: 0.875rem;
    }

    /* Timeline Card */
    .timeline-card {
        grid-column: span 1;
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .timeline-card .section-header {
        margin-bottom: 1.5rem;
    }

    .timeline-card h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
    }

    .link-primary {
        color: #0052cc;
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 600;
    }

    .timeline {
        position: relative;
        padding-left: 2rem;
    }

    .timeline::before {
        content: '';
        position: absolute;
        left: 8px;
        top: 0;
        bottom: 0;
        width: 2px;
        background: #e6e8ea;
    }

    .timeline-item {
        position: relative;
        margin-bottom: 1.5rem;
    }

    .timeline-item:last-child {
        margin-bottom: 0;
    }

    .timeline-dot {
        position: absolute;
        left: -1.5rem;
        top: 0.25rem;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: #0052cc;
        border: 3px solid white;
        box-shadow: 0 0 0 2px #e6e8ea;
    }

    .timeline-content {
        padding-left: 0.5rem;
    }

    .timeline-date {
        font-size: 0.75rem;
        color: #434654;
        font-weight: 600;
        display: block;
        margin-bottom: 0.25rem;
    }

    .timeline-content p {
        color: #191c1e;
        font-size: 0.875rem;
    }

    .btn {
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-primary {
        background: #0052cc;
        color: white;
    }

    .btn-primary:hover {
        background: #003d9b;
        transform: translateY(-1px);
    }

    .btn-secondary {
        background: #e6e8ea;
        color: #191c1e;
    }

    .btn-secondary:hover {
        background: #d8dadc;
    }

    /* Modal */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-content {
        background: white;
