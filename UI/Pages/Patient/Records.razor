        color: #191c1e;
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: #434654;
        margin-bottom: 1.5rem;
    }

    .text-muted {
        color: #434654 !important;
    }

    .badge-other {
        background: #f3f4f6;
        color: #6b7280;
    }

    .record-icon.other {
        background: #f3f4f6;
        color: #6b7280;
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .content-grid {
            grid-template-columns: 1fr;
        }

        .records-section,
        .stats-card,
        .timeline-card {
            grid-column: span 1;
        }

        .search-box {
            min-width: 200px;
        }
    }

    @@media (max-width: 768px) {
        .filter-tabs {
