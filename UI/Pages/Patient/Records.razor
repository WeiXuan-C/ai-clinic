@page "/patient/records"
@layout Components.Layout.SidebarLayout

<PageTitle>Medical Records - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>Medical Records</h1>
        <p class="body-md" style="margin: 0.5rem;">
            <span class="status-indicator">●</span>
            Secure access to your complete medical history
        </p>
    </div>
    <div class="header-right">
        <button class="btn btn-secondary" @onclick="ShowExportDialog">
            <i data-lucide="download"></i>
            Export Records
        </button>
        <button class="btn btn-primary" @onclick="ShowUploadDialog">
            <i data-lucide="upload"></i>
            Upload Document
        </button>
    </div>
</header>

@* Export Options Dialog *@
@if (showExportDialog)
{
    <div class="modal-overlay" @onclick="CloseExportDialog">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Export Medical Records</h3>
                <button class="icon-btn" @onclick="CloseExportDialog">
                    <i data-lucide="x"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Export Range</label>
                    <select class="form-input" @bind="exportRange">
                        <option value="all">All Records</option>
                        <option value="custom">Custom Date Range</option>
                    </select>
                </div>

                @if (exportRange == "custom")
                {
                    <div class="form-group">
                        <label>Start Date</label>
                        <input type="date" class="form-input" @bind="exportStartDate" max="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="form-group">
                        <label>End Date</label>
                        <input type="date" class="form-input" @bind="exportEndDate" max="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                }

                @if (!string.IsNullOrEmpty(exportErrorMessage))
                {
                    <div class="alert alert-error">
                        <i data-lucide="alert-circle"></i>
                        <span>@exportErrorMessage</span>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseExportDialog">Cancel</button>
                <button class="btn btn-primary" @onclick="ExportRecords" disabled="@isExporting">
                    @if (isExporting)
                    {
                        <div class="spinner-sm"></div>
                        <span>Exporting...</span>
                    }
                    else
                    {
                        <i data-lucide="download"></i>
                        <span>Export to PDF</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

<!-- Upload Dialog -->
@if (showUploadModal)
{
    <div class="modal-overlay" @onclick="CloseUploadDialog">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Upload Medical Document</h3>
                <button class="icon-btn" @onclick="CloseUploadDialog">
                    <i data-lucide="x"></i>
                </button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-error">
                        <i data-lucide="alert-circle"></i>
                        <span>@errorMessage</span>
                    </div>
                }
                <div class="form-group">
                    <label>Title *</label>
                    <input class="form-input" @bind="uploadTitle" placeholder="Blood Test Results" />
                </div>
                <div class="form-group">
                    <label>Document Type *</label>
                    <select class="form-input" @bind="uploadType">
                        <option value="">Select type...</option>
                        <option value="Lab Result">Lab Result</option>
                        <option value="Prescription">Prescription</option>
                        <option value="Imaging">Imaging</option>
                        <option value="Visit Note">Visit Note</option>
                        <option value="Immunization">Immunization</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea class="form-input" rows="3" @bind="uploadDescription"></textarea>
                </div>
                <div class="form-group">
                    <label>File *</label>
                    <InputFile class="file-input" OnChange="OnFileSelected" />
                    @if (selectedFile != null)
                    {
                        <div class="file-preview">
                            <i data-lucide="file"></i>
                            <span>@selectedFile.Name (@FormatFileSize(selectedFile.Size))</span>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseUploadDialog">Cancel</button>
                <button class="btn btn-primary" @onclick="UploadDocument" disabled="@isUploading">
                    @if (isUploading)
                    {
                        <div class="spinner-sm"></div>
                        <span>Uploading...</span>
                    }
                    else
                    {
                        <i data-lucide="upload"></i>
                        <span>Upload</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

<!-- Filter Tabs -->
<div class="filter-tabs">
    <button class="tab-btn @(selectedFilter == "All" ? "active" : "")" @onclick="@(() => FilterRecords("All"))">
        All Records (@(recordsData?.Statistics.TotalRecords ?? 0))
    </button>
    <button class="tab-btn @(selectedFilter == "Lab Results" ? "active" : "")" @onclick="@(() => FilterRecords("Lab Results"))">
        Lab Results (@(recordsData?.Statistics.LabResults ?? 0))
    </button>
    <button class="tab-btn @(selectedFilter == "Prescriptions" ? "active" : "")" @onclick="@(() => FilterRecords("Prescriptions"))">
        Prescriptions (@(recordsData?.Statistics.Prescriptions ?? 0))
    </button>
    <button class="tab-btn @(selectedFilter == "Imaging" ? "active" : "")" @onclick="@(() => FilterRecords("Imaging"))">
        Imaging (@(recordsData?.Statistics.ImagingStudies ?? 0))
    </button>
    <button class="tab-btn @(selectedFilter == "Visit Notes" ? "active" : "")" @onclick="@(() => FilterRecords("Visit Notes"))">
        Visit Notes (@(recordsData?.Statistics.VisitNotes ?? 0))
    </button>
    <button class="tab-btn @(selectedFilter == "Immunizations" ? "active" : "")" @onclick="@(() => FilterRecords("Immunizations"))">
        Immunizations (@(recordsData?.Statistics.Immunizations ?? 0))
    </button>
</div>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success">
        <i data-lucide="check-circle"></i>
        <span>@successMessage</span>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage) && !showUploadModal)
{
    <div class="alert alert-error">
        <i data-lucide="alert-circle"></i>
        <span>@errorMessage</span>
    </div>
}

<!-- Content Grid -->
<div class="content-grid">
    <!-- Recent Records -->
    <section class="records-section">
        <div class="section-header">
            <h2 class="headline-md">All Records</h2>
            <div class="search-box">
                <i data-lucide="search"></i>
                <input type="text" placeholder="Search records..." value="@searchQuery" @oninput="OnSearchChanged" />
            </div>
        </div>
        
        <div class="records-list">
            @if (isLoading)
            {
                <div class="loading-state">
                    <div class="spinner"></div>
                    <p class="body-md">Loading records...</p>
                </div>
            }
            else if (!filteredRecords.Any())
            {
                <div class="empty-state">
                    <i data-lucide="folder-open"></i>
                    <h3>No records found</h3>
                    <p>Uploaded documents and consultation records will appear here.</p>
                </div>
            }
            else
            {
                @foreach (var record in filteredRecords)
                {
                    <div class="record-item">
                        <div class="record-icon @GetRecordIconClass(record.Type)">
                            <i data-lucide="file-text"></i>
                        </div>
                        <div class="record-info">
                            <h4 class="headline-sm">@record.Title</h4>
                            <p class="body-sm">@record.Type - @FormatDate(record.Date)</p>
                            <p class="body-sm">@record.Description</p>
                            @if (record.FileSize > 0)
                            {
                                <p class="body-sm text-muted">@FormatFileSize(record.FileSize)</p>
                            }
                        </div>
                        <div class="record-actions">
                            <span class="badge @GetBadgeClass(record.Type)">@record.Type.ToUpperInvariant()</span>
                            <button class="icon-btn-sm" title="Preview" @onclick="@(() => PreviewRecord(record.Id, record.RecordCategory))">
                                <i data-lucide="eye"></i>
                            </button>
                            <button class="icon-btn-sm" title="Download" @onclick="@(() => DownloadRecord(record.Id, record.RecordCategory))">
                                <i data-lucide="download"></i>
                            </button>
                            <button class="icon-btn-sm" title="Delete" @onclick="@(() => DeleteRecord(record.Id, record.RecordCategory))">
                                <i data-lucide="trash-2"></i>
                            </button>
                        </div>
                    </div>
                }
            }
            @*
            <div class="record-item">
                <div class="record-icon lab">
                    <i data-lucide="flask-conical"></i>
                </div>
                <div class="record-info">
                    <h4 class="headline-sm">Blood Test Results</h4>
