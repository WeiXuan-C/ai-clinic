        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
    }

    .link-primary {
        color: #0052cc;
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 600;
    }

    .timeline {
        position: relative;
        padding-left: 2rem;
    }

    .timeline::before {
        content: '';
