@page "/patient/records"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout Components.Layout.SidebarLayout

<PageTitle>Medical Records - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>Medical Records</h1>
        <p class="body-md" style="margin: 0.5rem;">
            <span class="status-indicator">●</span>
            Secure access to your complete medical history
        </p>
    </div>
    <div class="header-right">
        <button class="btn btn-secondary">
            <i data-lucide="download"></i>
            Export Records
        </button>
        <button class="btn btn-primary">
            <i data-lucide="upload"></i>
            Upload Document
        </button>
    </div>
</header>

<!-- Filter Tabs -->
<div class="filter-tabs">
    <button class="tab-btn active">All Records</button>
    <button class="tab-btn">Lab Results</button>
    <button class="tab-btn">Prescriptions</button>
    <button class="tab-btn">Imaging</button>
    <button class="tab-btn">Visit Notes</button>
    <button class="tab-btn">Immunizations</button>
</div>

<!-- Content Grid -->
<div class="content-grid">
    <!-- Recent Records -->
    <section class="records-section">
        <div class="section-header">
            <h2 class="headline-md">Recent Records</h2>
            <div class="search-box">
                <i data-lucide="search"></i>
                <input type="text" placeholder="Search records..." />
            </div>
        </div>
        
        <div class="records-list">
            <!-- Lab Result -->
            <div class="record-item">
                <div class="record-icon lab">
                    <i data-lucide="flask-conical"></i>
                </div>
                <div class="record-info">
                    <h4 class="headline-sm">Complete Blood Count (CBC)</h4>
                    <p class="body-sm">Lab Results • October 15, 2023</p>
                    <p class="body-sm">Dr. Helena Vance • Quest Diagnostics</p>
                </div>
                <div class="record-actions">
                    <span class="badge badge-lab">LAB RESULT</span>
                    <button class="icon-btn-sm">
                        <i data-lucide="eye"></i>
                    </button>
                    <button class="icon-btn-sm">
                        <i data-lucide="download"></i>
                    </button>
                </div>
            </div>

            <!-- Prescription -->
            <div class="record-item">
                <div class="record-icon prescription">
                    <i data-lucide="pill"></i>
                </div>
                <div class="record-info">
                    <h4 class="headline-sm">Lisinopril 10mg Prescription</h4>
                    <p class="body-sm">Prescription • October 12, 2023</p>
                    <p class="body-sm">Dr. Michael Chen • 90-day supply</p>
                </div>
                <div class="record-actions">
                    <span class="badge badge-prescription">PRESCRIPTION</span>
                    <button class="icon-btn-sm">
                        <i data-lucide="eye"></i>
                    </button>
                    <button class="icon-btn-sm">
                        <i data-lucide="download"></i>
                    </button>
                </div>
            </div>

            <!-- Visit Note -->
            <div class="record-item">
                <div class="record-icon visit">
                    <i data-lucide="file-text"></i>
                </div>
                <div class="record-info">
                    <h4 class="headline-sm">Annual Physical Examination</h4>
                    <p class="body-sm">Visit Notes • October 10, 2023</p>
                    <p class="body-sm">Dr. Michael Chen • Primary Care</p>
                </div>
                <div class="record-actions">
                    <span class="badge badge-visit">VISIT NOTE</span>
                    <button class="icon-btn-sm">
                        <i data-lucide="eye"></i>
                    </button>
                    <button class="icon-btn-sm">
                        <i data-lucide="download"></i>
                    </button>
                </div>
            </div>

            <!-- Imaging -->
            <div class="record-item">
                <div class="record-icon imaging">
                    <i data-lucide="scan"></i>
                </div>
                <div class="record-info">
                    <h4 class="headline-sm">Chest X-Ray</h4>
                    <p class="body-sm">Imaging • September 28, 2023</p>
                    <p class="body-sm">Dr. Sarah Williams • Radiology Dept</p>
                </div>
                <div class="record-actions">
                    <span class="badge badge-imaging">IMAGING</span>
                    <button class="icon-btn-sm">
                        <i data-lucide="eye"></i>
                    </button>
                    <button class="icon-btn-sm">
                        <i data-lucide="download"></i>
                    </button>
                </div>
            </div>

            <!-- Immunization -->
            <div class="record-item">
                <div class="record-icon immunization">
                    <i data-lucide="syringe"></i>
                </div>
                <div class="record-info">
                    <h4 class="headline-sm">Influenza Vaccine</h4>
                    <p class="body-sm">Immunization • September 15, 2023</p>
                    <p class="body-sm">Nurse Jennifer Lee • Preventive Care</p>
                </div>
                <div class="record-actions">
                    <span class="badge badge-immunization">IMMUNIZATION</span>
                    <button class="icon-btn-sm">
                        <i data-lucide="eye"></i>
                    </button>
                    <button class="icon-btn-sm">
                        <i data-lucide="download"></i>
                    </button>
                </div>
            </div>

            <!-- AI Analysis -->
            <div class="record-item">
                <div class="record-icon ai">
                    <i data-lucide="brain"></i>
                </div>
                <div class="record-info">
                    <h4 class="headline-sm">AI Health Risk Assessment</h4>
                    <p class="body-sm">AI Analysis • September 10, 2023</p>
                    <p class="body-sm">Clinical AI Assistant • Predictive Analytics</p>
                </div>
                <div class="record-actions">
                    <span class="badge badge-ai">AI ANALYSIS</span>
                    <button class="icon-btn-sm">
                        <i data-lucide="eye"></i>
                    </button>
                    <button class="icon-btn-sm">
                        <i data-lucide="download"></i>
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick Stats -->
    <section class="stats-card">
        <h3 class="headline-md">Record Summary</h3>
        <div class="stats-list">
            <div class="stat-item">
                <i data-lucide="file-text" class="stat-icon"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">247</h4>
                    <p class="body-sm">Total Records</p>
                </div>
            </div>
            <div class="stat-item">
                <i data-lucide="flask-conical" class="stat-icon"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">42</h4>
                    <p class="body-sm">Lab Results</p>
                </div>
            </div>
            <div class="stat-item">
                <i data-lucide="pill" class="stat-icon"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">18</h4>
                    <p class="body-sm">Prescriptions</p>
                </div>
            </div>
            <div class="stat-item">
                <i data-lucide="scan" class="stat-icon"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">12</h4>
                    <p class="body-sm">Imaging Studies</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Timeline View -->
    <section class="timeline-card">
        <div class="section-header">
            <h3 class="headline-md">Medical Timeline</h3>
            <button class="link-primary">View Full Timeline</button>
        </div>
        <div class="timeline">
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="timeline-date">Oct 15, 2023</span>
                    <p class="body-md">Blood work completed</p>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="timeline-date">Oct 12, 2023</span>
                    <p class="body-md">Prescription renewed</p>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="timeline-date">Oct 10, 2023</span>
                    <p class="body-md">Annual physical exam</p>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="timeline-date">Sep 28, 2023</span>
                    <p class="body-md">Chest X-ray performed</p>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="timeline-date">Sep 15, 2023</span>
                    <p class="body-md">Flu vaccine administered</p>
                </div>
            </div>
        </div>
    </section>
</div>

