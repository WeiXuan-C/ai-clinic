@page "/patient/profile-mud"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout Components.Layout.SidebarLayout
@inject AuthController AuthController
@inject AuthState AuthState
@inject PatientController PatientController
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>My Profile - AI Medical Clinic</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    @if (!AuthState.IsAuthenticated)
    {
        <MudPaper Class="pa-8 text-center">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.body1" Class="mt-4">Checking authentication...</MudText>
        </MudPaper>
    }
    else if (isLoading)
    {
        <MudPaper Class="pa-8 text-center">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.body1" Class="mt-4">Loading profile...</MudText>
        </MudPaper>
    }
    else
    {
        <MudText Typo="Typo.h4" Class="mb-2">My Profile</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
            Manage your personal and medical information
        </MudText>

        <MudGrid>
            <!-- Profile Photo Card -->
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-6 text-center" Elevation="2">
                    <MudAvatar Size="Size.Large" Style="width: 120px; height: 120px; margin: 0 auto;">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" />
                    </MudAvatar>
                    
                    <MudText Typo="Typo.h6" Class="mt-4">@(profile?.FullName ?? "No Name")</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@AuthState.CurrentUser?.Email</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                        Member since @(profile?.CreatedAt.ToString("MMMM yyyy") ?? "N/A")
                    </MudText>
                    
                    @if (isEditing)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CameraAlt" Class="mt-4" FullWidth="true">
                            Change Photo
                        </MudButton>
                    }
                </MudPaper>
            </MudItem>

            <!-- Profile Form -->
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-6" Elevation="2">
                    <div class="d-flex justify-space-between align-center mb-4">
                        <MudText Typo="Typo.h6">Personal Information</MudText>
                        <div>
                            @if (isEditing)
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Error" StartIcon="@Icons.Material.Filled.Close" OnClick="CancelEdit" Class="mr-2">
                                    Cancel
                                </MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Check" OnClick="SaveChanges" Disabled="@isSaving">
                                    @(isSaving ? "Saving..." : "Save")
                                </MudButton>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" OnClick="EnableEdit">
                                    Edit Profile
                                </MudButton>
                            }
                        </div>
                    </div>

                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="fullName" Label="Full Name" Variant="Variant.Outlined" Disabled="@(!isEditing)" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudDatePicker @bind-Date="dateOfBirth" Label="Date of Birth" Variant="Variant.Outlined" Disabled="@(!isEditing)" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Value="@AuthState.CurrentUser?.Email" Label="Email Address" Variant="Variant.Outlined" Disabled="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect @bind-Value="gender" Label="Gender" Variant="Variant.Outlined" Disabled="@(!isEditing)">
                                <MudSelectItem Value="@("")">Select Gender</MudSelectItem>
                                <MudSelectItem Value="@("Male")">Male</MudSelectItem>
                                <MudSelectItem Value="@("Female")">Female</MudSelectItem>
                                <MudSelectItem Value="@("Other")">Other</MudSelectItem>
                                <MudSelectItem Value="@("Prefer not to say")">Prefer not to say</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="address" Label="Address" Variant="Variant.Outlined" Lines="2" Disabled="@(!isEditing)" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                <!-- Medical Information -->
                <MudPaper Class="pa-6 mt-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-4">Medical Information</MudText>
                    
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudSelect @bind-Value="bloodType" Label="Blood Type" Variant="Variant.Outlined" Disabled="@(!isEditing)">
                                <MudSelectItem Value="@("")">Select Blood Type</MudSelectItem>
                                <MudSelectItem Value="@("O+")">O+</MudSelectItem>
                                <MudSelectItem Value="@("O-")">O-</MudSelectItem>
                                <MudSelectItem Value="@("A+")">A+</MudSelectItem>
                                <MudSelectItem Value="@("A-")">A-</MudSelectItem>
                                <MudSelectItem Value="@("B+")">B+</MudSelectItem>
                                <MudSelectItem Value="@("B-")">B-</MudSelectItem>
                                <MudSelectItem Value="@("AB+")">AB+</MudSelectItem>
                                <MudSelectItem Value="@("AB-")">AB-</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="allergiesInput" Label="Allergies (comma-separated)" Variant="Variant.Outlined" Lines="3" 
                                          Disabled="@(!isEditing)" HelperText="e.g., Penicillin, Peanuts, Shellfish" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="currentMedicationsInput" Label="Current Medications (comma-separated)" Variant="Variant.Outlined" Lines="3"
                                          Disabled="@(!isEditing)" HelperText="e.g., Lisinopril 10mg daily, Metformin 500mg" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="chronicConditionsInput" Label="Chronic Conditions (comma-separated)" Variant="Variant.Outlined" Lines="3"
                                          Disabled="@(!isEditing)" HelperText="e.g., Type 2 Diabetes, Hypertension" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                <!-- Emergency Contact -->
                <MudPaper Class="pa-6 mt-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-4">Emergency Contact</MudText>
                    
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="emergencyContactName" Label="Contact Name" Variant="Variant.Outlined" Disabled="@(!isEditing)" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="emergencyContactPhone" Label="Phone Number" Variant="Variant.Outlined" Disabled="@(!isEditing)" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private bool isLoading = true;
    private bool isEditing = false;
    private bool isSaving = false;

    private PatientProfile? profile;
    private PatientProfile? originalProfile;

    // Form fields
    private string? fullName;
    private DateTime? dateOfBirth;
    private string? gender;
    private string? address;
    private string? emergencyContactName;
    private string? emergencyContactPhone;
    private string? bloodType;
    private string? allergiesInput;
    private string? chronicConditionsInput;
    private string? currentMedicationsInput;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/auth/signin");
            return;
        }
        
        await LoadProfile();
    }

    private async Task LoadProfile()
    {
        try
        {
            isLoading = true;

            if (AuthState.CurrentUser == null)
            {
                Snackbar.Add("Please sign in to view your profile.", Severity.Warning);
                await Task.Delay(1500);
                Navigation.NavigateTo("/auth/signin");
                return;
            }

            profile = await PatientController.GetProfileAsync(AuthState.CurrentUser.Id);

            if (profile != null)
            {
                originalProfile = profile;
                PopulateFormFields(profile);
            }
            else
            {
                Snackbar.Add("Profile not found. Please create your profile first.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading profile: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void PopulateFormFields(PatientProfile profileData)
    {
        fullName = profileData.FullName;
        dateOfBirth = profileData.DateOfBirth;
        gender = profileData.Gender;
        address = profileData.Address;
        emergencyContactName = profileData.EmergencyContactName;
        emergencyContactPhone = profileData.EmergencyContactPhone;
        bloodType = profileData.BloodType;
        allergiesInput = profileData.Allergies != null ? string.Join(", ", profileData.Allergies) : null;
        chronicConditionsInput = profileData.ChronicConditions != null ? string.Join(", ", profileData.ChronicConditions) : null;
        currentMedicationsInput = profileData.CurrentMedications != null ? string.Join(", ", profileData.CurrentMedications) : null;
    }

    private void EnableEdit()
    {
        isEditing = true;
    }

    private void CancelEdit()
    {
        isEditing = false;
        
        if (originalProfile != null)
        {
            PopulateFormFields(originalProfile);
        }
    }

    private async Task SaveChanges()
    {
        try
        {
            isSaving = true;

            if (AuthState.CurrentUser == null)
            {
                Snackbar.Add("User not authenticated", Severity.Error);
                return;
            }

            var request = new UpdatePatientProfileRequest(
                FullName: fullName,
                DateOfBirth: dateOfBirth,
                Gender: gender,
                Address: address,
                EmergencyContactName: emergencyContactName,
                EmergencyContactPhone: emergencyContactPhone,
                BloodType: bloodType,
                Allergies: ParseCommaSeparated(allergiesInput),
                ChronicConditions: ParseCommaSeparated(chronicConditionsInput),
                CurrentMedications: ParseCommaSeparated(currentMedicationsInput)
            );

            profile = await PatientController.UpdateProfileAsync(AuthState.CurrentUser.Id, request);
            originalProfile = profile;

            Snackbar.Add("Profile updated successfully!", Severity.Success);
            isEditing = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving profile: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }

    private string[]? ParseCommaSeparated(string? input)
    {
        if (string.IsNullOrWhiteSpace(input))
            return null;

        return input.Split(',')
            .Select(s => s.Trim())
            .Where(s => !string.IsNullOrEmpty(s))
            .ToArray();
    }
}
