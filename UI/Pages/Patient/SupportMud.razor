@page "/patient/support-mud"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout Components.Layout.SidebarLayout
@inject AuthState AuthState
@inject PatientController PatientController
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Support - AI Medical Clinic</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    @if (!AuthState.IsAuthenticated)
    {
        <MudPaper Class="pa-8 text-center">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.body1" Class="mt-4">Checking authentication...</MudText>
        </MudPaper>
    }
    else
    {
        <div class="d-flex justify-space-between align-center mb-6">
            <div>
                <MudText Typo="Typo.h4" Class="mb-2">Help & Support</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small" Color="Color.Success" /> We're here to help 24/7
                </MudText>
            </div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Chat">
                Start Live Chat
            </MudButton>
        </div>

        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Class="pa-6">
            <!-- Submit Ticket Tab -->
            <MudTabPanel Text="Submit Ticket" Icon="@Icons.Material.Filled.Add">
                <MudGrid>
                    <MudItem xs="12" md="8">
                        <MudPaper Class="pa-6" Elevation="0">
                            <MudText Typo="Typo.h6" Class="mb-4">Create Support Ticket</MudText>
                            
                            <MudForm @ref="form" @bind-IsValid="@formIsValid">
                                <MudTextField @bind-Value="ticketSubject" Label="Subject" Variant="Variant.Outlined" 
                                              Required="true" RequiredError="Subject is required" Class="mb-4" />
                                
                                <MudSelect @bind-Value="ticketCategory" Label="Category" Variant="Variant.Outlined" Class="mb-4">
                                    <MudSelectItem Value="@("technical")">Technical Support</MudSelectItem>
                                    <MudSelectItem Value="@("billing")">Billing Question</MudSelectItem>
                                    <MudSelectItem Value="@("medical")">Medical Records</MudSelectItem>
                                    <MudSelectItem Value="@("account")">Account Issue</MudSelectItem>
                                    <MudSelectItem Value="@("other")">General Inquiry</MudSelectItem>
                                </MudSelect>
                                
                                <MudSelect @bind-Value="ticketPriority" Label="Priority" Variant="Variant.Outlined" Class="mb-4">
                                    <MudSelectItem Value="@("low")">Low</MudSelectItem>
                                    <MudSelectItem Value="@("medium")">Medium</MudSelectItem>
                                    <MudSelectItem Value="@("high")">High</MudSelectItem>
                                    <MudSelectItem Value="@("urgent")">Urgent</MudSelectItem>
                                </MudSelect>
                                
                                <MudTextField @bind-Value="ticketDescription" Label="Description" Variant="Variant.Outlined" 
                                              Lines="6" Required="true" RequiredError="Description is required" 
                                              HelperText="Describe your issue or question in detail" Class="mb-4" />
                                
                                <MudFileUpload T="IBrowserFile" OnFilesChanged="HandleFileUpload" Accept=".pdf,.jpg,.jpeg,.png,.doc,.docx">
                                    <CustomContent>
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.AttachFile"
                                                   OnClick="@context.OpenFilePickerAsync">
                                            Attach Files
                                        </MudButton>
                                    </CustomContent>
                                </MudFileUpload>
                                
                                @if (uploadedFiles.Any())
                                {
                                    <MudChipSet T="string" Class="mt-2">
                                        @foreach (var file in uploadedFiles)
                                        {
                                            <MudChip T="string" Text="@file.Name" OnClose="() => RemoveFile(file)" />
                                        }
                                    </MudChipSet>
                                }
                                
                                <div class="d-flex justify-end mt-6">
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                                               OnClick="SubmitTicket" Disabled="@(!formIsValid || isSubmitting)">
                                        @(isSubmitting ? "Submitting..." : "Submit Ticket")
                                    </MudButton>
                                </div>
                            </MudForm>
                        </MudPaper>
                    </MudItem>
                    
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-6" Elevation="0">
                            <MudText Typo="Typo.h6" Class="mb-4">Quick Actions</MudText>
                            
                            <MudList T="string">
                                <MudListItem T="string" Icon="@Icons.Material.Filled.Chat" IconColor="Color.Primary">
                                    <MudText Typo="Typo.subtitle1">Live Chat</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Chat with our support team</MudText>
                                </MudListItem>
                                <MudListItem T="string" Icon="@Icons.Material.Filled.Phone" IconColor="Color.Primary">
                                    <MudText Typo="Typo.subtitle1">Call Us</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">1-800-AI-CLINIC</MudText>
                                </MudListItem>
                                <MudListItem T="string" Icon="@Icons.Material.Filled.Email" IconColor="Color.Primary">
                                    <MudText Typo="Typo.subtitle1">Email</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">support@aiclinic.com</MudText>
                                </MudListItem>
                                <MudListItem T="string" Icon="@Icons.Material.Filled.Book" IconColor="Color.Primary">
                                    <MudText Typo="Typo.subtitle1">Help Center</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Browse articles & guides</MudText>
                                </MudListItem>
                            </MudList>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            <!-- My Tickets Tab -->
            <MudTabPanel Text="My Tickets" Icon="@Icons.Material.Filled.List">
                @if (isLoadingTickets)
                {
                    <div class="text-center pa-8">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                        <MudText Typo="Typo.body1" Class="mt-4">Loading tickets...</MudText>
                    </div>
                }
                else if (!myTickets.Any())
                {
                    <MudAlert Severity="Severity.Info">You haven't submitted any support tickets yet.</MudAlert>
                }
                else
                {
                    <MudTable Items="@myTickets" Hover="true" Breakpoint="Breakpoint.Sm" Dense="true">
                        <HeaderContent>
                            <MudTh>Subject</MudTh>
                            <MudTh>Category</MudTh>
                            <MudTh>Priority</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Created</MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Subject">@context.Subject</MudTd>
                            <MudTd DataLabel="Category">
                                <MudChip T="string" Size="Size.Small" Color="Color.Default">@context.Category</MudChip>
                            </MudTd>
                            <MudTd DataLabel="Priority">
                                <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(context.Priority)">@context.Priority</MudChip>
                            </MudTd>
                            <MudTd DataLabel="Status">
                                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
                            </MudTd>
                            <MudTd DataLabel="Created">@context.CreatedAt.ToString("MMM dd, yyyy")</MudTd>
                            <MudTd DataLabel="Actions">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Primary" 
                                               OnClick="() => ViewTicket(context.Id)" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudTabPanel>

            <!-- FAQ Tab -->
            <MudTabPanel Text="FAQ" Icon="@Icons.Material.Filled.Help">
                <MudExpansionPanels MultiExpansion="true">
                    <MudExpansionPanel Text="How do I schedule an appointment?">
                        <MudText Typo="Typo.body2">
                            You can schedule an appointment by clicking on "Book Doctor Visit" from your dashboard or navigating to the Consultation page. 
                            Select your preferred doctor, date, and time slot.
                        </MudText>
                    </MudExpansionPanel>
                    
                    <MudExpansionPanel Text="How do I access my medical records?">
                        <MudText Typo="Typo.body2">
                            Navigate to the "Medical Records" section from the sidebar menu. You can view, download, and share your records securely from there.
                        </MudText>
                    </MudExpansionPanel>
                    
                    <MudExpansionPanel Text="Is my health data secure?">
                        <MudText Typo="Typo.body2">
                            Yes, we use bank-level encryption and are fully HIPAA compliant. Your data is encrypted both in transit and at rest, 
                            and we never share your information without your explicit consent.
                        </MudText>
                    </MudExpansionPanel>
                    
                    <MudExpansionPanel Text="How does the AI assistant work?">
                        <MudText Typo="Typo.body2">
                            Our AI assistant uses advanced machine learning to analyze your symptoms and health data. It provides preliminary assessments 
                            but always recommends consulting with a licensed physician for diagnosis and treatment.
                        </MudText>
                    </MudExpansionPanel>
                    
                    <MudExpansionPanel Text="Can I connect my wearable devices?">
                        <MudText Typo="Typo.body2">
                            Yes! We support Apple Watch, Fitbit, Garmin, and other popular wearables. Go to Settings > Connected Devices to link your devices.
                        </MudText>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudTabPanel>
        </MudTabs>
    }
</MudContainer>

@code {
    private MudForm? form;
    private bool formIsValid;
    private bool isSubmitting = false;
    private bool isLoadingTickets = false;

    private string ticketSubject = string.Empty;
    private string ticketCategory = "technical";
    private string ticketPriority = "medium";
    private string ticketDescription = string.Empty;
    private List<IBrowserFile> uploadedFiles = new();
    private List<SupportTicket> myTickets = new();

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/auth/signin");
            return;
        }
        
        await LoadTickets();
    }

    private async Task LoadTickets()
    {
        try
        {
            isLoadingTickets = true;

            if (AuthState.CurrentUser != null)
            {
                var tickets = await PatientController.GetUserSupportTicketsAsync(AuthState.CurrentUser.Id);
                myTickets = tickets.ToList();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading tickets: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoadingTickets = false;
        }
    }

    private void HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            uploadedFiles.Add(file);
        }
    }

    private void RemoveFile(IBrowserFile file)
    {
        uploadedFiles.Remove(file);
    }

    private async Task SubmitTicket()
    {
        try
        {
            isSubmitting = true;

            if (AuthState.CurrentUser == null)
            {
                Snackbar.Add("User not authenticated", Severity.Error);
                return;
            }

            var request = new CreateSupportTicketRequest(
                UserId: AuthState.CurrentUser.Id,
                Subject: ticketSubject,
                Description: ticketDescription,
                Category: ticketCategory,
                Priority: ticketPriority
            );

            var (success, message, ticket) = await PatientController.CreateSupportTicketAsync(request);

            if (success)
            {
                Snackbar.Add("Support ticket submitted successfully! We'll get back to you soon.", Severity.Success);
                
                // Reset form
                ticketSubject = string.Empty;
                ticketDescription = string.Empty;
                ticketCategory = "technical";
                ticketPriority = "medium";
                uploadedFiles.Clear();
                
                // Reload tickets
                await LoadTickets();
            }
            else
            {
                Snackbar.Add(message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error submitting ticket: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ViewTicket(Guid ticketId)
    {
        Snackbar.Add("Ticket details view coming soon", Severity.Info);
    }

    private Color GetPriorityColor(string priority)
    {
        return priority.ToLower() switch
        {
            "urgent" => Color.Error,
            "high" => Color.Warning,
            "medium" => Color.Info,
            "low" => Color.Default,
            _ => Color.Default
        };
    }

    private Color GetStatusColor(string status)
    {
        return status.ToLower() switch
        {
            "open" => Color.Info,
            "in_progress" => Color.Warning,
            "resolved" => Color.Success,
            "closed" => Color.Default,
            _ => Color.Default
        };
    }
}
