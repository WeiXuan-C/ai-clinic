@page "/doctor/analytics"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout Components.Layout.DoctorSidebarLayout

<PageTitle>Analytics - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>Analytics & Insights</h1>
        <p class="body-md" style="margin: 0.5rem;">
            <span class="status-indicator">●</span>
            Track your performance and patient outcomes
        </p>
    </div>
    <div class="header-right">
        <select class="period-selector">
            <option value="week">This Week</option>
            <option value="month" selected>This Month</option>
            <option value="quarter">This Quarter</option>
            <option value="year">This Year</option>
        </select>
        <button class="btn btn-primary">
            <i data-lucide="download"></i>
            Export Report
        </button>
    </div>
</header>

<!-- Content Grid -->
<div class="content-grid">
    <!-- Key Metrics -->
    <section class="metrics-section">
        <h2 class="headline-md">Key Metrics</h2>
        <div class="metrics-grid">
            <div class="metric-card">
                <div class="metric-header">
                    <i data-lucide="users" class="metric-icon"></i>
                    <span class="trend positive">+12%</span>
                </div>
                <h3 class="metric-value">542</h3>
                <p class="metric-label">Total Patients</p>
                <div class="metric-chart">
                    <div class="chart-bar" style="height: 40%"></div>
                    <div class="chart-bar" style="height: 60%"></div>
                    <div class="chart-bar" style="height: 45%"></div>
                    <div class="chart-bar" style="height: 80%"></div>
                    <div class="chart-bar" style="height: 100%"></div>
                </div>
            </div>

            <div class="metric-card">
                <div class="metric-header">
                    <i data-lucide="calendar-check" class="metric-icon"></i>
                    <span class="trend positive">+8%</span>
                </div>
                <h3 class="metric-value">187</h3>
                <p class="metric-label">Consultations</p>
                <div class="metric-chart">
                    <div class="chart-bar" style="height: 60%"></div>
                    <div class="chart-bar" style="height: 70%"></div>
                    <div class="chart-bar" style="height: 55%"></div>
                    <div class="chart-bar" style="height: 90%"></div>
                    <div class="chart-bar" style="height: 100%"></div>
                </div>
            </div>

            <div class="metric-card">
                <div class="metric-header">
                    <i data-lucide="clock" class="metric-icon"></i>
                    <span class="trend positive">-5%</span>
                </div>
                <h3 class="metric-value">18 min</h3>
                <p class="metric-label">Avg Response Time</p>
                <div class="metric-chart">
                    <div class="chart-bar" style="height: 100%"></div>
                    <div class="chart-bar" style="height: 80%"></div>
                    <div class="chart-bar" style="height: 70%"></div>
                    <div class="chart-bar" style="height: 60%"></div>
                    <div class="chart-bar" style="height: 50%"></div>
                </div>
            </div>

            <div class="metric-card">
                <div class="metric-header">
                    <i data-lucide="star" class="metric-icon"></i>
                    <span class="trend positive">+2%</span>
                </div>
                <h3 class="metric-value">4.9</h3>
                <p class="metric-label">Patient Rating</p>
                <div class="metric-chart">
                    <div class="chart-bar" style="height: 85%"></div>
                    <div class="chart-bar" style="height: 88%"></div>
                    <div class="chart-bar" style="height: 90%"></div>
                    <div class="chart-bar" style="height: 95%"></div>
                    <div class="chart-bar" style="height: 100%"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- Patient Demographics -->
    <section class="demographics-section">
        <div class="section-header">
            <h2 class="headline-md">Patient Demographics</h2>
        </div>
        <div class="demographics-grid">
            <div class="demo-card">
                <h4 class="headline-sm">Age Distribution</h4>
                <div class="demo-bars">
                    <div class="demo-bar-item">
                        <span class="demo-label">18-30</span>
                        <div class="demo-bar">
                            <div class="demo-fill" style="width: 25%"></div>
                        </div>
                        <span class="demo-value">25%</span>
                    </div>
                    <div class="demo-bar-item">
                        <span class="demo-label">31-45</span>
                        <div class="demo-bar">
                            <div class="demo-fill" style="width: 35%"></div>
                        </div>
                        <span class="demo-value">35%</span>
                    </div>
                    <div class="demo-bar-item">
                        <span class="demo-label">46-60</span>
                        <div class="demo-bar">
                            <div class="demo-fill" style="width: 28%"></div>
                        </div>
                        <span class="demo-value">28%</span>
                    </div>
                    <div class="demo-bar-item">
                        <span class="demo-label">60+</span>
                        <div class="demo-bar">
                            <div class="demo-fill" style="width: 12%"></div>
                        </div>
                        <span class="demo-value">12%</span>
                    </div>
                </div>
            </div>

            <div class="demo-card">
                <h4 class="headline-sm">Gender Distribution</h4>
                <div class="gender-stats">
                    <div class="gender-item">
                        <div class="gender-circle" style="background: #1e40af;">
                            <span>52%</span>
                        </div>
                        <p class="body-sm">Female</p>
                    </div>
                    <div class="gender-item">
                        <div class="gender-circle" style="background: #10b981;">
                            <span>46%</span>
                        </div>
                        <p class="body-sm">Male</p>
                    </div>
                    <div class="gender-item">
                        <div class="gender-circle" style="background: #f59e0b;">
                            <span>2%</span>
                        </div>
                        <p class="body-sm">Other</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Top Conditions -->
    <section class="conditions-section">
        <div class="section-header">
            <h2 class="headline-md">Top Conditions Treated</h2>
        </div>
        <div class="conditions-list">
            <div class="condition-item">
                <span class="condition-rank">1</span>
                <div class="condition-info">
                    <h4 class="headline-sm">Hypertension</h4>
                    <div class="condition-bar">
                        <div class="condition-fill" style="width: 85%"></div>
                    </div>
                </div>
                <span class="condition-count">127 patients</span>
            </div>
            <div class="condition-item">
                <span class="condition-rank">2</span>
                <div class="condition-info">
                    <h4 class="headline-sm">Type 2 Diabetes</h4>
                    <div class="condition-bar">
                        <div class="condition-fill" style="width: 72%"></div>
                    </div>
                </div>
                <span class="condition-count">98 patients</span>
            </div>
            <div class="condition-item">
                <span class="condition-rank">3</span>
                <div class="condition-info">
                    <h4 class="headline-sm">Anxiety Disorders</h4>
                    <div class="condition-bar">
                        <div class="condition-fill" style="width: 65%"></div>
                    </div>
                </div>
                <span class="condition-count">87 patients</span>
            </div>
            <div class="condition-item">
                <span class="condition-rank">4</span>
                <div class="condition-info">
                    <h4 class="headline-sm">Asthma</h4>
                    <div class="condition-bar">
                        <div class="condition-fill" style="width: 48%"></div>
                    </div>
                </div>
                <span class="condition-count">64 patients</span>
            </div>
            <div class="condition-item">
                <span class="condition-rank">5</span>
                <div class="condition-info">
                    <h4 class="headline-sm">Chronic Pain</h4>
                    <div class="condition-bar">
                        <div class="condition-fill" style="width: 42%"></div>
                    </div>
                </div>
                <span class="condition-count">56 patients</span>
            </div>
        </div>
    </section>

    <!-- Performance Insights -->
    <section class="insights-section">
        <div class="section-header">
            <h2 class="headline-md">AI-Powered Insights</h2>
        </div>
        <div class="insights-list">
            <div class="insight-card positive">
                <i data-lucide="trending-up" class="insight-icon"></i>
                <div class="insight-content">
                    <h4 class="headline-sm">Excellent Response Time</h4>
                    <p class="body-sm">Your average response time is 35% faster than the platform average. Patients appreciate your quick replies!</p>
                </div>
            </div>
            <div class="insight-card info">
                <i data-lucide="users" class="insight-icon"></i>
                <div class="insight-content">
                    <h4 class="headline-sm">Growing Patient Base</h4>
                    <p class="body-sm">You've gained 42 new patients this month. Consider adjusting your availability to accommodate demand.</p>
                </div>
            </div>
            <div class="insight-card warning">
                <i data-lucide="calendar" class="insight-icon"></i>
                <div class="insight-content">
                    <h4 class="headline-sm">Peak Hours Identified</h4>
                    <p class="body-sm">Most appointment requests come between 2-4 PM. Consider blocking additional slots during these hours.</p>
                </div>
            </div>
        </div>
    </section>
</div>

