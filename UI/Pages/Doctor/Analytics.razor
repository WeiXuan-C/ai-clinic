@page "/doctor/analytics"
@layout Components.Layout.DoctorSidebarLayout

<PageTitle>Analytics - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

@if (isLoading)
{
    <div class="loading-container">
        <p>Loading analytics...</p>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="error-container">
        <p>@errorMessage</p>
        <button class="btn btn-primary" @onclick="LoadAnalyticsData">Retry</button>
    </div>
}
else if (analyticsData != null)
{
    <!-- Header -->
    <header class="content-header">
        <div class="header-left">
            <h1>Analytics & Insights</h1>
            <p class="body-md" style="margin: 0.5rem;">
                <span class="status-indicator">●</span>
                Track your performance and patient outcomes
            </p>
        </div>
        <div class="header-right">
            <select class="period-selector" value="@selectedPeriod" @onchange="OnPeriodChanged">
                <option value="week">This Week</option>
                <option value="month">This Month</option>
                <option value="quarter">This Quarter</option>
                <option value="year">This Year</option>
            </select>
        </div>
    </header>

    <!-- Content Grid -->
    <div class="content-grid">
        <!-- Key Metrics -->
        <section class="metrics-section">
            <h2 class="headline-md">Key Metrics</h2>
            <div class="metrics-grid">
                <div class="metric-card">
                    <div class="metric-header">
                        <i data-lucide="users" class="metric-icon"></i>
                    </div>
                    <h3 class="metric-value">@analyticsData.Metrics.TotalPatients</h3>
                    <p class="metric-label">Total Patients</p>
                </div>

                <div class="metric-card">
                    <div class="metric-header">
                        <i data-lucide="calendar-check" class="metric-icon"></i>
                    </div>
                    <h3 class="metric-value">@analyticsData.Metrics.TotalConsultations</h3>
                    <p class="metric-label">Consultations</p>
                </div>

                <div class="metric-card">
                    <div class="metric-header">
                        <i data-lucide="clock" class="metric-icon"></i>
                    </div>
                    <h3 class="metric-value">@analyticsData.Metrics.AverageResponseTimeMinutes min</h3>
                    <p class="metric-label">Avg Response Time</p>
                </div>

                <div class="metric-card">
                    <div class="metric-header">
                        <i data-lucide="star" class="metric-icon"></i>
                    </div>
                    <h3 class="metric-value">@analyticsData.Metrics.PatientRating.ToString("F1")</h3>
                    <p class="metric-label">Patient Rating</p>
                </div>
            </div>
        </section>

        <!-- Top Conditions -->
        <section class="conditions-section">
            <div class="section-header">
                <h2 class="headline-md">Top Conditions Treated</h2>
            </div>
            <div class="conditions-list">
                @if (analyticsData.TopConditions.Any())
                {
                    @for (int i = 0; i < analyticsData.TopConditions.Count; i++)
                    {
                        var condition = analyticsData.TopConditions[i];
                        <div class="condition-item">
                            <span class="condition-rank">@(i + 1)</span>
                            <div class="condition-info">
                                <h4 class="headline-sm">@condition.ConditionName</h4>
                                <div class="condition-bar">
                                    <div class="condition-fill" style="width: @GetConditionPercentage(condition)%"></div>
                                </div>
                            </div>
                            <span class="condition-count">@condition.PatientCount patient@(condition.PatientCount != 1 ? "s" : "")</span>
                        </div>
                    }
                }
                else
                {
                    <p class="body-md" style="color: #434654; padding: 1rem;">No condition data available for this period.</p>
                }
            </div>
        </section>

        <!-- Performance Insights -->
        <section class="insights-section">
            <div class="section-header">
                <h2 class="headline-md">Performance Summary</h2>
            </div>
            <div class="insights-list">
                <div class="insight-card info">
                    <i data-lucide="users" class="insight-icon"></i>
                    <div class="insight-content">
                        <h4 class="headline-sm">Patient Base</h4>
                        <p class="body-sm">You've treated @analyticsData.Metrics.TotalPatients unique patients during this period with @analyticsData.Metrics.TotalConsultations total consultations.</p>
                    </div>
                </div>
                <div class="insight-card positive">
                    <i data-lucide="star" class="insight-icon"></i>
                    <div class="insight-content">
                        <h4 class="headline-sm">Patient Satisfaction</h4>
                        <p class="body-sm">Your average rating is @analyticsData.Metrics.PatientRating.ToString("F1") out of 5.0. Keep up the excellent work!</p>
                    </div>
                </div>
            </div>
        </section>
    </div>
}

<style>
    .loading-container, .error-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 400px;
        gap: 1rem;
    }

    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2rem;
    }

    .header-left h1 {
        font-size: 2rem;
        font-weight: 700;
        color: #191c1e;
        margin: 0.5rem;
        font-family: 'Manrope', sans-serif;
    }

    .header-left p {
        color: #434654;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .status-indicator {
        color: #10b981;
        font-size: 0.75rem;
    }

    .header-right {
        display: flex;
        gap: 1rem;
    }

    .period-selector {
        padding: 0.75rem 1.5rem;
        border: 1px solid #e6e8ea;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        background: white;
    }

    .period-selector:focus {
        outline: none;
        border-color: #1e40af;
    }

    .content-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
    }

    .metrics-section {
        grid-column: span 2;
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .metrics-section h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
        margin-bottom: 1.5rem;
    }

    .metrics-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
    }

    .metric-card {
        padding: 1.5rem;
        background: #f7f9fb;
        border-radius: 12px;
    }

    .metric-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .metric-icon {
        width: 40px;
        height: 40px;
        background: #1e40af;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        color: white;
    }

    .metric-value {
        font-size: 2rem;
        font-weight: 700;
        color: #191c1e;
        margin-bottom: 0.25rem;
    }

    .metric-label {
        color: #434654;
        font-size: 0.875rem;
    }

    .conditions-section {
        grid-column: span 1;
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .section-header {
        margin-bottom: 1.5rem;
    }

    .section-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
    }

    .conditions-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .condition-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        background: #f7f9fb;
        border-radius: 12px;
    }

    .condition-rank {
        width: 32px;
        height: 32px;
        background: #1e40af;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.875rem;
    }

    .condition-info {
        flex: 1;
    }

    .condition-info h4 {
        font-size: 0.9375rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.5rem;
    }

    .condition-bar {
        height: 8px;
        background: #e6e8ea;
        border-radius: 4px;
        overflow: hidden;
    }

    .condition-fill {
        height: 100%;
        background: linear-gradient(90deg, #1e40af, #10b981);
        border-radius: 4px;
    }

    .condition-count {
        font-size: 0.8125rem;
        color: #434654;
        font-weight: 500;
        white-space: nowrap;
    }

    .insights-section {
        grid-column: span 1;
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .insights-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .insight-card {
        display: flex;
        gap: 1rem;
        padding: 1.5rem;
        border-radius: 12px;
        border-left: 4px solid;
    }

    .insight-card.positive {
        background: #f0fdf4;
        border-left-color: #10b981;
    }

    .insight-card.info {
        background: #eff6ff;
        border-left-color: #1e40af;
    }

    .insight-icon {
        width: 48px;
        height: 48px;
        min-width: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    .insight-card.positive .insight-icon {
        background: #d1fae5;
        color: #059669;
    }

    .insight-card.info .insight-icon {
        background: #dbeafe;
        color: #1e40af;
    }

    .insight-content h4 {
        font-size: 1rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.5rem;
    }

    .insight-content p {
        color: #434654;
        line-height: 1.5;
    }

    .btn {
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        font-size: 0.875rem;
    }

    .btn-primary {
        background: #1e40af;
        color: white;
    }

    .btn-primary:hover {
        background: #1e3a8a;
    }

    @@media (max-width: 1200px) {
        .metrics-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 1024px) {
        .content-grid {
            grid-template-columns: 1fr;
        }

        .metrics-section,
        .conditions-section,
        .insights-section {
            grid-column: span 1;
        }
    }

    @@media (max-width: 768px) {
        .metrics-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
