@page "/doctor/records"
@layout Components.Layout.DoctorSidebarLayout
@using ai_clinic.Models

<PageTitle>Consultation History - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>Consultation History</h1>
        <p class="body-md" style="margin: 0.5rem;">
            <span class="status-indicator">●</span>
            View your consultation history with patients and medical records
        </p>
    </div>
    <div class="header-right">
        <button class="btn btn-secondary" @onclick="RefreshData">
            Refresh
        </button>
    </div>
</header>

<!-- Search Bar -->
<div class="search-section">
    <div class="search-box">
        <input type="text" 
               placeholder="🔍 Search by patient name or email..." 
               @bind="searchQuery" 
               @bind:event="oninput" />
    </div>
</div>

<!-- Content Grid -->
<div class="content-grid">
    <!-- Patient List -->
    <section class="patients-section">
        <div class="section-header">
            <h2 class="headline-md">Patients (@patientConversations.Count)</h2>
        </div>
        
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="text-align: center; padding: 3rem;">
                <p class="body-md" style="color: #d32f2f;">@errorMessage</p>
            </div>
        }
        else if (!GetFilteredPatients().Any())
        {
            <div style="text-align: center; padding: 3rem;">
                <p class="body-md">No patient consultations found</p>
            </div>
        }
        else
        {
            <div class="patients-list">
                @foreach (var patient in GetFilteredPatients())
                {
                    var isSelected = selectedPatientId == patient.PatientId;
                    <div class="patient-item @(isSelected ? "selected" : "")" 
                         @onclick="() => SelectPatient(patient.PatientId)">
                        <div class="patient-avatar">
                            @if (patient.ProfilePhoto != null)
                            {
                                <img src="@($"data:image/jpeg;base64,{Convert.ToBase64String(patient.ProfilePhoto)}")" 
                                     alt="@patient.PatientName" />
                            }
                            else
                            {
                                <span>👤</span>
                            }
                        </div>
                        <div class="patient-info">
                            <h4 class="headline-sm">@patient.PatientName</h4>
                            <p class="body-sm">@patient.PatientEmail</p>
                            <p class="body-sm" style="color: #10b981;">
                                @patient.ConversationCount consultation@(patient.ConversationCount != 1 ? "s" : "")
                            </p>
                        </div>
                        <div class="patient-badge">
                            <span class="badge badge-visit">@patient.MedicalRecordCount record@(patient.MedicalRecordCount != 1 ? "s" : "")</span>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <!-- Details Section -->
    <section class="details-section">
        @if (selectedPatientId == null)
        {
            <div style="text-align: center; padding: 3rem;">
                <div style="font-size: 4rem; color: #e6e8ea; margin-bottom: 1rem;">👤</div>
                <p class="body-md" style="color: #434654;">Select a patient to view consultation history and medical records</p>
            </div>
        }
        else
        {
            var patient = patientConversations.FirstOrDefault(p => p.PatientId == selectedPatientId);
            if (patient != null)
            {
                <div class="patient-details-header">
                    <div class="patient-avatar-large">
                        @if (patient.ProfilePhoto != null)
                        {
                            <img src="@($"data:image/jpeg;base64,{Convert.ToBase64String(patient.ProfilePhoto)}")" 
                                 alt="@patient.PatientName" />
                        }
                        else
                        {
                            <span>👤</span>
                        }
                    </div>
                    <div>
                        <h2 class="headline-lg">@patient.PatientName</h2>
                        <p class="body-md">@patient.PatientEmail</p>
                        @if (patient.DateOfBirth.HasValue)
                        {
                            <p class="body-sm" style="color: #434654;">
                                Age: @CalculateAge(patient.DateOfBirth.Value) years
                            </p>
                        }
                    </div>
                </div>

                <!-- Tabs -->
                <div class="tabs">
                    <button class="tab-btn @(activeTab == "conversations" ? "active" : "")" 
                            @onclick='() => activeTab = "conversations"'>
                        💬 Consultations (@patient.ConversationCount)
                    </button>
                    <button class="tab-btn @(activeTab == "records" ? "active" : "")" 
                            @onclick='() => activeTab = "records"'>
                        📄 Medical Records (@patient.MedicalRecordCount)
                    </button>
                </div>

                <!-- Tab Content -->
                <div class="tab-content">
                    @if (activeTab == "conversations")
                    {
                        <div class="consultations-list">
                            @if (!patient.Conversations.Any())
                            {
                                <p class="body-md" style="text-align: center; padding: 2rem; color: #434654;">
                                    No consultations found
                                </p>
                            }
                            else
                            {
                                @foreach (var conversation in patient.Conversations.OrderByDescending(c => c.LastMessageAt))
                                {
                                    <div class="consultation-card" @onclick="() => ViewConversation(conversation.Id)">
                                        <div class="consultation-header">
                                            <div>
                                                <h4 class="headline-sm">@(conversation.Title ?? "Consultation")</h4>
                                                <p class="body-sm" style="color: #434654;">
                                                    Started: @conversation.StartedAt.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")
                                                </p>
                                            </div>
                                            <span class="badge @GetStatusBadgeClass(conversation.Status)">
                                                @conversation.Status
                                            </span>
                                        </div>
                                        <div class="consultation-stats">
                                            <div class="stat-chip">
                                                <span>💬 @conversation.TotalMessages messages</span>
                                            </div>
                                            @if (!string.IsNullOrEmpty(conversation.AiSuggestedSpecialization))
                                            {
                                                <div class="stat-chip">
                                                    <span>🩺 @conversation.AiSuggestedSpecialization</span>
                                                </div>
                                            }
                                            @if (conversation.ClosedAt.HasValue)
                                            {
                                                <div class="stat-chip">
                                                    <span>📅 Closed: @conversation.ClosedAt.Value.ToLocalTime().ToString("MMM dd, yyyy")</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <div class="records-list">
                            @if (!patient.MedicalRecords.Any())
                            {
                                <p class="body-md" style="text-align: center; padding: 2rem; color: #434654;">
                                    No medical records found
                                </p>
                            }
                            else
                            {
                                @foreach (var record in patient.MedicalRecords.OrderByDescending(r => r.RecordDate))
                                {
                                    <div class="record-card" @onclick="() => ViewRecord(record)">
                                        <div class="record-icon @GetRecordIconClass(record.RecordType)">
                                            <span>@GetRecordIconEmoji(record.RecordType)</span>
                                        </div>
                                        <div class="record-info">
                                            <h4 class="headline-sm">@record.Title</h4>
                                            <p class="body-sm">@record.RecordDate.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")</p>
                                            @if (!string.IsNullOrEmpty(record.DiagnosisDescription))
                                            {
                                                <p class="body-sm" style="color: #434654; margin-top: 0.5rem;">
                                                    Diagnosis: @record.DiagnosisDescription
                                                </p>
                                            }
                                        </div>
                                        <span class="badge @GetRecordBadgeClass(record.RecordType)">
                                            @record.RecordType
                                        </span>
                                        <button class="btn-icon-sm" @onclick:stopPropagation @onclick="() => ViewRecord(record)" title="View Details">
                                            👁️
                                        </button>
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
            }
        }
    </section>
</div>

<!-- View Record Modal -->
@if (showRecordModal && selectedRecord != null)
{
    <div class="modal-overlay" @onclick="CloseModals">
        <div class="modal-content modal-clean" @onclick:stopPropagation>
            <!-- Clean Header -->
            <div class="modal-header-clean">
                <div class="header-title-section">
                    <div class="record-type-icon">
                        @GetRecordIconEmoji(selectedRecord.RecordType)
                    </div>
                    <div>
                        <h2 class="modal-title-clean">@selectedRecord.Title</h2>
                        <p class="modal-date">@selectedRecord.RecordDate.ToLocalTime().ToString("MMMM dd, yyyy • hh:mm tt")</p>
                    </div>
                </div>
                <button class="btn-close-clean" @onclick="CloseModals">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>

            <!-- Clean Body -->
            <div class="modal-body-clean">
                <!-- Patient & Type Row -->
                <div class="info-grid">
                    <div class="info-item">
                        <label class="info-label-clean">Patient</label>
                        <div class="info-value-clean">@(selectedRecord.Patient?.Email ?? "N/A")</div>
                    </div>
                    <div class="info-item">
                        <label class="info-label-clean">Record Type</label>
                        <span class="badge-clean @GetRecordBadgeClass(selectedRecord.RecordType)">
                            @selectedRecord.RecordType
                        </span>
                    </div>
                </div>

                <!-- Diagnosis Section -->
                @if (!string.IsNullOrEmpty(selectedRecord.DiagnosisDescription) || !string.IsNullOrEmpty(selectedRecord.DiagnosisCode))
                {
                    <div class="section-clean">
                        <h3 class="section-title-clean">Diagnosis</h3>
                        @if (!string.IsNullOrEmpty(selectedRecord.DiagnosisCode))
                        {
                            <div class="diagnosis-code-clean">
                                <span class="code-label">ICD-10:</span>
                                <span class="code-value">@selectedRecord.DiagnosisCode</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(selectedRecord.DiagnosisDescription))
                        {
                            <p class="section-content-clean">@selectedRecord.DiagnosisDescription</p>
                        }
                    </div>
                }

                <!-- Medical Details Section -->
                <div class="section-clean">
                    <h3 class="section-title-clean">Medical Details</h3>
                    <div class="section-content-clean">@selectedRecord.Content</div>
                </div>

                <!-- Medications Section -->
                @if (!string.IsNullOrEmpty(selectedRecord.Medications))
                {
                    <div class="section-clean">
                        <h3 class="section-title-clean">Medications</h3>
                        <div class="section-content-clean">@selectedRecord.Medications</div>
                    </div>
                }
            </div>

            <!-- Clean Footer -->
            <div class="modal-footer-clean">
                <button class="btn-close-modal" @onclick="CloseModals">Close</button>
            </div>
        </div>
    </div>
}

