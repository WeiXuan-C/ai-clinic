    }

    .tab-btn.active {
        background: #1e40af;
        color: white;
        border-color: #1e40af;
    }

    .content-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 2rem;
    }

    .records-section {
        grid-column: span 1;
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.75rem;
    }

    .section-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
    }

    .search-box {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        background: #f7f9fb;
        border-radius: 8px;
