@page "/doctor/records"
@layout Components.Layout.DoctorSidebarLayout

<PageTitle>Medical Records - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>Medical Records</h1>
        <p class="body-md" style="margin: 0.5rem;">
            <span class="status-indicator">●</span>
            Manage patient medical records and documentation
        </p>
    </div>
    <div class="header-right">
        <button class="btn btn-secondary">
            <i data-lucide="download"></i>
            Export
        </button>
        <button class="btn btn-primary">
            <i data-lucide="file-plus"></i>
            New Record
        </button>
    </div>
</header>

<!-- Filter Tabs -->
<div class="filter-tabs">
    <button class="tab-btn @(currentFilter == "all" ? "active" : "")" @onclick='() => SetFilter("all")'>All Records</button>
    <button class="tab-btn @(currentFilter == "lab" ? "active" : "")" @onclick='() => SetFilter("lab")'>Lab Results</button>
    <button class="tab-btn @(currentFilter == "prescriptions" ? "active" : "")" @onclick='() => SetFilter("prescriptions")'>Prescriptions</button>
    <button class="tab-btn @(currentFilter == "records" ? "active" : "")" @onclick='() => SetFilter("records")'>Visit Notes</button>
    <button class="tab-btn @(currentFilter == "imaging" ? "active" : "")" @onclick='() => SetFilter("imaging")'>Imaging</button>
</div>

<!-- Content Grid -->
<div class="content-grid">
    <!-- Records List -->
    <section class="records-section">
        <div class="section-header">
            <h2 class="headline-md">Recent Records</h2>
            <div class="search-box">
                <i data-lucide="search"></i>
                <input type="text" placeholder="Search records..." @bind="searchQuery" @bind:event="oninput" @onkeyup="@(async (e) => { if (e.Key == "Enter") await HandleSearch(); })" />
            </div>
        </div>
        
        @if (isLoading)
        {
            <div style="text-align: center; padding: 3rem;">
                <p class="body-md">Loading records...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="text-align: center; padding: 3rem;">
                <p class="body-md" style="color: #d32f2f;">@errorMessage</p>
            </div>
        }
        else if (!GetFilteredRecords().Any())
        {
            <div style="text-align: center; padding: 3rem;">
                <p class="body-md">No records found</p>
            </div>
        }
        else
        {
            <div class="records-list">
                @foreach (var record in GetFilteredRecords())
                {
                    var recordType = GetRecordType(record);
                    <div class="record-item">
                        <div class="record-icon @GetIconClass(recordType)">
                            <i data-lucide="@GetIconName(recordType)"></i>
                        </div>
                        <div class="record-info">
                            <h4 class="headline-sm">@GetRecordTitle(record)</h4>
                            <p class="body-sm">Date: @GetRecordDate(record)</p>
                            <p class="body-sm">@GetRecordDetails(record)</p>
                        </div>
                        <span class="badge @GetBadgeClass(recordType)">@recordType.ToUpper()</span>
                        <div class="record-actions">
                            <button class="btn-icon-sm">
                                <i data-lucide="eye"></i>
                            </button>
                            <button class="btn-icon-sm">
                                <i data-lucide="edit-2"></i>
                            </button>
                            <button class="btn-icon-sm">
                                <i data-lucide="download"></i>
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <!-- Quick Stats -->
    <section class="stats-card">
        <h3 class="headline-md">Record Summary</h3>
        @if (isLoading)
        {
            <p class="body-sm">Loading...</p>
        }
        else
        {
            <div class="stats-list">
                <div class="stat-item">
                    <i data-lucide="file-text" class="stat-icon"></i>
                    <div class="stat-info">
                        <h4 class="headline-lg">@statistics.TotalRecords</h4>
                        <p class="body-sm">Total Records</p>
                    </div>
                </div>
                <div class="stat-item">
                    <i data-lucide="flask-conical" class="stat-icon"></i>
                    <div class="stat-info">
                        <h4 class="headline-lg">@statistics.LabResults</h4>
                        <p class="body-sm">Lab Results</p>
                    </div>
                </div>
                <div class="stat-item">
                    <i data-lucide="pill" class="stat-icon"></i>
                    <div class="stat-info">
                        <h4 class="headline-lg">@statistics.Prescriptions</h4>
                        <p class="body-sm">Prescriptions</p>
                    </div>
                </div>
                <div class="stat-item">
                    <i data-lucide="scan" class="stat-icon"></i>
                    <div class="stat-info">
                        <h4 class="headline-lg">@statistics.ImagingStudies</h4>
                        <p class="body-sm">Imaging Studies</p>
                    </div>
                </div>
            </div>
        }
    </section>
</div>

<style>
    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2rem;
    }

    .header-left h1 {
        font-size: 2rem;
        font-weight: 700;
        color: #191c1e;
        margin: 0.5rem;
        font-family: 'Manrope', sans-serif;
    }

    .header-left p {
        color: #434654;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .status-indicator {
        color: #10b981;
        font-size: 0.75rem;
    }

    .header-right {
        display: flex;
        gap: 1rem;
    }

    .filter-tabs {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        overflow-x: auto;
        padding-bottom: 0.5rem;
    }

    .tab-btn {
        padding: 0.75rem 1.5rem;
        background: white;
        border: 1px solid #e6e8ea;
        border-radius: 8px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
        font-size: 0.875rem;
    }

    .tab-btn:hover {
        background: #f7f9fb;
    }

    .tab-btn.active {
        background: #1e40af;
        color: white;
        border-color: #1e40af;
    }

    .content-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 2rem;
    }

    .records-section {
        grid-column: span 1;
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.75rem;
    }

    .section-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
    }

    .search-box {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        background: #f7f9fb;
        border-radius: 8px;
        min-width: 300px;
    }

    .search-box input {
        border: none;
        background: transparent;
        outline: none;
        font-size: 0.875rem;
        width: 100%;
    }

    .records-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .record-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem;
        background: #f7f9fb;
        border-radius: 12px;
        transition: all 0.2s;
    }

    .record-item:hover {
        background: #eceef0;
        transform: translateX(4px);
    }

    .record-icon {
        width: 48px;
        height: 48px;
        min-width: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    .record-icon.lab {
        background: #dbeafe;
        color: #1e40af;
    }

    .record-icon.prescription {
        background: #f3e5f5;
        color: #7b1fa2;
    }

    .record-icon.visit {
        background: #d1fae5;
        color: #059669;
    }

    .record-icon.imaging {
        background: #fef3c7;
        color: #d97706;
    }

    .record-info {
        flex: 1;
    }

    .record-info h4 {
        font-size: 1rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.25rem;
    }

    .record-info p {
        font-size: 0.8125rem;
        color: #434654;
        margin-bottom: 0.125rem;
    }

    .badge {
        padding: 0.375rem 0.75rem;
        border-radius: 6px;
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        white-space: nowrap;
    }

    .badge-lab {
        background: #dbeafe;
        color: #1e40af;
    }

    .badge-prescription {
        background: #f3e5f5;
        color: #7b1fa2;
    }

    .badge-visit {
        background: #d1fae5;
        color: #059669;
    }

    .badge-imaging {
        background: #fef3c7;
        color: #d97706;
    }

    .record-actions {
        display: flex;
        gap: 0.5rem;
    }

    .btn-icon-sm {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: white;
        border: 1px solid #e6e8ea;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

    .btn-icon-sm:hover {
        background: #1e40af;
        color: white;
        border-color: #1e40af;
    }

    .stats-card {
        grid-column: span 1;
        background: white;
        padding: 2rem;
        border-radius: 16px;
        height: fit-content;
    }

    .stats-card h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
        margin-bottom: 1.5rem;
    }

    .stats-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .stat-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        background: #f7f9fb;
        border-radius: 12px;
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        min-width: 48px;
        background: #10b981;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: white;
    }

    .stat-info h4 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #191c1e;
        margin-bottom: 0.25rem;
    }

    .stat-info p {
        color: #434654;
        font-size: 0.875rem;
    }

    .btn {
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-primary {
        background: #1e40af;
        color: white;
    }

    .btn-primary:hover {
        background: #1e3a8a;
        transform: translateY(-1px);
    }

    .btn-secondary {
        background: #e6e8ea;
        color: #191c1e;
    }

    .btn-secondary:hover {
        background: #d8dadc;
    }

    @@media (max-width: 1024px) {
        .content-grid {
            grid-template-columns: 1fr;
        }

        .records-section,
        .stats-card {
            grid-column: span 1;
        }

        .search-box {
            min-width: 200px;
        }
    }

    @@media (max-width: 768px) {
        .record-item {
            flex-wrap: wrap;
        }

        .record-actions {
            width: 100%;
            justify-content: flex-end;
        }
    }
</style>
