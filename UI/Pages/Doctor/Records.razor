@page "/doctor/records"
@layout Components.Layout.DoctorSidebarLayout
@using ai_clinic.Models

<PageTitle>Medical Records - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>Medical Records</h1>
        <p class="body-md" style="margin: 0.5rem;">
            <span class="status-indicator">●</span>
            Manage patient medical records and documentation
        </p>
    </div>
    <div class="header-right">
        <button class="btn btn-secondary" @onclick="OpenExportModal">
            <i data-lucide="download"></i>
            Export
        </button>
        <button class="btn btn-primary" @onclick="OpenNewRecordModal">
            <i data-lucide="file-plus"></i>
            New Record
        </button>
    </div>
</header>

<!-- Filter Tabs -->
<div class="filter-tabs">
    <button class="tab-btn @(currentFilter == "all" ? "active" : "")" @onclick='() => SetFilter("all")'>All Records</button>
    <button class="tab-btn @(currentFilter == "lab" ? "active" : "")" @onclick='() => SetFilter("lab")'>Lab Results</button>
    <button class="tab-btn @(currentFilter == "prescriptions" ? "active" : "")" @onclick='() => SetFilter("prescriptions")'>Prescriptions</button>
    <button class="tab-btn @(currentFilter == "records" ? "active" : "")" @onclick='() => SetFilter("records")'>Visit Notes</button>
    <button class="tab-btn @(currentFilter == "imaging" ? "active" : "")" @onclick='() => SetFilter("imaging")'>Imaging</button>
</div>

<!-- Content Grid -->
<div class="content-grid">
    <!-- Records List -->
    <section class="records-section">
        <div class="section-header">
            <h2 class="headline-md">Recent Records</h2>
            <div class="search-box">
                <i data-lucide="search"></i>
                <input type="text" placeholder="Search records..." @bind="searchQuery" @bind:event="oninput" @onkeyup="@(async (e) => { if (e.Key == "Enter") await HandleSearch(); })" />
            </div>
        </div>
        
        @if (isLoading)
        {
            <div style="text-align: center; padding: 3rem;">
                <p class="body-md">Loading records...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="text-align: center; padding: 3rem;">
                <p class="body-md" style="color: #d32f2f;">@errorMessage</p>
            </div>
        }
        else if (!GetFilteredRecords().Any())
        {
            <div style="text-align: center; padding: 3rem;">
                <p class="body-md">No records found</p>
            </div>
        }
        else
        {
            <div class="records-list">
                @foreach (var record in GetFilteredRecords())
                {
                    var recordType = GetRecordType(record);
                    <div class="record-item">
                        <div class="record-icon @GetIconClass(recordType)">
                            <i data-lucide="@GetIconName(recordType)"></i>
                        </div>
                        <div class="record-info">
                            <h4 class="headline-sm">@GetRecordTitle(record)</h4>
                            <p class="body-sm">Date: @GetRecordDate(record)</p>
                            <p class="body-sm">@GetRecordDetails(record)</p>
                        </div>
                        <span class="badge @GetBadgeClass(recordType)">@recordType.ToUpper()</span>
                        <div class="record-actions">
                            <button class="btn-icon-sm" @onclick="() => ViewRecord(record)" title="View">
                                <i data-lucide="eye"></i>
                            </button>
                            <button class="btn-icon-sm" @onclick="() => EditRecord(record)" title="Edit">
                                <i data-lucide="edit-2"></i>
                            </button>
                            <button class="btn-icon-sm" @onclick="() => DownloadRecord(record)" title="Download">
                                <i data-lucide="download"></i>
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <!-- Quick Stats -->
    <section class="stats-card">
        <h3 class="headline-md">Record Summary</h3>
        @if (isLoading)
        {
            <p class="body-sm">Loading...</p>
        }
        else
        {
            <div class="stats-list">
                <div class="stat-item">
                    <i data-lucide="file-text" class="stat-icon"></i>
                    <div class="stat-info">
                        <h4 class="headline-lg">@statistics.TotalRecords</h4>
                        <p class="body-sm">Total Records</p>
                    </div>
                </div>
                <div class="stat-item">
                    <i data-lucide="flask-conical" class="stat-icon"></i>
                    <div class="stat-info">
                        <h4 class="headline-lg">@statistics.LabResults</h4>
                        <p class="body-sm">Lab Results</p>
                    </div>
                </div>
                <div class="stat-item">
                    <i data-lucide="pill" class="stat-icon"></i>
                    <div class="stat-info">
                        <h4 class="headline-lg">@statistics.Prescriptions</h4>
                        <p class="body-sm">Prescriptions</p>
                    </div>
                </div>
                <div class="stat-item">
                    <i data-lucide="scan" class="stat-icon"></i>
                    <div class="stat-info">
                        <h4 class="headline-lg">@statistics.ImagingStudies</h4>
                        <p class="body-sm">Imaging Studies</p>
                    </div>
                </div>
            </div>
        }
    </section>
</div>

<!-- View Record Modal -->
@if (showViewModal && selectedRecord != null)
{
    <div class="modal-overlay" @onclick="CloseModals">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h2 class="headline-lg">@GetRecordTitle(selectedRecord)</h2>
                <button class="btn-icon" @onclick="CloseModals">
                    <i data-lucide="x"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="record-detail">
                    <div class="detail-row">
                        <span class="detail-label">Type:</span>
                        <span class="badge @GetBadgeClass(GetRecordType(selectedRecord))">@GetRecordType(selectedRecord)</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Date:</span>
                        <span class="detail-value">@GetRecordDate(selectedRecord)</span>
                    </div>
                    @if (selectedRecord is MedicalRecord mr)
                    {
                        <div class="detail-row">
                            <span class="detail-label">Patient:</span>
                            <span class="detail-value">@(mr.Patient?.Email ?? "N/A")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(mr.DiagnosisDescription))
                        {
                            <div class="detail-row">
                                <span class="detail-label">Diagnosis:</span>
                                <span class="detail-value">@mr.DiagnosisDescription</span>
                            </div>
                        }
                        <div class="detail-section">
                            <span class="detail-label">Content:</span>
                            <div class="detail-content">@mr.Content</div>
                        </div>
                    }
                    else if (selectedRecord is Prescription p)
                    {
                        <div class="detail-row">
                            <span class="detail-label">Patient:</span>
                            <span class="detail-value">@(p.Patient?.Email ?? "N/A")</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Medication:</span>
                            <span class="detail-value">@p.MedicationName</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Dosage:</span>
                            <span class="detail-value">@p.Dosage</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Frequency:</span>
                            <span class="detail-value">@p.Frequency</span>
                        </div>
                        @if (!string.IsNullOrEmpty(p.Duration))
                        {
                            <div class="detail-row">
                                <span class="detail-label">Duration:</span>
                                <span class="detail-value">@p.Duration</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(p.Instructions))
                        {
                            <div class="detail-section">
                                <span class="detail-label">Instructions:</span>
                                <div class="detail-content">@p.Instructions</div>
                            </div>
                        }
                        <div class="detail-row">
                            <span class="detail-label">Status:</span>
                            <span class="badge @(p.IsActive ? "badge-visit" : "badge-imaging")">
                                @(p.IsActive ? "ACTIVE" : "INACTIVE")
                            </span>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModals">Close</button>
                <button class="btn btn-primary" @onclick="() => { CloseModals(); EditRecord(selectedRecord); }">
                    <i data-lucide="edit-2"></i>
                    Edit
                </button>
            </div>
        </div>
    </div>
}

<!-- Edit Record Modal -->
@if (showEditModal && selectedRecord != null)
{
    <div class="modal-overlay" @onclick="CloseModals">
        <div class="modal-content modal-large" @onclick:stopPropagation>
            <div class="modal-header">
                <h2 class="headline-lg">Edit @GetRecordType(selectedRecord)</h2>
                <button class="btn-icon" @onclick="CloseModals">
                    <i data-lucide="x"></i>
                </button>
            </div>
            <div class="modal-body">
                @if (selectedRecord is MedicalRecord mr)
                {
                    <div class="form-group">
                        <label>Title</label>
                        <input type="text" class="form-input" @bind="editMedicalRecord.Title" />
                    </div>
                    <div class="form-group">
                        <label>Record Type</label>
                        <select class="form-input" @bind="editMedicalRecord.RecordType">
                            <option value="Lab Result">Lab Result</option>
                            <option value="Imaging">Imaging</option>
                            <option value="Visit Note">Visit Note</option>
                            <option value="Consultation">Consultation</option>
                            <option value="Prescription">Prescription</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Diagnosis</label>
                        <input type="text" class="form-input" @bind="editMedicalRecord.DiagnosisDescription" />
                    </div>
                    <div class="form-group">
                        <label>Content</label>
                        <textarea class="form-textarea" rows="8" @bind="editMedicalRecord.Content"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Record Date</label>
                        <input type="date" class="form-input" @bind="editMedicalRecordDate" />
                    </div>
                }
                else if (selectedRecord is Prescription p)
                {
                    <div class="form-group">
                        <label>Medication Name</label>
                        <input type="text" class="form-input" @bind="editPrescription.MedicationName" />
                    </div>
                    <div class="form-group">
                        <label>Dosage</label>
                        <input type="text" class="form-input" @bind="editPrescription.Dosage" />
                    </div>
                    <div class="form-group">
                        <label>Frequency</label>
                        <input type="text" class="form-input" @bind="editPrescription.Frequency" />
                    </div>
                    <div class="form-group">
                        <label>Duration</label>
                        <input type="text" class="form-input" @bind="editPrescription.Duration" />
                    </div>
                    <div class="form-group">
                        <label>Instructions</label>
                        <textarea class="form-textarea" rows="4" @bind="editPrescription.Instructions"></textarea>
                    </div>
                    <div class="form-group">
                        <label class="checkbox-label">
                            <input type="checkbox" @bind="editPrescription.IsActive" />
                            <span>Active Prescription</span>
                        </label>
                    </div>
                }
                
                @if (!string.IsNullOrEmpty(editErrorMessage))
                {
                    <div class="alert alert-error">
                        <i data-lucide="alert-circle"></i>
                        @editErrorMessage
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModals" disabled="@isSaving">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveRecord" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span>Saving...</span>
                    }
                    else
                    {
                        <i data-lucide="save"></i>
                        <span>Save Changes</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

<style>
