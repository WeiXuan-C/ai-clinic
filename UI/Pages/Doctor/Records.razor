        background: #e6e8ea;
    }

    .modal-body {
        padding: 2rem;
        overflow-y: auto;
        flex: 1;
    }

    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
        padding: 1.5rem 2rem;
        border-top: 1px solid #e6e8ea;
    }

    /* Record Detail Styles */
    .record-detail {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .detail-row {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
    }

    .detail-section {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .detail-label {
        font-weight: 600;
        color: #191c1e;
        min-width: 120px;
