@page "/doctor/profile"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout Components.Layout.DoctorSidebarLayout

<PageTitle>Profile - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>My Profile</h1>
        <p class="body-md" style="margin: 0.5rem;">
            Manage your professional information and credentials
        </p>
    </div>
    <div class="header-right">
        @if (isEditing)
        {
            <button type="button" class="btn btn-discard" @onclick="CancelEdit">
                <i data-lucide="x"></i>
                Discard
            </button>
            <button type="button" class="btn btn-save" @onclick="SaveChanges" disabled="@isSaving">
                <i data-lucide="check"></i>
                @(isSaving ? "Saving..." : "Save")
            </button>
        }
        else
        {
            <button type="button" class="btn btn-primary" @onclick="EnableEdit">
                <i data-lucide="edit-2"></i>
                Edit Profile
            </button>
        }
    </div>
</header>

<!-- Content Grid -->
<div class="content-grid">
    <!-- Profile Photo Section -->
    <section class="profile-photo-card">
        <div class="photo-container">
            <div class="avatar-large">
                <i data-lucide="stethoscope"></i>
            </div>
            @if (isEditing)
            {
                <button type="button" class="photo-upload-btn">
                    <i data-lucide="camera"></i>
                </button>
            }
        </div>
        <div class="photo-info">
            <h3 class="headline-sm">@fullName</h3>
            <p class="body-md">@email</p>
            <p class="body-sm">@specialty</p>
            <div class="rating-display">
                <i data-lucide="star"></i>
                <span>4.9 (247 reviews)</span>
            </div>
        </div>
    </section>

    <!-- Professional Information -->
    <section class="info-card">
        <div class="section-header">
            <h2 class="headline-md">Professional Information</h2>
        </div>
        <div class="form-grid">
            <div class="form-group">
                <label class="body-sm">Full Name</label>
                <input type="text" class="form-input" @bind="fullName" disabled="@(!isEditing)" />
            </div>
            <div class="form-group">
                <label class="body-sm">Medical License Number</label>
                <input type="text" class="form-input" @bind="licenseNumber" disabled="@(!isEditing)" />
            </div>
            <div class="form-group">
                <label class="body-sm">Email Address</label>
                <input type="email" class="form-input" @bind="email" disabled />
            </div>
            <div class="form-group">
                <label class="body-sm">Phone Number</label>
                <input type="tel" class="form-input" @bind="phoneNumber" disabled="@(!isEditing)" />
            </div>
            <div class="form-group">
                <label class="body-sm">Specialty</label>
                <select class="form-input" @bind="specialty" disabled="@(!isEditing)">
                    <option value="">Select Specialty</option>
                    <option value="Cardiology">Cardiology</option>
                    <option value="Dermatology">Dermatology</option>
                    <option value="Endocrinology">Endocrinology</option>
                    <option value="Family Medicine">Family Medicine</option>
                    <option value="Internal Medicine">Internal Medicine</option>
                    <option value="Neurology">Neurology</option>
                    <option value="Pediatrics">Pediatrics</option>
                    <option value="Psychiatry">Psychiatry</option>
                </select>
            </div>
            <div class="form-group">
                <label class="body-sm">Years of Experience</label>
                <input type="number" class="form-input" @bind="yearsExperience" disabled="@(!isEditing)" />
            </div>
            <div class="form-group full-width">
                <label class="body-sm">Bio</label>
                <textarea class="form-input" rows="4" @bind="bio" disabled="@(!isEditing)" 
                          placeholder="Tell patients about yourself..."></textarea>
            </div>
        </div>
    </section>

    <!-- Credentials & Certifications -->
    <section class="info-card">
        <div class="section-header">
            <h2 class="headline-md">Credentials & Certifications</h2>
        </div>
        <div class="form-grid">
            <div class="form-group full-width">
                <label class="body-sm">Medical School</label>
                <input type="text" class="form-input" @bind="medicalSchool" disabled="@(!isEditing)" />
            </div>
            <div class="form-group">
                <label class="body-sm">Graduation Year</label>
                <input type="number" class="form-input" @bind="graduationYear" disabled="@(!isEditing)" />
            </div>
            <div class="form-group">
                <label class="body-sm">Board Certification</label>
                <input type="text" class="form-input" @bind="boardCertification" disabled="@(!isEditing)" />
            </div>
            <div class="form-group full-width">
                <label class="body-sm">Languages Spoken (comma-separated)</label>
                <input type="text" class="form-input" @bind="languagesInput" disabled="@(!isEditing)" 
                       placeholder="e.g., English, Spanish, French" />
            </div>
        </div>
    </section>

    <!-- Practice Settings -->
    <section class="info-card">
        <div class="section-header">
            <h2 class="headline-md">Practice Settings</h2>
        </div>
        <div class="form-grid">
            <div class="form-group">
                <label class="body-sm">Consultation Fee</label>
                <input type="number" class="form-input" @bind="consultationFee" disabled="@(!isEditing)" />
            </div>
            <div class="form-group">
                <label class="body-sm">Availability Status</label>
                <select class="form-input" @bind="availabilityStatus" disabled="@(!isEditing)">
                    <option value="Available">Available</option>
                    <option value="Busy">Busy</option>
                    <option value="Away">Away</option>
                    <option value="Offline">Offline</option>
                </select>
            </div>
            <div class="form-group full-width">
                <label class="body-sm">Office Address</label>
                <textarea class="form-input" rows="2" @bind="officeAddress" disabled="@(!isEditing)"></textarea>
            </div>
        </div>
    </section>
</div>

@code {
    private bool isEditing = false;
    private bool isSaving = false;

    // Form fields
    private string? fullName = "Dr. John Smith";
    private string? email = "dr.smith@aiclinic.com";
    private string? phoneNumber = "+1 (555) 123-4567";
    private string? licenseNumber = "MD-123456";
    private string? specialty = "Cardiology";
    private int yearsExperience = 15;
    private string? bio = "Board-certified cardiologist with over 15 years of experience in treating cardiovascular diseases.";
    private string? medicalSchool = "Harvard Medical School";
    private int graduationYear = 2008;
    private string? boardCertification = "American Board of Internal Medicine - Cardiology";
    private string? languagesInput = "English, Spanish";
    private decimal consultationFee = 150;
    private string? availabilityStatus = "Available";
    private string? officeAddress = "123 Medical Center Dr, Suite 400\nNew York, NY 10001";

    private void EnableEdit()
    {
        isEditing = true;
    }

    private void CancelEdit()
    {
        isEditing = false;
        // Reset form fields to original values
    }

    private async Task SaveChanges()
    {
        isSaving = true;
        try
        {
            // TODO: Implement save logic
            await Task.Delay(1000); // Simulate API call
            isEditing = false;
        }
        finally
        {
            isSaving = false;
        }
    }
}

<style>
    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2rem;
    }

    .header-left h1 {
        font-size: 2rem;
        font-weight: 700;
        color: #191c1e;
        margin: 0.5rem;
        font-family: 'Manrope', sans-serif;
    }

    .header-left p {
        color: #434654;
    }

    .header-right {
        display: flex;
        gap: 1rem;
    }

    .content-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 2rem;
    }

    .profile-photo-card {
        grid-column: span 1;
        background: white;
        padding: 2rem;
        border-radius: 16px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        height: fit-content;
    }

    .photo-container {
        position: relative;
        margin-bottom: 1.5rem;
    }

    .avatar-large {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, #10b981, #059669);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: white;
    }

    .photo-upload-btn {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #1e40af;
        color: white;
        border: 3px solid white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .photo-info h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
        margin-bottom: 0.5rem;
    }

    .photo-info p {
        color: #434654;
        margin-bottom: 0.25rem;
    }

    .rating-display {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        margin-top: 1rem;
        color: #d97706;
        font-weight: 600;
    }

    .info-card {
        grid-column: span 2;
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .info-card:first-of-type {
        grid-column: 2;
        grid-row: 1;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.75rem;
    }

    .section-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-group.full-width {
        grid-column: span 2;
    }

    .form-group label {
        color: #434654;
        font-weight: 500;
    }

    .form-input {
        padding: 0.875rem 1rem;
        border: 1px solid #e6e8ea;
        border-radius: 8px;
        font-size: 0.9375rem;
        font-family: 'Inter', sans-serif;
        transition: all 0.2s;
    }

    .form-input:focus {
        outline: none;
        border-color: #1e40af;
        box-shadow: 0 0 0 3px rgba(30, 64, 175, 0.1);
    }

    .form-input:disabled {
        background-color: #f5f5f5;
        cursor: not-allowed;
    }

    textarea.form-input {
        resize: vertical;
        min-height: 80px;
    }

    select.form-input {
        cursor: pointer;
    }

    .btn {
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-primary {
        background: #1e40af;
        color: white;
    }

    .btn-primary:hover:not(:disabled) {
        background: #1e3a8a;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(30, 64, 175, 0.3);
    }

    .btn-save {
        background: #10b981;
        color: white;
    }

    .btn-save:hover:not(:disabled) {
        background: #059669;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

    .btn-save:disabled {
        background: #a5d6a7;
        cursor: not-allowed;
    }

    .btn-discard {
        background: #d32f2f;
        color: white;
    }

    .btn-discard:hover {
        background: #b71c1c;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(211, 47, 47, 0.3);
    }

    @@media (max-width: 1024px) {
        .content-grid {
            grid-template-columns: 1fr;
        }

        .profile-photo-card,
        .info-card,
        .info-card:first-of-type {
            grid-column: span 1;
            grid-row: auto;
        }
    }

    @@media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }

        .form-group.full-width {
            grid-column: span 1;
        }

        .header-right {
            flex-direction: column;
        }
    }
</style>
