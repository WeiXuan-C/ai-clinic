@page "/doctor/consultation"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout Components.Layout.DoctorSidebarLayout
@inject ai_clinic.Controller.DoctorProfileController DoctorController
@inject ai_clinic.Controller.ConversationController ConversationController
@inject NavigationManager Navigation

<PageTitle>Consultations - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>My Consultations</h1>
        <p class="body-md" style="margin: 0.5rem;">
            <span class="status-indicator @GetStatusClass()">●</span>
            @activeChatrooms active chatrooms
        </p>
    </div>
    <div class="header-right">
        <div class="availability-selector">
            <label class="body-sm">Availability:</label>
            <select class="availability-dropdown" @bind="currentAvailability" @bind:after="UpdateAvailability">
                <option value="available">🟢 Available</option>
                <option value="busy">🟡 Busy</option>
                <option value="away">🟠 Away</option>
                <option value="offline">🔴 Offline</option>
            </select>
        </div>
        <button class="btn btn-secondary" @onclick="RefreshChatrooms">
            <i data-lucide="refresh-cw"></i>
            Refresh
        </button>
    </div>
</header>

<!-- Filter Tabs -->
<div class="filter-tabs">
    <button class="tab-btn @(selectedFilter == "all" ? "active" : "")" @onclick='() => selectedFilter = "all"'>
        All Chatrooms (@conversations.Count())
    </button>
    <button class="tab-btn @(selectedFilter == "active" ? "active" : "")" @onclick='() => selectedFilter = "active"'>
        Active (@conversations.Count(c => c.Status == "active"))
    </button>
    <button class="tab-btn @(selectedFilter == "pending" ? "active" : "")" @onclick='() => selectedFilter = "pending"'>
        Pending (@conversations.Count(c => c.ConsultationStatus == "pending"))
    </button>
    <button class="tab-btn @(selectedFilter == "completed" ? "active" : "")" @onclick='() => selectedFilter = "completed"'>
        Completed (@conversations.Count(c => c.Status == "closed"))
    </button>
</div>

<!-- Content Grid -->
<div class="content-grid">
    <!-- Chatroom List -->
    <section class="chatrooms-section">
        <div class="section-header">
            <h2 class="headline-md">Chatrooms</h2>
            <div class="search-box">
                <i data-lucide="search"></i>
                <input type="text" placeholder="Search chatrooms..." @bind="searchQuery" @bind:event="oninput" />
            </div>
        </div>
        
        @if (isLoading)
        {
            <div class="loading-state">
                <i data-lucide="loader"></i>
                <p>Loading chatrooms...</p>
            </div>
        }
        else if (!FilteredConversations.Any())
        {
            <div class="empty-state">
                <i data-lucide="message-circle"></i>
                <h3>No chatrooms found</h3>
                <p>You don't have any @(selectedFilter == "all" ? "" : selectedFilter) chatrooms yet.</p>
            </div>
        }
        else
        {
            <div class="chatrooms-list">
                @foreach (var conversation in FilteredConversations)
                {
                    <div class="chatroom-item @GetChatroomClass(conversation)" @onclick="() => EnterChatroom(conversation.Id)">
                        <div class="chatroom-avatar">
                            <span>@GetPatientInitials(conversation)</span>
                        </div>
                        <div class="chatroom-info">
                            <h4 class="headline-sm">@(conversation.Title ?? "Patient Consultation")</h4>
                            <p class="body-sm">
                                @if (conversation.InitialSymptoms != null && conversation.InitialSymptoms.Any())
                                {
                                    <text>Symptoms: @string.Join(", ", conversation.InitialSymptoms.Take(2))</text>
                                }
                                else
                                {
                                    <text>No symptoms recorded</text>
                                }
                            </p>
                            <p class="body-sm">
                                Messages: @conversation.TotalMessages 
                                @if (conversation.AiMessagesCount > 0)
                                {
                                    <span class="ai-badge">
                                        <i data-lucide="bot"></i>
                                        @conversation.AiMessagesCount AI
                                    </span>
                                }
                            </p>
                        </div>
                        <div class="chatroom-meta">
                            <span class="badge @GetStatusBadgeClass(conversation)">@GetStatusText(conversation)</span>
                            <span class="time-badge">@GetTimeAgo(conversation.LastMessageAt)</span>
                            @if (conversation.RequiredSpecialization != null)
                            {
                                <span class="specialization-tag">@conversation.RequiredSpecialization</span>
                            }
                        </div>
                        <div class="chatroom-actions">
                            <button class="btn-primary-sm" @onclick:stopPropagation="true" @onclick="() => EnterChatroom(conversation.Id)">
                                <i data-lucide="message-circle"></i>
                                Enter Chat
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <!-- Quick Stats -->
    <section class="stats-sidebar">
        <h3 class="headline-md">Overview</h3>
        
        <div class="availability-card">
            <div class="availability-header">
                <i data-lucide="activity"></i>
                <h4 class="headline-sm">Your Status</h4>
            </div>
            <div class="availability-display">
                <span class="status-dot @GetStatusClass()"></span>
                <span class="status-text">@GetAvailabilityText()</span>
            </div>
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <p class="status-message">@statusMessage</p>
            }
        </div>

        <div class="stats-list">
            <div class="stat-item">
                <i data-lucide="message-circle" class="stat-icon"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">@conversations.Count</h4>
                    <p class="body-sm">Total Chatrooms</p>
                </div>
            </div>
            <div class="stat-item">
                <i data-lucide="activity" class="stat-icon active"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">@conversations.Count(c => c.Status == "active")</h4>
                    <p class="body-sm">Active</p>
                </div>
            </div>
            <div class="stat-item">
                <i data-lucide="clock" class="stat-icon"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">@conversations.Count(c => c.ConsultationStatus == "pending")</h4>
                    <p class="body-sm">Pending</p>
                </div>
            </div>
            <div class="stat-item">
                <i data-lucide="check-circle" class="stat-icon success"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">@conversations.Count(c => c.Status == "closed")</h4>
                    <p class="body-sm">Completed</p>
                </div>
            </div>
        </div>

        <div class="ai-summary">
            <div class="ai-header">
                <i data-lucide="bot"></i>
                <h4 class="headline-sm">AI Insights</h4>
            </div>
            <p class="body-sm">
                @conversations.Count(c => c.AiMessagesCount > 0) chatrooms have AI pre-assessments.
                @if (conversations.Any())
                {
                    <text>Average messages per chat: @((int)conversations.Average(c => c.TotalMessages))</text>
                }
            </p>
        </div>
    </section>
</div>

@code {
    private List<ai_clinic.Interfaces.Conversation> conversations = new();
    private string currentAvailability = "available";
    private string selectedFilter = "all";
    private string searchQuery = "";
    private bool isLoading = true;
    private string statusMessage = "";
    private int activeChatrooms => conversations.Count(c => c.Status == "active");

    private IEnumerable<ai_clinic.Interfaces.Conversation> FilteredConversations
    {
        get
        {
            var filtered = conversations.AsEnumerable();

            // Apply status filter
            filtered = selectedFilter switch
            {
                "active" => filtered.Where(c => c.Status == "active"),
                "pending" => filtered.Where(c => c.ConsultationStatus == "pending"),
                "completed" => filtered.Where(c => c.Status == "closed"),
                _ => filtered
            };

            // Apply search filter
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                filtered = filtered.Where(c =>
                    (c.Title?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (c.InitialSymptoms?.Any(s => s.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)) ?? false) ||
                    (c.RequiredSpecialization?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false)
                );
            }

            return filtered.OrderByDescending(c => c.LastMessageAt);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadChatrooms();
        await LoadDoctorAvailability();
    }

    private async Task LoadChatrooms()
    {
        isLoading = true;
        try
        {
            // TODO: Get current doctor's user ID from auth service
            var doctorUserId = Guid.Parse("00000000-0000-0000-0000-000000000001"); // Placeholder
            
            var allConversations = await ConversationController.GetConversationsByUserIdAsync(doctorUserId.ToString());
            conversations = allConversations.Cast<ai_clinic.Interfaces.Conversation>().ToList();
        }
        catch (Exception ex)
        {
            statusMessage = $"Error loading chatrooms: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadDoctorAvailability()
    {
        try
        {
            // TODO: Load actual doctor profile and get availability
            currentAvailability = "available";
        }
        catch (Exception ex)
        {
            statusMessage = $"Error loading availability: {ex.Message}";
        }
    }

    private async Task UpdateAvailability()
    {
        try
        {
            var result = await DoctorController.UpdateAvailabilityAsync(currentAvailability);
            if (result.Success)
            {
                statusMessage = $"Status updated to {GetAvailabilityText()}";
                StateHasChanged();
                
                // Clear message after 3 seconds
                await Task.Delay(3000);
                statusMessage = "";
                StateHasChanged();
            }
            else
            {
                statusMessage = result.Message;
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Error updating availability: {ex.Message}";
        }
    }

    private async Task RefreshChatrooms()
    {
        await LoadChatrooms();
        statusMessage = "Chatrooms refreshed";
        StateHasChanged();
        await Task.Delay(2000);
        statusMessage = "";
        StateHasChanged();
    }

    private void EnterChatroom(Guid conversationId)
    {
        Navigation.NavigateTo($"/doctor/chat/{conversationId}");
    }

    private string GetStatusClass()
    {
        return currentAvailability switch
        {
            "available" => "status-available",
            "busy" => "status-busy",
            "away" => "status-away",
            "offline" => "status-offline",
            _ => ""
        };
    }

    private string GetAvailabilityText()
    {
        return currentAvailability switch
        {
            "available" => "Available",
            "busy" => "Busy",
            "away" => "Away",
            "offline" => "Offline",
            _ => "Unknown"
        };
    }

    private string GetChatroomClass(ai_clinic.Interfaces.Conversation conversation)
    {
        if (conversation.ConsultationStatus == "urgent") return "urgent";
        if (conversation.Status == "active") return "active";
        return "";
    }

    private string GetPatientInitials(ai_clinic.Interfaces.Conversation conversation)
    {
        // TODO: Get actual patient name from patient profile
        return "PT";
    }

    private string GetStatusBadgeClass(ai_clinic.Interfaces.Conversation conversation)
    {
        return conversation.Status switch
        {
            "active" => "badge-active",
            "closed" => "badge-completed",
            _ => conversation.ConsultationStatus switch
            {
                "pending" => "badge-pending",
                "urgent" => "badge-urgent",
                _ => "badge-default"
            }
        };
    }

    private string GetStatusText(ai_clinic.Interfaces.Conversation conversation)
    {
        if (conversation.Status == "closed") return "COMPLETED";
        if (conversation.ConsultationStatus == "urgent") return "URGENT";
        if (conversation.ConsultationStatus == "pending") return "PENDING";
        return "ACTIVE";
    }

    private string GetTimeAgo(DateTime dateTime)
    {
        var timeSpan = DateTime.UtcNow - dateTime;
        
        if (timeSpan.TotalMinutes < 1) return "Just now";
        if (timeSpan.TotalMinutes < 60) return $"{(int)timeSpan.TotalMinutes} min ago";
        if (timeSpan.TotalHours < 24) return $"{(int)timeSpan.TotalHours} hour{((int)timeSpan.TotalHours != 1 ? "s" : "")} ago";
        if (timeSpan.TotalDays < 7) return $"{(int)timeSpan.TotalDays} day{((int)timeSpan.TotalDays != 1 ? "s" : "")} ago";
        
        return dateTime.ToString("MMM dd");
    }
}

