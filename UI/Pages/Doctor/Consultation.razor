@page "/doctor/consultation"
@layout Components.Layout.DoctorSidebarLayout
@using ai_clinic.Models
@using ai_clinic.UI.Components

<PageTitle>Consultations - AI Medical Clinic</PageTitle>

<div class="consultation-container">
    <!-- Left Sidebar: History -->
    <div class="history-sidebar">
        <div class="history-sidebar-header">
            <h3>CONVERSATIONS</h3>
        </div>
        <div class="history-list">
            @if (conversationList.Count > 0)
            {
                @foreach (var conv in conversationList)
                {
                    <div class="history-item @(currentConversation?.Id == conv.Id ? "active" : "")"
                         @onclick="@(() => LoadConversation(conv.Id))">
                        <div class="history-header">
                            <div class="history-title">@conv.Title</div>
                            @if (conv.UnreadCount > 0)
                            {
                                <span class="unread-badge">@conv.UnreadCount</span>
                            }
                        </div>
                        <div class="history-meta">@FormatTime(conv.LastMessageAt) • @conv.Status</div>
                        @if (conv.IsAiConversation)
                        {
                            <span class="ai-tag">
                                <i data-lucide="bot" style="width: 12px; height: 12px;"></i>
                                AI Pre-assessment
                            </span>
                        }
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: 24px; color: #6b7280;">
                    <i data-lucide="inbox" style="width: 48px; height: 48px; color: #d1d5db; margin: 0 auto 12px;"></i>
                    <p>No conversations yet</p>
                </div>
            }
        </div>
    </div>

    <!-- Main Chat Area -->
    <div class="chat-area">
        @if (currentConversation != null)
        {
            <!-- Header -->
            <div class="chat-header" @key="@($"header-{currentConversation.Id}")">
                <div class="chat-header-title">
                    <i data-lucide="user" style="width: 20px; height: 20px; color: #3b82f6;"></i>
                    <span>@(currentConversation.Patient?.Email?.Split('@')[0] ?? "Patient")</span>
                </div>
            </div>

            <!-- Chat Messages -->
            <div class="messages-container" id="messages-container">
                @foreach (var message in messages)
                {
                    <div class="message @(message.SenderType == MessageSenderType.Doctor ? "user-message" :
                                         message.SenderType == MessageSenderType.AI ? "ai-message" : "patient-message")">
                        <div class="message-avatar">
                            @if (message.SenderType == MessageSenderType.Doctor)
                            {
                                @if (!string.IsNullOrEmpty(doctorPhotoUrl))
                                {
                                    <img src="@doctorPhotoUrl" alt="Doctor" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" />
                                }
                                else
                                {
                                    <i data-lucide="user" style="width: 20px; height: 20px; color: white;"></i>
                                }
                            }
                            else if (message.SenderType == MessageSenderType.AI)
                            {
                                <i data-lucide="bot" style="width: 20px; height: 20px; color: white;"></i>
                            }
                            else
                            {
                                @if (!string.IsNullOrEmpty(patientPhotoUrl))
                                {
                                    <img src="@patientPhotoUrl" alt="Patient" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" />
                                }
                                else
                                {
                                    <i data-lucide="user" style="width: 20px; height: 20px; color: white;"></i>
                                }
                            }
                        </div>
                        <div class="message-content">
                            <div class="message-text">
                                @if (message.SenderType == MessageSenderType.AI)
                                {
                                    <MarkdownRenderer Content="@message.Content" />
                                }
                                else
                                {
                                    @message.Content
                                }

                                @* Display attachments if any *@
                                @if (!string.IsNullOrEmpty(message.DocumentReferences))
                                {
                                    var docs = GetMessageDocuments(message.Id);
                                    if (docs.Any())
                                    {
                                        <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(0,0,0,0.1);">
                                            @foreach (var doc in docs)
                                            {
                                                @if (IsImageDocument(doc))
                                                {
                                                    <!-- Image attachment - display inline -->
                                                    <div style="margin-top: 8px;">
                                                        <img src="@GetImageDataUrl(doc)" 
                                                             alt="@doc.FileName" 
                                                             style="max-width: 100%; max-height: 300px; border-radius: 8px; cursor: pointer;"
                                                             @onclick="@(() => DownloadDocument(doc))"
                                                             title="Click to download: @doc.FileName" />
                                                        <div style="font-size: 11px; color: #6b7280; margin-top: 4px;">
                                                            @doc.FileName (@FormatFileSize(doc.FileSizeBytes))
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <!-- Non-image attachment - show download link -->
                                                    <div style="margin-top: 8px; padding: 8px 12px; background: rgba(0,0,0,0.05); border-radius: 8px; display: flex; align-items: center; gap: 8px; cursor: pointer;"
                                                         @onclick="@(() => DownloadDocument(doc))">
                                                        <i data-lucide="file" style="width: 16px; height: 16px; color: #6b7280;"></i>
                                                        <div style="flex: 1; min-width: 0;">
                                                            <div style="font-size: 12px; font-weight: 500; color: #111827; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                                @doc.FileName
                                                            </div>
                                                            <div style="font-size: 11px; color: #6b7280;">
                                                                @FormatFileSize(doc.FileSizeBytes)
                                                            </div>
                                                        </div>
                                                        <i data-lucide="download" style="width: 16px; height: 16px; color: #8b5cf6;"></i>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                }

                                <div class="message-time">@message.CreatedAt.ToString("HH:mm")</div>
                            </div>
                        </div>
                    </div>
                }

                @if (isTyping)
                {
                    <div class="message ai-message">
                        <div class="message-avatar">
                            <i data-lucide="bot" style="width: 20px; height: 20px; color: white;"></i>
                        </div>
                        <div class="typing-indicator">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                    </div>
                }
            </div>

            <!-- Input Area -->
            <div class="input-area" @key="@($"input-{currentConversation.Id}")">
                <div class="input-features">
                    <span class="feature-badge">
                        <i data-lucide="shield-check" style="width: 14px; height: 14px;"></i>
                        Professional medical consultation
                    </span>
                </div>

                <div class="input-box">
                    <button class="icon-btn" title="Emoji">
                        <i data-lucide="smile" style="width: 20px; height: 20px;"></i>
                    </button>
                    <input type="text"
                           placeholder="Type your response..."
                           @bind="newMessage"
                           @bind:event="oninput"
                           @onkeydown="HandleKeyPress" />
                    <button class="icon-btn" title="Voice input">
                        <i data-lucide="mic" style="width: 20px; height: 20px;"></i>
                    </button>
                    <button class="send-btn @(string.IsNullOrWhiteSpace(newMessage) ? "disabled" : "")"
                            @onclick="SendMessage"
                            disabled="@(string.IsNullOrWhiteSpace(newMessage))"
                            title="Send message">
                        <i data-lucide="send" style="width: 20px; height: 20px;"></i>
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i data-lucide="message-circle" style="width: 64px; height: 64px; color: #d1d5db; margin-bottom: 16px;"></i>
                <div class="empty-state-text">Select a conversation to start</div>
            </div>
        }
    </div>

    <!-- Right Sidebar: Conversation Info -->
    <div class="context-sidebar">
        <h3>Conversation Info</h3>
        @if (currentConversation != null)
        {
            <p class="context-description">
                Consultation with @(currentConversation.Patient?.Email?.Split('@')[0] ?? "Patient")
            </p>

            <div style="margin-top: 20px;">
                <p style="font-size: 13px; color: #6b7280; margin-bottom: 8px;">
                    <strong>Started:</strong> @currentConversation.StartedAt.ToString("MMM dd, yyyy HH:mm")
                </p>
                <p style="font-size: 13px; color: #6b7280; margin-bottom: 8px;">
                    <strong>Messages:</strong> @currentConversation.TotalMessages
                </p>
                <p style="font-size: 13px; color: #6b7280; margin-bottom: 8px;">
                    <strong>Status:</strong> @currentConversation.Status
                </p>
                @if (!string.IsNullOrEmpty(currentConversation.InitialSymptoms))
                {
                    <div style="margin-top: 16px; padding: 12px; background: #f0f9ff; border-radius: 8px; border-left: 3px solid #0ea5e9;">
                        <p style="font-size: 12px; font-weight: 600; color: #0284c7; margin-bottom: 4px;">Initial Symptoms:</p>
                        <p style="font-size: 13px; color: #0c4a6e; line-height: 1.5; margin: 0;">@currentConversation.InitialSymptoms</p>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="context-description">No conversation selected</p>
        }
    </div>
</div>

