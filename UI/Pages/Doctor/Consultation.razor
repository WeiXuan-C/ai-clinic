@page "/doctor/consultation"
@layout Components.Layout.DoctorSidebarLayout

<PageTitle>Consultations - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>My Consultations</h1>
        <p class="body-md" style="margin: 0.5rem;">
            <span class="status-indicator status-available">●</span>
            5 active chatrooms
        </p>
    </div>
    <div class="header-right">
        <div class="availability-selector">
            <label class="body-sm">Availability:</label>
            <select class="availability-dropdown">
                <option value="available">🟢 Available</option>
                <option value="busy">🟡 Busy</option>
                <option value="away">🟠 Away</option>
                <option value="offline">🔴 Offline</option>
            </select>
        </div>
        <button class="btn btn-secondary">
            <i data-lucide="refresh-cw"></i>
            Refresh
        </button>
    </div>
</header>

<!-- Filter Tabs -->
<div class="filter-tabs">
    <button class="tab-btn active">
        All Chatrooms (5)
    </button>
    <button class="tab-btn">
        Active (3)
    </button>
    <button class="tab-btn">
        Pending (2)
    </button>
    <button class="tab-btn">
        Completed (0)
    </button>
</div>

<!-- Content Grid -->
<div class="content-grid">
    <!-- Chatroom List -->
    <section class="chatrooms-section">
        <div class="section-header">
            <h2 class="headline-md">Chatrooms</h2>
            <div class="search-box">
                <i data-lucide="search"></i>
                <input type="text" placeholder="Search chatrooms..." />
            </div>
        </div>
        
        <div class="chatrooms-list">
            <div class="chatroom-item active">
                <div class="chatroom-avatar">
                    <span>SJ</span>
                </div>
                <div class="chatroom-info">
                    <h4 class="headline-sm">Patient Consultation</h4>
                    <p class="body-sm">
                        Symptoms: Headache, Fever
                    </p>
                    <p class="body-sm">
                        Messages: 12 
                        <span class="ai-badge">
                            <i data-lucide="bot"></i>
                            5 AI
                        </span>
                    </p>
                </div>
                <div class="chatroom-meta">
                    <span class="badge badge-active">ACTIVE</span>
                    <span class="time-badge">5 min ago</span>
                    <span class="specialization-tag">Cardiology</span>
                </div>
                <div class="chatroom-actions">
                    <button class="btn-primary-sm">
                        <i data-lucide="message-circle"></i>
                        Enter Chat
                    </button>
                </div>
            </div>
            <div class="chatroom-item urgent">
                <div class="chatroom-avatar">
                    <span>MC</span>
                </div>
                <div class="chatroom-info">
                    <h4 class="headline-sm">Urgent Consultation</h4>
                    <p class="body-sm">
                        Symptoms: Chest Pain
                    </p>
                    <p class="body-sm">
                        Messages: 3 
                        <span class="ai-badge">
                            <i data-lucide="bot"></i>
                            2 AI
                        </span>
                    </p>
                </div>
                <div class="chatroom-meta">
                    <span class="badge badge-urgent">URGENT</span>
                    <span class="time-badge">2 min ago</span>
                </div>
                <div class="chatroom-actions">
                    <button class="btn-primary-sm">
                        <i data-lucide="message-circle"></i>
                        Enter Chat
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick Stats -->
    <section class="stats-sidebar">
        <h3 class="headline-md">Overview</h3>
        
        <div class="availability-card">
            <div class="availability-header">
                <i data-lucide="activity"></i>
                <h4 class="headline-sm">Your Status</h4>
            </div>
            <div class="availability-display">
                <span class="status-dot status-available"></span>
                <span class="status-text">Available</span>
            </div>
            <p class="status-message">Ready to accept new consultations</p>
        </div>

        <div class="stats-list">
            <div class="stat-item">
                <i data-lucide="message-circle" class="stat-icon"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">5</h4>
                    <p class="body-sm">Total Chatrooms</p>
                </div>
            </div>
            <div class="stat-item">
                <i data-lucide="activity" class="stat-icon active"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">3</h4>
                    <p class="body-sm">Active</p>
                </div>
            </div>
            <div class="stat-item">
                <i data-lucide="clock" class="stat-icon"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">2</h4>
                    <p class="body-sm">Pending</p>
                </div>
            </div>
            <div class="stat-item">
                <i data-lucide="check-circle" class="stat-icon success"></i>
                <div class="stat-info">
                    <h4 class="headline-lg">0</h4>
                    <p class="body-sm">Completed</p>
                </div>
            </div>
        </div>

        <div class="ai-summary">
            <div class="ai-header">
                <i data-lucide="bot"></i>
                <h4 class="headline-sm">AI Insights</h4>
            </div>
            <p class="body-sm">
                3 chatrooms have AI pre-assessments.
                Average messages per chat: 8
            </p>
        </div>
    </section>
</div>

<style>
    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2rem;
    }

    .header-left h1 {
        font-size: 2rem;
        font-weight: 700;
        color: #191c1e;
        margin: 0.5rem;
        font-family: 'Manrope', sans-serif;
    }

    .header-left p {
        color: #434654;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .status-indicator {
        font-size: 0.75rem;
    }

    .status-indicator.status-available {
        color: #10b981;
    }

    .status-indicator.status-busy {
        color: #f59e0b;
    }

    .status-indicator.status-away {
        color: #f97316;
    }

    .status-indicator.status-offline {
        color: #6b7280;
    }

    .header-right {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .availability-selector {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1rem;
        background: white;
        border-radius: 8px;
        border: 1px solid #e6e8ea;
    }

    .availability-selector label {
        color: #434654;
        font-weight: 500;
    }

    .availability-dropdown {
        padding: 0.5rem 1rem;
        border: 1px solid #e6e8ea;
        border-radius: 6px;
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        background: white;
        transition: all 0.2s;
    }

    .availability-dropdown:focus {
        outline: none;
        border-color: #1e40af;
    }

    .filter-tabs {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        overflow-x: auto;
        padding-bottom: 0.5rem;
    }

    .tab-btn {
        padding: 0.75rem 1.5rem;
        background: white;
        border: 1px solid #e6e8ea;
        border-radius: 8px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
        font-size: 0.875rem;
    }

    .tab-btn:hover {
        background: #f7f9fb;
    }

    .tab-btn.active {
        background: #1e40af;
        color: white;
        border-color: #1e40af;
    }

    .content-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 2rem;
    }

    .chatrooms-section {
        grid-column: span 1;
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.75rem;
    }

    .section-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
    }

    .search-box {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        background: #f7f9fb;
        border-radius: 8px;
        min-width: 300px;
    }

    .search-box input {
        border: none;
        background: transparent;
        outline: none;
        font-size: 0.875rem;
        width: 100%;
    }

    .loading-state,
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem 2rem;
        text-align: center;
        color: #434654;
    }

    .loading-state i,
    .empty-state i {
        font-size: 3rem;
        margin-bottom: 1rem;
        color: #9ca3af;
    }

    .empty-state h3 {
        font-size: 1.25rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.5rem;
    }

    .chatrooms-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .chatroom-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem;
        background: #f7f9fb;
        border-radius: 12px;
        border-left: 4px solid #e6e8ea;
        transition: all 0.2s;
        cursor: pointer;
    }

    .chatroom-item:hover {
        background: #eceef0;
        transform: translateX(4px);
    }

    .chatroom-item.urgent {
        border-left-color: #ef4444;
        background: #fef2f2;
    }

    .chatroom-item.active {
        border-left-color: #10b981;
        background: #f0fdf4;
    }

    .chatroom-avatar {
        width: 56px;
        height: 56px;
        min-width: 56px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1e40af, #1e3a8a);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 1.125rem;
    }

    .chatroom-info {
        flex: 1;
    }

    .chatroom-info h4 {
        font-size: 1rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.25rem;
    }

    .chatroom-info p {
        font-size: 0.8125rem;
        color: #434654;
        margin-bottom: 0.125rem;
    }

    .ai-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.125rem 0.5rem;
        background: #f3e8ff;
        border-radius: 4px;
        color: #7c3aed;
        font-size: 0.75rem;
        font-weight: 600;
        margin-left: 0.5rem;
    }

    .chatroom-meta {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.5rem;
    }

    .badge {
        padding: 0.375rem 0.75rem;
        border-radius: 6px;
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        white-space: nowrap;
    }

    .badge-urgent {
        background: #fee2e2;
        color: #991b1b;
    }

    .badge-active {
        background: #d1fae5;
        color: #065f46;
    }

    .badge-pending {
        background: #fef3c7;
        color: #92400e;
    }

    .badge-completed {
        background: #e0e7ff;
        color: #3730a3;
    }

    .badge-default {
        background: #f3f4f6;
        color: #4b5563;
    }

    .time-badge {
        font-size: 0.75rem;
        color: #434654;
        font-weight: 500;
    }

    .specialization-tag {
        font-size: 0.75rem;
        padding: 0.25rem 0.5rem;
        background: #dbeafe;
        color: #1e40af;
        border-radius: 4px;
        font-weight: 500;
    }

    .chatroom-actions {
        display: flex;
        gap: 0.5rem;
    }

    .btn-primary-sm {
        padding: 0.5rem 1rem;
        background: #1e40af;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 0.8125rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-primary-sm:hover {
        background: #1e3a8a;
    }

    .stats-sidebar {
        grid-column: span 1;
        background: white;
        padding: 2rem;
        border-radius: 16px;
        height: fit-content;
    }

    .stats-sidebar h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
        margin-bottom: 1.5rem;
    }

    .availability-card {
        padding: 1.5rem;
        background: linear-gradient(135deg, #f0f9ff, #e0f2fe);
        border-radius: 12px;
        margin-bottom: 1.5rem;
    }

    .availability-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
        color: #1e40af;
    }

    .availability-header h4 {
        font-size: 1rem;
        font-weight: 600;
    }

    .availability-display {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.5rem;
    }

    .status-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
    }

    .status-dot.status-available {
        background: #10b981;
    }

    .status-dot.status-busy {
        background: #f59e0b;
    }

    .status-dot.status-away {
        background: #f97316;
    }

    .status-dot.status-offline {
        background: #6b7280;
    }

    .status-text {
        font-size: 1.125rem;
        font-weight: 600;
        color: #191c1e;
    }

    .status-message {
        font-size: 0.8125rem;
        color: #059669;
        font-weight: 500;
        margin-top: 0.5rem;
    }

    .stats-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .stat-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        background: #f7f9fb;
        border-radius: 12px;
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        min-width: 48px;
        background: #1e40af;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: white;
    }

    .stat-icon.active {
        background: #10b981;
    }

    .stat-icon.success {
        background: #10b981;
    }

    .stat-info h4 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #191c1e;
        margin-bottom: 0.25rem;
    }

    .stat-info p {
        color: #434654;
        font-size: 0.875rem;
    }

    .ai-summary {
        padding: 1.5rem;
        background: linear-gradient(135deg, #f3e8ff, #e9d5ff);
        border-radius: 12px;
    }

    .ai-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
        color: #7c3aed;
    }

    .ai-header h4 {
        font-size: 1rem;
        font-weight: 600;
    }

    .ai-summary p {
        color: #6b21a8;
        margin-bottom: 0;
        line-height: 1.5;
        font-size: 0.875rem;
    }

    .btn {
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-primary {
        background: #1e40af;
        color: white;
    }

    .btn-primary:hover {
        background: #1e3a8a;
        transform: translateY(-1px);
    }

    .btn-secondary {
        background: #e6e8ea;
        color: #191c1e;
    }

    .btn-secondary:hover {
        background: #d8dadc;
    }

    @@media (max-width: 1024px) {
        .content-grid {
            grid-template-columns: 1fr;
        }

        .chatrooms-section,
        .stats-sidebar {
            grid-column: span 1;
        }

        .search-box {
            min-width: 200px;
        }
    }

    @@media (max-width: 768px) {
        .chatroom-item {
            flex-wrap: wrap;
        }

        .chatroom-actions {
            width: 100%;
            justify-content: flex-end;
        }

        .header-right {
            flex-direction: column;
            align-items: stretch;
        }

        .availability-selector {
            width: 100%;
        }
    }
</style>
