@page "/doctor/support"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout Components.Layout.DoctorSidebarLayout

<PageTitle>Support - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>Help & Support</h1>
        <p class="body-md" style="margin: 0.5rem;">
            <span class="status-indicator">●</span>
            Professional support available 24/7
        </p>
    </div>
    <div class="header-right">
        <button class="btn btn-primary">
            <i data-lucide="message-circle"></i>
            Contact Support
        </button>
    </div>
</header>

<!-- Content Grid -->
<div class="content-grid">
    <!-- Quick Actions -->
    <section class="quick-actions-section">
        <h2 class="headline-md">Quick Actions</h2>
        <div class="actions-grid">
            <div class="action-card">
                <i data-lucide="message-square" class="action-icon"></i>
                <h3 class="headline-sm">Live Chat</h3>
                <p class="body-sm">Chat with technical support</p>
            </div>
            <div class="action-card">
                <i data-lucide="phone" class="action-icon"></i>
                <h3 class="headline-sm">Call Us</h3>
                <p class="body-sm">1-800-DOC-HELP</p>
            </div>
            <div class="action-card">
                <i data-lucide="mail" class="action-icon"></i>
                <h3 class="headline-sm">Email</h3>
                <p class="body-sm">doctors@aiclinic.com</p>
            </div>
            <div class="action-card">
                <i data-lucide="book-open" class="action-icon"></i>
                <h3 class="headline-sm">Documentation</h3>
                <p class="body-sm">Browse guides & resources</p>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
        <div class="section-header">
            <h2 class="headline-md">Frequently Asked Questions</h2>
            <div class="search-box">
                <i data-lucide="search"></i>
                <input type="text" placeholder="Search FAQs..." />
            </div>
        </div>
        
        <div class="faq-list">
            <div class="faq-item">
                <div class="faq-question">
                    <h4 class="headline-sm">How do I access patient medical records?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">Navigate to the "Medical Records" section from the sidebar. You can search, filter, and access all patient records securely from there.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <h4 class="headline-sm">How does the AI pre-assessment work?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">Our AI assistant conducts preliminary patient assessments based on symptoms and medical history. You'll receive a detailed report to review before the consultation.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <h4 class="headline-sm">Can I customize my availability schedule?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">Yes! Go to Settings > Availability to set your working hours, maximum daily patients, and availability status.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <h4 class="headline-sm">How do I prescribe medications?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">During or after a consultation, click on the patient's record and select "New Prescription". The system integrates with major pharmacies for e-prescribing.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <h4 class="headline-sm">Is the platform HIPAA compliant?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">Yes, our platform is fully HIPAA compliant with end-to-end encryption, secure data storage, and comprehensive audit logs.</p>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question">
                    <h4 class="headline-sm">How do I handle urgent consultations?</h4>
                    <i data-lucide="chevron-down" class="faq-icon"></i>
                </div>
                <div class="faq-answer">
                    <p class="body-md">Urgent cases are flagged with a red badge and appear at the top of your patient queue. You'll receive immediate notifications for urgent requests.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Form -->
    <section class="contact-form-section">
        <div class="section-header">
            <h2 class="headline-md">Submit a Support Ticket</h2>
            <p class="body-sm">We typically respond within 2 hours</p>
        </div>
        
        <form class="contact-form">
            <div class="form-group">
                <label class="body-sm">Category</label>
                <select class="form-input">
                    <option>Select a category...</option>
                    <option>Technical Issue</option>
                    <option>Patient Records</option>
                    <option>Billing Question</option>
                    <option>Feature Request</option>
                    <option>Account Issue</option>
                    <option>Other</option>
                </select>
            </div>
            
            <div class="form-group">
                <label class="body-sm">Priority</label>
                <div class="priority-options">
                    <label class="radio-option">
                        <input type="radio" name="priority" value="low" checked />
                        <span>Low</span>
                    </label>
                    <label class="radio-option">
                        <input type="radio" name="priority" value="medium" />
                        <span>Medium</span>
                    </label>
                    <label class="radio-option">
                        <input type="radio" name="priority" value="high" />
                        <span>High</span>
                    </label>
                    <label class="radio-option">
                        <input type="radio" name="priority" value="urgent" />
                        <span>Urgent</span>
                    </label>
                </div>
            </div>

            <div class="form-group">
                <label class="body-sm">Description</label>
                <textarea class="form-input" rows="6" placeholder="Describe your issue or question..."></textarea>
            </div>

            <div class="form-group">
                <label class="body-sm">Attachments (optional)</label>
                <div class="file-upload">
                    <i data-lucide="paperclip"></i>
                    <span>Click to upload or drag and drop</span>
                    <input type="file" multiple />
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Submit Ticket</button>
        </form>
    </section>

    <!-- Resources Section -->
    <section class="resources-section">
        <h2 class="headline-md">Professional Resources</h2>
        <div class="resources-list">
            <a href="#" class="resource-item">
                <i data-lucide="book" class="resource-icon"></i>
                <div class="resource-info">
                    <h4 class="headline-sm">Clinical Guidelines</h4>
                    <p class="body-sm">Evidence-based practice guidelines</p>
                </div>
                <i data-lucide="arrow-right" class="arrow-icon"></i>
            </a>
            <a href="#" class="resource-item">
                <i data-lucide="video" class="resource-icon"></i>
                <div class="resource-info">
                    <h4 class="headline-sm">Training Videos</h4>
                    <p class="body-sm">Platform tutorials and best practices</p>
                </div>
                <i data-lucide="arrow-right" class="arrow-icon"></i>
            </a>
            <a href="#" class="resource-item">
                <i data-lucide="shield-check" class="resource-icon"></i>
                <div class="resource-info">
                    <h4 class="headline-sm">HIPAA Compliance</h4>
                    <p class="body-sm">Security and privacy information</p>
                </div>
                <i data-lucide="arrow-right" class="arrow-icon"></i>
            </a>
            <a href="#" class="resource-item">
                <i data-lucide="file-text" class="resource-icon"></i>
                <div class="resource-info">
                    <h4 class="headline-sm">API Documentation</h4>
                    <p class="body-sm">Integration guides for developers</p>
                </div>
                <i data-lucide="arrow-right" class="arrow-icon"></i>
            </a>
        </div>
    </section>

    <!-- System Status -->
    <section class="status-section">
        <div class="section-header">
            <h2 class="headline-md">System Status</h2>
            <span class="badge badge-success">ALL SYSTEMS OPERATIONAL</span>
        </div>
        <div class="status-list">
            <div class="status-item">
                <div class="status-indicator operational"></div>
                <span class="body-md">Doctor Portal</span>
                <span class="status-label">Operational</span>
            </div>
            <div class="status-item">
                <div class="status-indicator operational"></div>
                <span class="body-md">AI Assistant</span>
                <span class="status-label">Operational</span>
            </div>
            <div class="status-item">
                <div class="status-indicator operational"></div>
                <span class="body-md">Video Consultations</span>
                <span class="status-label">Operational</span>
            </div>
            <div class="status-item">
                <div class="status-indicator operational"></div>
                <span class="body-md">Medical Records</span>
                <span class="status-label">Operational</span>
            </div>
        </div>
    </section>
</div>

