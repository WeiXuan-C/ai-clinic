@page "/doctor/settings"
@using ai_clinic.Models
@layout Components.Layout.DoctorSidebarLayout

<PageTitle>Settings - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>Settings</h1>
        <p class="body-md" style="margin: 0.5rem;">
            Manage your account preferences and practice settings
        </p>
    </div>
</header>

<!-- Content Grid -->
@if (isLoading)
{
    <div style="text-align: center; padding: 3rem;">
        <div class="spinner"></div>
        <p class="body-md" style="margin-top: 1rem;">Loading settings...</p>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-error" style="max-width: 900px; margin: 0 auto 2rem;">
        <i data-lucide="alert-circle"></i>
        <span>@errorMessage</span>
    </div>
}
else
{
@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="success-banner">
        <i data-lucide="check-circle"></i>
        <span>@successMessage</span>
    </div>
}
<div class="content-grid">
    <!-- Account Settings -->
    <section class="settings-card">
        <div class="section-header">
            <div class="header-with-icon">
                <i data-lucide="user-cog" class="section-icon"></i>
                <h2 class="headline-md">Account Settings</h2>
            </div>
        </div>
        <div class="settings-list">
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Email Address</h4>
                    <p class="body-sm">@settings.Email</p>
                </div>
                <button class="btn-link" @onclick="OpenEmailChangeModal">Change</button>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Password</h4>
                    <p class="body-sm">••••••••</p>
                </div>
                <button class="btn-link" @onclick="OpenPasswordChangeModal">Change</button>
            </div>
        </div>
    </section>

    <!-- Availability Settings -->
    <section class="settings-card">
        <div class="section-header">
            <div class="header-with-icon">
                <i data-lucide="calendar" class="section-icon"></i>
                <h2 class="headline-md">Availability Settings</h2>
            </div>
        </div>
        <div class="settings-list">
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Current Status</h4>
                    <p class="body-sm">Set your availability status for patients</p>
                </div>
                <select class="select-input" @bind="settings.AvailabilityStatus" @bind:after="SaveSettings">
                    <option value="@DoctorAvailabilityStatus.Available">Available</option>
                    <option value="@DoctorAvailabilityStatus.Busy">Busy</option>
                    <option value="@DoctorAvailabilityStatus.Offline">Offline</option>
                </select>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Auto-Accept Appointments</h4>
                    <p class="body-sm">Automatically accept new appointment requests</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" @bind="settings.AutoAcceptAppointments" @bind:after="SaveSettings" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Maximum Daily Patients</h4>
                    <p class="body-sm">Limit the number of patients per day</p>
                </div>
                <input type="number" min="1" max="100" class="number-input" @bind="settings.MaxDailyPatients" @bind:after="SaveSettings" />
            </div>
        </div>
    </section>

    <!-- Notification Settings -->
    <section class="settings-card">
