' ==================== Entity Relationships ====================
User "1" -- "0..1" DoctorProfile : has >
User "1" -- "0..*" Conversation : handles as doctor >
User "1" -- "0..*" Message : sends >
User "1" -- "0..*" MedicalRecord : creates as doctor >
User "1" -- "0..*" Prescription : prescribes as doctor >
User "1" -- "0..*" ActivityLog : performs >

DoctorProfile "1" -- "0..*" DoctorRating : rated >
DoctorProfile "1" -- "0..*" Conversation : assigned to >
DoctorProfile "1" -- "0..*" ConsultationNote : creates >

Conversation "1" -- "1..*" Message : contains >
Conversation "1" -- "0..*" Document : has >
Conversation "1" -- "0..1" ConsultationNote : documented in >
Conversation "1" -- "0..*" MedicalRecord : generates >

ConsultationNote "1" -- "0..*" Prescription : includes >
ConsultationNote "1" -- "0..1" MedicalRecord : references >

' ==================== Doctor Matching Strategy ====================
IDoctorMatchingStrategy <|.. BalancedMatchingStrategy : implements
IDoctorMatchingStrategy <|.. SpecializationBasedMatchingStrategy : implements
IDoctorMatchingStrategy <|.. SymptomBasedMatchingStrategy : implements

DoctorRecommendationService "1" --> "1" IDoctorMatchingStrategy : uses current
DoctorRecommendationService "1" ..> "0..*" DoctorProfile : queries
DoctorRecommendationService "1" ..> "0..*" DoctorMatchResult : returns
DoctorRecommendationService "1" ..> "1" DoctorSearchCriteria : accepts

BalancedMatchingStrategy "1" ..> "0..*" DoctorProfile : evaluates
BalancedMatchingStrategy "1" ..> "0..*" DoctorMatchResult : creates

' ==================== AI Strategy Pattern ====================
IAiModelStrategy <|.. BaseAiModelAdapter : implements
BaseAiModelAdapter <|-- Gemma4Strategy : extends
BaseAiModelAdapter <|-- MiniMaxStrategy : extends
BaseAiModelAdapter <|-- NemotronStrategy : extends
BaseAiModelAdapter <|-- OwlAlphaStrategy : extends
BaseAiModelAdapter <|-- QianfanOcrStrategy : extends

AiAssistantService "1" --> "1" AiModelContext : uses
AiModelContext "1" o-- "1" IAiModelStrategy : uses strategy >
BaseAiModelAdapter "1" --> "1" OpenRouterApiClient : calls

' ==================== Hub Dependencies ====================
ConsultationHub "1" ..> "0..*" Message : broadcasts
ConsultationHub "1" ..> "0..*" Conversation : notifies

@enduml
