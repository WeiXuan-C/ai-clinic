@startuml Admin Domain - Complete Class Diagram

title Admin Domain - Complete UML Class Diagram
scale 0.8
skinparam linetype ortho
skinparam nodesep 80
skinparam ranksep 80

' ========================================
' UI LAYER
' ========================================

package "UI Layer" #LightBlue {
    class AdminDashboard <<boundary>> {
        -adminFacade : AdminFacade
        -authFacade : AuthFacade
        +OnInitializedAsync() : Task
        +LoadDashboardData() : Task
        +ViewAllUsers() : Task
        +VerifyDoctor() : Task
        +SuspendUser() : Task
        +ViewActivityLogs() : Task
        +ViewSupportTickets() : Task
        +RespondToTicket() : Task
        +ViewSystemHealth() : Task
    }
}

' ========================================
' FACADE LAYER
' ========================================

package "Facade Layer" #LightGreen {
    
    class AdminFacade <<facade>> {
        +GetDashboardDataAsync() : Task
        +VerifyDoctorAsync() : Task
        +SuspendUserAsync() : Task
        +GetSystemHealthAsync() : Task
        +RespondToTicketAsync() : Task
        +GetAllUsersAsync() : Task
        +GetDoctorsForVerificationAsync() : Task
        +GetActivityLogsAsync() : Task
        +GetSupportTicketsAsync() : Task
        +UpdateSupportTicketStatusAsync() : Task
        +UnsuspendUserAsync() : Task
        +DeleteUserAsync() : Task
    }
    
    class AuthFacade <<facade>> {
        +RegisterAsync() : Task
        +SignInAsync() : Task
        +SignOutAsync() : Task
        +IsAuthenticated : bool
        +CurrentUser : User
        +IsAdmin : bool
        +GetUserInitials() : string
        +GetDisplayName() : string
    }
}

' ========================================
' SERVICE LAYER
' ========================================

package "Service Layer" #LightYellow {
    
    together {
        class UserService <<service>> {
            +GetByIdAsync() : Task
            +GetByEmailAsync() : Task
            +CreateAsync() : Task
            +AuthenticateAsync() : Task
            +UpdateAsync() : Task
            +DeactivateAsync() : Task
            +ActivateAsync() : Task
            +DeleteAsync() : Task
            +GetByRoleAsync() : Task
            +GetAllUsersAsync() : Task
        }
        
        class AuthStateService <<service>> {
            -_currentUser : User
            +IsAuthenticated : bool
            +CurrentUser : User
            +IsAdmin : bool
            +SetCurrentUserAsync() : Task
            +ClearCurrentUserAsync() : Task
            +GetUserInitials() : string
            +GetDisplayName() : string
        }
    }
    
    together {
        class ActivityLogService <<service>> {
            +LogActivityAsync() : Task
            +GetByUserIdAsync() : Task
            +GetRecentLogsAsync() : Task
            +GetByActionAsync() : Task
        }
        
        class DoctorProfileService <<service>> {
            +GetByUserIdAsync() : Task
            +GetAllAsync() : Task
            +CreateAsync() : Task
            +UpdateAsync() : Task
        }
        
        class PatientProfileService <<service>> {
            +GetByUserIdAsync() : Task
            +CreateAsync() : Task
            +UpdateAsync() : Task
        }
    }
    
    together {
        class StatisticsService <<service>> {
            +GetUserCountByRoleAsync() : Task
            +GetConversationStatsAsync() : Task
            +GetDoctorPerformanceAsync() : Task
            +GetPatientActivityAsync() : Task
        }
        
        class SupportTicketService <<service>> {
            +GetByIdAsync() : Task
            +GetByUserIdAsync() : Task
            +CreateAsync() : Task
            +AddResponseAsync() : Task
            +UpdateStatusAsync() : Task
            +GetOpenTicketsAsync() : Task
            +GetAllTicketsAsync() : Task
            +GetByStatusAsync() : Task
        }
    }
    
    class UserSuspensionService <<service>> {
        +SuspendUserAsync() : Task
        +LiftSuspensionAsync() : Task
        +GetActiveSuspensionAsync() : Task
        +GetUserSuspensionHistoryAsync() : Task
        +IsUserSuspendedAsync() : Task
        +GetAllActiveSuspensionsAsync() : Task
        +ExtendSuspensionAsync() : Task
    }
}

' ========================================
' DATA ACCESS LAYER
' ========================================

package "Data Access Layer" #LightCoral {
    
    class DbClient <<singleton>> {
        -{static} _instance : Lazy<DbClient>
        -_connectionString : string
        +{static} Instance : DbClient
        -DbClient()
        +GetDb() : AiClinicDbContext
    }
    
    class AiClinicDbContext <<context>> {
        +Users : DbSet<User>
        +PatientProfiles : DbSet<PatientProfile>
        +DoctorProfiles : DbSet<DoctorProfile>
        +AdminProfiles : DbSet<AdminProfile>
        +Conversations : DbSet<Conversation>
        +ActivityLogs : DbSet<ActivityLog>
        +SupportTickets : DbSet<SupportTicket>
        +SupportTicketAttachments : DbSet<SupportTicketAttachment>
        +SupportTicketResponses : DbSet<SupportTicketResponse>
        +UserSuspensions : DbSet<UserSuspension>
        +AiAssistantSettings : DbSet<AiAssistantSetting>
        #OnModelCreating() : void
    }
}

' ========================================
' ENTITY LAYER
' ========================================

package "Entity Layer" #LightGray {
    
    together {
        class User <<entity>> {
            +Id : Guid
            +Email : string
            +PasswordHash : string
            +Phone : string
            +Role : UserRole
            +IsActive : bool
            +CreatedAt : DateTime
            +UpdatedAt : DateTime
            +LastLoginAt : DateTime
            +IsDeactivated : bool
            +DeactivatedAt : DateTime
        }
        
        class AdminProfile <<entity>> {
            +Id : Guid
            +UserId : Guid
            +FullName : string
            +CreatedAt : DateTime
            +UpdatedAt : DateTime
            +ManageUsers : bool
            +ManageAi : bool
            +ManageDoctors : bool
            +ManageTickets : bool
            +ManagePermissions : bool
        }
    }
    
    together {
        class PatientProfile <<entity>> {
            +Id : Guid
            +UserId : Guid
            +FullName : string
            +DateOfBirth : DateTime
            +Gender : string
            +Email : string
            +Phone : string
            +CreatedAt : DateTime
            +UpdatedAt : DateTime
        }
        
        class DoctorProfile <<entity>> {
            +Id : Guid
            +UserId : Guid
            +FullName : string
            +Title : string
            +LicenseNumber : string
            +PrimarySpecialization : string
            +YearsOfExperience : int
            +AverageRating : decimal
            +TotalRatings : int
            +TotalConsultations : int
            +IsVerified : bool
            +IsActive : bool
            +CreatedAt : DateTime
            +UpdatedAt : DateTime
        }
    }
    
    together {
        class ActivityLog <<entity>> {
            +Id : Guid
            +UserId : Guid
            +Action : string
            +EntityType : string
            +EntityId : Guid
            +IpAddress : string
            +UserAgent : string
            +Details : string
            +CreatedAt : DateTime
        }
        
        class Conversation <<entity>> {
            +Id : Guid
            +PatientId : Guid
            +AssignedDoctorId : Guid
            +Title : string
            +Status : ConversationStatus
            +StartedAt : DateTime
            +TotalMessages : int
            +CreatedAt : DateTime
        }
    }
    
    together {
        class SupportTicket <<entity>> {
            +Id : Guid
            +UserId : Guid
            +Subject : string
            +Description : string
            +Category : string
            +Priority : string
            +Status : string
            +CreatedAt : DateTime
            +UpdatedAt : DateTime
            +ResolvedAt : DateTime
            +ClosedAt : DateTime
        }
        
        class SupportTicketAttachment <<entity>> {
            +Id : Guid
            +TicketId : Guid
            +FileName : string
            +FileUrl : string
            +FileSizeBytes : long
            +MimeType : string
            +UploadedAt : DateTime
        }
        
        class SupportTicketResponse <<entity>> {
            +Id : Guid
            +TicketId : Guid
            +ResponderId : Guid
            +Message : string
            +IsInternalNote : bool
            +CreatedAt : DateTime
        }
    }
    
    together {
        class UserSuspension <<entity>> {
            +Id : Guid
            +UserId : Guid
            +SuspendedByAdminId : Guid
            +Reason : string
            +SuspensionStart : DateTime
            +SuspensionEnd : DateTime
            +IsActive : bool
            +LiftedAt : DateTime
            +LiftedByAdminId : Guid
            +CreatedAt : DateTime
        }
        
        class AiAssistantSetting <<entity>> {
            +Id : Guid
            +ModelName : string
            +IsActive : bool
            +SystemPrompt : string
            +EnableDocumentAnalysis : bool
            +EnableSymptomChecker : bool
            +EnableDoctorRecommendation : bool
            +CreatedByAdminId : Guid
            +CreatedAt : DateTime
            +UpdatedAt : DateTime
        }
    }
}

' ========================================
' RELATIONSHIPS WITH MULTIPLICITY
' ========================================

' ==================== UI to Facade ====================
AdminDashboard "1" --> "1" AdminFacade : uses
AdminDashboard "1" --> "1" AuthFacade : uses

' ==================== Facade to Service ====================
AdminFacade "1" --> "1" UserService : uses
AdminFacade "1" --> "1" DoctorProfileService : uses
AdminFacade "1" --> "1" PatientProfileService : uses
AdminFacade "1" --> "1" StatisticsService : uses
AdminFacade "1" --> "1" SupportTicketService : uses
AdminFacade "1" --> "1" ActivityLogService : uses
AdminFacade "1" --> "1" UserSuspensionService : uses

AuthFacade "1" --> "1" UserService : uses
AuthFacade "1" --> "1" ActivityLogService : uses
AuthFacade "1" --> "1" AuthStateService : uses

' ==================== Service to Data Access ====================
UserService "1" --> "1" DbClient : uses
ActivityLogService "1" --> "1" DbClient : uses
DoctorProfileService "1" --> "1" DbClient : uses
PatientProfileService "1" --> "1" DbClient : uses
SupportTicketService "1" --> "1" DbClient : uses
StatisticsService "1" --> "1" DbClient : uses
UserSuspensionService "1" --> "1" DbClient : uses

' ==================== Service to Entity (manages) ====================
UserService "1" ..> "0..*" User : manages
PatientProfileService "1" ..> "0..*" PatientProfile : manages
DoctorProfileService "1" ..> "0..*" DoctorProfile : manages
ActivityLogService "1" ..> "0..*" ActivityLog : manages
SupportTicketService "1" ..> "0..*" SupportTicket : manages
UserSuspensionService "1" ..> "0..*" UserSuspension : manages

' ==================== Data Access to Context ====================
DbClient "1" --> "1" AiClinicDbContext : creates

' ==================== Context to Entities ====================
AiClinicDbContext "1" --> "0..*" User : maps
AiClinicDbContext "1" --> "0..*" PatientProfile : maps
AiClinicDbContext "1" --> "0..*" DoctorProfile : maps
AiClinicDbContext "1" --> "0..*" AdminProfile : maps
AiClinicDbContext "1" --> "0..*" Conversation : maps
AiClinicDbContext "1" --> "0..*" ActivityLog : maps
AiClinicDbContext "1" --> "0..*" SupportTicket : maps
AiClinicDbContext "1" --> "0..*" SupportTicketAttachment : maps
AiClinicDbContext "1" --> "0..*" SupportTicketResponse : maps
AiClinicDbContext "1" --> "0..*" UserSuspension : maps
AiClinicDbContext "1" --> "0..*" AiAssistantSetting : maps

' ==================== Entity Relationships ====================
User "1" -- "0..1" AdminProfile : has >
User "1" -- "0..1" PatientProfile : has >
User "1" -- "0..1" DoctorProfile : has >
User "1" -- "0..*" UserSuspension : suspended >
User "1" -- "0..*" ActivityLog : performs >
User "1" -- "0..*" SupportTicket : creates >

AdminProfile "1" -- "0..*" UserSuspension : issues >
AdminProfile "1" -- "0..*" AiAssistantSetting : configures >

SupportTicket "1" -- "0..*" SupportTicketAttachment : has >
SupportTicket "1" -- "0..*" SupportTicketResponse : has >

SupportTicketResponse "1" -- "1" User : responded by >

UserSuspension "1" -- "1" User : suspends >
UserSuspension "1" -- "1" AdminProfile : issued by >

@enduml
