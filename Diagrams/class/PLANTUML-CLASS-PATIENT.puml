' ==================== Service to Data Access ====================
PatientProfileService "1" --> "1" DbClient : uses
ConversationService "1" --> "1" DbClient : uses
MessageService "1" --> "1" DbClient : uses
MedicalRecordService "1" --> "1" DbClient : uses
PrescriptionService "1" --> "1" DbClient : uses
DocumentService "1" --> "1" DbClient : uses
UserService "1" --> "1" DbClient : uses
ActivityLogService "1" --> "1" DbClient : uses
SupportTicketService "1" --> "1" DbClient : uses

' ==================== Service to Entity (manages) ====================
PatientProfileService "1" ..> "0..*" PatientProfile : manages
ConversationService "1" ..> "0..*" Conversation : manages
MessageService "1" ..> "0..*" Message : manages
MedicalRecordService "1" ..> "0..*" MedicalRecord : manages
PrescriptionService "1" ..> "0..*" Prescription : manages
DocumentService "1" ..> "0..*" Document : manages
UserService "1" ..> "0..*" User : manages
ActivityLogService "1" ..> "0..*" ActivityLog : manages
SupportTicketService "1" ..> "0..*" SupportTicket : manages

' ==================== Data Access to Context ====================
