' ==================== Context to Entities ====================
AiClinicDbContext "1" --> "0..*" User : maps
AiClinicDbContext "1" --> "0..*" PatientProfile : maps
AiClinicDbContext "1" --> "0..*" Conversation : maps
AiClinicDbContext "1" --> "0..*" Message : maps
AiClinicDbContext "1" --> "0..*" MedicalRecord : maps
AiClinicDbContext "1" --> "0..*" Prescription : maps
AiClinicDbContext "1" --> "0..*" Document : maps
AiClinicDbContext "1" --> "0..*" ConsultationNote : maps
AiClinicDbContext "1" --> "0..*" DoctorRating : maps
AiClinicDbContext "1" --> "0..*" SupportTicket : maps
AiClinicDbContext "1" --> "0..*" ActivityLog : maps

' ==================== Entity Relationships ====================
User "1" -- "0..1" PatientProfile : has >
User "1" -- "0..*" Conversation : creates as patient >
User "1" -- "0..*" Message : sends >
User "1" -- "0..*" Document : uploads >
User "1" -- "0..*" MedicalRecord : has as patient >
User "1" -- "0..*" Prescription : receives as patient >
User "1" -- "0..*" SupportTicket : creates >
User "1" -- "0..*" ActivityLog : performs >

PatientProfile "1" -- "0..*" MedicalRecord : owns >
PatientProfile "1" -- "0..*" Document : has >

Conversation "1" -- "1..*" Message : contains >
Conversation "1" -- "0..*" Document : includes >
Conversation "1" -- "0..1" ConsultationNote : documented in >
Conversation "1" -- "0..*" MedicalRecord : generates >
Conversation "1" -- "0..1" DoctorRating : rated by >

ConsultationNote "1" -- "0..*" Prescription : includes >
ConsultationNote "1" -- "0..1" MedicalRecord : references >

SupportTicket "1" -- "0..*" ActivityLog : tracked by >

' ==================== Workflow Service Dependencies ====================
