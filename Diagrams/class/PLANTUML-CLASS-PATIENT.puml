PatientFacade "1" --> "1" MedicalRecordService : uses
PatientFacade "1" --> "1" PrescriptionService : uses
PatientFacade "1" --> "1" DocumentService : uses
PatientFacade "1" --> "1" PatientConsultationWorkflowService : uses
PatientFacade "1" --> "1" MedicalRecordExportService : uses
PatientFacade "1" --> "1" ActivityLogService : uses

ConsultationFacade "1" --> "1" ConversationService : uses
