object "<u>aiContext1 : AiModelContext</u>" as aiContext {
  <b>CurrentStrategy</b> = "Gemma4Strategy"
  <b>ModelName</b> = "google/gemma-2-9b-it"
  IsInitialized = true
  LastRequestTime = "2026-05-08 10:12:44"
}

object "<u>gemmaStrategy1 : Gemma4Strategy</u>" as gemmaStrategy {
  <b>ModelIdentifier</b> = "google/gemma-2-9b-it"
  MaxTokens = 1000
  Temperature = 0.7
  IsAvailable = true
}

object "<u>apiClient1 : OpenRouterApiClient</u>" as apiClient {
  <b>BaseUrl</b> = "https://openrouter.ai/api/v1"
  <b>IsConnected</b> = true
  LastRequestTime = "2026-05-08 10:12:44"
  ResponseTime = 1.2
}

' ========== SYMPTOM ANALYSIS RESULT ==========
object "<u>symptomAnalysis1 : SymptomAnalysis</u>" as symptomAnalysis {
  <b>ConversationId</b> = "conv5678-90ab-cdef-1234-567890abcdef"
  <b>Symptoms</b> = "["skin rash", "itching", "redness", "bilateral", "spreading"]"
  <b>SuggestedSpecialization</b> = "Dermatology"
  <b>ConfidenceScore</b> = 0.92
  PossibleConditions = "["Contact Dermatitis", "Allergic Reaction", "Eczema"]"
  Urgency = "Medium"
  AnalyzedAt = "2026-05-08 10:12:45"
}

' ========== OBJECT LINKS ==========

' Patient and conversation
patient1 -- patientProfile1
patient1 -- conversation1

' Conversation and messages
conversation1 -- patMsg1
conversation1 -- aiMsg1
conversation1 -- patMsg2
conversation1 -- aiMsg2

' AI strategy pattern
aiContext -- gemmaStrategy
gemmaStrategy -- apiClient

' AI generates messages and analysis
aiContext ..> aiMsg1
aiContext ..> aiMsg2
aiContext ..> symptomAnalysis

' Analysis linked to conversation
conversation1 -- symptomAnalysis

