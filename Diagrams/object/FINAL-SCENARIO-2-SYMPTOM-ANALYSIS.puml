}

' ========== MESSAGES ==========
object "<u>patientMsg1 : Message</u>" as patMsg1 {
  <b>Id</b> = "patmsg11-2222-3333-4444-555566667777"
  <b>SenderType</b> = Patient
  <b>SenderId</b> = "user3456-789a-bcde-f012-3456789abcde"
  Content = "I have a red, itchy rash on my arms that started 3 days ago. It's getting worse and spreading."
  CreatedAt = "2026-05-08 10:11:00"
  IsRead = true
}

object "<u>aiMsg1 : Message</u>" as aiMsg1 {
  <b>Id</b> = "aimsg111-2222-3333-4444-555566667777"
  <b>SenderType</b> = AI
  SenderId = null
  Content = "I understand you have a skin rash. Can you describe the exact location, size, and any other symptoms?"
  <b>AiModelUsed</b> = "google/gemma-2-9b-it"
  AiConfidenceScore = 0.89
  CreatedAt = "2026-05-08 10:10:30"
  IsRead = true
}

object "<u>patientMsg2 : Message</u>" as patMsg2 {
  <b>Id</b> = "patmsg22-3333-4444-5555-666677778888"
  <b>SenderType</b> = Patient
  <b>SenderId</b> = "user3456-789a-bcde-f012-3456789abcde"
  Content = "It's on both arms, about 5cm patches. Very itchy, red, slightly raised. No fever."
  CreatedAt = "2026-05-08 10:12:00"
  IsRead = true
}

object "<u>aiMsg2 : Message</u>" as aiMsg2 {
  <b>Id</b> = "aimsg222-3333-4444-5555-666677778888"
  <b>SenderType</b> = AI
  SenderId = null
  Content = "Based on your symptoms (bilateral arm rash, itching, redness), I recommend consulting a dermatologist. This could be contact dermatitis or an allergic reaction."
  <b>AiModelUsed</b> = "google/gemma-2-9b-it"
  <b>AiConfidenceScore</b> = 0.92
  CreatedAt = "2026-05-08 10:12:45"
  IsRead = true
}

