@startuml Patient Symptom Analysis with AI
title Object Diagram: Patient Reports Symptoms and AI Analyzes
note as N1
  <b>Scenario:</b> Patient Lisa Wong reports skin rash symptoms.
  AI assistant analyzes symptoms and suggests dermatology specialization.
  <b>Timestamp:</b> May 8, 2026 - 10:10-10:13 UTC
  <b>Focus:</b> Patient, conversation, AI messages, symptom analysis
end note

' ========== PATIENT ==========
object "<u>patient1 : User</u>" as patient1 {
  <b>Id</b> = "user3456-789a-bcde-f012-3456789abcde"
  <b>Email</b> = "lisa.wong@email.com"
  <b>Role</b> = Patient
  IsActive = true
  AiAnalysisEnabled = true
}

object "<u>patientProfile1 : PatientProfile</u>" as patientProfile1 {
  <b>Id</b> = "pat23456-789a-bcde-f012-3456789abcde"
  <b>FullName</b> = "Lisa Wong Mei Ling"
  Gender = "Female"
  BloodType = "A+"
  Allergies = "["Latex"]"
}

' ========== NEW CONVERSATION ==========
object "<u>conversation1 : Conversation</u>" as conversation1 {
  <b>Id</b> = "conv5678-90ab-cdef-1234-567890abcdef"
  <b>PatientId</b> = "user3456-789a-bcde-f012-3456789abcde"
  <b>AssignedDoctorId</b> = null
