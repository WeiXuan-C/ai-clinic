@startuml Patient Rating Doctor
title Object Diagram: Patient Rates Doctor After Consultation
note as N1
  <b>Scenario:</b> Patient John Tan rates Dr. Sarah Lee with 5 stars
  after completed consultation. System calculates new average rating,
  updates doctor profile, and sends notification to doctor.
  <b>Timestamp:</b> May 8, 2026 - 15:00-15:01 UTC
  <b>Focus:</b> Rating submission, calculation, profile update, notification
end note

' ========== PATIENT ==========
object "<u>patient1 : User</u>" as patient1 {
  <b>Id</b> = "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
  <b>Email</b> = "john.tan@email.com"
  <b>Role</b> = Patient
  IsActive = true
}

object "<u>patientProfile1 : PatientProfile</u>" as patientProfile1 {
  <b>Id</b> = "p1a2b3c4-d5e6-f789-0abc-def123456789"
  <b>FullName</b> = "John Tan Wei Ming"
  Gender = "Male"
  BloodType = "O+"
}

' ========== DOCTOR ==========
object "<u>doctor1 : User</u>" as doctor1 {
  <b>Id</b> = "d1e2f3a4-b5c6-7890-abcd-ef9876543210"
  <b>Email</b> = "dr.sarah.lee@clinic.com"
  <b>Role</b> = Doctor
  IsActive = true
}

' ========== DOCTOR PROFILE (BEFORE RATING) ==========
object "<u>doctorProfileBefore : DoctorProfile</u>" as doctorProfileBefore {
  <b>Id</b> = "doc1a2b3-c4d5-e6f7-8901-abcdef123456"
  <b>FullName</b> = "Dr. Sarah Lee Mei Ling"
  PrimarySpecialization = "Cardiology"
  LicenseNumber = "MMC-45678"
  TotalConsultations = 488
  <b>AverageRating</b> = 4.75
  <b>TotalRatings</b> = 156
  IsVerified = true
}

' ========== DOCTOR PROFILE (AFTER RATING) ==========
object "<u>doctorProfileAfter : DoctorProfile</u>" as doctorProfileAfter {
  <b>Id</b> = "doc1a2b3-c4d5-e6f7-8901-abcdef123456"
  <b>FullName</b> = "Dr. Sarah Lee Mei Ling"
  PrimarySpecialization = "Cardiology"
  LicenseNumber = "MMC-45678"
  TotalConsultations = 488
  <b>AverageRating</b> = 4.76
  <b>TotalRatings</b> = 157
  IsVerified = true
}

' ========== COMPLETED CONVERSATION ==========
object "<u>conversation1 : Conversation</u>" as conversation1 {
  <b>Id</b> = "conv1234-5678-90ab-cdef-1234567890ab"
  <b>PatientId</b> = "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
  <b>AssignedDoctorId</b> = "d1e2f3a4-b5c6-7890-abcd-ef9876543210"
  Title = "Chest Pain Consultation"
  <b>Status</b> = Closed
  ConsultationStatus = "completed"
  DiagnosisCompleted = true
  PrescriptionGenerated = true
  ClosedAt = "2026-05-08 14:45:00"
}

' ========== RATING SUBMITTED ==========
object "<u>rating1 : DoctorRating</u>" as rating1 {
  <b>Id</b> = "rating12-3456-789a-bcde-f123456789ab"
  <b>DoctorId</b> = "d1e2f3a4-b5c6-7890-abcd-ef9876543210"
  <b>PatientId</b> = "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
  <b>ConversationId</b> = "conv1234-5678-90ab-cdef-1234567890ab"
  <b>Rating</b> = 5
  ReviewText = "Excellent doctor! Very thorough examination and clear explanation. Dr. Lee took time to understand my concerns and provided comprehensive treatment plan. Highly recommend!"
  <b>ProfessionalismRating</b> = 5
  <b>CommunicationRating</b> = 5
  <b>KnowledgeRating</b> = 5
  <b>ResponseTimeRating</b> = 4
  CreatedAt = "2026-05-08 15:00:00"
}

' ========== RATING STATISTICS ==========
object "<u>ratingStats1 : RatingStatistics</u>" as ratingStats {
  <b>DoctorId</b> = "d1e2f3a4-b5c6-7890-abcd-ef9876543210"
  <b>TotalRatings</b> = 157
  <b>AverageOverallRating</b> = 4.76
  AverageProfessionalism = 4.82
  AverageCommunication = 4.79
  AverageKnowledge = 4.88
  AverageResponseTime = 4.55
  <b>FiveStarCount</b> = 98
  <b>FourStarCount</b> = 47
  ThreeStarCount = 10
  TwoStarCount = 2
  OneStarCount = 0
  LastUpdated = "2026-05-08 15:00:05"
}

' ========== NOTIFICATION ==========
object "<u>notification1 : Notification</u>" as notification1 {
  <b>Id</b> = "notif123-4567-89ab-cdef-0123456789ab"
  <b>UserId</b> = "d1e2f3a4-b5c6-7890-abcd-ef9876543210"
  <b>Type</b> = "NewRating"
  Title = "New 5-Star Rating Received"
  Message = "John Tan rated your consultation 5 stars with excellent feedback"
  <b>IsRead</b> = false
  CreatedAt = "2026-05-08 15:00:01"
}

' ========== MEDICAL RECORD (FOR CONTEXT) ==========
object "<u>medicalRecord1 : MedicalRecord</u>" as medicalRecord1 {
  <b>Id</b> = "record12-3456-789a-bcde-f123456789ab"
  <b>PatientId</b> = "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
  <b>ConversationId</b> = "conv1234-5678-90ab-cdef-1234567890ab"
  RecordType = "Consultation"
  Title = "Cardiology Consultation - Hypertension Stage 2"
  DiagnosisCode = "I10"
  RecordDate = "2026-05-08 14:40:00"
}

' ========== OBJECT LINKS ==========

' Patient and doctor
patient1 -- patientProfile1
doctor1 -- doctorProfileBefore
doctor1 -- doctorProfileAfter

' Completed conversation
patient1 -- conversation1
doctor1 -- conversation1
conversation1 -- medicalRecord1

' Rating submission
patient1 -- rating1
rating1 -- doctor1
rating1 -- conversation1

' Rating processing
rating1 ..> doctorProfileBefore
doctorProfileBefore ..> doctorProfileAfter
rating1 ..> ratingStats
ratingStats ..> doctorProfileAfter

' Notification
rating1 ..> notification1
notification1 -- doctor1

note right of rating1
  <b>5-Star Rating Details:</b>
  Overall: ⭐⭐⭐⭐⭐ (5/5)
  
  <b>Category Breakdown:</b>
  • Professionalism: 5/5
  • Communication: 5/5
  • Knowledge: 5/5
  • Response Time: 4/5
  
  <b>Review:</b>
  "Excellent doctor! Very
  thorough and caring..."
  
  <b>Impact:</b>
  Rating increased from
  4.75 → 4.76
end note

note bottom of ratingStats
  <b>Rating Calculation:</b>
  Formula: (Old Avg × Old Count + New Rating) ÷ New Count
  
  <b>Calculation:</b>
  (4.75 × 156 + 5) ÷ 157 = 4.76
  
  <b>Distribution:</b>
  ⭐⭐⭐⭐⭐: 98 (62.4%)
  ⭐⭐⭐⭐: 47 (29.9%)
  ⭐⭐⭐: 10 (6.4%)
  ⭐⭐: 2 (1.3%)
  ⭐: 0 (0%)
  
  <b>Excellent Performance!</b>
  Top-rated cardiologist
end note

note top of doctorProfileAfter
  <b>Profile Update:</b>
  State change after rating
  
  <b>Before:</b>
  • Average: 4.75
  • Total: 156 ratings
  
  <b>After:</b>
  • Average: 4.76 ⬆️
  • Total: 157 ratings
  
  <b>Status:</b>
  Top-rated cardiologist
end note

note left of notification1
  <b>Real-time Notification:</b>
  
  <b>Sent to:</b> Dr. Sarah Lee
  <b>Type:</b> NewRating
  <b>Status:</b> Unread
  
  <b>Message:</b>
  "John Tan rated your
  consultation 5 stars"
  
  <b>Delivery:</b>
  • Email notification
  • In-app notification
  • SMS (if enabled)
end note

note bottom of conversation1
  <b>Completed Consultation:</b>
  
  <b>Status:</b> Closed
  <b>Outcome:</b> Successful
  
  <b>Deliverables:</b>
  ✓ Diagnosis provided
  ✓ Prescriptions generated
  ✓ Medical record created
  ✓ Patient satisfied (5 stars)
  
  <b>Duration:</b> ~40 minutes
end note

@enduml
