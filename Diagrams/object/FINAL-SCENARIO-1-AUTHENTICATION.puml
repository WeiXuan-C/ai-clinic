' ========== SHARED DATABASE (SINGLETON) ==========
object "<u>dbClient : DbClient</u>" as dbClient {
  <b>ConnectionString</b> = "Data Source=ai-clinic.db"
  <b>IsConnected</b> = true
  PoolSize = 10
  ActiveConnections = 5
}

' ========== OBJECT LINKS ==========

' Patient links
patientUser -- patientProfile
patientUser -- patientSession
patientSession -- patientToken
patientSession -- patientRefresh

' Doctor links
doctorUser -- doctorProfile
doctorUser -- doctorSession
doctorSession -- doctorToken
doctorSession -- doctorRefresh

' Admin links
adminUser -- adminProfile
adminUser -- adminSession
adminSession -- adminToken
adminSession -- adminRefresh

' All users share database (Singleton Pattern)
patientUser ..> dbClient
doctorUser ..> dbClient
adminUser ..> dbClient

note right of patientUser
  <b>Patient Role:</b>
  • Access consultations
  • View medical records
  • Rate doctors
  
  <b>Session:</b> 30 min timeout
  <b>Tokens:</b> Access (1h) + Refresh (7d)
end note

note top of doctorUser
  <b>Doctor Role:</b>
  • Conduct consultations
  • Write prescriptions
  • View patient records
  
  <b>Status:</b> Available
end note

note left of adminUser
  <b>Admin Role:</b>
  • Manage all users
  • Verify doctors
  • View system reports
  
  <b>Access:</b> SuperAdmin
end note

note bottom of dbClient
  <b>Singleton Pattern:</b>
  Single database connection
  shared by all users
  
  <b>Pool:</b> 10 max, 5 active
end note

@enduml
