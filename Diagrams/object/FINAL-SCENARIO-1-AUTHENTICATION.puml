@startuml Authentication - All User Roles
title Object Diagram: User Authentication for Patient, Doctor, and Admin
note as N1
  <b>Scenario:</b> Three users authenticate simultaneously at system login.
  Each role receives session with JWT tokens after successful authentication.
  <b>Timestamp:</b> May 8, 2026 - 09:00-09:10 UTC
  <b>Focus:</b> User objects, profiles, sessions, and tokens at runtime
end note

' ========== PATIENT AUTHENTICATION ==========
object "<u>patientUser : User</u>" as patientUser {
  <b>Id</b> = "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
  <b>Email</b> = "john.tan@email.com"
  <b>Role</b> = Patient
  <b>IsActive</b> = true
  LastLoginAt = "2026-05-08 09:00:00"
}

object "<u>patientProfile : PatientProfile</u>" as patientProfile {
  <b>Id</b> = "p1a2b3c4-d5e6-f789-0abc-def123456789"
  <b>FullName</b> = "John Tan Wei Ming"
  Gender = "Male"
  BloodType = "O+"
  Allergies = "["Penicillin", "Peanuts"]"
}

object "<u>patientSession : UserSession</u>" as patientSession {
  <b>SessionId</b> = "sess-pat1-5678-90ab-cdef-1234567890ab"
  IpAddress = "203.106.55.123"
  <b>IsActive</b> = true
  ExpiresAt = "2026-05-08 09:30:00"
}

object "<u>patientAccessToken : JwtToken</u>" as patientToken {
  <b>TokenId</b> = "jwt-pat-1234-5678-abcd"
  <b>TokenType</b> = "Access"
  Claims = "{role: Patient}"
  ExpiresAt = "2026-05-08 10:00:00"
}

object "<u>patientRefreshToken : JwtToken</u>" as patientRefresh {
  <b>TokenId</b> = "ref-pat-1234-5678-abcd"
  <b>TokenType</b> = "Refresh"
  ExpiresAt = "2026-05-15 09:00:00"
}

