@inherits LayoutComponentBase

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<div class="page">

    <main class="main-content">
        @Body
    </main>
</div>

<style>
    .page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .navbar {
        position: sticky;
        top: 0;
        z-index: 1000;
        padding: 1rem 0;
        border-bottom: 1px solid rgba(195, 198, 214, 0.2);
    }

    .navbar-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .navbar-brand {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
        color: var(--on-surface);
    }

    .brand-icon {
        font-size: 2rem;
    }

    .brand-text {
        font-weight: 700;
    }

    .navbar-menu {
        display: flex;
        align-items: center;
        gap: 2rem;
    }

    .nav-link {
        text-decoration: none;
        color: var(--on-surface);
        font-weight: 500;
        transition: color 0.3s ease;
    }

    .nav-link:hover {
        color: var(--primary);
    }

    .main-content {
        flex: 1;
    }

    .footer {
        background: var(--surface-container-low);
        padding: 2rem 0;
        text-align: center;
        margin-top: 4rem;
    }

    .footer p {
        color: var(--on-surface-variant);
    }

    @@media (max-width: 768px) {
        .navbar-menu {
            display: none;
        }
    }
</style>
