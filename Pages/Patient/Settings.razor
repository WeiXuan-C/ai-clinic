@page "/patient/settings"
@layout Components.Layout.SidebarLayout

<PageTitle>Settings - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>Settings</h1>
        <p class="body-md" style="margin: 0.5rem;">
            Manage your account preferences and privacy settings
        </p>
    </div>
</header>

<!-- Content Grid -->
<div class="content-grid">
    <!-- Account Settings -->
    <section class="settings-card">
        <div class="section-header">
            <div class="header-with-icon">
                <i data-lucide="user-cog" class="section-icon"></i>
                <h2 class="headline-md">Account Settings</h2>
            </div>
        </div>
        <div class="settings-list">
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Email Address</h4>
                    <p class="body-sm">sarah.johnson@email.com</p>
                </div>
                <button class="btn-link">Change</button>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Password</h4>
                    <p class="body-sm">Last changed 3 months ago</p>
                </div>
                <button class="btn-link">Update</button>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Two-Factor Authentication</h4>
                    <p class="body-sm">Add an extra layer of security</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Biometric Login</h4>
                    <p class="body-sm">Use fingerprint or face recognition</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" checked />
                    <span class="toggle-slider"></span>
                </label>
            </div>
        </div>
    </section>

    <!-- Notification Preferences -->
    <section class="settings-card">
        <div class="section-header">
            <div class="header-with-icon">
                <i data-lucide="bell" class="section-icon"></i>
                <h2 class="headline-md">Notifications</h2>
            </div>
        </div>
        <div class="settings-list">
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Appointment Reminders</h4>
                    <p class="body-sm">Get notified before scheduled appointments</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" checked />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Lab Results</h4>
                    <p class="body-sm">Receive alerts when results are available</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" checked />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Prescription Refills</h4>
                    <p class="body-sm">Reminders when prescriptions need refilling</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" checked />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Health Insights</h4>
                    <p class="body-sm">AI-powered health tips and recommendations</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" checked />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Marketing Communications</h4>
                    <p class="body-sm">Updates about new features and services</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
        </div>
    </section>

    <!-- Privacy Settings -->
    <section class="settings-card">
        <div class="section-header">
            <div class="header-with-icon">
                <i data-lucide="shield" class="section-icon"></i>
                <h2 class="headline-md">Privacy & Security</h2>
            </div>
        </div>
        <div class="settings-list">
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Data Sharing</h4>
                    <p class="body-sm">Share health data with research programs</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">AI Analysis</h4>
                    <p class="body-sm">Allow AI to analyze your health data</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" checked />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Activity Tracking</h4>
                    <p class="body-sm">Track app usage for better experience</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" checked />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Download My Data</h4>
                    <p class="body-sm">Export all your personal and medical data</p>
                </div>
                <button class="btn-link">Download</button>
            </div>
        </div>
    </section>

    <!-- Appearance -->
    <section class="settings-card">
        <div class="section-header">
            <div class="header-with-icon">
                <i data-lucide="palette" class="section-icon"></i>
                <h2 class="headline-md">Appearance</h2>
            </div>
        </div>
        <div class="settings-list">
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Theme</h4>
                    <p class="body-sm">Choose your preferred color scheme</p>
                </div>
                <select class="select-input">
                    <option>Light</option>
                    <option>Dark</option>
                    <option>Auto</option>
                </select>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Language</h4>
                    <p class="body-sm">Select your preferred language</p>
                </div>
                <select class="select-input">
                    <option>English (US)</option>
                    <option>Spanish</option>
                    <option>French</option>
                    <option>German</option>
                    <option>Chinese</option>
                </select>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Accessibility</h4>
                    <p class="body-sm">High contrast mode for better visibility</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
        </div>
    </section>

    <!-- Connected Devices -->
    <section class="settings-card">
        <div class="section-header">
            <div class="header-with-icon">
                <i data-lucide="watch" class="section-icon"></i>
                <h2 class="headline-md">Connected Devices</h2>
            </div>
            <button class="btn btn-primary-sm">Add Device</button>
        </div>
        <div class="devices-list">
            <div class="device-item">
                <div class="device-icon">
                    <i data-lucide="watch"></i>
                </div>
                <div class="device-info">
                    <h4 class="headline-sm">Apple Watch Series 8</h4>
                    <p class="body-sm">Last synced: 5 minutes ago</p>
                </div>
                <span class="badge badge-success">CONNECTED</span>
                <button class="icon-btn-sm">
                    <i data-lucide="x"></i>
                </button>
            </div>
            <div class="device-item">
                <div class="device-icon">
                    <i data-lucide="activity"></i>
                </div>
                <div class="device-info">
                    <h4 class="headline-sm">Fitbit Charge 5</h4>
                    <p class="body-sm">Last synced: 2 hours ago</p>
                </div>
                <span class="badge badge-success">CONNECTED</span>
                <button class="icon-btn-sm">
                    <i data-lucide="x"></i>
                </button>
            </div>
        </div>
    </section>

    <!-- Danger Zone -->
    <section class="settings-card danger-zone">
        <div class="section-header">
            <div class="header-with-icon">
                <i data-lucide="alert-triangle" class="section-icon danger"></i>
                <h2 class="headline-md">Danger Zone</h2>
            </div>
        </div>
        <div class="settings-list">
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Deactivate Account</h4>
                    <p class="body-sm">Temporarily disable your account</p>
                </div>
                <button class="btn-danger-outline">Deactivate</button>
            </div>
            <div class="setting-item">
                <div class="setting-info">
                    <h4 class="headline-sm">Delete Account</h4>
                    <p class="body-sm">Permanently delete your account and all data</p>
                </div>
                <button class="btn-danger">Delete</button>
            </div>
        </div>
    </section>
</div>

