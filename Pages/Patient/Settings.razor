<style>
    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2rem;
    }

    .header-left h1 {
        font-size: 2rem;
        font-weight: 700;
        color: #191c1e;
        margin: 0.5rem;
        font-family: 'Manrope', sans-serif;
    }

    .header-left p {
        color: #434654;
    }

    .content-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
    }

    /* Settings Card */
    .settings-card {
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .settings-card.danger-zone {
        border: 2px solid #ffebee;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.75rem;
    }

    .header-with-icon {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .section-icon {
        font-size: 1.5rem;
        color: #0052cc;
    }

    .section-icon.danger {
        color: #d32f2f;
    }

    .section-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
    }

    /* Settings List */
    .settings-list {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .setting-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem;
        background: #f7f9fb;
        border-radius: 12px;
    }

    .setting-info {
        flex: 1;
    }

    .setting-info h4 {
        font-size: 1rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.25rem;
    }

    .setting-info p {
        font-size: 0.875rem;
        color: #434654;
    }

    /* Toggle Switch */
    .toggle-switch {
        position: relative;
        display: inline-block;
        width: 48px;
        height: 28px;
    }

    .toggle-switch input {
        opacity: 0;
        width: 0;
        height: 0;
    }

    .toggle-slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #e6e8ea;
        transition: 0.3s;
        border-radius: 28px;
    }

    .toggle-slider:before {
        position: absolute;
        content: "";
        height: 20px;
        width: 20px;
        left: 4px;
        bottom: 4px;
        background-color: white;
        transition: 0.3s;
        border-radius: 50%;
    }

    input:checked + .toggle-slider {
        background-color: #0052cc;
    }

    input:checked + .toggle-slider:before {
        transform: translateX(20px);
    }

    /* Buttons */
    .btn-link {
        color: #0052cc;
        background: none;
        border: none;
        font-weight: 600;
        cursor: pointer;
        font-size: 0.875rem;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        transition: all 0.2s;
    }

    .btn-link:hover {
        background: #e3f2fd;
    }

    .select-input {
        padding: 0.625rem 1rem;
        border: 1px solid #e6e8ea;
        border-radius: 8px;
        font-size: 0.875rem;
        cursor: pointer;
        background: white;
        min-width: 150px;
    }

    .select-input:focus {
        outline: none;
        border-color: #0052cc;
    }

    .btn-primary-sm {
        padding: 0.625rem 1.25rem;
        background: #0052cc;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

    .btn-primary-sm:hover {
        background: #003d9b;
    }

    .btn-danger-outline {
        padding: 0.625rem 1.25rem;
        background: white;
        color: #d32f2f;
        border: 2px solid #d32f2f;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

    .btn-danger-outline:hover {
        background: #ffebee;
    }

    .btn-danger {
        padding: 0.625rem 1.25rem;
        background: #d32f2f;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        font-size: 0.875rem;
        transition: all 0.2s;
    }

    .btn-danger:hover {
        background: #b71c1c;
    }

    /* Devices List */
    .devices-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .device-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem;
        background: #f7f9fb;
        border-radius: 12px;
    }

    .device-icon {
        width: 48px;
        height: 48px;
        min-width: 48px;
        background: #76f3ea;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: #006a65;
    }

    .device-info {
        flex: 1;
    }

    .device-info h4 {
        font-size: 1rem;
        font-weight: 600;
        color: #191c1e;
        margin-bottom: 0.25rem;
    }

    .device-info p {
        font-size: 0.75rem;
        color: #434654;
    }

    .badge {
        padding: 0.375rem 0.75rem;
        border-radius: 6px;
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.05em;
    }

    .badge-success {
        background: #76f3ea;
        color: #006a65;
    }

    .icon-btn-sm {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: white;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

    .icon-btn-sm:hover {
        background: #ffebee;
        color: #d32f2f;
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .content-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .setting-item {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }

        .device-item {
            flex-wrap: wrap;
        }
    }
</style>
