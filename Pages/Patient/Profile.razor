@page "/patient/profile"
@layout Components.Layout.SidebarLayout

<PageTitle>Profile - AI Medical Clinic</PageTitle>

<link rel="stylesheet" href="/css/stitch-design-system.css" />

<!-- Header -->
<header class="content-header">
    <div class="header-left">
        <h1>My Profile</h1>
        <p class="body-md" style="margin: 0.5rem;">
            Manage your personal and medical information
        </p>
    </div>
    <div class="header-right">
        <button class="btn btn-secondary">Cancel</button>
        <button class="btn btn-primary">Save Changes</button>
    </div>
</header>

<!-- Content Grid -->
<div class="content-grid">
    <!-- Profile Photo Section -->
    <section class="profile-photo-card">
        <div class="photo-container">
            <div class="avatar-large">
                <i data-lucide="user"></i>
            </div>
            <button class="photo-upload-btn">
                <i data-lucide="camera"></i>
            </button>
        </div>
        <div class="photo-info">
            <h3 class="headline-sm">Sarah Johnson</h3>
            <p class="body-md">Patient ID: #PAT-2024-8432</p>
            <p class="body-sm">Member since October 2023</p>
        </div>
    </section>

    <!-- Personal Information -->
    <section class="info-card">
        <div class="section-header">
            <h2 class="headline-md">Personal Information</h2>
            <button class="icon-btn">
                <i data-lucide="edit-2"></i>
            </button>
        </div>
        <div class="form-grid">
            <div class="form-group">
                <label class="body-sm">Full Name</label>
                <input type="text" class="form-input" value="Sarah Johnson" />
            </div>
            <div class="form-group">
                <label class="body-sm">Date of Birth</label>
                <input type="date" class="form-input" value="1990-05-15" />
            </div>
            <div class="form-group">
                <label class="body-sm">Email Address</label>
                <input type="email" class="form-input" value="sarah.johnson@email.com" />
            </div>
            <div class="form-group">
                <label class="body-sm">Phone Number</label>
                <input type="tel" class="form-input" value="+1 (555) 123-4567" />
            </div>
            <div class="form-group full-width">
                <label class="body-sm">Address</label>
                <input type="text" class="form-input" value="123 Medical Plaza, Suite 400" />
            </div>
            <div class="form-group">
                <label class="body-sm">City</label>
                <input type="text" class="form-input" value="San Francisco" />
            </div>
            <div class="form-group">
                <label class="body-sm">State</label>
                <input type="text" class="form-input" value="California" />
            </div>
            <div class="form-group">
                <label class="body-sm">ZIP Code</label>
                <input type="text" class="form-input" value="94102" />
            </div>
        </div>
    </section>

    <!-- Medical Information -->
    <section class="info-card">
        <div class="section-header">
            <h2 class="headline-md">Medical Information</h2>
            <button class="icon-btn">
                <i data-lucide="edit-2"></i>
            </button>
        </div>
        <div class="form-grid">
            <div class="form-group">
                <label class="body-sm">Blood Type</label>
                <select class="form-input">
                    <option>O+</option>
                    <option>O-</option>
                    <option>A+</option>
                    <option>A-</option>
                    <option>B+</option>
                    <option>B-</option>
                    <option>AB+</option>
                    <option>AB-</option>
                </select>
            </div>
            <div class="form-group">
                <label class="body-sm">Height</label>
                <input type="text" class="form-input" value="5'6&quot;" />
            </div>
            <div class="form-group">
                <label class="body-sm">Weight</label>
                <input type="text" class="form-input" value="140 lbs" />
            </div>
            <div class="form-group">
                <label class="body-sm">Gender</label>
                <select class="form-input">
                    <option>Female</option>
                    <option>Male</option>
                    <option>Other</option>
                    <option>Prefer not to say</option>
                </select>
            </div>
            <div class="form-group full-width">
                <label class="body-sm">Allergies</label>
                <textarea class="form-input" rows="3">Penicillin, Peanuts, Shellfish</textarea>
            </div>
            <div class="form-group full-width">
                <label class="body-sm">Current Medications</label>
                <textarea class="form-input" rows="3">Lisinopril 10mg daily, Metformin 500mg twice daily</textarea>
            </div>
            <div class="form-group full-width">
                <label class="body-sm">Medical Conditions</label>
                <textarea class="form-input" rows="3">Type 2 Diabetes (controlled), Hypertension</textarea>
            </div>
        </div>
    </section>

    <!-- Emergency Contact -->
    <section class="info-card">
        <div class="section-header">
            <h2 class="headline-md">Emergency Contact</h2>
            <button class="icon-btn">
                <i data-lucide="edit-2"></i>
            </button>
        </div>
        <div class="form-grid">
            <div class="form-group">
                <label class="body-sm">Contact Name</label>
                <input type="text" class="form-input" value="Michael Johnson" />
            </div>
            <div class="form-group">
                <label class="body-sm">Relationship</label>
                <input type="text" class="form-input" value="Spouse" />
            </div>
            <div class="form-group">
                <label class="body-sm">Phone Number</label>
                <input type="tel" class="form-input" value="+1 (555) 987-6543" />
            </div>
            <div class="form-group">
                <label class="body-sm">Email</label>
                <input type="email" class="form-input" value="michael.j@email.com" />
            </div>
        </div>
    </section>

    <!-- Insurance Information -->
    <section class="info-card">
        <div class="section-header">
            <h2 class="headline-md">Insurance Information</h2>
            <button class="icon-btn">
                <i data-lucide="edit-2"></i>
            </button>
        </div>
        <div class="form-grid">
            <div class="form-group">
                <label class="body-sm">Insurance Provider</label>
                <input type="text" class="form-input" value="Blue Cross Blue Shield" />
            </div>
            <div class="form-group">
                <label class="body-sm">Policy Number</label>
                <input type="text" class="form-input" value="BCBS-123456789" />
            </div>
            <div class="form-group">
                <label class="body-sm">Group Number</label>
                <input type="text" class="form-input" value="GRP-987654" />
            </div>
            <div class="form-group">
                <label class="body-sm">Policy Holder</label>
                <input type="text" class="form-input" value="Sarah Johnson" />
            </div>
        </div>
    </section>
</div>

@code {
    // Component logic here
}

<style>
    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2rem;
    }

    .header-left h1 {
        font-size: 2rem;
        font-weight: 700;
        color: #191c1e;
        margin: 0.5rem;
        font-family: 'Manrope', sans-serif;
    }

    .header-left p {
        color: #434654;
    }

    .header-right {
        display: flex;
        gap: 1rem;
    }

    .content-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 2rem;
    }

    /* Profile Photo Card */
    .profile-photo-card {
        grid-column: span 1;
        background: white;
        padding: 2rem;
        border-radius: 16px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        height: fit-content;
    }

    .photo-container {
        position: relative;
        margin-bottom: 1.5rem;
    }

    .avatar-large {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, #76f3ea, #006a65);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: white;
    }

    .photo-upload-btn {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #0052cc;
        color: white;
        border: 3px solid white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .photo-info h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
        margin-bottom: 0.5rem;
    }

    .photo-info p {
        color: #434654;
        margin-bottom: 0.25rem;
    }

    /* Info Cards */
    .info-card {
        grid-column: span 2;
        background: white;
        padding: 2rem;
        border-radius: 16px;
    }

    .info-card:first-of-type {
        grid-column: 2;
        grid-row: 1;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.75rem;
    }

    .section-header h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #191c1e;
    }

    .icon-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #f2f4f6;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
    }

    .icon-btn:hover {
        background: #e6e8ea;
    }

    /* Form Styles */
    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-group.full-width {
        grid-column: span 2;
    }

    .form-group label {
        color: #434654;
        font-weight: 500;
    }

    .form-input {
        padding: 0.875rem 1rem;
        border: 1px solid #e6e8ea;
        border-radius: 8px;
        font-size: 0.9375rem;
        font-family: 'Inter', sans-serif;
        transition: all 0.2s;
    }

    .form-input:focus {
        outline: none;
        border-color: #0052cc;
        box-shadow: 0 0 0 3px rgba(0, 82, 204, 0.1);
    }

    textarea.form-input {
        resize: vertical;
        min-height: 80px;
    }

    select.form-input {
        cursor: pointer;
    }

    .btn {
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        font-size: 0.875rem;
    }

    .btn-primary {
        background: #0052cc;
        color: white;
    }

    .btn-primary:hover {
        background: #003d9b;
        transform: translateY(-1px);
    }

    .btn-secondary {
        background: #e6e8ea;
        color: #191c1e;
    }

    .btn-secondary:hover {
        background: #d8dadc;
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .content-grid {
            grid-template-columns: 1fr;
        }

        .profile-photo-card,
        .info-card,
        .info-card:first-of-type {
            grid-column: span 1;
            grid-row: auto;
        }
    }

    @@media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }

        .form-group.full-width {
            grid-column: span 1;
        }

        .header-right {
            flex-direction: column;
        }
    }
</style>
