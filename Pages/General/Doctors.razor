@page "/general/doctors"
@layout ai_clinic.Components.Layout.MainLayout

<PageTitle>Find Doctors - AI Medical Clinic</PageTitle>

<div class="doctors-page">
    <div class="container">
        <!-- Header Section -->
        <div class="page-header-section">            
            <div class="search-row">
                <div class="search-container">
                    <i data-lucide="search" class="search-icon"></i>
                    <input type="text" @bind="searchQuery" @bind:event="oninput" placeholder="Search by name, specialty, or condition..." class="search-input" />
                </div>
                <button class="btn-available-today" @onclick="FilterAvailableToday">
                    <i data-lucide="calendar" class="calendar-icon"></i>
                    Available Today
                </button>
            </div>
        </div>

        <!-- Filters Section -->
        <section class="filters-section">
            <div class="filter-buttons">
                <button class="filter-btn" @onclick="ToggleSpecialtyFilter">
                    Specialty <span class="dropdown-arrow">▼</span>
                </button>
                <button class="filter-btn" @onclick="ToggleOrganizationFilter">
                    Organization <span class="dropdown-arrow">▼</span>
                </button>
                <button class="filter-btn" @onclick="ToggleRatingFilter">
                    Rating <span class="dropdown-arrow">▼</span>
                </button>
                <button class="filter-btn" @onclick="ToggleInsuranceFilter">
                    Insurance <span class="dropdown-arrow">▼</span>
                </button>
            </div>
            <div class="results-count">@FilteredDoctors.Count() specialists found</div>
        </section>

        <!-- Doctors Grid -->
        <section class="doctors-grid">
            @foreach (var doctor in FilteredDoctors)
            {
                <div class="doctor-card">
                    <button class="bookmark-btn" @onclick="@(() => ToggleBookmark(doctor.Id))">
                        <i data-lucide="bookmark" class="bookmark-icon @(doctor.IsBookmarked ? "filled" : "")"></i>
                    </button>
                    
                    <div class="doctor-card-header">
                        <div class="doctor-photo">
                            <div class="photo-placeholder" style="background: @doctor.PhotoColor;">
                                @doctor.Name.Substring(0, 1)
                            </div>
                            @if (doctor.IsOnline)
                            {
                                <span class="online-badge"></span>
                            }
                        </div>
                        
                        <div class="doctor-info">
                            <h3 class="doctor-name">@doctor.Name</h3>
                            <div class="doctor-tags">
                                <span class="specialty-tag">@doctor.Specialty.ToUpper()</span>
                                <span class="organization-tag">@doctor.Organization.ToUpper()</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="doctor-rating">
                        <div class="stars">
                            @for (int i = 0; i < 5; i++)
                            {
                                <i data-lucide="star" class="star @(i < Math.Floor(doctor.Rating) ? "filled" : "")"></i>
                            }
                        </div>
                        <span class="rating-text">@doctor.Rating.ToString("0.0") <span class="review-count">(@doctor.ReviewCount reviews)</span></span>
                    </div>
                    
                    <div class="availability-card">
                        <div class="availability-info">
                            <i data-lucide="clock" class="clock-icon"></i>
                            <div class="availability-text">
                                <div class="availability-label">Next Available</div>
                                <div class="availability-time">@doctor.NextAvailable</div>
                            </div>
                        </div>
                        @if (doctor.IsAvailableToday)
                        {
                            <span class="availability-badge">✦ AVAILABILITY</span>
                        }
                        @if (doctor.IsOnline && !doctor.IsAvailableToday)
                        {
                            <span class="ai-assist-badge">✦ AI ASSIST READY</span>
                        }
                    </div>
                </div>
            }
        </section>

        @if (!FilteredDoctors.Any())
        {
            <div class="empty-state">
                <p class="empty-message">No doctors found matching your criteria</p>
                <button class="btn-primary" @onclick="ClearFilters">Clear Filters</button>
            </div>
        }
    </div>
</div>

@code {
