@page "/general/about"
@layout ai_clinic.Components.Layout.MainLayout

<PageTitle>About Us - AI Medical Clinic</PageTitle>

<div class="about-page">
    <div class="container">

        <!-- Mission & Vision Section -->
        <section class="mission-vision-section">
            <div class="mission-vision-grid">
                <div class="mission-card">
                    <div class="card-icon mission-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 2L2 7L12 12L22 7L12 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M2 17L12 22L22 17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M2 12L12 17L22 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <h2 class="card-title">Our Mission</h2>
                    <p class="card-text">
                        To provide accessible, high-quality healthcare using cutting-edge AI. We believe that professional medical insight should not be a luxury, but a fundamental right powered by secure, scalable technology.
                    </p>
                </div>
                <div class="vision-card">
                    <div class="card-icon vision-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <h2 class="card-title">Our Vision</h2>
                    <p class="card-text">
                        A world where everyone has a clinical sanctuary in their pocket. We envision a future where proactive health monitoring and immediate clinical triage are seamless parts of everyday life.
                    </p>
                </div>
            </div>
        </section>

        <!-- Core Value Section -->
        <section class="hybrid-synergy-section">
            <h2 class="synergy-heading">The Core Value</h2>
            <p class="synergy-subtitle">Our proprietary model combines the speed of silicon with the intuition of clinical experience.</p>
            
            <div class="synergy-grid">
                <div class="synergy-card synergy-ai">
                    <h3 class="synergy-title">Real-time AI Diagnostic Layer</h3>
                    <p class="synergy-text">
                        Our AI processes thousands of medical journals and patient records in milliseconds to provide preliminary triage with 99.2% accuracy in symptom mapping.
                    </p>
                    <div class="synergy-badges">
                        <span class="badge badge-cyan">LLM Trained on PubMed</span>
                        <span class="badge badge-cyan">HIPAA Compliant</span>
                    </div>
                </div>

                <div class="synergy-card synergy-safety">
                    <div class="synergy-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <h3 class="synergy-title">Safety Protocols</h3>
                    <p class="synergy-text">
                        Every AI recommendation is cross-referenced against established clinical guidelines and red-flagged for human review if thresholds are met.
                    </p>
                </div>

                <div class="synergy-card synergy-response">
                    <div class="synergy-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <h3 class="synergy-title">Instant Response</h3>
                    <p class="synergy-text">
                        Reduce wait times from weeks to seconds. Immediate clinical guidance available 24/7, anywhere in the world.
                    </p>
                </div>

                <div class="synergy-card synergy-human">
                    <div class="synergy-image">
                        <div class="doctor-placeholder">
                            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                    </div>
                    <h3 class="synergy-title">Human-in-the-Loop</h3>
                    <p class="synergy-text">
                        Technology is the tool, but humans are the heart. Complex cases are automatically routed to our global network of board-certified physicians for final verification.
                    </p>
                </div>
            </div>
        </section>

        <!-- Team Section -->
        <section class="team-section">
            <div class="team-header">
                <h2 class="section-heading">Leadership Team</h2>
                <p class="team-subtitle">Meet the visionaries driving healthcare innovation</p>
            </div>
            <div class="team-grid">
                <div class="team-card">
                    <div class="team-card-inner">
                        <div class="team-photo">
                            <div class="photo-placeholder" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                <span class="initials">JD</span>
                            </div>
                            <div class="photo-overlay">
                                <div class="social-links">
                                    <a href="#" class="social-icon" aria-label="LinkedIn">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            <rect x="2" y="9" width="4" height="12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            <circle cx="4" cy="4" r="2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </a>
                                    <a href="#" class="social-icon" aria-label="Email">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            <polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="team-content">
                            <h3 class="team-name">Dr. Jane Doe</h3>
                            <p class="team-role">Chief Medical Officer</p>
                            <p class="team-bio">Former Chief of Medicine at Johns Hopkins, 20+ years in healthcare innovation.</p>
                            <div class="team-stats">
                                <div class="stat-item">
                                    <span class="stat-value">20+</span>
                                    <span class="stat-label">Years</span>
                                </div>
