                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="cta-section">
            <div class="cta-card">
                <h2 class="cta-title">Ready to Experience the Future of Healthcare?</h2>
                <p class="cta-text">Join thousands of patients who trust AI Clinic for their health needs.</p>
                <a href="/auth/login" class="btn-cta">Get Started Today</a>
            </div>
        </section>
    </div>
</div>

<style>

    /* Mission & Vision Section */
    .mission-vision-section {
        margin: 4rem 0;
    }

    .mission-vision-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
    }

    .mission-card,
    .vision-card {
        background: var(--surface-container-lowest);
        border-radius: var(--radius-xl);
        padding: 2.5rem;
        position: relative;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
    }

    .mission-card {
        border-left: 4px solid #5B7FE8;
    }

    .vision-card {
        border-left: 4px solid #4DD4D4;
    }

    .card-icon {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
    }

    .mission-icon {
        background: #E8EEFF;
        color: #5B7FE8;
    }

    .vision-icon {
        background: #E0F7F7;
        color: #4DD4D4;
    }

    .card-title {
        font-family: var(--font-headline);
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--on-surface);
        margin-bottom: 1rem;
    }

    .card-text {
        font-size: 1rem;
        color: var(--on-surface-variant);
        line-height: 1.7;
    }

    /* Core Value Section */
    .hybrid-synergy-section {
        margin: 5rem 0;
        padding: 3rem 0;
    }

    .synergy-heading {
        font-family: var(--font-headline);
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--on-surface);
        text-align: center;
        margin-bottom: 1rem;
    }

    .synergy-subtitle {
        font-size: 1.125rem;
        color: var(--on-surface-variant);
        text-align: center;
        margin-bottom: 3rem;
        max-width: 700px;
        margin-left: auto;
        margin-right: auto;
    }

    .synergy-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
    }

    .synergy-card {
        background: var(--surface-container-lowest);
        border-radius: var(--radius-xl);
        padding: 2.5rem;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
        transition: all 0.3s ease;
    }

    .synergy-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    }

    .synergy-ai {
        background: linear-gradient(135deg, #F8FAFE 0%, #FFFFFF 100%);
    }

    .synergy-safety {
        background: linear-gradient(135deg, #1E4BA8 0%, #2563D4 100%);
        color: white;
    }

    .synergy-safety .synergy-title,
    .synergy-safety .synergy-text {
        color: white;
    }

    .synergy-response {
        background: linear-gradient(135deg, #0D7C7C 0%, #0F9B9B 100%);
        color: white;
    }

    .synergy-response .synergy-title,
    .synergy-response .synergy-text {
        color: white;
    }

    .synergy-human {
        background: linear-gradient(135deg, #F0F2F5 0%, #FFFFFF 100%);
        display: flex;
        align-items: center;
        gap: 2rem;
    }

    .synergy-icon {
        width: 56px;
        height: 56px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
        background: rgba(255, 255, 255, 0.2);
    }

    .synergy-title {
        font-family: var(--font-headline);
        font-size: 1.375rem;
        font-weight: 700;
        color: var(--on-surface);
        margin-bottom: 1rem;
    }

    .synergy-text {
        font-size: 0.9375rem;
        color: var(--on-surface-variant);
        line-height: 1.7;
        margin-bottom: 1.5rem;
    }

    .synergy-badges {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .badge {
        display: inline-block;
        padding: 0.5rem 1rem;
        border-radius: var(--radius-full);
        font-size: 0.8125rem;
        font-weight: 600;
    }

    .badge-cyan {
        background: #D4F4F4;
        color: #0D7C7C;
    }

    .synergy-image {
        flex-shrink: 0;
    }

    .doctor-placeholder {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, #E8EEFF 0%, #D4E4FF 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #5B7FE8;
    }

    /* Team Section */
    .team-section {
        margin: 5rem 0;
        padding: 3rem 0;
    }

    .team-header {
        text-align: center;
        margin-bottom: 4rem;
    }

    .team-subtitle {
        font-size: 1.125rem;
        color: var(--on-surface-variant);
        margin-top: 1rem;
    }

    .team-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2.5rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .team-card {
        background: var(--surface-container-lowest);
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
    }

    .team-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--primary) 0%, var(--tertiary) 100%);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.4s ease;
    }

    .team-card:hover::before {
        transform: scaleX(1);
    }

    .team-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
    }

    .team-card-inner {
        padding: 2.5rem;
        display: flex;
        gap: 2rem;
        align-items: flex-start;
    }

    .team-photo {
        position: relative;
        flex-shrink: 0;
    }

    .photo-placeholder {
        width: 140px;
        height: 140px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        font-weight: 700;
        color: white;
        position: relative;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
        transition: all 0.4s ease;
    }

    .team-card:hover .photo-placeholder {
        transform: scale(1.05);
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.2);
    }

    .initials {
        position: relative;
        z-index: 2;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    }

    .photo-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.7);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .team-card:hover .photo-overlay {
        opacity: 1;
    }

    .social-links {
        display: flex;
        gap: 1rem;
    }

    .social-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(10px);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        transition: all 0.3s ease;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .social-icon:hover {
        background: rgba(255, 255, 255, 0.25);
        transform: translateY(-2px);
    }

    .team-content {
        flex: 1;
        min-width: 0;
    }

    .team-name {
        font-family: var(--font-headline);
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--on-surface);
        margin-bottom: 0.5rem;
        line-height: 1.3;
    }

    .team-role {
        font-size: 1rem;
        color: var(--primary);
        font-weight: 600;
        margin-bottom: 1rem;
        display: inline-block;
        padding: 0.25rem 0.75rem;
        background: var(--primary-container);
